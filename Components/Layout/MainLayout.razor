@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject IUserSettingsService SettingsService
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="app-container @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-brand">OpCentrix</span>
            <button class="sidebar-toggle" @onclick="ToggleSidebar" title="Toggle sidebar">☰</button>
        </div>
        <NavMenu />
    </aside>

    <div class="main-area">
        <header class="top-bar">
            <button class="mobile-toggle" @onclick="ToggleSidebar" title="Menu">☰</button>
            <span class="top-bar-spacer"></span>
            <AuthorizeView>
                <Authorized>
                    <span class="top-bar-user">@context.User.Identity?.Name</span>
                    <a href="/account/logout" class="btn-topbar">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/account/login" class="btn-topbar">Login</a>
                </NotAuthorized>
            </AuthorizeView>
            <button class="btn-topbar" @onclick="ToggleDarkMode" title="@ThemeTooltip">@ThemeIcon</button>
        </header>

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<Opcentrix_V3.Components.Shared.ToastContainer />
<Opcentrix_V3.Components.Shared.DebugFab />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _sidebarCollapsed;
    private string _themePreference = "dark";
    private int _userId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // Read stored preference and always re-apply to DOM.
            // Enhanced navigation may have reset data-theme to the
            // hardcoded default in App.razor, so we must push the
            // correct value back every time a circuit starts.
            _themePreference = await JS.InvokeAsync<string>("opcentrix.getTheme") ?? "dark";
            await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
        }
        catch (JSDisconnectedException) { return; }

        if (AuthState is not null)
        {
            var state = await AuthState;
            var userIdClaim = state.User.FindFirst("UserId")?.Value;
            if (int.TryParse(userIdClaim, out var uid))
            {
                _userId = uid;
                try
                {
                    var settings = await SettingsService.GetSettingsAsync(uid);

                    // DB is authoritative — override localStorage if they disagree
                    if (settings.Theme != _themePreference)
                    {
                        _themePreference = settings.Theme;
                        await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
                    }

                    await JS.InvokeVoidAsync("opcentrix.debugFab.setEnabled", settings.DebugFabEnabled);
                }
                catch (JSDisconnectedException) { return; }
                catch (Exception) { /* DB or auth failure — keep localStorage theme */ }
            }
        }

        StateHasChanged();
    }

    private string ThemeIcon => _themePreference switch
    {
        "light" => "☀️",
        "system" => "💻",
        _ => "🌙"
    };

    private string ThemeTooltip => _themePreference switch
    {
        "light" => "Theme: Light (click for System)",
        "system" => "Theme: System (click for Dark)",
        _ => "Theme: Dark (click for Light)"
    };

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;

    private async Task ToggleDarkMode()
    {
        _themePreference = _themePreference switch
        {
            "dark" => "light",
            "light" => "system",
            _ => "dark"
        };

        try
        {
            await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
        }
        catch (JSDisconnectedException) { return; }

        if (_userId > 0)
        {
            try { await SettingsService.SaveThemeAsync(_userId, _themePreference); }
            catch (Exception) { /* DB save failed — localStorage already has the value */ }
        }
    }

    }
