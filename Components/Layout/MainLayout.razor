@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject IUserSettingsService SettingsService
@inject TabManagerService TabManager
@inject NavigationManager Nav
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="app-container @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-brand">OpCentrix</span>
            <button class="sidebar-toggle" @onclick="ToggleSidebar" title="Toggle sidebar">☰</button>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <span class="sidebar-user">@context.User.Identity?.Name</span>
                    <a href="/account/logout" class="sidebar-footer-btn" title="Logout">🚪</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/account/login" class="sidebar-footer-btn" title="Login">🔑</a>
                </NotAuthorized>
            </AuthorizeView>
            <button class="sidebar-footer-btn" @onclick="ToggleDarkMode" title="@ThemeTooltip">@ThemeIcon</button>
        </div>
    </aside>

    <button class="mobile-menu-btn" @onclick="ToggleSidebar" title="Menu">☰</button>

    <div class="main-area">
        <TabStrip />

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<Opcentrix_V3.Components.Shared.ToastContainer />
<Opcentrix_V3.Components.Shared.DebugFab />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _sidebarCollapsed;
    private string _themePreference = "dark";
    private int _userId;

    /// <summary>
    /// Route-to-tab mapping. Every navigation auto-creates a tab.
    /// </summary>
    private static readonly Dictionary<string, (string Title, string Icon)> _routeMap = new(StringComparer.OrdinalIgnoreCase)
    {
        [""] = ("Dashboard", "📊"),
        ["scheduler"] = ("Scheduler", "📅"),
        ["scheduler/capacity"] = ("Capacity", "📊"),
        ["workorders"] = ("Work Orders", "📋"),
        ["builds"] = ("Build Planning", "🏗️"),
        ["parts"] = ("Parts Library", "🔩"),
        ["shopfloor"] = ("Operator Queue", "🏭"),
        ["tracking"] = ("Part Tracker", "🔍"),
        ["machines"] = ("Machines", "🖥️"),
        ["analytics"] = ("Analytics", "📈"),
        ["analytics/on-time-delivery"] = ("On-Time Delivery", "⏱️"),
        ["analytics/quality"] = ("Quality Metrics", "✅"),
        ["analytics/oee"] = ("Machine OEE", "⚙️"),
        ["analytics/cost"] = ("Cost Analysis", "💲"),
        ["search"] = ("Search", "🔎"),
        ["quotes"] = ("Quotes", "💰"),
        ["quotes/rfq-inbox"] = ("RFQ Inbox", "📥"),
        ["maintenance"] = ("Maintenance", "🔧"),
        ["maintenance/workorders"] = ("Maint. Orders", "📝"),
        ["maintenance/rules"] = ("Maint. Rules", "📐"),
        ["inventory"] = ("Inventory", "📦"),
        ["inventory/items"] = ("Inventory Items", "📋"),
        ["inventory/receive"] = ("Receive Stock", "📥"),
        ["quality"] = ("Quality", "🔍"),
        ["quality/ncr"] = ("NCR Management", "📋"),
        ["quality/capa"] = ("CAPA Board", "🔧"),
        ["quality/spc"] = ("SPC Charts", "📈"),
        ["admin"] = ("Admin", "⚙️"),
        ["admin/stages"] = ("Stage Config", "🔧"),
    };

    protected override void OnInitialized()
    {
        TabManager.EnsureHomeTab();
        SyncTabFromCurrentUrl();
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _themePreference = await JS.InvokeAsync<string>("opcentrix.getTheme") ?? "dark";
            await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
        }
        catch (JSDisconnectedException) { return; }

        if (AuthState is not null)
        {
            var state = await AuthState;
            var userIdClaim = state.User.FindFirst("UserId")?.Value;
            if (int.TryParse(userIdClaim, out var uid))
            {
                _userId = uid;
                try
                {
                    var settings = await SettingsService.GetSettingsAsync(uid);

                    if (settings.Theme != _themePreference)
                    {
                        _themePreference = settings.Theme;
                        await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
                    }

                    await JS.InvokeVoidAsync("opcentrix.debugFab.setEnabled", settings.DebugFabEnabled);
                }
                catch (JSDisconnectedException) { return; }
                catch (Exception) { /* DB or auth failure — keep localStorage theme */ }
            }
        }

        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        SyncTabFromCurrentUrl();
        InvokeAsync(StateHasChanged);
    }

    private void SyncTabFromCurrentUrl()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0];

        // Skip auth pages — don't create tabs for login/logout
        if (relativePath.StartsWith("account", StringComparison.OrdinalIgnoreCase)) return;

        // Try exact match first, then pattern matches for detail pages
        if (_routeMap.TryGetValue(relativePath, out var info))
        {
            TabManager.Open(info.Title, info.Icon, "/" + relativePath, pinned: relativePath == "");
        }
        else
        {
            // Detail pages: workorders/5, parts/12, etc.
            var (title, icon) = ResolveDetailTab(relativePath);
            TabManager.Open(title, icon, "/" + relativePath);
        }
    }

    private static (string Title, string Icon) ResolveDetailTab(string path)
    {
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);

        return segments switch
        {
            ["workorders", _] => ($"WO #{segments[1]}", "📋"),
            ["parts", _] => ($"Part #{segments[1]}", "🔩"),
            ["parts", _, "edit"] => ($"Edit Part #{segments[1]}", "✏️"),
            ["quotes", _] => ($"Quote #{segments[1]}", "💰"),
            ["machines", _] => ($"Machine #{segments[1]}", "🖥️"),
            ["builds", _] => ($"Build #{segments[1]}", "🏗️"),
            ["shopfloor", "stage", var slug] => ($"Stage: {slug}", "🏭"),
            ["quality", "ncr", _] => ($"NCR #{segments[2]}", "📋"),
            _ => (path.Split('/')[^1], "📄"),
        };
    }

    private string ThemeIcon => _themePreference switch
    {
        "light" => "☀️",
        "system" => "💻",
        _ => "🌙"
    };

    private string ThemeTooltip => _themePreference switch
    {
        "light" => "Theme: Light (click for System)",
        "system" => "Theme: System (click for Dark)",
        _ => "Theme: Dark (click for Light)"
    };

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;

    private async Task ToggleDarkMode()
    {
        _themePreference = _themePreference switch
        {
            "dark" => "light",
            "light" => "system",
            _ => "dark"
        };

        try
        {
            await JS.InvokeVoidAsync("opcentrix.setTheme", _themePreference);
        }
        catch (JSDisconnectedException) { return; }

        if (_userId > 0)
        {
            try { await SettingsService.SaveThemeAsync(_userId, _themePreference); }
            catch (Exception) { /* DB save failed — localStorage already has the value */ }
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
    }
