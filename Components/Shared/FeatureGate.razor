@inject ITenantFeatureService Features

@if (Features.IsEnabled(Feature))
{
    @ChildContent
}
else
{
    <div class="card" style="max-width: 500px; margin: 80px auto; text-align: center; padding: 40px;">
        <div style="font-size: 3rem; margin-bottom: 16px;">🔒</div>
        <h2 style="margin-bottom: 12px;">Module Not Enabled</h2>
        <p style="color: var(--text-muted); margin-bottom: 24px;">
            @ModuleName is not enabled for your organization.
            Contact your administrator to enable this module.
        </p>
        <a class="btn btn-secondary" href="admin/features">Go to Admin → Features</a>
    </div>
}

@code {
    [Parameter, EditorRequired] public string Feature { get; set; } = "";
    [Parameter] public string ModuleName { get; set; } = "This module";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
