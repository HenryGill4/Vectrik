@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="file-upload-zone @(_isDragging ? "drag-over" : "")"
     @ondragenter="OnDragEnter"
     @ondragleave="OnDragLeave"
     @ondragover:preventDefault>
    <InputFile OnChange="OnFilesSelected" multiple="@Multiple" accept="@Accept" class="file-input-hidden" />
    <div class="file-upload-content">
        <span class="file-upload-icon">📁</span>
        <p class="file-upload-text">Drag & drop files here or click to browse</p>
        @if (!string.IsNullOrEmpty(Accept))
        {
            <p class="file-upload-hint">Accepted: @Accept</p>
        }
        @if (MaxSizeMB > 0)
        {
            <p class="file-upload-hint">Max size: @MaxSizeMB MB — images can be cropped/rotated before upload</p>
        }
    </div>
</div>

@if (_selectedFiles.Count > 0)
{
    <div class="file-upload-list">
        @foreach (var file in _selectedFiles)
        {
            <div class="file-upload-item">
                <span class="file-upload-item-icon">@GetFileIcon(file.Name)</span>
                <span class="file-upload-item-name">
                    @file.Name
                    @if (_editedFiles.ContainsKey(file.Name))
                    {
                        <span style="color: var(--success); font-size: 0.75rem; margin-left: 4px;">(edited)</span>
                    }
                </span>
                <span class="file-upload-item-size">@FormatSize(file.Size)</span>
                @if (ImageEditor.IsImageFile(file.Name))
                {
                    <button class="img-editor-edit-btn" @onclick="() => OpenEditor(file)" title="Crop/rotate image">Edit</button>
                }
                <button class="btn btn-sm btn-danger" @onclick="() => RemoveFile(file)">✕</button>
            </div>
        }
    </div>
}

<ImageEditor @ref="_imageEditor"
             Visible="_showEditor"
             FileName="@_editorFileName"
             OnSave="OnEditorSave"
             OnCancel="OnEditorCancel" />

@code {
    [Parameter] public bool Multiple { get; set; } = true;
    [Parameter] public string Accept { get; set; } = ".pdf,.dxf,.step,.stp,.png,.jpg,.jpeg";
    [Parameter] public int MaxSizeMB { get; set; } = 50;
    [Parameter] public EventCallback<IReadOnlyList<IBrowserFile>> OnFilesChanged { get; set; }

    private bool _isDragging;
    private List<IBrowserFile> _selectedFiles = new();

    // Image editor
    private ImageEditor? _imageEditor;
    private bool _showEditor;
    private string? _editorFileName;
    private IBrowserFile? _editingFile;
    private Dictionary<string, byte[]> _editedFiles = new();

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        var maxBytes = MaxSizeMB * 1024L * 1024L;
        foreach (var file in e.GetMultipleFiles(20))
        {
            if (file.Size <= maxBytes && !_selectedFiles.Any(f => f.Name == file.Name))
            {
                _selectedFiles.Add(file);
            }
        }
        await OnFilesChanged.InvokeAsync(_selectedFiles.AsReadOnly());
    }

    private async Task RemoveFile(IBrowserFile file)
    {
        _selectedFiles.Remove(file);
        _editedFiles.Remove(file.Name);
        await OnFilesChanged.InvokeAsync(_selectedFiles.AsReadOnly());
    }

    private async Task OpenEditor(IBrowserFile file)
    {
        _editingFile = file;
        _editorFileName = file.Name;
        _showEditor = true;
        StateHasChanged();

        if (_imageEditor != null)
            await _imageEditor.LoadImageAsync(file);
    }

    private async Task OnEditorSave(ImageEditor.ImageEditorResult result)
    {
        _showEditor = false;
        if (_editingFile != null)
        {
            _editedFiles[_editingFile.Name] = result.ImageData;
        }
        _editingFile = null;
        await Task.CompletedTask;
    }

    private void OnEditorCancel()
    {
        _showEditor = false;
        _editingFile = null;
    }

    /// <summary>
    /// Returns edited image bytes for a file, if it was edited. Used by parent components.
    /// </summary>
    public byte[]? GetEditedBytes(string fileName) =>
        _editedFiles.TryGetValue(fileName, out var bytes) ? bytes : null;

    /// <summary>
    /// Returns all edited file data. Used by parent components during upload.
    /// </summary>
    public IReadOnlyDictionary<string, byte[]> GetAllEditedFiles() => _editedFiles;

    private void OnDragEnter() => _isDragging = true;
    private void OnDragLeave() => _isDragging = false;

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    private static string GetFileIcon(string name)
    {
        var ext = Path.GetExtension(name).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "📄",
            ".dxf" or ".dwg" => "📐",
            ".step" or ".stp" => "🧊",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" => "🖼️",
            _ => "📎"
        };
    }
}
