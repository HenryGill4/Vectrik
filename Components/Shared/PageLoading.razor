@* Branded page-level loading indicator. Usage: <PageLoading /> or <PageLoading Message="Loading orders..." /> *@

<div class="page-loading">
    <div class="page-loading-spinner">
        <svg class="page-loading-v" viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="plGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#3B82F6"/>
                    <stop offset="50%" stop-color="#06B6D4"/>
                    <stop offset="100%" stop-color="#22D3EE"/>
                </linearGradient>
            </defs>
            <polygon points="100,200 10,0 45,0 100,164 155,0 190,0" fill="url(#plGrad)"/>
        </svg>
    </div>
    <span class="page-loading-text">@Message</span>
</div>

@code {
    [Parameter] public string Message { get; set; } = "Loading...";
}
