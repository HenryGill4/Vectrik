@page "/"
@layout Components.Layout.PublicLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Vectrik - MES for Additive Manufacturing</PageTitle>

<!-- Hero -->
<section class="pub-hero">
    <div class="pub-hero-bg"></div>
    <div class="pub-hero-content">
        <svg class="pub-hero-v" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="heroAccent" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#3B82F6"/>
                    <stop offset="50%" stop-color="#06B6D4"/>
                    <stop offset="100%" stop-color="#22D3EE"/>
                </linearGradient>
                <filter id="heroGlow">
                    <feGaussianBlur stdDeviation="3" result="blur"/>
                    <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                </filter>
            </defs>
            <g transform="translate(32, 6)" filter="url(#heroGlow)">
                <polygon points="0,50 -24,0 -15,0 0,40 15,0 24,0" fill="url(#heroAccent)"/>
                <line x1="-21" y1="7" x2="-17" y2="7" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="-18" y1="18" x2="-14" y2="18" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="21" y1="7" x2="17" y2="7" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="18" y1="18" x2="14" y2="18" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <circle cx="0" cy="47" r="2" fill="#22D3EE" opacity="0.9"/>
            </g>
        </svg>
        <h1 class="pub-gradient-text">Manufacturing Intelligence</h1>
        <p class="pub-hero-sub">The next-generation MES platform for additive manufacturing. Schedule smarter. Build faster. Ship on time.</p>
        <div class="pub-hero-actions">
            <a href="/demo" class="pub-btn pub-btn-primary">Request Demo</a>
            <a href="/account/login" class="pub-btn pub-btn-ghost">Sign In</a>
        </div>
    </div>
</section>

<!-- Social Proof -->
<section class="pub-social-proof">
    <span class="pub-social-label">Built for regulated manufacturing</span>
    <div class="pub-social-badges">
        <span class="pub-badge">ISO 9001 Ready</span>
        <span class="pub-badge">AS9100 Ready</span>
        <span class="pub-badge">ITAR Ready</span>
        <span class="pub-badge">CMMC Ready</span>
    </div>
</section>

<!-- What Vectrik Delivers -->
<section class="pub-section pub-testimonials-section">
    <h2 class="pub-section-title pub-fade-up">Designed to Solve Real AM Problems</h2>
    <p class="pub-section-sub pub-fade-up">Every feature addresses challenges we experienced firsthand running SLS production floors.</p>
    <div class="pub-testimonial-grid">
        <div class="pub-testimonial-card pub-fade-up">
            <div class="pub-testimonial-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <h3 class="pub-testimonial-heading">End the Scheduling Spreadsheet</h3>
            <p class="pub-testimonial-text">Most AM shops schedule builds on whiteboards and spreadsheets, spending hours juggling machine capacity, changeover timing, and due dates. Vectrik replaces all of that with a visual Gantt scheduler that understands SLS-specific constraints like cooldown chambers and auto-changeover windows.</p>
        </div>
        <div class="pub-testimonial-card pub-fade-up">
            <div class="pub-testimonial-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="9 12 11 14 15 10"/>
                </svg>
            </div>
            <h3 class="pub-testimonial-heading">Audit-Ready from Day One</h3>
            <p class="pub-testimonial-text">Preparing for ISO 9001 or AS9100 audits shouldn't mean weeks of digging through paper records. Vectrik captures full traceability automatically &mdash; every part linked to its powder lot, every stage documented, every quality check recorded in-flow.</p>
        </div>
        <div class="pub-testimonial-card pub-fade-up">
            <div class="pub-testimonial-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <h3 class="pub-testimonial-heading">No More Surprise Downtime</h3>
            <p class="pub-testimonial-text">When a build finishes at 2 AM and no operator is available for the changeover, your $200/hr machine sits idle until morning. Vectrik's changeover analysis flags these risks before you commit to a schedule, so you can plan builds that keep machines running continuously.</p>
        </div>
    </div>
</section>

