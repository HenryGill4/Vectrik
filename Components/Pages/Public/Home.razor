@page "/"
@layout Components.Layout.PublicLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web

<!-- Hero -->
<section class="pub-hero">
    <div class="pub-hero-bg"></div>
    <div class="pub-hero-content">
        <svg class="pub-hero-v" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="heroAccent" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#3B82F6"/>
                    <stop offset="50%" stop-color="#06B6D4"/>
                    <stop offset="100%" stop-color="#22D3EE"/>
                </linearGradient>
                <filter id="heroGlow">
                    <feGaussianBlur stdDeviation="3" result="blur"/>
                    <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                </filter>
            </defs>
            <g transform="translate(32, 6)" filter="url(#heroGlow)">
                <polygon points="0,50 -24,0 -15,0 0,40 15,0 24,0" fill="url(#heroAccent)"/>
                <line x1="-21" y1="7" x2="-17" y2="7" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="-18" y1="18" x2="-14" y2="18" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="21" y1="7" x2="17" y2="7" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <line x1="18" y1="18" x2="14" y2="18" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
                <circle cx="0" cy="47" r="2" fill="#22D3EE" opacity="0.9"/>
            </g>
        </svg>
        <h1 class="pub-gradient-text">Manufacturing Intelligence</h1>
        <p class="pub-hero-sub">The next-generation MES platform for additive manufacturing. Schedule smarter. Build faster. Ship on time.</p>
        <div class="pub-hero-actions">
            <a href="/demo" class="pub-btn pub-btn-primary">Request Demo</a>
            <a href="/account/login" class="pub-btn pub-btn-ghost">Sign In</a>
        </div>
    </div>
</section>

<!-- Social Proof -->
<section class="pub-social-proof">
    <span class="pub-social-label">Built for regulated manufacturing</span>
    <div class="pub-social-badges">
        <span class="pub-badge">ISO 9001</span>
        <span class="pub-badge">AS9100</span>
        <span class="pub-badge">ITAR Compliant</span>
        <span class="pub-badge">CMMC Ready</span>
    </div>
</section>

<!-- Feature Highlights -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Built for Additive Manufacturing</h2>
    <p class="pub-section-sub pub-fade-up">From SLS build scheduling to final quality inspection &mdash; one platform, complete control.</p>
    <div class="pub-feature-grid">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                    <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Intelligent Scheduling</h3>
            <p class="pub-card-text">AI-powered build advisor optimizes plate composition, machine allocation, and changeover timing to maximize throughput and minimize downtime.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 20h20"/>
                    <path d="M5 20V8l4-4h6l4 4v12"/>
                    <path d="M9 20v-4h6v4"/>
                    <line x1="9" y1="12" x2="9" y2="12.01"/>
                    <line x1="15" y1="12" x2="15" y2="12.01"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Shop Floor Execution</h3>
            <p class="pub-card-text">Operator-friendly stage queues guide work through every production step &mdash; from SLS printing through depowdering, EDM, machining, and finishing.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="9 12 11 14 15 10"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Quality &amp; Compliance</h3>
            <p class="pub-card-text">Inline QC checks, NCR management, and full traceability keep you audit-ready for ISO 9001, AS9100, and ITAR requirements.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Real-Time Analytics</h3>
            <p class="pub-card-text">Machine OEE, cost analysis, and on-time delivery dashboards give you complete visibility into production performance.</p>
        </div>
    </div>
</section>

<!-- Product Showcase -->
<section class="pub-showcase pub-fade-up">
    <h2 class="pub-section-title">See Your Production in Real Time</h2>
    <div class="pub-showcase-frame">
        <div class="pub-showcase-header">
            <span class="pub-dot pub-dot-red"></span>
            <span class="pub-dot pub-dot-yellow"></span>
            <span class="pub-dot pub-dot-green"></span>
            <span class="pub-showcase-title">Production Scheduler &mdash; Gantt View</span>
        </div>
        <div class="pub-showcase-body">
            <svg viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="pub-showcase-svg">
                <!-- Grid lines -->
                <line x1="140" y1="0" x2="140" y2="260" stroke="#374151" stroke-width="0.5"/>
                @for (int i = 0; i < 8; i++)
                {
                    var x = 140 + (i * 82.5);
                    <line x1="@x" y1="0" x2="@x" y2="260" stroke="#1F2937" stroke-width="0.5" stroke-dasharray="4,4"/>
                }
                <!-- Row backgrounds -->
                <rect x="0" y="0" width="800" height="65" fill="#111827" rx="0"/>
                <rect x="0" y="65" width="800" height="65" fill="#0D1117" rx="0"/>
                <rect x="0" y="130" width="800" height="65" fill="#111827" rx="0"/>
                <rect x="0" y="195" width="800" height="65" fill="#0D1117" rx="0"/>
                <!-- Row labels -->
                <text x="12" y="38" fill="#9CA3AF" font-size="12" font-family="system-ui">EOS M4 #1</text>
                <text x="12" y="103" fill="#9CA3AF" font-size="12" font-family="system-ui">EOS M4 #2</text>
                <text x="12" y="168" fill="#9CA3AF" font-size="12" font-family="system-ui">Depowder</text>
                <text x="12" y="233" fill="#9CA3AF" font-size="12" font-family="system-ui">Wire EDM</text>
                <!-- Gantt bars - Row 1 -->
                <defs>
                    <linearGradient id="gBar1" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#3B82F6"/><stop offset="100%" stop-color="#06B6D4"/></linearGradient>
                    <linearGradient id="gBar2" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#8B5CF6"/><stop offset="100%" stop-color="#A78BFA"/></linearGradient>
                    <linearGradient id="gBar3" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#10B981"/><stop offset="100%" stop-color="#34D399"/></linearGradient>
                    <linearGradient id="gBar4" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#F59E0B"/><stop offset="100%" stop-color="#FBBF24"/></linearGradient>
                </defs>
                <rect x="150" y="18" width="200" height="28" rx="6" fill="url(#gBar1)" opacity="0.9"/>
                <text x="210" y="37" fill="white" font-size="10" font-family="system-ui" font-weight="500">Build 2847</text>
                <rect x="370" y="18" width="180" height="28" rx="6" fill="url(#gBar2)" opacity="0.9"/>
                <text x="425" y="37" fill="white" font-size="10" font-family="system-ui" font-weight="500">Build 2849</text>
                <!-- Row 2 -->
                <rect x="180" y="83" width="220" height="28" rx="6" fill="url(#gBar2)" opacity="0.9"/>
                <text x="250" y="102" fill="white" font-size="10" font-family="system-ui" font-weight="500">Build 2848</text>
                <rect x="420" y="83" width="160" height="28" rx="6" fill="url(#gBar1)" opacity="0.9"/>
                <text x="465" y="102" fill="white" font-size="10" font-family="system-ui" font-weight="500">Build 2850</text>
                <!-- Row 3 -->
                <rect x="360" y="148" width="80" height="28" rx="6" fill="url(#gBar3)" opacity="0.9"/>
                <text x="375" y="167" fill="white" font-size="10" font-family="system-ui" font-weight="500">DP-47</text>
                <rect x="460" y="148" width="80" height="28" rx="6" fill="url(#gBar3)" opacity="0.9"/>
                <text x="475" y="167" fill="white" font-size="10" font-family="system-ui" font-weight="500">DP-48</text>
                <!-- Row 4 -->
                <rect x="450" y="213" width="100" height="28" rx="6" fill="url(#gBar4)" opacity="0.9"/>
                <text x="470" y="232" fill="white" font-size="10" font-family="system-ui" font-weight="500">EDM-47</text>
                <rect x="570" y="213" width="100" height="28" rx="6" fill="url(#gBar4)" opacity="0.9"/>
                <text x="590" y="232" fill="white" font-size="10" font-family="system-ui" font-weight="500">EDM-48</text>
                <!-- Now indicator -->
                <line x1="310" y1="0" x2="310" y2="260" stroke="#EF4444" stroke-width="1.5" stroke-dasharray="6,3"/>
                <circle cx="310" cy="4" r="4" fill="#EF4444"/>
            </svg>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">How It Works</h2>
    <div class="pub-steps">
        <div class="pub-step pub-fade-up">
            <div class="pub-step-num">1</div>
            <h3>Connect Your Machines</h3>
            <p>Set up your SLS printers, CNC machines, and post-processing stations in minutes. Configure shifts, operators, and production stages to match your shop floor.</p>
        </div>
        <div class="pub-step-connector"></div>
        <div class="pub-step pub-fade-up">
            <div class="pub-step-num">2</div>
            <h3>Schedule Builds</h3>
            <p>Our AI-powered advisor recommends optimal build plates, timing, and sequences. Drag-and-drop Gantt scheduling with automatic changeover analysis.</p>
        </div>
        <div class="pub-step-connector"></div>
        <div class="pub-step pub-fade-up">
            <div class="pub-step-num">3</div>
            <h3>Track Production</h3>
            <p>Monitor every stage from print to ship with real-time dashboards, operator queues, and automated alerts. Never miss a delivery again.</p>
        </div>
    </div>
</section>

<!-- Bottom CTA -->
<section class="pub-cta-banner">
    <h2 class="pub-gradient-text">Ready to transform your factory floor?</h2>
    <p>Join manufacturers who've cut scheduling time by 60% and eliminated missed deliveries.</p>
    <a href="/demo" class="pub-btn pub-btn-primary pub-btn-lg">Request a Demo</a>
</section>
