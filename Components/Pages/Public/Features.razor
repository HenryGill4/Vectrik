@page "/features"
@layout Components.Layout.PublicLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web

<!-- Hero -->
<section class="pub-page-hero">
    <h1 class="pub-gradient-text">Platform Features</h1>
    <p class="pub-page-hero-sub">Everything you need to run a modern additive manufacturing operation &mdash; from first order to final shipment.</p>
</section>

<!-- Scheduling & Planning -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Scheduling &amp; Planning</h2>
    <p class="pub-section-sub pub-fade-up">Optimize every build, every machine, every shift.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 9h18"/>
                    <path d="M9 3v18"/>
                    <rect x="13" y="13" width="4" height="4" rx="0.5" fill="currentColor" opacity="0.3"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Gantt Scheduler</h3>
            <p class="pub-card-text">Visual drag-and-drop production scheduling with real-time machine timelines. See every build, every stage, and every dependency at a glance. Shift-period shading highlights off-hours and weekends automatically.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M12 8v4l3 3"/>
                    <path d="M7.5 4.2l-.3-.5M16.5 4.2l.3-.5"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Next Build Advisor</h3>
            <p class="pub-card-text">AI-powered build plate recommendations analyze demand, material compatibility, stack configurations, and due dates to suggest optimal plate compositions that maximize throughput.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4v16h16"/>
                    <polyline points="4 16 8 12 12 14 16 8 20 10"/>
                    <circle cx="16" cy="8" r="1.5" fill="currentColor" opacity="0.3"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Changeover Analysis</h3>
            <p class="pub-card-text">Automatically detects whether SLS build changeovers fall within operator shift windows. Flags risky sequences that could cause machine downtime and recommends safer alternatives.</p>
        </div>
    </div>
</section>

<!-- Shop Floor Execution -->
<section class="pub-section pub-section-alt">
    <h2 class="pub-section-title pub-fade-up">Shop Floor Execution</h2>
    <p class="pub-section-sub pub-fade-up">Empower every operator with the right information at the right time.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" rx="1"/>
                    <rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/>
                    <rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Operator Queues</h3>
            <p class="pub-card-text">Each stage gets a dedicated work queue showing priority-ordered jobs. Operators see exactly what to work on next with clear status indicators, estimated durations, and due-date urgency.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 11 12 14 22 4"/>
                    <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Stage Tracking</h3>
            <p class="pub-card-text">Real-time progress tracking through every production stage. From SLS print to depowder, wire EDM, CNC machining, finishing, QC, and shipping &mdash; nothing falls through the cracks.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="8" y1="13" x2="16" y2="13"/>
                    <line x1="8" y1="17" x2="16" y2="17"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Digital Work Instructions</h3>
            <p class="pub-card-text">Attach step-by-step instructions, photos, and checklists to any production stage. Operators get clear guidance at the machine, reducing errors and training time.</p>
        </div>
    </div>
</section>

<!-- Quality & Compliance -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Quality &amp; Compliance</h2>
    <p class="pub-section-sub pub-fade-up">Stay audit-ready without slowing down production.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="9 12 11 14 15 10"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Inline QC Checks</h3>
            <p class="pub-card-text">Embed quality checkpoints at any production stage. Operators complete inspections in-flow with pass/fail criteria, dimensional measurements, and photo documentation.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            <h3 class="pub-card-title">NCR Management</h3>
            <p class="pub-card-text">Non-conformance reports track defects from discovery through root-cause analysis to corrective action. Full audit trails for every quality event with automated notifications.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4v16h16"/>
                    <path d="M4 14l4-4 4 2 4-6 4 4"/>
                </svg>
            </div>
            <h3 class="pub-card-title">SPC Charts</h3>
            <p class="pub-card-text">Statistical process control charting tracks critical dimensions over time. Detect drift before it becomes a defect with automated control limit calculations and trend alerts.</p>
        </div>
    </div>
</section>

<!-- Analytics & Reporting -->
<section class="pub-section pub-section-alt">
    <h2 class="pub-section-title pub-fade-up">Analytics &amp; Reporting</h2>
    <p class="pub-section-sub pub-fade-up">Turn production data into actionable insights.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="12" width="4" height="9" rx="1"/>
                    <rect x="10" y="7" width="4" height="14" rx="1"/>
                    <rect x="17" y="3" width="4" height="18" rx="1"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Machine OEE</h3>
            <p class="pub-card-text">Overall Equipment Effectiveness dashboards show availability, performance, and quality metrics for every machine. Identify bottlenecks and optimize utilization across your fleet.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Cost Analysis</h3>
            <p class="pub-card-text">Track material, machine time, labor, and overhead costs per part, per build, and per work order. Compare quoted vs. actual costs to protect margins and improve future estimates.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <h3 class="pub-card-title">On-Time Delivery</h3>
            <p class="pub-card-text">Monitor delivery performance across all work orders with trend analysis, at-risk alerts, and root-cause breakdowns for late shipments. Set targets and track improvement over time.</p>
        </div>
    </div>
</section>

<!-- Platform -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Platform &amp; Infrastructure</h2>
    <p class="pub-section-sub pub-fade-up">Enterprise-grade foundation built for manufacturing.</p>
    <div class="pub-feature-grid">
        <div class="pub-card pub-card-compact pub-fade-up">
            <div class="pub-card-icon pub-card-icon-sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Multi-Tenant Architecture</h3>
            <p class="pub-card-text">Isolated data per customer with tenant-specific configuration, branding, and feature flags.</p>
        </div>
        <div class="pub-card pub-card-compact pub-fade-up">
            <div class="pub-card-icon pub-card-icon-sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Real-Time Updates</h3>
            <p class="pub-card-text">Live machine state monitoring via SignalR. Production changes appear instantly across all connected screens.</p>
        </div>
        <div class="pub-card pub-card-compact pub-fade-up">
            <div class="pub-card-icon pub-card-icon-sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Role-Based Access</h3>
            <p class="pub-card-text">Configurable user roles and stage assignments. Operators see their queues, managers see the full picture.</p>
        </div>
        <div class="pub-card pub-card-compact pub-fade-up">
            <div class="pub-card-icon pub-card-icon-sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                </svg>
            </div>
            <h3 class="pub-card-title">API &amp; Webhooks</h3>
            <p class="pub-card-text">REST API for integrating with ERP, CAM, and machine monitoring systems. Webhooks for event-driven automation.</p>
        </div>
    </div>
</section>

<!-- Machine Management -->
<section class="pub-section pub-section-alt">
    <h2 class="pub-section-title pub-fade-up">Machine Management</h2>
    <p class="pub-section-sub pub-fade-up">Monitor, maintain, and maximize every asset on your floor.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Status Monitoring</h3>
            <p class="pub-card-text">Live machine state tracking across your entire fleet. See which machines are running, idle, in changeover, or down at a glance. Instant alerts when status changes require attention.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="12" width="4" height="9" rx="1"/>
                    <rect x="10" y="7" width="4" height="14" rx="1"/>
                    <rect x="17" y="3" width="4" height="18" rx="1"/>
                </svg>
            </div>
            <h3 class="pub-card-title">OEE Tracking</h3>
            <p class="pub-card-text">Overall Equipment Effectiveness dashboards break down availability, performance, and quality for every machine. Spot utilization gaps and track improvement initiatives over time.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Maintenance Scheduling</h3>
            <p class="pub-card-text">Schedule preventive maintenance based on runtime hours, build counts, or calendar intervals. Track maintenance history, spare parts, and service records for every machine.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Shift Assignments</h3>
            <p class="pub-card-text">Assign operating shifts and operators to machines with flexible scheduling. The system automatically accounts for unmanned periods when planning builds and changeovers.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4v16h16"/>
                    <polyline points="4 16 8 12 12 14 16 8 20 10"/>
                    <circle cx="16" cy="8" r="1.5" fill="currentColor" opacity="0.3"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Changeover Analysis</h3>
            <p class="pub-card-text">Analyze SLS changeover timing against operator availability windows. Identify risky sequences that could leave machines idle and recommend schedule adjustments to maintain continuous operation.</p>
        </div>
    </div>
</section>

<!-- Work Order Management -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Work Order Management</h2>
    <p class="pub-section-sub pub-fade-up">From order intake to final shipment &mdash; track every detail.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Order Intake</h3>
            <p class="pub-card-text">Create work orders with customer details, required dates, and line items. Link parts, quantities, and special requirements. Import orders from your ERP or enter them directly.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="8" y1="6" x2="21" y2="6"/>
                    <line x1="8" y1="12" x2="21" y2="12"/>
                    <line x1="8" y1="18" x2="21" y2="18"/>
                    <line x1="3" y1="6" x2="3.01" y2="6"/>
                    <line x1="3" y1="12" x2="3.01" y2="12"/>
                    <line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Line-Item Tracking</h3>
            <p class="pub-card-text">Track individual line items through production with per-part status, quantity tracking, and completion percentages. See which lines are on schedule and which need attention.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Due Date Management</h3>
            <p class="pub-card-text">Set required dates per work order and line item. The scheduler highlights at-risk deliveries and prioritizes jobs automatically so the most urgent work gets built first.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Customer Linking</h3>
            <p class="pub-card-text">Associate work orders with customer accounts for order history, repeat-order shortcuts, and customer-specific reporting. Track delivery performance per customer over time.</p>
        </div>

        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Fulfillment Progress</h3>
            <p class="pub-card-text">Visual progress tracking from order creation through production, QC, and shipment. Dashboards show overall fulfillment rates, aging orders, and upcoming deadlines at a glance.</p>
        </div>
    </div>
</section>

<!-- Inventory & Materials -->
<section class="pub-section pub-section-alt">
    <h2 class="pub-section-title pub-fade-up">Inventory &amp; Materials</h2>
    <p class="pub-section-sub pub-fade-up">Full material traceability from powder lot to finished part.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
