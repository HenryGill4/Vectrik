<!-- Build Advisor -->
<section class="pub-section">
    <div class="pub-feature-spotlight pub-feature-spotlight-reverse pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">AI-Powered</div>
            <h2>Next Build Advisor</h2>
            <p>Stop spending hours manually composing build plates. The Next Build Advisor analyzes your open demand and recommends optimal plate compositions based on real production constraints.</p>
            <ul class="pub-feature-detail-list">
                <li>Aggregates unfulfilled demand across all open work orders</li>
                <li>Groups parts by material compatibility and build approach</li>
                <li>Evaluates single, double, and triple stack configurations</li>
                <li>Calculates print duration changes for each stacking option</li>
                <li>Prioritizes parts with the earliest due dates</li>
                <li>Recommends the plate composition that maximizes throughput while meeting deadlines</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-advisor-mockup">
                <div class="pub-advisor-header">Next Build Advisor</div>
                <div class="pub-advisor-rec">
                    <div class="pub-advisor-rec-label">Recommended Build Plate</div>
                    <div class="pub-advisor-rec-parts">
                        <div class="pub-advisor-part">
