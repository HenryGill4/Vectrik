@page "/features/analytics"
@layout Components.Layout.PublicLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Analytics &amp; Reporting - Vectrik</PageTitle>

<!-- Breadcrumb -->
<div class="pub-breadcrumb">
    <a href="/features">Features</a>
    <span class="pub-breadcrumb-sep">/</span>
    <span>Analytics &amp; Reporting</span>
</div>

<!-- Hero -->
<section class="pub-page-hero">
    <h1 class="pub-gradient-text">Analytics &amp; Reporting</h1>
    <p class="pub-page-hero-sub">Machine OEE, cost analysis, on-time delivery tracking, and capacity planning &mdash; turn production data into decisions, not just dashboards.</p>
</section>

<!-- Problem Statement -->
<section class="pub-section">
    <div class="pub-feature-detail">
        <div class="pub-feature-detail-content pub-fade-up">
            <h2 class="pub-section-title">Data That Drives Decisions</h2>
            <p class="pub-about-text">
                Most AM operations have data scattered across spreadsheets, machine logs, and ERP exports. Pulling a simple answer &mdash; "What's our true machine utilization?" or "Are we making money on this part?" &mdash; takes hours of manual aggregation.
            </p>
            <p class="pub-about-text">
                Because Vectrik captures data at every stage of production, analytics happen automatically. OEE calculates from real machine state data. Cost analysis pulls from actual print times, not estimates. Delivery performance tracks against committed dates, not optimistic guesses.
            </p>
        </div>
    </div>
</section>

<!-- Machine OEE -->
<section class="pub-section pub-section-alt">
    <div class="pub-feature-spotlight pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">Machine Performance</div>
            <h2>Machine OEE</h2>
            <p>Overall Equipment Effectiveness breaks down into three components: availability, performance, and quality. Vectrik calculates all three from real production data for every machine in your fleet.</p>
            <ul class="pub-feature-detail-list">
                <li><strong>Availability</strong> &mdash; uptime vs. downtime, including changeover delays and unplanned stops</li>
                <li><strong>Performance</strong> &mdash; actual vs. planned print/cycle times per build</li>
                <li><strong>Quality</strong> &mdash; first-pass yield from inline QC and NCR data</li>
                <li>Per-machine and fleet-wide OEE dashboards</li>
                <li>Trend tracking over days, weeks, and months</li>
                <li>Drill-down into specific downtime events and their root causes</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-oee-mockup">
                <div class="pub-oee-header">EOS M4 #1 &mdash; March 2026</div>
                <div class="pub-oee-bars">
                    <div class="pub-oee-bar">
                        <div class="pub-oee-bar-label">Availability</div>
                        <div class="pub-oee-bar-track">
                            <div class="pub-oee-bar-fill pub-oee-bar-avail" style="width: 87%"></div>
                        </div>
                        <span class="pub-oee-bar-val">87%</span>
                    </div>
                    <div class="pub-oee-bar">
                        <div class="pub-oee-bar-label">Performance</div>
                        <div class="pub-oee-bar-track">
                            <div class="pub-oee-bar-fill pub-oee-bar-perf" style="width: 94%"></div>
                        </div>
                        <span class="pub-oee-bar-val">94%</span>
                    </div>
                    <div class="pub-oee-bar">
                        <div class="pub-oee-bar-label">Quality</div>
                        <div class="pub-oee-bar-track">
                            <div class="pub-oee-bar-fill pub-oee-bar-qual" style="width: 98%"></div>
                        </div>
                        <span class="pub-oee-bar-val">98%</span>
                    </div>
                </div>
                <div class="pub-oee-total">
                    <span class="pub-oee-total-label">Overall OEE</span>
                    <span class="pub-oee-total-value">80.1%</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Cost Analysis -->
<section class="pub-section">
    <div class="pub-feature-spotlight pub-feature-spotlight-reverse pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">Margin Protection</div>
            <h2>Cost Analysis</h2>
            <p>Know the true cost of every part you produce. Vectrik tracks material, machine time, labor, and overhead to give you accurate per-part and per-build cost breakdowns.</p>
            <ul class="pub-feature-detail-list">
                <li>Machine time costs calculated from actual print hours at configured hourly rates</li>
                <li>Material costs from powder usage per build with lot pricing</li>
                <li>Labor costs from operator time logged at each stage</li>
                <li>Overhead allocation across builds and parts</li>
                <li>Quoted vs. actual cost comparison per work order</li>
                <li>Margin analysis to identify which jobs are profitable and which aren't</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-cost-mockup">
                <div class="pub-cost-header">Cost Breakdown: Build 2847</div>
                <div class="pub-cost-row">
                    <span class="pub-cost-label">Machine Time</span>
                    <span class="pub-cost-detail">24.5 hrs @ $200/hr</span>
                    <span class="pub-cost-amount">$4,900</span>
                </div>
                <div class="pub-cost-row">
                    <span class="pub-cost-label">Material (IN718)</span>
                    <span class="pub-cost-detail">3.2 kg @ $85/kg</span>
                    <span class="pub-cost-amount">$272</span>
                </div>
                <div class="pub-cost-row">
                    <span class="pub-cost-label">Post-Processing</span>
                    <span class="pub-cost-detail">6.5 hrs labor</span>
                    <span class="pub-cost-amount">$455</span>
                </div>
                <div class="pub-cost-row">
                    <span class="pub-cost-label">Overhead</span>
                    <span class="pub-cost-detail">12% allocation</span>
                    <span class="pub-cost-amount">$675</span>
                </div>
                <div class="pub-cost-total">
                    <span>Total Build Cost</span>
                    <span>$6,302</span>
                </div>
                <div class="pub-cost-perpart">
                    <span>Per Part (12 parts)</span>
                    <span>$525</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Delivery & Capacity -->
<section class="pub-section pub-section-alt">
    <h2 class="pub-section-title pub-fade-up">Delivery Performance &amp; Capacity Planning</h2>
    <p class="pub-section-sub pub-fade-up">Track what matters most: are you shipping on time, and do you have capacity for what's coming?</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <h3 class="pub-card-title">On-Time Delivery</h3>
            <p class="pub-card-text">Track delivery performance across all work orders. See trends over time, identify repeat late causes, and set improvement targets. At-risk alerts flag orders before they become late.</p>
        </div>
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="12" width="4" height="9" rx="1"/>
                    <rect x="10" y="7" width="4" height="14" rx="1"/>
                    <rect x="17" y="3" width="4" height="18" rx="1"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Capacity Utilization</h3>
            <p class="pub-card-text">See how full your machines are over the coming weeks. Identify open capacity windows for new orders or spot overcommitment before it causes delays.</p>
        </div>
        <div class="pub-card pub-fade-up">
            <div class="pub-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="8" y1="13" x2="16" y2="13"/>
                    <line x1="8" y1="17" x2="16" y2="17"/>
                </svg>
            </div>
            <h3 class="pub-card-title">Custom Reports</h3>
            <p class="pub-card-text">Export production data for any date range, machine, or customer. CSV exports for further analysis in your existing tools. Scheduled report delivery coming soon.</p>
        </div>
    </div>
</section>

<!-- Next/Prev Navigation -->
<section class="pub-section">
    <div class="pub-subpage-nav">
        <div class="pub-subpage-nav-item">
            <a href="/features/quality">
                <span class="pub-subpage-nav-dir">Previous</span>
                <span class="pub-subpage-nav-title">Quality &amp; Compliance</span>
            </a>
        </div>
        <div class="pub-subpage-nav-item pub-subpage-nav-disabled">
            <span class="pub-subpage-nav-dir">Next</span>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="pub-cta-banner">
    <h2 class="pub-gradient-text">See your data come alive</h2>
    <p>We'll walk you through OEE dashboards, cost analysis, and delivery tracking with your actual production scenarios.</p>
    <a href="/demo" class="pub-btn pub-btn-primary pub-btn-lg">Request a Demo</a>
</section>
