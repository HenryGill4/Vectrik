@page "/features/shop-floor"
@layout Components.Layout.PublicLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Shop Floor Execution - Vectrik</PageTitle>

<!-- Breadcrumb -->
<div class="pub-breadcrumb">
    <a href="/features">Features</a>
    <span class="pub-breadcrumb-sep">/</span>
    <span>Shop Floor Execution</span>
</div>

<!-- Hero -->
<section class="pub-page-hero">
    <h1 class="pub-gradient-text">Shop Floor Execution</h1>
    <p class="pub-page-hero-sub">Operator-friendly tools that guide work through every production stage &mdash; from SLS print through depowdering, wire EDM, CNC machining, finishing, and shipping.</p>
</section>

<!-- Problem Statement -->
<section class="pub-section">
    <div class="pub-feature-detail">
        <div class="pub-feature-detail-content pub-fade-up">
            <h2 class="pub-section-title">Beyond the Schedule</h2>
            <p class="pub-about-text">
                A schedule is only useful if the shop floor can execute it. Most AM operations rely on verbal handoffs, paper travelers, and operators walking the floor to find their next job. Parts get lost between stages, priorities shift without communication, and operators waste time figuring out what to work on next.
            </p>
            <p class="pub-about-text">
                Vectrik connects your schedule directly to the shop floor. Each production stage gets a dedicated digital queue. Operators log in, see their prioritized work, follow guided instructions, and record completions &mdash; all without leaving the workstation.
            </p>
        </div>
    </div>
</section>

<!-- Operator Queues -->
<section class="pub-section pub-section-alt">
    <div class="pub-feature-spotlight pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">Operator Experience</div>
            <h2>Stage Queues</h2>
            <p>Every production stage &mdash; depowder, wire EDM, CNC, finishing, QC &mdash; gets a dedicated work queue showing exactly what needs to be done, in priority order.</p>
            <ul class="pub-feature-detail-list">
                <li>Priority-ordered job cards with due-date urgency indicators</li>
                <li>One-tap start/complete actions for fast logging</li>
                <li>Estimated durations and elapsed time tracking per job</li>
                <li>Color-coded status: queued, in progress, completed, on hold</li>
                <li>Filter by machine, material, or work order</li>
                <li>Tablet and mobile-friendly interface for shop floor use</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-queue-mockup">
                <div class="pub-queue-header">
                    <span class="pub-queue-stage">CNC Machining</span>
                    <span class="pub-queue-count">4 jobs queued</span>
                </div>
                <div class="pub-queue-item pub-queue-active">
                    <div class="pub-queue-item-status pub-queue-status-active"></div>
                    <div class="pub-queue-item-info">
                        <span class="pub-queue-item-name">Bracket-A7 (x4)</span>
                        <span class="pub-queue-item-wo">WO-2847</span>
                    </div>
                    <span class="pub-queue-item-urgent">Due Tomorrow</span>
                </div>
                <div class="pub-queue-item">
                    <div class="pub-queue-item-status pub-queue-status-queued"></div>
                    <div class="pub-queue-item-info">
                        <span class="pub-queue-item-name">Housing-C3 (x2)</span>
                        <span class="pub-queue-item-wo">WO-2849</span>
                    </div>
                    <span class="pub-queue-item-time">Est. 45 min</span>
                </div>
                <div class="pub-queue-item">
                    <div class="pub-queue-item-status pub-queue-status-queued"></div>
                    <div class="pub-queue-item-info">
                        <span class="pub-queue-item-name">Cap-F1 (x6)</span>
                        <span class="pub-queue-item-wo">WO-2851</span>
                    </div>
                    <span class="pub-queue-item-time">Est. 30 min</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stage Tracking -->
<section class="pub-section">
    <div class="pub-feature-spotlight pub-feature-spotlight-reverse pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">Full Visibility</div>
            <h2>Multi-Stage Production Tracking</h2>
            <p>Track every job through the complete SLS production flow. Vectrik handles both build-level operations (print, depowder, EDM) and part-level operations (CNC, finishing, QC) seamlessly.</p>
            <ul class="pub-feature-detail-list">
                <li>Build-level tracking: SLS Print &rarr; Depowder &rarr; Wire EDM</li>
                <li>Part-level tracking: CNC Machining &rarr; Finishing &rarr; QC &rarr; Shipping</li>
                <li>Automatic transition from build-level to part-level after EDM cuts parts off the plate</li>
                <li>Real-time status updates across all connected screens</li>
                <li>Full history of who worked on each job and when</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-stage-flow">
                <div class="pub-stage-flow-item pub-stage-complete">
                    <div class="pub-stage-flow-dot"></div>
                    <span>SLS Print</span>
                </div>
                <div class="pub-stage-flow-line pub-stage-flow-line-complete"></div>
                <div class="pub-stage-flow-item pub-stage-complete">
                    <div class="pub-stage-flow-dot"></div>
                    <span>Depowder</span>
                </div>
                <div class="pub-stage-flow-line pub-stage-flow-line-complete"></div>
                <div class="pub-stage-flow-item pub-stage-active">
                    <div class="pub-stage-flow-dot"></div>
                    <span>Wire EDM</span>
                </div>
                <div class="pub-stage-flow-line"></div>
                <div class="pub-stage-flow-item">
                    <div class="pub-stage-flow-dot"></div>
                    <span>CNC</span>
                </div>
                <div class="pub-stage-flow-line"></div>
                <div class="pub-stage-flow-item">
                    <div class="pub-stage-flow-dot"></div>
                    <span>Finishing</span>
                </div>
                <div class="pub-stage-flow-line"></div>
                <div class="pub-stage-flow-item">
                    <div class="pub-stage-flow-dot"></div>
                    <span>QC</span>
                </div>
                <div class="pub-stage-flow-line"></div>
                <div class="pub-stage-flow-item">
                    <div class="pub-stage-flow-dot"></div>
                    <span>Ship</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Work Instructions -->
<section class="pub-section pub-section-alt">
    <div class="pub-feature-spotlight pub-fade-up">
        <div class="pub-feature-spotlight-text">
            <div class="pub-feature-spotlight-label">Guided Operations</div>
            <h2>Digital Work Instructions</h2>
            <p>Eliminate tribal knowledge and reduce training time. Attach step-by-step instructions to any production stage so operators get clear guidance at the machine.</p>
            <ul class="pub-feature-detail-list">
                <li>Step-by-step procedures with text, photos, and checklists</li>
                <li>Version-controlled &mdash; operators always see the latest revision</li>
                <li>Part-specific and stage-specific instruction sets</li>
                <li>Operators check off steps as they complete them</li>
                <li>Completion logs for training verification and audit trails</li>
                <li>Accessible on any device &mdash; desktop, tablet, or phone</li>
            </ul>
        </div>
        <div class="pub-feature-spotlight-visual">
            <div class="pub-instruction-mockup">
                <div class="pub-instruction-header">Work Instruction: CNC Setup - Bracket-A7</div>
                <div class="pub-instruction-step pub-instruction-step-done">
                    <span class="pub-instruction-check">&#10003;</span>
                    <span>Verify fixture is clean and clamped to table</span>
                </div>
                <div class="pub-instruction-step pub-instruction-step-done">
                    <span class="pub-instruction-check">&#10003;</span>
                    <span>Load program BRACKET-A7-v3.nc from network</span>
                </div>
                <div class="pub-instruction-step pub-instruction-step-active">
                    <span class="pub-instruction-num">3</span>
                    <span>Set work offset Z to top of part using edge finder</span>
                </div>
                <div class="pub-instruction-step">
                    <span class="pub-instruction-num">4</span>
                    <span>Run first piece at 50% feed rate and inspect</span>
                </div>
                <div class="pub-instruction-step">
                    <span class="pub-instruction-num">5</span>
                    <span>Log dimensional measurement in QC checklist</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Connected Features -->
<section class="pub-section">
    <h2 class="pub-section-title pub-fade-up">Shop Floor + Scheduling, Connected</h2>
    <p class="pub-section-sub pub-fade-up">What happens on the floor feeds back into the schedule in real time.</p>
    <div class="pub-feature-grid pub-feature-grid-3">
        <div class="pub-card pub-card-compact pub-fade-up">
            <h3 class="pub-card-title">Live Schedule Updates</h3>
            <p class="pub-card-text">When an operator completes a stage, the Gantt view updates instantly. Managers see real progress, not yesterday's status report.</p>
        </div>
        <div class="pub-card pub-card-compact pub-fade-up">
            <h3 class="pub-card-title">Bottleneck Detection</h3>
            <p class="pub-card-text">Queue depths per stage highlight where work is backing up. If CNC has 12 jobs queued and finishing has 2, you know where to focus.</p>
        </div>
        <div class="pub-card pub-card-compact pub-fade-up">
            <h3 class="pub-card-title">Operator Accountability</h3>
            <p class="pub-card-text">Every start/stop is logged with operator ID and timestamp. Know who worked on every part at every stage &mdash; critical for traceability.</p>
        </div>
    </div>
</section>

<!-- Next/Prev Navigation -->
<section class="pub-section pub-section-alt">
    <div class="pub-subpage-nav">
        <div class="pub-subpage-nav-item">
            <a href="/features/scheduling">
                <span class="pub-subpage-nav-dir">Previous</span>
                <span class="pub-subpage-nav-title">Scheduling &amp; Planning</span>
            </a>
        </div>
        <div class="pub-subpage-nav-item">
            <a href="/features/quality">
                <span class="pub-subpage-nav-dir">Next</span>
                <span class="pub-subpage-nav-title">Quality &amp; Compliance</span>
            </a>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="pub-cta-banner">
    <h2 class="pub-gradient-text">See the shop floor experience</h2>
    <p>We'll show you operator queues, work instructions, and real-time stage tracking in action.</p>
    <a href="/demo" class="pub-btn pub-btn-primary pub-btn-lg">Request a Demo</a>
</section>
