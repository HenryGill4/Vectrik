@page "/shopfloor/setup-queue"
@inject Vectrik.Services.ISetupDispatchService DispatchService
@inject Vectrik.Services.IPrintStartDispatchService PrintStartService
@inject Vectrik.Services.IPrintCompletionService PrintCompletionService
@inject Vectrik.Services.IMaintenanceDispatchService MaintenanceDispatchService
@inject Vectrik.Services.ToastService Toast
@inject Vectrik.Data.TenantDbContext Db
@using Vectrik.Models
@using Vectrik.Models.Enums
@using System.Text.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Setup Queue - Vectrik</PageTitle>

@* ── Maintenance Warning Banner ── *@
@if (_maintenanceBlocks.Any(b => b.Value.IsBlocked))
{
    <div class="setup-maintenance-banner">
        @foreach (var (machineId, block) in _maintenanceBlocks.Where(b => b.Value.IsBlocked))
        {
            <div class="setup-maintenance-alert">
                <span>⚙ @block.BlockReason</span>
            </div>
        }
    </div>
}

@* ── Urgent Changeover Alert Overlay ── *@
@if (_urgentChangeover != null)
{
    <div class="setup-urgent-overlay" @onclick="DismissUrgentAlert">
        <div class="setup-urgent-alert">
            <div class="setup-urgent-icon">⚠</div>
            <h2>CHANGEOVER REQUIRED</h2>
            <p>@_urgentChangeover.Machine?.Name — Chamber at risk of overflow</p>
            @if (_urgentChangeover.ScheduledStartAt.HasValue)
            {
                var overdue = (DateTime.UtcNow - _urgentChangeover.ScheduledStartAt.Value).TotalMinutes;
                <p class="setup-urgent-time">@(overdue > 0 ? $"OVERDUE by {overdue:F0} min" : $"Due in {Math.Abs(overdue):F0} min")</p>
            }
            <button class="btn btn-lg btn-danger" @onclick="() => AcceptAndStart(_urgentChangeover.Id)">Accept & Start Now</button>
            <button class="btn btn-lg btn-secondary" @onclick="DismissUrgentAlert">Dismiss</button>
        </div>
    </div>
}

<div class="setup-queue">
    <div class="setup-queue-header">
        <h1>Setup Queue</h1>
        @if (_operatorName != null)
        {
            <span class="setup-queue-operator">@_operatorName</span>
        }
    </div>

    @if (_loading)
    {
        <div class="loading"><span class="spinner"></span> Loading queue...</div>
    }
    else
    {
        @* ── Current Setup Panel ── *@
        @if (_currentSetup != null)
        {
            <div class="setup-current @(_currentSetup.DispatchType == DispatchType.PrintStart ? "setup-current--printstart" : "")">
                <div class="setup-current-header">
                    <h2>
                        @if (_currentSetup.DispatchType == DispatchType.PrintStart)
                        {
                            <text>Print Start</text>
                        }
                        else if (_currentSetup.DispatchType == DispatchType.Teardown && !string.IsNullOrEmpty(_currentSetup.InspectionChecklistJson))
                        {
                            <text>Post-Print Inspection</text>
                        }
                        else
                        {
                            <text>Current Setup</text>
                        }
                    </h2>
                    <span class="dispatch-card-badge dispatch-card-badge--@_currentSetup.Status.ToString().ToLower()">
                        @_currentSetup.StatusDisplay
                    </span>
                </div>
                <div class="setup-current-body">
                    <div class="setup-current-info">
                        <div class="setup-info-row">
                            <span class="setup-info-label">Dispatch</span>
                            <span class="setup-info-value">@_currentSetup.DispatchNumber</span>
                        </div>
                        <div class="setup-info-row">
                            <span class="setup-info-label">Machine</span>
                            <span class="setup-info-value">@_currentSetup.Machine?.Name</span>
                        </div>
                        @if (_currentSetup.MachineProgram != null)
                        {
                            <div class="setup-info-row">
                                <span class="setup-info-label">Program</span>
                                <span class="setup-info-value">@_currentSetup.MachineProgram.Name (@_currentSetup.MachineProgram.ProgramNumber)</span>
                            </div>
                        }
                        @if (_currentSetup.Part != null)
                        {
                            <div class="setup-info-row">
                                <span class="setup-info-label">Part</span>
                                <span class="setup-info-value">@_currentSetup.Part.PartNumber — @_currentSetup.Part.Name</span>
                            </div>
                        }
                        @if (_currentSetup.ToolingRequired != null)
                        {
                            <div class="setup-info-row">
                                <span class="setup-info-label">Tooling</span>
                                <span class="setup-info-value">@_currentSetup.ToolingRequired</span>
                            </div>
                        }
                        @if (_currentSetup.FixtureRequired != null)
                        {
                            <div class="setup-info-row">
                                <span class="setup-info-label">Fixture</span>
                                <span class="setup-info-value">@_currentSetup.FixtureRequired</span>
                            </div>
                        }
                        @if (_currentSetup.Notes != null)
                        {
                            <div class="setup-info-row">
                                <span class="setup-info-label">Notes</span>
                                <span class="setup-info-value">@_currentSetup.Notes</span>
                            </div>
                        }
                    </div>

                    @* Pre-Print Checklist (PrintStart dispatches) *@
                    @if (_currentSetup.DispatchType == DispatchType.PrintStart && _prePrintChecklist.Any())
                    {
                        <div class="setup-checklist">
                            <h3>Pre-Print Checklist</h3>
                            @foreach (var item in _prePrintChecklist)
                            {
                                <div class="setup-checklist-item">
                                    <label class="setup-checklist-label">
                                        <input type="checkbox" checked="@item.SignedOff"
                                               @onchange="(e) => TogglePrePrintItem(item.StepId, (bool)(e.Value ?? false))" />
                                        <span>@item.Title</span>
                                        @if (item.Required) { <span class="badge-required">Required</span> }
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    @* Inspection Checklist (Teardown dispatches) *@
                    @if (_currentSetup.DispatchType == DispatchType.Teardown && _inspectionChecklist.Any())
                    {
                        <div class="setup-checklist">
                            <h3>Post-Print Inspection</h3>
                            @foreach (var item in _inspectionChecklist)
                            {
                                <div class="setup-checklist-item @(item.Passed == false ? "setup-checklist-item--failed" : "")">
                                    <label class="setup-checklist-label">
                                        <input type="checkbox" checked="@item.Inspected"
                                               @onchange="(e) => ToggleInspectionItem(item.StepId, (bool)(e.Value ?? false))" />
                                        <span>@item.Title</span>
                                        @if (item.Required) { <span class="badge-required">Required</span> }
                                    </label>
                                    @if (item.Inspected)
                                    {
                                        <div class="setup-checklist-result">
                                            <label>
                                                <input type="radio" name="inspect-@item.StepId" checked="@(item.Passed == true)"
                                                       @onchange="() => SetInspectionResult(item.StepId, true)" /> Pass
                                            </label>
                                            <label>
                                                <input type="radio" name="inspect-@item.StepId" checked="@(item.Passed == false)"
                                                       @onchange="() => SetInspectionResult(item.StepId, false)" /> Fail
                                            </label>
                                        </div>
                                        @if (item.Passed == false)
                                        {
                                            <input type="text" class="form-control" placeholder="Failure notes..."
                                                   value="@item.FailureNotes"
                                                   @onchange="(e) => SetInspectionNotes(item.StepId, e.Value?.ToString())" />
                                        }
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* Timer *@
                    @if (_currentSetup.StartedAt.HasValue)
                    {
                        var elapsed = (DateTime.UtcNow - _currentSetup.StartedAt.Value).TotalMinutes;
                        <div class="setup-timer">
                            <span class="setup-timer-value">@($"{elapsed:F0}")</span>
                            <span class="setup-timer-label">minutes elapsed</span>
                            @if (_currentSetup.EstimatedSetupMinutes.HasValue)
                            {
                                var pct = Math.Min(100, elapsed / _currentSetup.EstimatedSetupMinutes.Value * 100);
                                <div class="setup-timer-bar">
                                    <div class="setup-timer-fill" style="width: @($"{pct:F0}%"); background: @(pct > 100 ? "var(--danger)" : "var(--accent)")"></div>
                                </div>
                                <span class="setup-timer-est">/ @($"{_currentSetup.EstimatedSetupMinutes:F0}") min estimated</span>
                            }
                        </div>
                    }
                </div>

                <div class="setup-current-actions">
                    @if (_currentSetup.DispatchType == DispatchType.PrintStart)
                    {
                        <button class="btn btn-xl btn-accent setup-start-print-btn"
                                disabled="@(!AllPrePrintItemsComplete())"
                                @onclick="CompletePrintStart">
                            START PRINT
                        </button>
                    }
                    else if (_currentSetup.DispatchType == DispatchType.Teardown && !string.IsNullOrEmpty(_currentSetup.InspectionChecklistJson))
                    {
                        <button class="btn btn-xl btn-accent"
                                disabled="@(!AllInspectionItemsComplete())"
                                @onclick="CompleteInspection">
                            COMPLETE INSPECTION
                        </button>
                    }
                    else if (_currentSetup.Status == DispatchStatus.InProgress)
                    {
                        <button class="btn btn-lg btn-accent" @onclick="CompleteCurrentSetup">Complete Setup</button>
                        <button class="btn btn-lg btn-secondary" @onclick="RequestVerification">Request Verification</button>
                    }
                    else if (_currentSetup.Status == DispatchStatus.PendingVerification)
                    {
                        <div class="setup-verification-waiting">Waiting for verification...</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="setup-current setup-current--empty">
                <p>No active setup. Accept a dispatch from the queue below to begin.</p>
            </div>
        }

        @* ── Queued Dispatches (filter out PlateLayout — engineer only) ── *@
        <div class="setup-queue-list">
            <h2>Next Up (@_queue.Count)</h2>
            @if (_queue.Any())
            {
                @foreach (var dispatch in _queue)
                {
                    <div class="setup-queue-card @(dispatch.DispatchType == DispatchType.Changeover && dispatch.Priority >= 85 ? "setup-queue-card--urgent" : "")">
                        <div class="setup-queue-card-header">
                            <span class="dispatch-card-number">@dispatch.DispatchNumber</span>
                            <span class="dispatch-card-badge dispatch-card-badge--@dispatch.Status.ToString().ToLower()">@dispatch.StatusDisplay</span>
                            <span class="dispatch-card-priority">P@dispatch.Priority</span>
                        </div>
                        <div class="setup-queue-card-body">
                            <span>@dispatch.Machine?.Name</span>
                            <span>@dispatch.TypeDisplay</span>
                            @if (dispatch.MachineProgram != null)
                            {
                                <span>@dispatch.MachineProgram.Name</span>
                            }
                            @if (dispatch.Part != null)
                            {
                                <span>@dispatch.Part.PartNumber</span>
                            }
                            @if (dispatch.EstimatedSetupMinutes.HasValue)
                            {
                                <span>~@($"{dispatch.EstimatedSetupMinutes:F0}") min</span>
                            }
                        </div>
                        <div class="setup-queue-card-actions">
                            @if (dispatch.Status == DispatchStatus.Assigned || dispatch.Status == DispatchStatus.Queued)
                            {
                                <button class="btn btn-lg btn-primary" @onclick="() => AcceptAndStart(dispatch.Id)">Accept & Start</button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="setup-queue-empty">No dispatches in queue.</div>
            }
        </div>

        @* ── Barcode Scan Input ── *@
        <div class="setup-barcode-section">
            <label>Scan Dispatch Barcode</label>
            <input type="text" class="form-control setup-barcode-input"
                   placeholder="Scan or type dispatch number..."
                   @bind="_barcodeScan"
                   @bind:event="oninput"
                   @onkeydown="HandleBarcodeScan" />
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private SetupDispatch? _currentSetup;
    private List<SetupDispatch> _queue = new();
    private string? _operatorName;
    private int _currentUserId;
    private string _barcodeScan = "";

    // Phase 2: Urgent changeover alert
    private SetupDispatch? _urgentChangeover;

    // Phase 3: Maintenance blocks
    private Dictionary<int, MaintenanceBlockResult> _maintenanceBlocks = new();

    // Phase 2: Pre-print checklist
    private List<SignOffChecklistItem> _prePrintChecklist = new();

    // Phase 2: Inspection checklist
    private List<InspectionChecklistItem> _inspectionChecklist = new();

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _operatorName = state.User.Identity?.Name;
            var userIdClaim = state.User.FindFirst("UserId")?.Value;
            if (int.TryParse(userIdClaim, out var uid))
                _currentUserId = uid;
        }
        await LoadQueueAsync();
    }

    private async Task LoadQueueAsync()
    {
        _loading = true;
        StateHasChanged();

        var all = await DispatchService.GetActiveDispatchesAsync();

        // Filter out PlateLayout dispatches (engineer-only)
        all = all.Where(d => d.DispatchType != DispatchType.PlateLayout).ToList();

        _currentSetup = all.FirstOrDefault(d =>
            d.Status is DispatchStatus.InProgress or DispatchStatus.PendingVerification);
        _queue = all
            .Where(d => d.Status is DispatchStatus.Queued or DispatchStatus.Assigned)
            .OrderByDescending(d => d.Priority)
            .ThenBy(d => d.QueuedAt)
            .ToList();

        // Check for urgent changeovers
        _urgentChangeover = all.FirstOrDefault(d =>
            d.DispatchType == DispatchType.Changeover
            && d.Priority >= 95
            && d.Status is DispatchStatus.Queued or DispatchStatus.Assigned);

        // Check maintenance blocks for machines in queue
        _maintenanceBlocks = new();
        var machineIds = all.Select(d => d.MachineId).Distinct();
        foreach (var mid in machineIds)
        {
            var block = await MaintenanceDispatchService.CheckMaintenanceBlockAsync(mid);
            if (block.IsBlocked) _maintenanceBlocks[mid] = block;
        }

        // Load checklists for current setup
        LoadChecklists();

        _loading = false;
        StateHasChanged();
    }

    private void LoadChecklists()
    {
        _prePrintChecklist = new();
        _inspectionChecklist = new();

        if (_currentSetup == null) return;

        if (_currentSetup.DispatchType == DispatchType.PrintStart
            && !string.IsNullOrEmpty(_currentSetup.PrePrintChecklistJson))
        {
            _prePrintChecklist = JsonSerializer.Deserialize<List<SignOffChecklistItem>>(
                _currentSetup.PrePrintChecklistJson) ?? new();
        }

        if (_currentSetup.DispatchType == DispatchType.Teardown
            && !string.IsNullOrEmpty(_currentSetup.InspectionChecklistJson))
        {
            _inspectionChecklist = JsonSerializer.Deserialize<List<InspectionChecklistItem>>(
                _currentSetup.InspectionChecklistJson) ?? new();
        }
    }

    // ── Pre-Print Checklist ──────────────────────────────────

    private void TogglePrePrintItem(int stepId, bool signedOff)
    {
        var item = _prePrintChecklist.FirstOrDefault(i => i.StepId == stepId);
        if (item != null)
        {
            item.SignedOff = signedOff;
            item.SignedBy = signedOff ? _operatorName : null;
            item.SignedAt = signedOff ? DateTime.UtcNow : null;
        }
    }

    private bool AllPrePrintItemsComplete()
        => _prePrintChecklist.Where(i => i.Required).All(i => i.SignedOff);

    private async Task CompletePrintStart()
    {
        if (_currentSetup == null) return;
        try
        {
            // Persist updated checklist to DB before service validates it
            var entity = await Db.SetupDispatches.FindAsync(_currentSetup.Id);
            if (entity != null)
            {
                entity.PrePrintChecklistJson = JsonSerializer.Serialize(_prePrintChecklist);
                await Db.SaveChangesAsync();
            }
            await PrintStartService.CompletePrintStartAsync(_currentSetup.Id, _currentUserId);
            Toast.ShowSuccess("Print started!");
            await LoadQueueAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // ── Inspection Checklist ─────────────────────────────────

    private void ToggleInspectionItem(int stepId, bool inspected)
    {
        var item = _inspectionChecklist.FirstOrDefault(i => i.StepId == stepId);
        if (item != null)
        {
            item.Inspected = inspected;
            item.InspectedBy = inspected ? _operatorName : null;
            item.InspectedAt = inspected ? DateTime.UtcNow : null;
            if (!inspected) { item.Passed = null; item.FailureNotes = null; }
        }
    }

    private void SetInspectionResult(int stepId, bool passed)
    {
        var item = _inspectionChecklist.FirstOrDefault(i => i.StepId == stepId);
        if (item != null) item.Passed = passed;
    }

    private void SetInspectionNotes(int stepId, string? notes)
    {
        var item = _inspectionChecklist.FirstOrDefault(i => i.StepId == stepId);
        if (item != null) item.FailureNotes = notes;
    }

    private bool AllInspectionItemsComplete()
        => _inspectionChecklist.Where(i => i.Required).All(i => i.Inspected && i.Passed.HasValue);

    private async Task CompleteInspection()
    {
        if (_currentSetup == null) return;
        try
        {
            var checklistJson = JsonSerializer.Serialize(_inspectionChecklist);
            await PrintCompletionService.CompleteInspectionAsync(_currentSetup.Id, checklistJson, _currentUserId);
            Toast.ShowSuccess("Inspection completed!");
            await LoadQueueAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // ── Existing Actions ─────────────────────────────────────

    private void DismissUrgentAlert() => _urgentChangeover = null;

    private async Task AcceptAndStart(int dispatchId)
    {
        try
        {
            await DispatchService.StartDispatchAsync(dispatchId);
            Toast.ShowSuccess("Setup started.");
            _urgentChangeover = null;
            await LoadQueueAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task CompleteCurrentSetup()
    {
        if (_currentSetup == null) return;
        try
        {
            await DispatchService.CompleteDispatchAsync(_currentSetup.Id);
            Toast.ShowSuccess("Setup completed!");
            await LoadQueueAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task RequestVerification()
    {
        if (_currentSetup == null) return;
        try
        {
            await DispatchService.RequestVerificationAsync(_currentSetup.Id);
            Toast.ShowSuccess("Verification requested.");
            await LoadQueueAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task HandleBarcodeScan(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_barcodeScan)) return;

        var dispatch = await DispatchService.GetByNumberAsync(_barcodeScan.Trim());
        if (dispatch == null)
        {
            Toast.ShowError($"Dispatch '{_barcodeScan}' not found.");
        }
        else if (dispatch.Status == DispatchStatus.Queued || dispatch.Status == DispatchStatus.Assigned)
        {
            await DispatchService.StartDispatchAsync(dispatch.Id);
            Toast.ShowSuccess($"Started {dispatch.DispatchNumber}");
            await LoadQueueAsync();
        }
        else
        {
            Toast.ShowError($"{dispatch.DispatchNumber} is already {dispatch.StatusDisplay}.");
        }

        _barcodeScan = "";
    }
}
