@page "/shopfloor/stage/{Slug}"
@inject IStageService StageService
@inject IMachineProgramService ProgramService
@inject ToastService Toast
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Vectrik.Models.Enums

<PageTitle>@(_stage?.Name ?? "Shop Floor") - Vectrik</PageTitle>

@if (_stage == null)
{
    <div class="loading"><span class="spinner"></span> Loading stage...</div>
}
else
{
    <div class="page-header">
        <h1 class="page-title" style="display: flex; align-items: center; gap: 10px;">
            <span style="color: @_stage.StageColor">⚙</span> @_stage.Name
        </h1>
        <span class="badge badge-active">@_stage.Department</span>
    </div>

    <div class="content-tab-bar">
        <button class="tab @(_tab == "queue" ? "active" : "")" @onclick='() => _tab = "queue"'>Queue (@_queue.Count)</button>
        <button class="tab @(_tab == "active" ? "active" : "")" @onclick='() => _tab = "active"'>Active (@_active.Count)</button>
        <button class="tab @(_tab == "history" ? "active" : "")" @onclick='() => _tab = "history"'>History (@_history.Count)</button>
    </div>

    @if (_tab == "queue")
    {
        @if (!_queue.Any())
        {
            <div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">No parts in queue</div></div>
        }
        else
        {
            <div class="card">
                <table class="data-table">
                    <thead><tr><th>Part</th><th>Job</th><th>Priority</th><th>Due</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var exec in _queue)
                        {
                            <tr>
                                <td>@exec.Job?.Part?.PartNumber</td>
                                <td>#@exec.JobId</td>
                                <td><span class="badge badge-@(exec.Job?.Priority.ToString().ToLower())">@exec.Job?.Priority</span></td>
                                <td>@exec.Job?.ScheduledEnd.ToString("MM/dd")</td>
                                <td><button class="btn btn-sm btn-primary" @onclick="() => StartWork(exec.Id)" disabled="@_actionInProgress">Start</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (_tab == "active")
    {
        @if (!_active.Any())
        {
            <div class="empty-state"><div class="empty-state-icon">🔄</div><div class="empty-state-text">No active work</div></div>
        }
        else
        {
            @foreach (var exec in _active)
            {
                <div class="card">
                    <div class="card-header">@exec.Job?.Part?.PartNumber — Job #@exec.JobId</div>
                    <div style="margin-bottom: 12px;">
                        <span class="form-label">Operator: @exec.OperatorName</span> | Started: @exec.StartedAt?.ToString("HH:mm")
                        @if (exec.StartedAt.HasValue)
                        {
                            var elapsed = DateTime.UtcNow - exec.StartedAt.Value;
                            <span style="margin-left: 8px; font-weight: 600; color: var(--accent);">
                                @((int)elapsed.TotalHours)h @(elapsed.Minutes)m elapsed
                            </span>
                        }
                        @if (exec.EstimatedHours.HasValue && exec.StartedAt.HasValue)
                        {
                            var elapsed = (DateTime.UtcNow - exec.StartedAt.Value).TotalHours;
                            if (elapsed > exec.EstimatedHours.Value)
                            {
                                <span style="color: var(--danger); font-weight: 600; margin-left: 8px;">⚠️ Over estimate by @((elapsed - exec.EstimatedHours.Value).ToString("F1"))h — consider logging a delay</span>
                            }
                        }
                    </div>
                    @if (exec.MachineProgramId.HasValue && exec.MachineProgram != null)
                    {
                        <div style="font-size: 0.85em; color: var(--text-muted); margin-bottom: 8px;">
                            📄 Program: <strong>@exec.MachineProgram.ProgramNumber</strong> — @exec.MachineProgram.Name
                        </div>
                    }

                    @* ── Stage-Specific Partial ── *@
                    @{ var stageSlug = _stage.StageSlug?.ToLower(); }
                    @switch (stageSlug)
                    {
                        case "sls-printing":
                            <ShopFloor.Partials.SLSPrinting Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "cnc-machining":
                            <ShopFloor.Partials.CNCMachining Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "quality-control":
                            <ShopFloor.Partials.QualityControl Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "shipping":
                            <ShopFloor.Partials.Shipping Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "wire-edm":
                            <ShopFloor.Partials.WireEDM Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "heat-treatment":
                            <ShopFloor.Partials.HeatTreatment Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "surface-finishing":
                            <ShopFloor.Partials.SurfaceFinishing Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "depowdering":
                            <ShopFloor.Partials.Depowdering Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        case "laser-engraving":
                            <ShopFloor.Partials.LaserEngraving Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                        default:
                            <ShopFloor.Partials.GenericStage Execution="exec" Stage="_stage" OnDataChanged="HandlePartialDataChanged" InitialValues="GetInitialValues(exec)" />
                            break;
                    }

                    @* ── Sign-Off Checklist ── *@
                    @if (_signOffItems.ContainsKey(exec.Id) && _signOffItems[exec.Id].Any())
                    {
                        <div class="card" style="margin: 12px 0; padding: 12px; border: 1px solid var(--border); border-radius: 6px;">
                            <div style="font-weight: 600; margin-bottom: 8px;">📋 Sign-Off Checklist</div>
                            @foreach (var item in _signOffItems[exec.Id])
                            {
                                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                                    <input type="checkbox" checked="@item.SignedOff" disabled="@(item.SignedOff || _actionInProgress)"
                                           @onchange="() => SignOffItem(exec.Id, item)" style="width: 18px; height: 18px;" />
                                    <span style="@(item.SignedOff ? "text-decoration: line-through; color: var(--text-muted);" : "")">
                                        @item.Title @(item.Required ? "*" : "")
                                    </span>
                                    @if (item.SignedOff)
                                    {
                                        <span style="font-size: 0.75em; color: var(--text-muted);">✓ @item.SignedBy @item.SignedAt?.ToString("HH:mm")</span>
                                    }
                                </div>
                            }
                            @{ var requiredUnsigned = _signOffItems[exec.Id].Where(i => i.Required && !i.SignedOff).Count(); }
                            @if (requiredUnsigned > 0)
                            {
                                <div style="font-size: 0.8em; color: var(--warning); margin-top: 6px;">⚠️ @requiredUnsigned required item(s) must be signed off before completing</div>
                            }
                        </div>
                    }

                    <div style="display: flex; gap: 8px;">
                        @{ var canComplete = !_signOffItems.ContainsKey(exec.Id) || !_signOffItems[exec.Id].Any(i => i.Required && !i.SignedOff); }
                        <button class="btn btn-success" @onclick="() => ShowCompleteModal(exec)" disabled="@(_actionInProgress || !canComplete)"
                                title="@(!canComplete ? "Complete all required sign-off items first" : "")">Complete</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => FailWork(exec.Id)" disabled="@_actionInProgress">Fail</button>
                    </div>
                </div>
            }
        }
    }

    @if (_tab == "history")
    {
        <div class="card">
            <table class="data-table">
                <thead><tr><th>Part</th><th>Operator</th><th>Duration</th><th>Status</th><th>Completed</th></tr></thead>
                <tbody>
                    @foreach (var exec in _history)
                    {
                        <tr>
                            <td>@exec.Job?.Part?.PartNumber</td>
                            <td>@exec.OperatorName</td>
                            <td>@(exec.ActualHours?.ToString("F1") ?? "—") hrs</td>
                            <td><span class="badge badge-@exec.Status.ToString().ToLower()">@exec.Status</span></td>
                            <td>@exec.CompletedAt?.ToString("MM/dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* ═══════════════════════════════════════════════════════════════
   COMPLETION + FEEDBACK MODAL
   ═══════════════════════════════════════════════════════════════ *@
@if (_showCompleteModal && _completingExecution != null)
{
    <div class="modal-overlay" @onclick="CloseCompleteModal">
        <div class="modal-content" style="max-width: 520px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>✅ Complete Stage</h3>
                <button class="btn btn-sm btn-secondary" @onclick="CloseCompleteModal">✕</button>
            </div>

            <div style="margin-bottom: 12px;">
                <div style="font-size: 0.9em;">Job #@_completingExecution.JobId — @_completingExecution.Job?.Part?.PartNumber</div>
                @if (_completingExecution.MachineProgramId.HasValue && _completingExecution.MachineProgram != null)
                {
                    <div style="font-size: 0.85em; color: var(--text-muted); margin-top: 4px;">
                        📄 Program: <strong>@_completingExecution.MachineProgram.ProgramNumber</strong> v@(_completingExecution.MachineProgram.Version)
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="form-label">Completion Notes (optional)</label>
                <textarea class="form-control" rows="2" @bind="_completionNotes" placeholder="Any notes about this run…"></textarea>
            </div>

            @if (_completingExecution.MachineProgramId.HasValue)
            {
                <div style="border: 1px solid var(--border-color); border-radius: 6px; padding: 12px; margin-top: 12px;">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <label style="margin: 0; font-weight: 600;">💬 Program Feedback</label>
                        <span style="font-size: 0.8em; color: var(--text-muted);">(optional — helps engineers improve this program)</span>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Category</label>
                            <select class="form-control" @bind="_feedbackCategory">
                                <option value="">— No feedback —</option>
                                @foreach (var c in Enum.GetValues<ProgramFeedbackCategory>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Severity</label>
                            <select class="form-control" @bind="_feedbackSeverity">
                                @foreach (var s in Enum.GetValues<ProgramFeedbackSeverity>())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_feedbackCategory))
                    {
                        <div class="form-group" style="margin-top: 8px; margin-bottom: 0;">
                            <label class="form-label">Comment <span style="color:var(--danger)">*</span></label>
                            <textarea class="form-control" rows="2" @bind="_feedbackComment" placeholder="Describe the issue or suggestion…"></textarea>
                        </div>
                    }
                </div>
            }

            @if (_siblingExecutions?.Any() == true)
            {
                <div style="border: 1px solid var(--border); border-radius: 6px; padding: 10px; margin-top: 12px; background: var(--bg-secondary);">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <input type="checkbox" @bind="_completeBatchMode" style="width: 18px; height: 18px;" />
                        <span>Complete all @(_siblingExecutions.Count + 1) jobs in this build at once</span>
                    </label>
                    <div style="font-size: 0.8em; color: var(--text-muted); margin-top: 4px;">
                        This will also complete: @string.Join(", ", _siblingExecutions.Select(e => $"Job #{e.JobId}"))
                    </div>
                </div>
            }

            <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px;">
                <button class="btn btn-secondary" @onclick="CloseCompleteModal">Cancel</button>
                <button class="btn btn-success" @onclick="ConfirmComplete" disabled="@_actionInProgress">
                    @if (_actionInProgress) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
                    Complete Stage
                </button>
            </div>
        </div>
    </div>
}

<AuthorizeView>
    <Authorized>
        @{ _currentUserId = int.TryParse(context.User.FindFirst("UserId")?.Value, out var uid) ? uid : 0; _currentUserName = context.User.FindFirst("FullName")?.Value ?? context.User.FindFirst(ClaimTypes.Name)?.Value ?? "Operator"; }
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public string Slug { get; set; } = "";
    private ProductionStage? _stage;
    private List<StageExecution> _queue = new(), _active = new(), _history = new();
    private string _tab = "queue";
    private int _currentUserId;
    private string _currentUserName = "";
    private bool _actionInProgress;

    // Partial form data collected from stage-specific partials
    private Dictionary<string, object?>? _partialData;

    // Sign-off checklist per execution
    private Dictionary<int, List<SignOffChecklistItem>> _signOffItems = new();

    // Completion modal
    private bool _showCompleteModal;
    private StageExecution? _completingExecution;
    private string? _completionNotes;
    private string _feedbackCategory = "";
    private ProgramFeedbackSeverity _feedbackSeverity = ProgramFeedbackSeverity.Low;
    private string? _feedbackComment;

    // Batch completion for build-level stages
    private bool IsBuildLevelStage => _stage?.StageSlug?.ToLower() is "sls-printing" or "depowdering" or "wire-edm";
    private List<StageExecution>? _siblingExecutions;
    private bool _completeBatchMode;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _stage = await StageService.GetStageBySlugAsync(Slug);
            if (_stage != null) await LoadData();
        }
        catch (Exception ex) { Toast.ShowError($"Failed to load stage: {ex.Message}"); }
    }

    private async Task LoadData()
    {
        var queue = await StageService.GetQueueForStageAsync(_stage!.Id);
        _queue = queue.OrderByDescending(e => e.Job?.Priority).ThenBy(e => e.Job?.ScheduledEnd).ToList();
        _active = await StageService.GetActiveWorkForStageAsync(_stage.Id);
        _history = await StageService.GetRecentCompletionsAsync(_stage.Id, 20);

        // Load sign-off checklists for active executions
        _signOffItems.Clear();
        foreach (var exec in _active)
        {
            try
            {
                var items = await StageService.GetSignOffChecklistAsync(exec.Id);
                if (items.Any())
                    _signOffItems[exec.Id] = items;
            }
            catch { /* Checklist not available — skip */ }
        }
    }

    private async Task StartWork(int executionId)
    {
        if (_actionInProgress) return;
        _actionInProgress = true;
        try
        {
            await StageService.StartStageExecutionAsync(executionId, _currentUserId, _currentUserName);
            Toast.ShowSuccess("Stage started");
            await LoadData();
            _tab = "active";
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _actionInProgress = false; }
    }

    private void HandlePartialDataChanged(Dictionary<string, object?> data)
    {
        _partialData = data;
    }

    private async Task SignOffItem(int executionId, SignOffChecklistItem item)
    {
        if (item.SignedOff || _actionInProgress) return;
        _actionInProgress = true;
        try
        {
            await StageService.SignOffChecklistItemAsync(executionId, item.StepId, _currentUserName);
            item.SignedOff = true;
            item.SignedBy = _currentUserName;
            item.SignedAt = DateTime.UtcNow;
            Toast.ShowSuccess($"Signed off: {item.Title}");
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _actionInProgress = false; }
    }

    private Dictionary<string, object?>? GetInitialValues(StageExecution exec)
    {
        if (string.IsNullOrWhiteSpace(exec.CustomFieldValues) || exec.CustomFieldValues == "{}")
            return null;
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, object?>>(exec.CustomFieldValues);
        }
        catch
        {
            return null;
        }
    }

    private void ShowCompleteModal(StageExecution exec)
    {
        _completingExecution = exec;
        _completionNotes = null;
        _feedbackCategory = "";
        _feedbackSeverity = ProgramFeedbackSeverity.Low;
        _feedbackComment = null;

        // Check for sibling build executions
        if (IsBuildLevelStage && exec.MachineProgramId.HasValue)
        {
            _siblingExecutions = _active
                .Where(e => e.MachineProgramId == exec.MachineProgramId && e.Id != exec.Id)
                .ToList();
        }
        else
        {
            _siblingExecutions = null;
        }

        _completeBatchMode = false;
        _showCompleteModal = true;
    }

    private void CloseCompleteModal()
    {
        _showCompleteModal = false;
        _completingExecution = null;
        _partialData = null;
    }

    private async Task ConfirmComplete()
    {
        if (_completingExecution == null || _actionInProgress) return;

        // Validate feedback comment is provided when a category is selected
        if (!string.IsNullOrEmpty(_feedbackCategory) && string.IsNullOrWhiteSpace(_feedbackComment))
        {
            Toast.ShowError("Please provide a comment for your feedback.");
            return;
        }

        _actionInProgress = true;
        try
        {
            var cfv = _partialData != null ? JsonSerializer.Serialize(_partialData) : null;
            await StageService.CompleteStageExecutionAsync(_completingExecution.Id, customFieldValues: cfv, notes: _completionNotes);

            // Submit program feedback if provided
            if (!string.IsNullOrEmpty(_feedbackCategory)
                && _completingExecution.MachineProgramId.HasValue
                && Enum.TryParse<ProgramFeedbackCategory>(_feedbackCategory, out var category))
            {
                var feedback = new ProgramFeedback
                {
                    MachineProgramId = _completingExecution.MachineProgramId.Value,
                    StageExecutionId = _completingExecution.Id,
                    OperatorUserId = _currentUserId.ToString(),
                    OperatorName = _currentUserName,
                    Category = category,
                    Severity = _feedbackSeverity,
                    Comment = _feedbackComment!,
                    SubmittedAt = DateTime.UtcNow
                };
                await ProgramService.SubmitFeedbackAsync(feedback);
                Toast.ShowSuccess("Stage completed. Feedback submitted — thank you!");
            }
            else if (!_completeBatchMode || _siblingExecutions == null || !_siblingExecutions.Any())
            {
                Toast.ShowSuccess("Stage completed");
            }

            // Batch complete sibling executions in the same build
            if (_completeBatchMode && _siblingExecutions?.Any() == true)
            {
                foreach (var sibling in _siblingExecutions)
                {
                    try
                    {
                        await StageService.CompleteStageExecutionAsync(sibling.Id, customFieldValues: cfv, notes: _completionNotes);
                    }
                    catch { /* Log but continue — don't block other completions */ }
                }
                Toast.ShowSuccess($"Build completed: {_siblingExecutions.Count + 1} jobs finished");
            }

            CloseCompleteModal();
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _actionInProgress = false; }
    }

    private async Task FailWork(int executionId)
    {
        if (_actionInProgress) return;
        _actionInProgress = true;
        try
        {
            await StageService.FailStageExecutionAsync(executionId, "Failed by operator");
            Toast.ShowError("Failure reported");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _actionInProgress = false; }
    }
}
