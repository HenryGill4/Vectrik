@* CNC Machining - Rich built-in stage partial *@
@using Opcentrix_V3.Models

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">🔧 CNC Machining Details</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px;">
        <div class="form-group"><label class="form-label">Operation Type</label>
            <select class="form-control"><option>Threading</option><option>Facing</option><option>Drilling</option><option>Milling</option><option>Turning</option></select>
        </div>
        <div class="form-group"><label class="form-label">Duration (min)</label><input class="form-control" type="number" inputmode="numeric" /></div>
        <div class="form-group"><label class="form-label">Tool Used</label><input class="form-control" /></div>
    </div>
</div>

@code {
    [Parameter] public StageExecution? Execution { get; set; }
}
