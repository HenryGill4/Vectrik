@* Heat Treatment - Rich built-in stage partial *@
@using Opcentrix_V3.Models

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">🔥 Heat Treatment Details</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px;">
        <div class="form-group"><label class="form-label">Batch Quantity</label><input class="form-control" type="number" inputmode="numeric" min="1" /></div>
        <div class="form-group"><label class="form-label">Oven Temperature (°C)</label><input class="form-control" type="number" inputmode="numeric" /></div>
        <div class="form-group"><label class="form-label">Hold Time (hrs)</label><input class="form-control" type="number" step="0.5" inputmode="decimal" /></div>
        <div class="form-group"><label class="form-label">Atmosphere</label>
            <select class="form-control"><option>Argon</option><option>Vacuum</option><option>Nitrogen</option></select>
        </div>
    </div>
</div>

@code {
    [Parameter] public StageExecution? Execution { get; set; }
}
