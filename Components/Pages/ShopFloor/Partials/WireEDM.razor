@* Wire EDM - Rich built-in stage partial with build-level context *@
@using Vectrik.Models
@using Vectrik.Services
@inject IMachineProgramService MachineProgramService

<WorkInstructionBanner PartId="Execution?.Job?.Part?.Id" StageId="Stage?.Id" />

@if (_program != null)
{
    @* ── Build-Level Mode ── *@
    <div class="card" style="margin-bottom: 16px;">
        <div class="card-header">📦 Build Plate: @_program.Name — Wire EDM</div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 12px;">
            <div><span class="form-label">Machine</span><div>@(Execution?.Machine?.Name ?? "—")</div></div>
            <div><span class="form-label">Material</span><div>@(_program.Material?.Name ?? "—")</div></div>
            <div><span class="form-label">Total Parts</span><div>@_program.TotalPartCount (@_program.UniquePartCount unique)</div></div>
            <div><span class="form-label">Status</span><div>@_program.Status</div></div>
        </div>

        @* Parts to Separate *@
        <div class="form-label" style="margin-bottom: 4px;">Parts on Build Plate</div>
        <table class="data-table" style="font-size: 0.85rem; margin-bottom: 12px;">
            <thead><tr><th>Part #</th><th>Name</th><th>Qty</th><th>WO #</th></tr></thead>
            <tbody>
                @foreach (var pp in _program.ProgramParts)
                {
                    <tr>
                        <td>@(pp.Part?.PartNumber ?? "—")</td>
                        <td>@(pp.Part?.Name ?? "—")</td>
                        <td>@pp.Quantity</td>
                        <td>@(pp.WorkOrderLine?.WorkOrder?.OrderNumber ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="alert alert-info" style="margin-bottom: 0; font-size: 0.85rem;">
            ✂️ When EDM is complete, use the <strong>Complete</strong> button above — you will be prompted to confirm part separation.
        </div>
    </div>
}
else
{
    @* ── Single-Part Mode (backward compatible) ── *@
    <div class="card" style="margin-bottom: 16px;">
        <div class="card-header">⚡ Wire EDM Details</div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 12px;">
            <div><span class="form-label">Part</span><div>@(Execution?.Job?.Part?.PartNumber ?? "—") — @(Execution?.Job?.Part?.Name ?? "")</div></div>
            <div><span class="form-label">Machine</span><div>@(Execution?.Machine?.Name ?? Execution?.Job?.Machine?.Name ?? "—")</div></div>
        </div>
    </div>
}

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">⚡ EDM Parameters</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px;">
        <div class="form-group"><label class="form-label">Cut Duration (min)</label><input class="form-control" type="number" inputmode="numeric" min="0" @bind="_cutDurationMin" @bind:after="NotifyDataChanged" /></div>
        <div class="form-group"><label class="form-label">Wire Used (m)</label><input class="form-control" type="number" step="0.1" inputmode="decimal" min="0" @bind="_wireUsedM" @bind:after="NotifyDataChanged" /></div>
        <div class="form-group"><label class="form-label">Wire Type</label>
            <select class="form-control" @bind="_wireType" @bind:after="NotifyDataChanged">
                <option value="">Select...</option>
                <option value="Brass 0.25mm">Brass 0.25mm</option>
                <option value="Brass 0.20mm">Brass 0.20mm</option>
                <option value="Molybdenum">Molybdenum</option>
            </select>
        </div>
    </div>
</div>

<LogDelayPanel Execution="Execution" LoggedBy="@_operatorName" />

@code {
    [Parameter] public StageExecution? Execution { get; set; }
    [Parameter] public ProductionStage? Stage { get; set; }
    [Parameter] public EventCallback<Dictionary<string, object?>> OnDataChanged { get; set; }
    [Parameter] public Dictionary<string, object?>? InitialValues { get; set; }

    private MachineProgram? _program;
    private string _operatorName => Execution?.OperatorName ?? "Operator";

    private int? _cutDurationMin;
    private double? _wireUsedM;
    private string _wireType = "";

    protected override async Task OnParametersSetAsync()
    {
        if (Execution?.MachineProgramId != null)
        {
            try
            {
                _program = await MachineProgramService.GetByIdAsync(Execution.MachineProgramId.Value);
            }
            catch
            {
                _program = null;
            }
        }
        else
        {
            _program = null;
        }

        HydrateFromInitialValues();
    }

    private void HydrateFromInitialValues()
    {
        if (InitialValues == null) return;
        if (InitialValues.TryGetValue("cutDurationMin", out var v1) && int.TryParse(v1?.ToString(), out var n1)) _cutDurationMin = n1;
        if (InitialValues.TryGetValue("wireUsedM", out var v2) && double.TryParse(v2?.ToString(), out var n2)) _wireUsedM = n2;
        if (InitialValues.TryGetValue("wireType", out var v3)) _wireType = v3?.ToString() ?? "";
    }

    private async Task NotifyDataChanged()
    {
        await OnDataChanged.InvokeAsync(new Dictionary<string, object?>
        {
            ["cutDurationMin"] = _cutDurationMin,
            ["wireUsedM"] = _wireUsedM,
            ["wireType"] = _wireType
        });
    }
}
