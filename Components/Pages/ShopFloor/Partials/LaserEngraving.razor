@* Laser Engraving - Serial number assignment *@
@using Opcentrix_V3.Models

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">🔤 Laser Engraving — Serial Number Assignment</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 12px;">
        <div><span class="form-label">Part</span><div>@(Execution?.Job?.Part?.PartNumber ?? "—") — @(Execution?.Job?.Part?.Name ?? "")</div></div>
        <div><span class="form-label">Quantity</span><div>@(Execution?.Job?.Quantity) pcs</div></div>
    </div>
    <div class="alert alert-warning" style="margin-bottom: 12px;">Each part must be assigned a unique serial number at this stage.</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
        <div class="form-group"><label class="form-label">Serial Number</label><input class="form-control" placeholder="Scan or enter serial..." inputmode="text" /></div>
        <div class="form-group"><label class="form-label">Engraving Power (%)</label><input class="form-control" type="number" min="10" max="100" value="80" inputmode="numeric" /></div>
        <div class="form-group"><label class="form-label">Engraving Speed (mm/s)</label><input class="form-control" type="number" min="100" max="5000" value="1000" inputmode="numeric" /></div>
    </div>
</div>

<LogDelayPanel Execution="Execution" LoggedBy="@_operatorName" />

@code {
    [Parameter] public StageExecution? Execution { get; set; }
    [Parameter] public ProductionStage? Stage { get; set; }

    private string _operatorName => Execution?.OperatorName ?? "Operator";
}
