@* Shipping - Packing + fulfillment *@
@using Opcentrix_V3.Models

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">📦 Shipping Details</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
        <div class="form-group"><label class="form-label">Carrier</label>
            <select class="form-control"><option>FedEx</option><option>UPS</option><option>DHL</option><option>USPS</option><option>Customer Pickup</option></select>
        </div>
        <div class="form-group"><label class="form-label">Tracking Number</label><input class="form-control" /></div>
        <div class="form-group"><label class="form-label">Package Count</label><input class="form-control" type="number" min="1" value="1" inputmode="numeric" /></div>
    </div>
    <div class="form-group"><label class="form-label">Packing List (serial numbers, one per line)</label><textarea class="form-control" rows="4" placeholder="SN-2026-00001&#10;SN-2026-00002"></textarea></div>
</div>

@code {
    [Parameter] public StageExecution? Execution { get; set; }
}
