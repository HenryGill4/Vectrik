@* Generic Stage - Fallback for custom stages, renders CustomFieldsConfig dynamically *@
@using Vectrik.Models

<WorkInstructionBanner PartId="Execution?.Job?.Part?.Id" StageId="Stage?.Id" />

<div class="card" style="margin-bottom: 16px;">
    <div class="card-header">📝 Stage Form</div>
    @if (_fields != null && _fields.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
            @foreach (var field in _fields)
                {
                    <div class="form-group">
                        <label class="form-label">@field.Label @(field.IsRequired ? "*" : "")</label>
                        @switch (field.FieldType?.ToLower())
                        {
                            case "dropdown":
                            case "select":
                                <select class="form-control"
                                        value="@GetFieldValue(field.Label)"
                                        @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())">
                                    <option value="">Select...</option>
                                    @if (!string.IsNullOrWhiteSpace(field.Options))
                                    {
                                        @foreach (var opt in field.Options.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)) { <option>@opt</option> }
                                    }
                                </select>
                                break;
                            case "checkbox":
                                <div style="min-height: var(--tap-target); display: flex; align-items: center;">
                                    <input type="checkbox" style="width: 20px; height: 20px;"
                                           checked="@IsFieldChecked(field.Label)"
                                           @onchange="e => SetCheckboxValue(field.Label, e.Value)" />
                                </div>
                                break;
                            case "number":
                            case "decimal":
                                <input class="form-control" type="number"
                                       min="@field.MinValue" max="@field.MaxValue"
                                       inputmode="numeric"
                                       value="@GetFieldValue(field.Label)"
                                       @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())" />
                                break;
                            case "textarea":
                                <textarea class="form-control" rows="3"
                                          value="@GetFieldValue(field.Label)"
                                          @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())"
                                          placeholder="@field.HelpText"></textarea>
                                break;
                            case "date":
                                <input class="form-control" type="date"
                                       value="@GetFieldValue(field.Label)"
                                       @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())" />
                                break;
                            case "measurement":
                                <div style="display: flex; gap: 6px; align-items: center;">
                                    <input class="form-control" type="number" step="any"
                                           min="@field.MinValue" max="@field.MaxValue"
                                           inputmode="decimal"
                                           style="color: @GetMeasurementColor(field); font-weight: 600; flex: 1;"
                                           value="@GetFieldValue(field.Label)"
                                           @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())" />
                                    @if (!string.IsNullOrWhiteSpace(field.Unit))
                                    {
                                        <span style="color: var(--text-muted); font-size: 0.85rem; white-space: nowrap;">@field.Unit</span>
                                    }
                                </div>
                                @if (field.ToleranceMin.HasValue || field.ToleranceMax.HasValue)
                                {
                                    <small style="color: var(--text-muted);">
                                        Tolerance: @(field.ToleranceMin?.ToString("F2") ?? "—") – @(field.ToleranceMax?.ToString("F2") ?? "—") @field.Unit
                                    </small>
                                }
                                break;
                            case "photo":
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <InputFile OnChange="e => HandleFileUpload(field.Label, e)" accept="image/*" capture="environment" />
                                    @if (!string.IsNullOrWhiteSpace(GetFieldValue(field.Label)))
                                    {
                                        <span style="color: var(--success); font-size: 0.85rem;">Photo captured</span>
                                    }
                                </div>
                                break;
                            case "file":
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <InputFile OnChange="e => HandleFileUpload(field.Label, e)" />
                                    @if (!string.IsNullOrWhiteSpace(GetFieldValue(field.Label)))
                                    {
                                        <span style="color: var(--success); font-size: 0.85rem;">File attached</span>
                                    }
                                </div>
                                break;
                            case "signature":
                                <div>
                                    <input class="form-control" type="text"
                                           placeholder="Type your name to sign"
                                           value="@GetFieldValue(field.Label)"
                                           @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())" />
                                    @if (!string.IsNullOrWhiteSpace(GetFieldValue(field.Label)))
                                    {
                                        <small style="color: var(--success);">Signed: @GetFieldValue(field.Label) at @DateTime.Now.ToString("HH:mm")</small>
                                    }
                                </div>
                                break;
                            default:
                                <input class="form-control" type="text"
                                       value="@GetFieldValue(field.Label)"
                                       @onchange="e => SetFieldValue(field.Label, e.Value?.ToString())" />
                                break;
                        }
                        @if (!string.IsNullOrWhiteSpace(field.HelpText) && field.FieldType?.ToLower() != "textarea")
                        {
                            <small style="color: var(--text-muted);">@field.HelpText</small>
                        }
                    </div>
                }
        </div>
    }
    else
    {
        <div class="empty-state"><div class="empty-state-text">No custom fields configured for this stage</div></div>
    }
</div>

<LogDelayPanel Execution="Execution" LoggedBy="@_operatorName" />

@code {
    [Parameter] public StageExecution? Execution { get; set; }
    [Parameter] public ProductionStage? Stage { get; set; }
    [Parameter] public EventCallback<Dictionary<string, object?>> OnDataChanged { get; set; }
    [Parameter] public Dictionary<string, object?>? InitialValues { get; set; }

    private List<CustomFieldDefinition>? _fields;
    private Dictionary<string, string> _fieldValues = new();
    private string _operatorName => Execution?.OperatorName ?? "Operator";

    protected override void OnParametersSet()
    {
        _fields = Stage?.GetCustomFields();
        HydrateFromInitialValues();
    }

    private void HydrateFromInitialValues()
    {
        if (InitialValues == null) return;
        foreach (var kvp in InitialValues)
        {
            if (kvp.Value is string strVal)
                _fieldValues[kvp.Key] = strVal;
            else if (kvp.Value != null)
                _fieldValues[kvp.Key] = kvp.Value.ToString() ?? "";
        }
    }

    private string GetFieldValue(string key) => _fieldValues.GetValueOrDefault(key, "");

    private string GetMeasurementColor(CustomFieldDefinition field)
    {
        var val = GetFieldValue(field.Label);
        if (!double.TryParse(val, out var num)) return "inherit";
        if (field.ToleranceMin.HasValue && num < field.ToleranceMin.Value) return "var(--danger)";
        if (field.ToleranceMax.HasValue && num > field.ToleranceMax.Value) return "var(--danger)";
        if (field.ToleranceMin.HasValue || field.ToleranceMax.HasValue) return "var(--success)";
        return "inherit";
    }

    private bool IsFieldChecked(string key) => GetFieldValue(key) == "true";

    private Task SetCheckboxValue(string key, object? value)
    {
        var isChecked = value is bool b && b;
        return SetFieldValue(key, isChecked ? "true" : "false");
    }

    private async Task SetFieldValue(string key, string? value)
    {
        _fieldValues[key] = value ?? "";
        await NotifyDataChanged();
    }

    private async Task HandleFileUpload(string key, InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024) return; // 10MB max
        // Store file name as the field value (actual file storage would need a file service)
        await SetFieldValue(key, $"{file.Name} ({file.Size / 1024}KB)");
    }

    private async Task NotifyDataChanged()
    {
        var data = new Dictionary<string, object?>();
        foreach (var kvp in _fieldValues)
            data[kvp.Key] = kvp.Value;
        await OnDataChanged.InvokeAsync(data);
    }
}
