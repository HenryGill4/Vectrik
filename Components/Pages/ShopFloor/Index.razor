@page "/shopfloor"
@rendermode InteractiveServer
@inject IStageService StageService
@inject ToastService Toast
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Shop Floor - OpCentrix</PageTitle>

<AuthorizeView>
    <Authorized>
        @{
            var userName = context.User.FindFirst("FullName")?.Value
                ?? context.User.FindFirst(ClaimTypes.Name)?.Value
                ?? "Operator";
            var userIdStr = context.User.FindFirst("UserId")?.Value;
            _currentUserId = int.TryParse(userIdStr, out var uid) ? uid : 0;
            _currentUserName = userName;
        }

        <div class="page-header">
            <h1 class="page-title">👋 Welcome, @userName</h1>
        </div>

        @if (_loading)
        {
            <div class="loading"><span class="spinner"></span> Loading your queue...</div>
        }
        else
        {
            @* ── Active Work ── *@
            @if (_currentExecution != null)
            {
                <div class="card" style="border-left: 4px solid var(--accent); margin-bottom: 20px;">
                    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                        <span>🔧 Currently Working</span>
                        <span class="badge badge-@_currentExecution.Status.ToString().ToLower()">@_currentExecution.Status</span>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 16px;">
                        <div>
                            <span class="form-label">Part</span>
                            <div style="font-weight: 600;">@(_currentExecution.Job?.Part?.PartNumber ?? "—")</div>
                        </div>
                        <div>
                            <span class="form-label">Stage</span>
                            <div style="font-weight: 600;">@(_currentExecution.ProductionStage?.Name ?? "—")</div>
                        </div>
                        <div>
                            <span class="form-label">Job</span>
                            <div>#@_currentExecution.JobId</div>
                        </div>
                        <div>
                            <span class="form-label">Machine</span>
                            <div>@(_currentExecution.Machine?.Name ?? "Unassigned")</div>
                        </div>
                        <div>
                            <span class="form-label">Started</span>
                            <div>@_currentExecution.ActualStartAt?.ToString("HH:mm") @GetElapsed(_currentExecution.ActualStartAt)</div>
                        </div>
                    </div>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        @if (_currentExecution.Status == StageExecutionStatus.Paused)
                        {
                            <button class="btn btn-primary" @onclick="ResumeCurrentWork" style="min-height: 44px;">▶ Resume</button>
                        }
                        else
                        {
                            <button class="btn btn-success" @onclick="() => ShowCompleteDialog(_currentExecution.Id)" style="min-height: 44px;">✓ Complete</button>
                            <button class="btn btn-warning" @onclick="() => ShowPauseDialog(_currentExecution.Id)" style="min-height: 44px;">⏸ Pause</button>
                        }
                        <button class="btn btn-danger btn-sm" @onclick="() => ShowFailDialog(_currentExecution.Id)" style="min-height: 44px;">✗ Fail / NCR</button>
                    </div>
                </div>
            }

            @* ── My Queue ── *@
            <div class="card" style="margin-bottom: 20px;">
                <div class="card-header">📋 My Queue (@_myQueue.Count)</div>
                @if (!_myQueue.Any())
                {
                    <div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">No assigned work</div></div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr><th>Part</th><th>Stage</th><th>Priority</th><th>Due</th><th>Machine</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var exec in _myQueue)
                            {
                                <tr>
                                    <td>@(exec.Job?.Part?.PartNumber ?? "—")</td>
                                    <td>@(exec.ProductionStage?.Name ?? "—")</td>
                                    <td><span class="badge badge-@(exec.Job?.Priority.ToString().ToLower())">@exec.Job?.Priority</span></td>
                                    <td>@exec.Job?.ScheduledEnd.ToString("MM/dd")</td>
                                    <td>@(exec.Machine?.Name ?? "—")</td>
                                    <td>
                                        @if (_currentExecution == null)
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="() => StartWork(exec.Id)" style="min-height: 44px;">▶ Start</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @* ── Available Work ── *@
            <div class="card" style="margin-bottom: 20px;">
                <div class="card-header">🔓 Available Work (@_availableWork.Count)</div>
                @if (!_availableWork.Any())
                {
                    <div class="empty-state"><div class="empty-state-icon">✅</div><div class="empty-state-text">No unassigned work available</div></div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr><th>Part</th><th>Stage</th><th>Priority</th><th>Due</th><th>Machine</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var exec in _availableWork)
                            {
                                <tr>
                                    <td>@(exec.Job?.Part?.PartNumber ?? "—")</td>
                                    <td>@(exec.ProductionStage?.Name ?? "—")</td>
                                    <td><span class="badge badge-@(exec.Job?.Priority.ToString().ToLower())">@exec.Job?.Priority</span></td>
                                    <td>@exec.Job?.ScheduledEnd.ToString("MM/dd")</td>
                                    <td>@(exec.Machine?.Name ?? "—")</td>
                                    <td>
                                        @if (_currentExecution == null)
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="() => ClaimAndStart(exec.Id)" style="min-height: 44px;">🙋 Claim & Start</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }

        @* ── Pause Dialog ── *@
        @if (_showPauseDialog)
        {
            <div class="modal-overlay" @onclick="() => _showPauseDialog = false">
                <div class="modal-content" @onclick:stopPropagation>
                    <div class="modal-header"><span class="modal-title">⏸ Pause / Delay</span><button class="modal-close" @onclick="() => _showPauseDialog = false">&times;</button></div>
                    <div class="form-group">
                        <label class="form-label">Category</label>
                        <select class="form-control" @bind="_pauseCategory">
                            @foreach (var cat in Enum.GetValues<DelayCategory>())
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Reason</label>
                        <textarea class="form-control" @bind="_pauseReason" rows="3" placeholder="Describe the delay..."></textarea>
                    </div>
                    <button class="btn btn-warning" @onclick="ConfirmPause" disabled="@string.IsNullOrWhiteSpace(_pauseReason)">Pause Work</button>
                </div>
            </div>
        }

        @* ── Complete Dialog ── *@
        @if (_showCompleteDialog)
        {
            <div class="modal-overlay" @onclick="() => _showCompleteDialog = false">
                <div class="modal-content" @onclick:stopPropagation>
                    <div class="modal-header"><span class="modal-title">✓ Complete Stage</span><button class="modal-close" @onclick="() => _showCompleteDialog = false">&times;</button></div>
                    <div class="form-group">
                        <label class="form-label">Notes (optional)</label>
                        <textarea class="form-control" @bind="_completeNotes" rows="3" placeholder="Any notes about the work..."></textarea>
                    </div>
                    <button class="btn btn-success" @onclick="ConfirmComplete">Complete</button>
                </div>
            </div>
        }

        @* ── Fail Dialog ── *@
        @if (_showFailDialog)
        {
            <div class="modal-overlay" @onclick="() => _showFailDialog = false">
                <div class="modal-content" @onclick:stopPropagation>
                    <div class="modal-header"><span class="modal-title">✗ Report Failure</span><button class="modal-close" @onclick="() => _showFailDialog = false">&times;</button></div>
                    <div class="form-group">
                        <label class="form-label">Failure Reason *</label>
                        <textarea class="form-control" @bind="_failReason" rows="3" placeholder="Describe what went wrong..."></textarea>
                    </div>
                    <button class="btn btn-danger" @onclick="ConfirmFail" disabled="@string.IsNullOrWhiteSpace(_failReason)">Report Failure</button>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private bool _loading = true;
    private int _currentUserId;
    private string _currentUserName = "";
    private StageExecution? _currentExecution;
    private List<StageExecution> _myQueue = new();
    private List<StageExecution> _availableWork = new();

    // Dialog state
    private bool _showPauseDialog, _showCompleteDialog, _showFailDialog;
    private int _dialogExecutionId;
    private string _pauseReason = "";
    private DelayCategory _pauseCategory = DelayCategory.Other;
    private string _completeNotes = "";
    private string _failReason = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _currentUserId > 0)
        {
            await LoadData();
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        _currentExecution = await StageService.GetCurrentExecutionForOperatorAsync(_currentUserId);
        var queue = await StageService.GetOperatorQueueAsync(_currentUserId);
        _myQueue = queue.Where(e => e.Status == StageExecutionStatus.NotStarted).ToList();
        _availableWork = await StageService.GetAvailableWorkAsync();
    }

    private async Task StartWork(int executionId)
    {
        try
        {
            await StageService.StartStageExecutionAsync(executionId, _currentUserId, _currentUserName);
            Toast.ShowSuccess("Stage started");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task ClaimAndStart(int executionId)
    {
        try
        {
            await StageService.AssignOperatorAsync(executionId, _currentUserId);
            await StageService.StartStageExecutionAsync(executionId, _currentUserId, _currentUserName);
            Toast.ShowSuccess("Work claimed and started");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task ResumeCurrentWork()
    {
        if (_currentExecution == null) return;
        try
        {
            await StageService.ResumeStageExecutionAsync(_currentExecution.Id);
            Toast.ShowSuccess("Work resumed");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // Pause
    private void ShowPauseDialog(int executionId) { _dialogExecutionId = executionId; _pauseReason = ""; _pauseCategory = DelayCategory.Other; _showPauseDialog = true; }
    private async Task ConfirmPause()
    {
        try
        {
            await StageService.PauseStageExecutionAsync(_dialogExecutionId, _pauseReason, _pauseCategory, _currentUserName);
            Toast.ShowSuccess("Work paused — delay logged");
            _showPauseDialog = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // Complete
    private void ShowCompleteDialog(int executionId) { _dialogExecutionId = executionId; _completeNotes = ""; _showCompleteDialog = true; }
    private async Task ConfirmComplete()
    {
        try
        {
            await StageService.CompleteStageExecutionAsync(_dialogExecutionId, notes: _completeNotes);
            Toast.ShowSuccess("Stage completed!");
            _showCompleteDialog = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // Fail
    private void ShowFailDialog(int executionId) { _dialogExecutionId = executionId; _failReason = ""; _showFailDialog = true; }
    private async Task ConfirmFail()
    {
        try
        {
            await StageService.FailStageExecutionAsync(_dialogExecutionId, _failReason);
            Toast.ShowError("Failure reported");
            _showFailDialog = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private string GetElapsed(DateTime? start)
    {
        if (!start.HasValue) return "";
        var elapsed = DateTime.UtcNow - start.Value;
        return $"({elapsed.Hours}h {elapsed.Minutes}m ago)";
    }
}
