@page "/analytics"
@inject IAnalyticsService AnalyticsService
@rendermode InteractiveServer

<PageTitle>Analytics - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Analytics Dashboard</h1>
</div>

@if (_kpis == null) { <div class="loading"><span class="spinner"></span></div> }
else
{
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-label">Avg Utilization</div><div class="kpi-value">@_kpis.AverageUtilization.ToString("F1")%</div></div>
        <div class="kpi-card"><div class="kpi-label">On-Time Delivery</div><div class="kpi-value">@_kpis.OnTimeDeliveryRate.ToString("F1")%</div></div>
        <div class="kpi-card"><div class="kpi-label">Scrap Rate</div><div class="kpi-value">@_kpis.ScrapRate.ToString("F1")%</div></div>
        <div class="kpi-card"><div class="kpi-label">Avg Cost/Part</div><div class="kpi-value">$@_kpis.AverageCostPerPart.ToString("F2")</div></div>
        <div class="kpi-card"><div class="kpi-label">Active Jobs</div><div class="kpi-value">@_kpis.ActiveJobs</div></div>
        <div class="kpi-card"><div class="kpi-label">Active Work Orders</div><div class="kpi-value">@_kpis.ActiveWorkOrders</div></div>
        <div class="kpi-card"><div class="kpi-label">Maintenance Alerts</div><div class="kpi-value">@_kpis.MaintenanceAlerts</div></div>
    </div>

    @if (_utilizations != null && _utilizations.Any())
    {
        <div class="card">
            <div class="card-header">Machine Utilization (Last 30 Days)</div>
            <table class="data-table">
                <thead><tr><th>Machine</th><th>Utilization</th><th>Scheduled Hrs</th><th>Actual Hrs</th></tr></thead>
                <tbody>
                    @foreach (var m in _utilizations)
                    {
                        <tr>
                            <td>@m.MachineName</td>
                            <td>
                                <div style="background: var(--bg-tertiary); border-radius: 4px; height: 20px; width: 200px; overflow: hidden; display: inline-block; vertical-align: middle;">
                                    <div style="background: var(--accent); height: 100%; width: @(m.UtilizationPercent)%"></div>
                                </div>
                                @m.UtilizationPercent.ToString("F0")%
                            </td>
                            <td>@m.TotalScheduledHours.ToString("F1")</td>
                            <td>@m.TotalActualHours.ToString("F1")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_kpis.Pipeline.Any())
    {
        <div class="card">
            <div class="card-header">Stage Pipeline</div>
            <table class="data-table">
                <thead><tr><th>Stage</th><th>In Queue</th><th>In Progress</th><th>Completed</th></tr></thead>
                <tbody>
                    @foreach (var s in _kpis.Pipeline)
                    {
                        <tr>
                            <td><span style="color: @s.StageColor">⚙</span> @s.StageName</td>
                            <td>@s.PartsInQueue</td>
                            <td>@s.PartsInProgress</td>
                            <td>@s.PartsCompleted</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private DashboardKpis? _kpis;
    private List<MachineUtilization>? _utilizations;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _kpis = await AnalyticsService.GetDashboardKpisAsync();
            _utilizations = await AnalyticsService.GetMachineUtilizationAsync(DateTime.UtcNow.AddDays(-30), DateTime.UtcNow);
        }
        catch
        {
            _kpis = new DashboardKpis();
            _utilizations = new();
        }
    }
}
