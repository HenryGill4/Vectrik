@page "/analytics"
@inject IAnalyticsService AnalyticsService
@inject IOeeService OeeService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Analytics - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Analytics Dashboard</h1>
    <div class="page-actions">
        <button class="btn btn-secondary" @onclick="ExportCsv" title="Export to CSV">📥 Export</button>
        <select class="form-control" style="width:180px;display:inline-block" @onchange="OnRangeChanged">
            <option value="7">Last 7 Days</option>
            <option value="30" selected>Last 30 Days</option>
            <option value="90">Last 90 Days</option>
        </select>
    </div>
</div>

@if (_kpis == null) { <div class="loading"><span class="spinner"></span> Loading analytics...</div> }
else
{
    <div class="kpi-grid">
        <div class="kpi-card" @onclick="GoToOtd" style="cursor:pointer">
            <div class="kpi-label">On-Time Delivery</div>
            <div class="kpi-value">@_kpis.OnTimeDeliveryRate.ToString("F1")%</div>
        </div>
        <div class="kpi-card" @onclick="GoToQuality" style="cursor:pointer">
            <div class="kpi-label">First Pass Yield</div>
            <div class="kpi-value">@_kpis.FirstPassYield.ToString("F1")%</div>
        </div>
        <div class="kpi-card" @onclick="GoToOee" style="cursor:pointer">
            <div class="kpi-label">OEE</div>
            <div class="kpi-value">@(_overallOee?.Oee.ToString("F1") ?? "—")%</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Active Jobs</div>
            <div class="kpi-value">@_kpis.ActiveJobs</div>
        </div>
        <div class="kpi-card" style="@(_kpis.OpenNcrs > 3 ? "border-color:var(--danger)" : "")">
            <div class="kpi-label">Open NCRs</div>
            <div class="kpi-value" style="@(_kpis.OpenNcrs > 3 ? "color:var(--danger)" : "")">@_kpis.OpenNcrs</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Avg Cost/Part</div>
            <div class="kpi-value">$@_kpis.AverageCostPerPart.ToString("F2")</div>
        </div>
    </div>

    <!-- Production Output Chart -->
    @if (_dailyOutput.Count > 0)
    {
        <div class="card" style="margin-top:1rem">
            <div class="card-header">Production Output (Parts Completed per Day)</div>
            <div style="padding:1rem;overflow-x:auto">
                @{ var maxOut = _dailyOutput.Max(d => d.Value); if (maxOut == 0) maxOut = 1; }
                <svg viewBox="0 0 @(_dailyOutput.Count * 30 + 40) 200" style="width:100%;min-width:400px;height:200px">
                    @for (int i = 0; i < _dailyOutput.Count; i++)
                    {
                        var dp = _dailyOutput[i];
                        var barH = dp.Value / maxOut * 160;
                        var x = i * 30 + 20;
                        var y = 170 - barH;
                        <rect x="@x" y="@y" width="24" height="@barH" fill="var(--accent)" rx="2" />
                        <foreignObject x="@x" y="180" width="24" height="16"><span style="font-size:8px;color:var(--text-muted);display:block;text-align:center">@dp.Date.ToString("dd")</span></foreignObject>
                    }
                </svg>
            </div>
        </div>
    }

    <!-- Machine Utilization -->
    @if (_utilizations != null && _utilizations.Any())
    {
        <div class="card" style="margin-top:1rem">
            <div class="card-header">Machine Utilization (Last @_rangeDays Days)</div>
            <table class="data-table">
                <thead><tr><th>Machine</th><th>Utilization</th><th>Scheduled Hrs</th><th>Actual Hrs</th></tr></thead>
                <tbody>
                    @foreach (var m in _utilizations)
                    {
                        <tr>
                            <td>@m.MachineName</td>
                            <td>
                                <div style="background: var(--bg-tertiary); border-radius: 4px; height: 20px; width: 200px; overflow: hidden; display: inline-block; vertical-align: middle;">
                                    <div style="background: var(--accent); height: 100%; width: @(m.UtilizationPercent)%"></div>
                                </div>
                                @m.UtilizationPercent.ToString("F0")%
                            </td>
                            <td>@m.TotalScheduledHours.ToString("F1")</td>
                            <td>@m.TotalActualHours.ToString("F1")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Job Status Breakdown -->
    @if (_jobBreakdown.Count > 0)
    {
        <div class="card" style="margin-top:1rem">
            <div class="card-header">Job Status Breakdown</div>
            <div style="padding:1rem;display:flex;flex-wrap:wrap;gap:1rem">
                @foreach (var item in _jobBreakdown)
                {
                    <div class="kpi-card" style="flex:1;min-width:100px">
                        <div class="kpi-label">@item.Status</div>
                        <div class="kpi-value">@item.Count</div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Stage Pipeline -->
    @if (_kpis.Pipeline.Any())
    {
        <div class="card" style="margin-top:1rem">
            <div class="card-header">Stage Pipeline</div>
            <table class="data-table">
                <thead><tr><th>Stage</th><th>In Queue</th><th>In Progress</th><th>Completed</th></tr></thead>
                <tbody>
                    @foreach (var s in _kpis.Pipeline)
                    {
                        <tr>
                            <td><span style="color: @s.StageColor">⚙</span> @s.StageName</td>
                            <td>@s.PartsInQueue</td>
                            <td>@s.PartsInProgress</td>
                            <td>@s.PartsCompleted</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private DashboardKpis? _kpis;
    private List<MachineUtilization>? _utilizations;
    private List<DailyDataPoint> _dailyOutput = new();
    private List<JobStatusCount> _jobBreakdown = new();
    private OeeData? _overallOee;
    private int _rangeDays = 30;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var now = DateTime.UtcNow;
            var from = now.AddDays(-_rangeDays);
            _kpis = await AnalyticsService.GetDashboardKpisAsync();
            _utilizations = await AnalyticsService.GetMachineUtilizationAsync(from, now);
            _dailyOutput = await AnalyticsService.GetDailyOutputAsync(from, now);
            _jobBreakdown = await AnalyticsService.GetJobStatusBreakdownAsync();
            try { _overallOee = await OeeService.GetOverallOeeAsync(from, now); } catch { _overallOee = null; }
        }
        catch
        {
            _kpis = new DashboardKpis();
            _utilizations = new();
        }
    }

    private async Task OnRangeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var d))
        {
            _rangeDays = d;
            _kpis = null;
            await LoadDataAsync();
        }
    }

    private void GoToOtd() => Nav.NavigateTo("/analytics/on-time-delivery");
    private void GoToQuality() => Nav.NavigateTo("/analytics/quality");
    private void GoToOee() => Nav.NavigateTo("/analytics/oee");

    private void ExportCsv()
    {
        if (_utilizations == null || !_utilizations.Any()) return;
        var csv = "Machine,Utilization%,ScheduledHrs,ActualHrs\n" +
            string.Join("\n", _utilizations.Select(m => $"{m.MachineName},{m.UtilizationPercent:F1},{m.TotalScheduledHours:F1},{m.TotalActualHours:F1}"));
        Nav.NavigateTo($"data:text/csv;charset=utf-8,{Uri.EscapeDataString(csv)}", forceLoad: true);
    }
}
