@page "/tracking"
@inject IPartTrackerService TrackerService
@inject ToastService Toast
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Part Tracker - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Part Tracker</h1>
</div>

<div class="card" style="margin-bottom: 20px;">
    <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: end;">
        <select class="form-control" style="width: auto;" @bind="_searchType">
            <option value="wo">Work Order #</option>
            <option value="part">Part Number</option>
            <option value="serial">Serial Number</option>
        </select>
        <div style="flex:1;min-width:200px;position:relative">
            @if (_scanMode)
            {
                <label class="form-label" style="font-size:0.75rem;color:var(--accent)">🔫 Barcode Scan Mode — scan or type and press Enter</label>
            }
            <input id="trackingSearch" class="form-control" style="width:100%" placeholder="@(_scanMode ? "Scan barcode..." : "Search...")"
                   @bind="_searchTerm" @onkeypress="HandleKey" @ref="_searchInput" />
        </div>
        <button class="btn btn-primary" @onclick="Search" disabled="@_searching">
            @if (_searching) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
            Search
        </button>
        @if (_searched)
        {
            <button class="btn btn-sm btn-secondary" @onclick="ClearResults">Clear</button>
        }
        <button class="btn btn-sm @(_scanMode ? "btn-accent" : "btn-secondary")" @onclick="ToggleScanMode" title="Toggle barcode scan mode">🔫</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger" style="margin-bottom: 16px;">@_error</div>
}

@if (_searching)
{
    <div class="loading"><span class="spinner"></span> Searching...</div>
}

@if (!_searching && _result != null && _result.Lines.Any())
{
    @foreach (var line in _result.Lines)
    {
        <div class="card">
            <div class="card-header">@line.OrderNumber — @line.PartNumber (@line.PartName)</div>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 8px; margin-bottom: 12px;">
                <div><span class="form-label">Ordered</span><div>@line.QuantityOrdered</div></div>
                <div><span class="form-label">Produced</span><div>@line.QuantityProduced</div></div>
                <div><span class="form-label">Shipped</span><div>@line.QuantityShipped</div></div>
            </div>
            @if (line.SerializedParts.Any())
            {
                <table class="data-table">
                    <thead><tr><th>ID</th><th>Stage</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var pi in line.SerializedParts)
                        {
                            <tr>
                                <td>
                                    @pi.SerialNumber
                                    @if (pi.SerialNumber.StartsWith("TMP-"))
                                    {
                                        <span class="badge" style="background:#F59E0B;color:#000;font-size:0.65rem;margin-left:4px;">Temp</span>
                                    }
                                </td>
                                <td>@pi.CurrentStageName</td>
                                <td><span class="badge badge-@pi.Status.ToLower()">@pi.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@if (!_searching && _serialResult != null)
{
    <div class="card">
        <div class="card-header">
            @_serialResult.SerialNumber — @_serialResult.PartNumber
            @if (_serialResult.SerialNumber.StartsWith("TMP-"))
            {
                <span class="badge" style="background:#F59E0B;color:#000;font-size:0.7rem;margin-left:6px;">Temp ID</span>
            }
        </div>
        <div style="margin-bottom: 12px;">
            <span class="badge badge-@_serialResult.Status.ToLower()">@_serialResult.Status</span>
            Current Stage: @_serialResult.CurrentStageName
        </div>
        @if (_serialResult.History.Any())
        {
            <table class="data-table">
                <thead><tr><th>Stage</th><th>Operator</th><th>Started</th><th>Completed</th><th>Duration</th></tr></thead>
                <tbody>
                    @foreach (var h in _serialResult.History)
                    {
                        <tr>
                            <td>@h.StageName</td>
                            <td>@h.OperatorName</td>
                            <td>@h.StartedAt.ToString("MM/dd HH:mm")</td>
                            <td>@(h.CompletedAt?.ToString("MM/dd HH:mm") ?? "In progress")</td>
                            <td>@(h.DurationHours?.ToString("F1") ?? "—") hrs</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@if (!_searching && _searched && _result?.Lines.Count == 0 && _serialResult == null)
{
    <div class="empty-state"><div class="empty-state-icon">🔍</div><div class="empty-state-text">No results found</div></div>
}

@code {
    private string _searchType = "wo", _searchTerm = "";
    private PartTrackerResult? _result;
    private PartInstanceTrack? _serialResult;
    private bool _searched;
    private bool _searching;
    private string? _error;
    private bool _scanMode;
    private ElementReference _searchInput;

    private async Task HandleKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Search(); }

    private async Task Search()
    {
        _result = null; _serialResult = null; _searched = true; _error = null;
        if (string.IsNullOrWhiteSpace(_searchTerm)) { _error = "Please enter a search term."; return; }
        _searching = true;
        try
        {
            switch (_searchType)
            {
                case "wo": _result = await TrackerService.TrackByWorkOrderAsync(_searchTerm.Trim()); break;
                case "part": _result = await TrackerService.TrackByPartNumberAsync(_searchTerm.Trim()); break;
                case "serial": _serialResult = await TrackerService.TrackBySerialNumberAsync(_searchTerm.Trim()); break;
            }
            if (_scanMode) { _searchTerm = ""; }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Search failed: {ex.Message}");
            _error = $"Search failed: {ex.Message}";
        }
        finally
        {
            _searching = false;
        }
    }

    private void ClearResults()
    {
        _result = null;
        _serialResult = null;
        _searched = false;
        _error = null;
        _searchTerm = "";
    }

    private void ToggleScanMode()
    {
        _scanMode = !_scanMode;
        if (_scanMode) { _searchType = "serial"; }
    }
}
