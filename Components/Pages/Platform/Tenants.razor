@page "/platform/tenants"
@inject ITenantService TenantService
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]

<PageTitle>Customers - Vectrik Platform</PageTitle>

<div class="page-header">
    <h1 class="page-title">Customers</h1>
    <button class="btn btn-primary" @onclick="CreateNew">+ New Customer</button>
</div>

<div style="margin-bottom: 16px;">
    <input class="form-control" placeholder="Search customers..." @bind="_search" @bind:event="oninput"
           style="max-width: 400px;" />
</div>

@if (_tenants == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (!FilteredTenants.Any())
{
    <div class="card" style="padding: 32px; text-align: center; color: var(--text-muted);">
        No customers found.
    </div>
}
else
{
    <div class="tenant-card-grid">
        @foreach (var t in FilteredTenants)
        {
            <div class="tenant-card" @onclick="() => GoToTenant(t.Code)">
                <div class="tenant-card-header">
                    @if (!string.IsNullOrWhiteSpace(t.LogoUrl))
                    {
                        <img class="tenant-card-logo" src="@t.LogoUrl" alt="@t.CompanyName"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                        <div class="tenant-card-initials" style="display:none; background: @(t.PrimaryColor ?? "#6366f1");">
                            @t.CompanyName[0]
                        </div>
                    }
                    else
                    {
                        <div class="tenant-card-initials" style="background: @(t.PrimaryColor ?? "#6366f1");">
                            @t.CompanyName[0]
                        </div>
                    }
                    <span class="badge @(t.IsActive ? "badge-active" : "badge-cancelled")" style="position: absolute; top: 12px; right: 12px;">
                        @(t.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="tenant-card-body">
                    <div class="tenant-card-name">@t.CompanyName</div>
                    <div class="tenant-card-code">@t.Code</div>
                    <div class="tenant-card-meta">
                        @if (!string.IsNullOrWhiteSpace(t.SubscriptionTier))
                        {
                            <span class="tier-badge tier-badge-@(t.SubscriptionTier?.ToLowerInvariant().Replace(" ", ""))">@t.SubscriptionTier</span>
                        }
                        else
                        {
                            <span class="tier-badge tier-badge-free">No Tier</span>
                        }
                        <span style="color: var(--text-muted); font-size: 0.8rem;">
                            @(_userCounts.GetValueOrDefault(t.Code, 0)) user@(_userCounts.GetValueOrDefault(t.Code, 0) == 1 ? "" : "s")
                        </span>
                    </div>
                    <div style="color: var(--text-muted); font-size: 0.75rem; margin-top: 4px;">
                        Created @t.CreatedDate.ToString("MMM d, yyyy")
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Vectrik.Models.Platform.Tenant>? _tenants;
    private Dictionary<string, int> _userCounts = new();
    private string _search = "";

    private void CreateNew() => Nav.NavigateTo("/platform/tenants/new");
    private void GoToTenant(string code) => Nav.NavigateTo($"/platform/tenants/{code}");

    private IEnumerable<Vectrik.Models.Platform.Tenant> FilteredTenants =>
        _tenants?.Where(t =>
            string.IsNullOrWhiteSpace(_search) ||
            t.CompanyName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            t.Code.Contains(_search, StringComparison.OrdinalIgnoreCase)
        ) ?? Enumerable.Empty<Vectrik.Models.Platform.Tenant>();

    protected override async Task OnInitializedAsync()
    {
        _tenants = await TenantService.GetAllTenantsAsync();
        foreach (var t in _tenants)
        {
            try { _userCounts[t.Code] = await TenantService.GetTenantUserCountAsync(t.Code); }
            catch { _userCounts[t.Code] = 0; }
        }
    }
}
