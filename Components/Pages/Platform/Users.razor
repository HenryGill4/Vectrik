@page "/platform/users"
@inject Opcentrix_V3.Data.PlatformDbContext PlatformDb
@inject IAuthService AuthService
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@rendermode InteractiveServer

<PageTitle>Platform Users - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Platform Users</h1>
    <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New User</button>
</div>

@if (_users == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>Username</th><th>Role</th></tr></thead>
            <tbody>
                @foreach (var u in _users)
                {
                    <tr><td>@u.Username</td><td>@u.Role</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showCreate)
{
    <div class="modal-overlay" @onclick="() => _showCreate = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">New Platform User</span>
                <button class="modal-close" @onclick="() => _showCreate = false">&times;</button>
            </div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }
            <div class="form-group"><label class="form-label">Username</label><input class="form-control" @bind="_username" /></div>
            <div class="form-group"><label class="form-label">Password</label><input class="form-control" type="password" @bind="_password" /></div>
            <button class="btn btn-primary" @onclick="Create">Create</button>
        </div>
    </div>
}

@code {
    private List<Opcentrix_V3.Models.Platform.PlatformUser>? _users;
    private bool _showCreate;
    private string _username = "", _password = "";
    private string? _error;

    protected override async Task OnInitializedAsync() => _users = await PlatformDb.PlatformUsers.ToListAsync();

    private async Task Create()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password)) { _error = "Both fields required."; return; }
        PlatformDb.PlatformUsers.Add(new() { Username = _username, PasswordHash = AuthService.HashPassword(_password), Role = "SuperAdmin" });
        await PlatformDb.SaveChangesAsync();
        _showCreate = false;
        _users = await PlatformDb.PlatformUsers.ToListAsync();
    }
}
