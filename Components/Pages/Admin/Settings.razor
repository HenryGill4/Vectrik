@page "/admin/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject Vectrik.Data.TenantDbContext Db
@inject ToastService Toast
@using Microsoft.EntityFrameworkCore

<PageTitle>Settings - Admin - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">System Settings</h1>
    <button class="btn btn-primary" @onclick="NewSetting">+ New Setting</button>
</div>

@if (_settings == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (!_settings.Any())
{
    <div class="empty-state">
        <div class="empty-state-text">No system settings configured.</div>
    </div>
}
else
{
    <div class="content-tab-bar" style="margin-bottom: 16px;">
        <button class="tab @(_categoryFilter == null ? "active" : "")" @onclick="() => _categoryFilter = null">All (@_settings.Count)</button>
        @foreach (var cat in _settings.Select(s => s.Category).Distinct().OrderBy(c => c))
        {
            <button class="tab @(_categoryFilter == cat ? "active" : "")" @onclick="() => _categoryFilter = cat">@cat (@_settings.Count(s => s.Category == cat))</button>
        }
    </div>

    @foreach (var group in _settings.Where(s => _categoryFilter == null || s.Category == _categoryFilter).GroupBy(s => s.Category).OrderBy(g => g.Key))
    {
        <div class="card" style="margin-bottom: 12px;">
            <div class="card-header">@group.Key</div>
            <table class="data-table">
                <thead><tr><th>Key</th><th>Value</th><th>Description</th><th></th></tr></thead>
                <tbody>
                    @foreach (var s in group)
                    {
                        <tr>
                            <td style="font-family: monospace;">@s.Key</td>
                            <td style="max-width: 300px; word-break: break-all;">
                                @if (IsBooleanValue(s.Value))
                                {
                                    <span class="badge @(s.Value == "true" ? "badge-active" : "badge-cancelled")">@s.Value</span>
                                }
                                else
                                {
                                    @s.Value
                                }
                            </td>
                            <td style="color: var(--text-muted);">@(s.Description ?? "—")</td>
                            <td style="white-space: nowrap;">
                                <button class="btn btn-sm btn-secondary" @onclick="() => EditSetting(s)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(s)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (_showForm)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">@(_editId.HasValue ? "Edit" : "New") Setting</span><button class="modal-close" @onclick="() => _showForm = false">&times;</button></div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }
            <div class="form-group">
                <label class="form-label">Key <span style="color:var(--danger);">*</span></label>
                <input class="form-control" @bind="_editKey" disabled="@_editId.HasValue" placeholder="e.g. company.timezone" />
                <small style="color: var(--text-muted);">Lowercase with dots, e.g. category.setting_name</small>
            </div>
            <div class="form-group">
                <label class="form-label">Value</label>
                <textarea class="form-control" @bind="_editValue" rows="3"></textarea>
            </div>
            <div class="form-group"><label class="form-label">Category</label>
                <select class="form-control" @bind="_editCategory">
                    <option>General</option><option>Branding</option><option>Numbering</option><option>Quality</option>
                    <option>Inventory</option><option>Costing</option><option>Shipping</option><option>Defense</option>
                    <option>Workflow</option><option>Serial</option><option>Debug</option><option>Notifications</option>
                </select>
            </div>
            <div class="form-group"><label class="form-label">Description</label><input class="form-control" @bind="_editDescription" placeholder="Explain what this setting controls" /></div>
            <div style="display: flex; gap: 8px; margin-top: 12px;">
                <button class="btn btn-primary" @onclick="Save">Save</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    private List<SystemSetting>? _settings;
    private bool _showForm;
    private int? _editId;
    private string _editKey = "", _editValue = "", _editCategory = "General";
    private string? _editDescription, _error;
    private string? _categoryFilter;
    private ConfirmDialog _confirm = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await Db.SystemSettings.OrderBy(s => s.Category).ThenBy(s => s.Key).ToListAsync();
        }
        catch
        {
            _settings = new();
        }
    }

    private void NewSetting()
    {
        _editId = null;
        _editKey = "";
        _editValue = "";
        _editCategory = "General";
        _editDescription = null;
        _error = null;
        _showForm = true;
    }

    private void EditSetting(SystemSetting s)
    {
        _editId = s.Id;
        _editKey = s.Key;
        _editValue = s.Value;
        _editCategory = s.Category;
        _editDescription = s.Description;
        _error = null;
        _showForm = true;
    }

    private async Task Save()
    {
        _error = null;
        if (!_editId.HasValue && string.IsNullOrWhiteSpace(_editKey))
        {
            _error = "Key is required.";
            return;
        }

        try
        {
            if (_editId.HasValue)
            {
                var s = await Db.SystemSettings.FindAsync(_editId.Value);
                if (s != null)
                {
                    s.Value = _editValue;
                    s.Category = _editCategory;
                    s.Description = _editDescription;
                    s.LastModifiedDate = DateTime.UtcNow;
                    s.LastModifiedBy = "Admin";
                }
            }
            else
            {
                Db.SystemSettings.Add(new SystemSetting
                {
                    Key = _editKey.Trim().ToLowerInvariant(),
                    Value = _editValue,
                    Category = _editCategory,
                    Description = _editDescription,
                    LastModifiedBy = "Admin"
                });
            }
            await Db.SaveChangesAsync();
            _showForm = false;
            _editId = null;
            _settings = await Db.SystemSettings.OrderBy(s => s.Category).ThenBy(s => s.Key).ToListAsync();
            Toast.ShowSuccess("Setting saved.");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ConfirmDelete(SystemSetting s)
    {
        if (await _confirm.ShowAsync($"Delete setting '{s.Key}'? This cannot be undone.", "Delete Setting"))
        {
            try
            {
                Db.SystemSettings.Remove(s);
                await Db.SaveChangesAsync();
                _settings = await Db.SystemSettings.OrderBy(x => x.Category).ThenBy(x => x.Key).ToListAsync();
                Toast.ShowSuccess($"Setting '{s.Key}' deleted.");
            }
            catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        }
    }

    private static bool IsBooleanValue(string value) => value is "true" or "false";
}
