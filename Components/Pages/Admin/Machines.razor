@page "/admin/machines"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Manager")]
@inject IMachineService MachineService
@inject ToastService Toast

<PageTitle>Machines - Admin - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Machines</h1>
    <a href="/machines/new" class="btn btn-primary">+ New Machine</a>
</div>

@if (_machines == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (!_machines.Any())
{
    <div class="empty-state">
        <div class="empty-state-text">No machines configured yet. Click "+ New Machine" to add your first machine.</div>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>ID</th><th>Name</th><th>Type</th><th>Department</th><th>Rate</th><th>Status</th><th>Hours</th><th></th></tr></thead>
            <tbody>
                @foreach (var m in _machines)
                {
                    <tr>
                        <td style="font-family: monospace;">@m.MachineId</td>
                        <td>@m.Name</td>
                        <td>@m.MachineType</td>
                        <td>@(m.Department ?? "—")</td>
                        <td>$@m.HourlyRate/hr</td>
                        <td><span class="badge badge-@m.Status.ToString().ToLower()">@m.Status</span></td>
                        <td>@m.TotalOperatingHours.ToString("F0")</td>
                        <td style="white-space: nowrap;">
                            <a href="machines/@m.Id" class="btn btn-sm btn-secondary">Edit</a>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(m)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    private List<Machine>? _machines;
    private ConfirmDialog _confirm = null!;

    protected override async Task OnInitializedAsync()
    {
        try { _machines = await MachineService.GetAllMachinesAsync(); }
        catch (Exception ex) { Toast.ShowError($"Failed to load machines: {ex.Message}"); _machines = new(); }
    }

    private async Task ConfirmDelete(Machine m)
    {
        if (await _confirm.ShowAsync($"Delete machine '{m.Name}' ({m.MachineId})? This cannot be undone.", "Delete Machine"))
        {
            try
            {
                await MachineService.DeleteMachineAsync(m.Id);
                Toast.ShowSuccess($"Machine '{m.Name}' deleted.");
                _machines = await MachineService.GetAllMachinesAsync();
            }
            catch (Exception ex) { Toast.ShowError($"Failed to delete: {ex.Message}"); }
        }
    }
}
