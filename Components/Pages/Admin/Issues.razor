@page "/admin/issues"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject IDevIssueService IssueService
@inject ISchedulingDiagnosticsService SchedulingDiag
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Copilot Prompt Workshop - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">🎯 Copilot Prompt Workshop</h1>
    <button class="btn btn-primary" @onclick="OpenCreate">+ New Issue</button>
</div>

@if (_issues is null)
{
    <p style="color: var(--text-secondary);">Loading…</p>
}
else
{
    <!-- Stats -->
    <div class="issue-stats">
        <div class="issue-stat">
            <span class="issue-stat-count" style="color: var(--danger);">@_issues.Count(i => i.Status == DevIssueStatus.InProgress)</span>
            <span class="issue-stat-label">Active</span>
        </div>
        <div class="issue-stat">
            <span class="issue-stat-count" style="color: var(--warning);">@_issues.Count(i => i.Status == DevIssueStatus.Open)</span>
            <span class="issue-stat-label">Queued</span>
        </div>
        <div class="issue-stat">
            <span class="issue-stat-count" style="color: var(--success);">@_issues.Count(i => i.Status == DevIssueStatus.Fixed)</span>
            <span class="issue-stat-label">Fixed</span>
        </div>
        <div class="issue-stat">
            <span class="issue-stat-count" style="color: var(--accent);">@_issues.Count(i => i.Status == DevIssueStatus.Verified)</span>
            <span class="issue-stat-label">Verified</span>
        </div>
    </div>

    <!-- ═══ CURRENT ISSUE — Full Prompt View ═══ -->
    @if (_currentIssue is not null)
    {
        <div class="card pw-active">
            <div class="pw-active-header">
                <span class="pw-active-label">🔥 WORKING ON</span>
                <span class="issue-badge issue-badge-@_currentIssue.Type.ToString().ToLowerInvariant()">@TypeIcon(_currentIssue.Type) @_currentIssue.Type</span>
                <span class="issue-badge issue-badge-priority-@_currentIssue.Priority.ToString().ToLowerInvariant()">@_currentIssue.Priority</span>
                @if (!string.IsNullOrWhiteSpace(_currentIssue.SystemArea))
                {
                    <span class="pw-area-badge">@_currentIssue.SystemArea</span>
                }
                <span style="margin-left:auto; font-size:0.75rem; color:var(--text-muted);">⏱️ @FormatAgo(_currentIssue.StartedAt)</span>
            </div>

            <!-- Prompt Preview (the actual thing you copy) -->
            <div class="pw-prompt-box">
                <div class="pw-prompt-header">
                    <span>📋 COPILOT PROMPT</span>
                    <button class="btn btn-sm btn-primary" @onclick="() => CopyPromptAsync(_currentIssue)">Copy to Clipboard</button>
                </div>
                <pre class="pw-prompt-text">@GeneratePrompt(_currentIssue)</pre>
            </div>

            <div class="pw-active-actions">
                <button class="btn btn-sm btn-success" @onclick="() => OpenResolve(_currentIssue)">✅ Mark Fixed</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => OpenEdit(_currentIssue)">✏️ Edit</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => WontFixAsync(_currentIssue)">🚫 Won't Fix</button>
            </div>
        </div>
    }
    else
    {
        <div class="card pw-empty">
            No issue active. Pick one from the queue and hit <strong>▶ Start</strong> to focus on it.
        </div>
    }

    <!-- ═══ QUEUE ═══ -->
    @if (_queueIssues.Count > 0)
    {
        <h3 class="issue-section-title">📋 Queue (@_queueIssues.Count)</h3>
        <div class="pw-queue">
            @foreach (var issue in _queueIssues)
            {
                <div class="card pw-card" @onclick="() => TogglePreview(issue.Id)">
                    <div class="pw-card-top">
                        <span class="issue-badge issue-badge-@issue.Type.ToString().ToLowerInvariant()">@TypeIcon(issue.Type) @issue.Type</span>
                        <span class="issue-badge issue-badge-priority-@issue.Priority.ToString().ToLowerInvariant()">@issue.Priority</span>
                        @if (!string.IsNullOrWhiteSpace(issue.SystemArea))
                        {
                            <span class="pw-area-badge">@issue.SystemArea</span>
                        }
                        <span class="pw-card-id">#@issue.Id</span>
                    </div>
                    <div class="pw-card-title">@issue.Title</div>
                    @if (!string.IsNullOrWhiteSpace(issue.AffectedPage))
                    {
                        <div class="pw-card-page">@issue.AffectedPage</div>
                    }

                    @* Expandable prompt preview *@
                    @if (_previewId == issue.Id)
                    {
                        <div class="pw-card-preview" @onclick:stopPropagation>
                            <pre class="pw-prompt-text pw-prompt-text-sm">@GeneratePrompt(issue)</pre>
                        </div>
                    }

                    <div class="pw-card-actions" @onclick:stopPropagation>
                        <button class="btn btn-sm btn-primary" @onclick="() => StartAsync(issue.Id)">▶ Start</button>
                        <button class="btn btn-sm btn-secondary" @onclick="() => CopyPromptAsync(issue)">📋 Copy</button>
                        <button class="btn btn-sm btn-secondary" @onclick="() => OpenEdit(issue)">✏️</button>
                        <button class="btn btn-sm btn-danger-outline" @onclick="() => DeleteAsync(issue.Id)">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ═══ FIXED — Awaiting Verification ═══ -->
    @if (_fixedIssues.Count > 0)
    {
        <h3 class="issue-section-title">🔧 Fixed — Verify on Device (@_fixedIssues.Count)</h3>
        <div class="pw-queue">
            @foreach (var issue in _fixedIssues)
            {
                <div class="card pw-card pw-card-fixed">
                    <div class="pw-card-top">
                        <span class="issue-badge issue-badge-@issue.Type.ToString().ToLowerInvariant()">@TypeIcon(issue.Type)</span>
                        <span class="pw-card-id">#@issue.Id</span>
                    </div>
                    <div class="pw-card-title">@issue.Title</div>
                    @if (!string.IsNullOrWhiteSpace(issue.Resolution))
                    {
                        <div class="pw-card-resolution">💬 @issue.Resolution</div>
                    }
                    <div class="pw-card-actions">
                        <button class="btn btn-sm btn-success" @onclick="() => VerifyAsync(issue.Id)">✅ Verified</button>
                        <button class="btn btn-sm btn-warning" @onclick="() => ReopenAsync(issue.Id)">🔄 Reopen</button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ═══ RESOLVED HISTORY ═══ -->
    @if (_resolvedIssues.Count > 0)
    {
        <details class="issue-history">
            <summary class="issue-section-title" style="cursor:pointer;">
                📜 Resolved (@_resolvedIssues.Count)
            </summary>
            <table class="data-table" style="margin-top: 8px;">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Type</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Resolved</th>
                        <th>Resolution</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in _resolvedIssues)
                    {
                        <tr>
                            <td>@issue.Id</td>
                            <td>@TypeIcon(issue.Type)</td>
                            <td>@issue.Title</td>
                            <td>
                                @if (issue.Status == DevIssueStatus.Verified)
                                {
                                    <span style="color:var(--success);">✅</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);">🚫</span>
                                }
                            </td>
                            <td>@issue.ResolvedAt?.ToString("MMM dd")</td>
                            <td style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@issue.Resolution</td>
                        </tr>
                    }
                </tbody>
            </table>
        </details>
    }
}

<!-- ═══ CREATE / EDIT MODAL (Prompt Builder) ═══ -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content pw-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(_editingIssue.Id == 0 ? "📝 New Issue" : "✏️ Edit #" + _editingIssue.Id)</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>

            <div class="pw-builder">
                <!-- Left: Form fields -->
                <div class="pw-builder-form">
                    <!-- Type -->
                    <div class="form-group">
                        <label>Type</label>
                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            @foreach (var t in Enum.GetValues<DevIssueType>())
                            {
                                <button class="btn btn-sm @(_editingIssue.Type == t ? "btn-primary" : "btn-secondary")"
                                        @onclick="() => _editingIssue.Type = t">
                                    @TypeIcon(t) @t
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Priority + System Area (side by side) -->
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                        <div class="form-group">
                            <label>Priority</label>
                            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                @foreach (var p in Enum.GetValues<DevIssuePriority>())
                                {
                                    <button class="btn btn-sm @(_editingIssue.Priority == p ? "btn-primary" : "btn-secondary")"
                                            @onclick="() => _editingIssue.Priority = p"
                                            style="padding:4px 10px; font-size:0.75rem;">
                                        @p
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="form-group">
                            <label>System Area</label>
                            <select class="form-control" @bind="_editingIssue.SystemArea">
                                <option value="">— select —</option>
                                @foreach (var area in SystemAreas)
                                {
                                    <option value="@area">@area</option>
                                }
                            </select>
                        </div>
                    </div>

                    @* ── Scheduling Issue: Machine Picker + Auto-Capture ── *@
                    @if (_editingIssue.Type == DevIssueType.SchedulingIssue)
                    {
                        <div class="form-group">
                            <label>Machine <span class="pw-hint">select a machine to auto-capture scheduling data</span></label>
                            <div style="display:flex; gap:8px; align-items:center;">
                                <select class="form-control" style="flex:1;" value="@_selectedMachineId"
                                        @onchange="OnMachineSelectedAsync">
                                    <option value="0">— select machine —</option>
                                    @if (_machines is not null)
                                    {
                                        @foreach (var m in _machines)
                                        {
                                            <option value="@m.Id">@m.Name (@m.MachineType) — @m.Status</option>
                                        }
                                    }
                                </select>
                                @if (_capturingSnapshot)
                                {
                                    <span class="spinner" style="width:20px;height:20px;"></span>
                                }
                                else if (_editingSnapshot is not null)
                                {
                                    <span style="color:var(--success);" title="Snapshot captured">✅</span>
                                }
                            </div>
                        </div>

                        @if (_editingSnapshot is not null)
                        {
                            <div class="pw-snapshot-summary">
                                <div class="pw-snapshot-header">📸 Auto-Captured Snapshot</div>
                                <div class="pw-snapshot-stats">
                                    <span>⏱️ @_editingSnapshot.Executions.Count executions</span>
                                    <span>🏗️ @_editingSnapshot.BuildPackages.Count programs</span>
                                    <span>⚠️ @_editingSnapshot.Conflicts.Count conflicts</span>
                                    <span>📋 @_editingSnapshot.UnscheduledCount unscheduled</span>
                                </div>
                                @if (_editingSnapshot.Conflicts.Count > 0)
                                {
                                    <div style="color:var(--danger); font-size:0.8rem; margin-top:4px;">
                                        @foreach (var c in _editingSnapshot.Conflicts)
                                        {
                                            <div>🔴 Overlap: @c.DescriptionA vs @c.DescriptionB</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }

                    <!-- Title -->
                    <div class="form-group">
                        <label>Title <span class="pw-hint">Short, specific — this becomes the prompt heading</span></label>
                        <input type="text" class="form-control" @bind="_editingIssue.Title" @bind:event="oninput"
                               placeholder="@TitlePlaceholder(_editingIssue.Type)" />
                    </div>

                    <!-- Affected Page -->
                    <div class="form-group">
                        <label>Affected Page <span class="pw-hint">auto-filled from report button</span></label>
                        <input type="text" class="form-control" @bind="_editingIssue.AffectedPage" @bind:event="oninput"
                               placeholder="/scheduler, /parts/edit/5" />
                    </div>

                    <!-- Description (type-adaptive) -->
                    <div class="form-group">
                        <label>@DescriptionLabel(_editingIssue.Type) <span class="pw-hint">be specific — this is the core of the prompt</span></label>
                        <textarea class="form-control" rows="3" @bind="_editingIssue.Description" @bind:event="oninput"
                                  placeholder="@DescriptionPlaceholder(_editingIssue.Type)"></textarea>
                    </div>

                    <!-- Expected -->
                    <div class="form-group">
                        <label>@ExpectedLabel(_editingIssue.Type)</label>
                        <textarea class="form-control" rows="2" @bind="_editingIssue.Expected" @bind:event="oninput"
                                  placeholder="@ExpectedPlaceholder(_editingIssue.Type)"></textarea>
                    </div>

                    <!-- Steps / Element -->
                    <div class="form-group">
                        <label>@StepsLabel(_editingIssue.Type)</label>
                        <textarea class="form-control" rows="2" @bind="_editingIssue.StepsOrElement" @bind:event="oninput"
                                  placeholder="@StepsPlaceholder(_editingIssue.Type)"></textarea>
                    </div>

                    <!-- Related Files -->
                    <div class="form-group">
                        <label>Related Files <span class="pw-hint">helps Copilot find the right code</span></label>
                        <textarea class="form-control" rows="2" @bind="_editingIssue.RelatedFiles" @bind:event="oninput"
                                  placeholder="Components/Pages/Scheduler/Views/GanttView.razor&#10;Services/SchedulingService.cs"></textarea>
                    </div>

                    <!-- Acceptance Criteria -->
                    <div class="form-group">
                        <label>Done When <span class="pw-hint">how you'll verify the fix</span></label>
                        <textarea class="form-control" rows="2" @bind="_editingIssue.AcceptanceCriteria" @bind:event="oninput"
                                  placeholder="- Build bars appear on SLS machine rows&#10;- Click bar shows details popover"></textarea>
                    </div>
                </div>

                <!-- Right: Live Prompt Preview -->
                <div class="pw-builder-preview">
                    <div class="pw-preview-header">📋 Live Prompt Preview</div>
                    <pre class="pw-prompt-text">@GeneratePrompt(_editingIssue)</pre>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-secondary" @onclick="() => CopyPromptAsync(_editingIssue)">📋 Copy Prompt</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@string.IsNullOrWhiteSpace(_editingIssue.Title)">
                    @(_editingIssue.Id == 0 ? "💾 Save to Queue" : "💾 Save")
                </button>
            </div>
        </div>
    </div>
}

<!-- Resolve Modal -->
@if (_showResolve)
{
    <div class="modal-overlay" @onclick="() => _showResolve = false">
        <div class="modal-content" style="max-width: 500px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Mark Fixed: @_resolvingIssue?.Title</h3>
                <button class="modal-close" @onclick="() => _showResolve = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>What was done to fix it?</label>
                    <textarea class="form-control" rows="3" @bind="_resolutionText"
                              placeholder="Brief description of the fix — files changed, approach taken"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => _showResolve = false">Cancel</button>
                <button class="btn btn-success" @onclick="ConfirmResolveAsync">✅ Mark Fixed</button>
            </div>
        </div>
    </div>
}

@code {
    private List<DevIssue>? _issues;

    private DevIssue? _currentIssue;
    private List<DevIssue> _queueIssues = [];
    private List<DevIssue> _fixedIssues = [];
    private List<DevIssue> _resolvedIssues = [];

    private bool _showModal;
    private DevIssue _editingIssue = new();
    private int? _previewId;

    private bool _showResolve;
    private DevIssue? _resolvingIssue;
    private string _resolutionText = "";

    // Scheduling diagnostics
    private List<Machine>? _machines;
    private int _selectedMachineId;
    private bool _capturingSnapshot;
    private SchedulingSnapshot? _editingSnapshot;

    private static readonly string[] SystemAreas =
    [
        "Scheduler — Gantt",
        "Scheduler — Builds",
        "Scheduler — Orders",
        "Scheduler — PartPath",
        "Scheduler — Stages",
        "Scheduler — Table",
        "Scheduler — Toolbar",
        "Work Orders",
        "Parts",
        "Builds / SLS Pipeline",
        "Shop Floor",
        "Tracking",
        "Quality",
        "Analytics",
        "Inventory",
        "Maintenance",
        "Quotes",
        "Admin",
        "Layout / Nav",
        "CSS / Styling",
        "Service Layer",
        "Database / Migrations"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        try { _machines = await SchedulingDiag.GetSchedulableMachinesAsync(); } catch { _machines = []; }
    }

    private async Task LoadAsync()
    {
        _issues = await IssueService.GetAllAsync();
        _currentIssue = _issues.FirstOrDefault(i => i.Status == DevIssueStatus.InProgress);
        _queueIssues = _issues.Where(i => i.Status == DevIssueStatus.Open).ToList();
        _fixedIssues = _issues.Where(i => i.Status == DevIssueStatus.Fixed).ToList();
        _resolvedIssues = _issues
            .Where(i => i.Status is DevIssueStatus.Verified or DevIssueStatus.WontFix)
            .OrderByDescending(i => i.ResolvedAt)
            .ToList();
    }

    // --- CRUD ---

    private void OpenCreate()
    {
        _editingIssue = new DevIssue();
        _selectedMachineId = 0;
        _editingSnapshot = null;
        _showModal = true;
    }

    private void OpenEdit(DevIssue issue)
    {
        _editingIssue = new DevIssue
        {
            Id = issue.Id,
            Title = issue.Title,
            Type = issue.Type,
            Priority = issue.Priority,
            SystemArea = issue.SystemArea,
            Description = issue.Description,
            Expected = issue.Expected,
            StepsOrElement = issue.StepsOrElement,
            RelatedFiles = issue.RelatedFiles,
            AcceptanceCriteria = issue.AcceptanceCriteria,
            AffectedPage = issue.AffectedPage,
            EnvironmentContext = issue.EnvironmentContext,
            Status = issue.Status,
            SortOrder = issue.SortOrder,
            CreatedAt = issue.CreatedAt,
            StartedAt = issue.StartedAt,
            ResolvedAt = issue.ResolvedAt,
            Resolution = issue.Resolution,
            MachineContext = issue.MachineContext,
            ScheduleSnapshotJson = issue.ScheduleSnapshotJson
        };
        _selectedMachineId = 0;
        _editingSnapshot = null;
        if (!string.IsNullOrWhiteSpace(issue.ScheduleSnapshotJson))
        {
            try { _editingSnapshot = System.Text.Json.JsonSerializer.Deserialize<SchedulingSnapshot>(issue.ScheduleSnapshotJson); } catch { }
        }
        _showModal = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingIssue.Title)) return;

        if (_editingIssue.Id == 0)
        {
            await IssueService.CreateAsync(_editingIssue);
            Toast.ShowSuccess("Issue queued");
        }
        else
        {
            await IssueService.UpdateAsync(_editingIssue);
            Toast.ShowSuccess("Issue updated");
        }

        _showModal = false;
        await LoadAsync();
    }

    private void CloseModal() => _showModal = false;

    private async Task OnMachineSelectedAsync(ChangeEventArgs e)
    {
        _selectedMachineId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _editingSnapshot = null;
        _editingIssue.MachineContext = null;
        _editingIssue.ScheduleSnapshotJson = null;

        if (_selectedMachineId <= 0) return;

        _capturingSnapshot = true;
        try
        {
            _editingSnapshot = await SchedulingDiag.CaptureSnapshotAsync(_selectedMachineId);
            _editingIssue.MachineContext = _editingSnapshot.Machine.Name;
            _editingIssue.ScheduleSnapshotJson =
                System.Text.Json.JsonSerializer.Serialize(_editingSnapshot,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = false });

            // Auto-fill scheduling-related defaults
            if (string.IsNullOrWhiteSpace(_editingIssue.SystemArea))
                _editingIssue.SystemArea = "Scheduler — Gantt";
            if (string.IsNullOrWhiteSpace(_editingIssue.AffectedPage))
                _editingIssue.AffectedPage = "/scheduler";
            if (string.IsNullOrWhiteSpace(_editingIssue.RelatedFiles))
                _editingIssue.RelatedFiles = string.Join("\n",
                [
                    "Services/BuildSchedulingService.cs",
                    "Services/SchedulingService.cs",
                    "Services/BuildPlanningService.cs",
                    "Components/Pages/Scheduler/Views/GanttView.razor",
                    "Components/Pages/Scheduler/Components/GanttMachineRow.razor"
                ]);

            Toast.ShowSuccess($"Captured snapshot: {_editingSnapshot.Executions.Count} executions, {_editingSnapshot.Conflicts.Count} conflicts");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Snapshot capture failed: {ex.Message}");
        }
        finally
        {
            _capturingSnapshot = false;
        }
    }

    private void TogglePreview(int id) =>
        _previewId = _previewId == id ? null : id;

    // --- Status transitions ---

    private async Task StartAsync(int id)
    {
        await IssueService.StartAsync(id);
        Toast.ShowInfo("Issue started — prompt is ready above");
        await LoadAsync();
    }

    private void OpenResolve(DevIssue issue)
    {
        _resolvingIssue = issue;
        _resolutionText = "";
        _showResolve = true;
    }

    private async Task ConfirmResolveAsync()
    {
        if (_resolvingIssue is null) return;
        await IssueService.ResolveAsync(_resolvingIssue.Id, _resolutionText);
        _showResolve = false;
        Toast.ShowSuccess("Marked fixed — verify on device when ready");
        await LoadAsync();
    }

    private async Task VerifyAsync(int id)
    {
        await IssueService.VerifyAsync(id);
        Toast.ShowSuccess("Verified and closed");
        await LoadAsync();
    }

    private async Task WontFixAsync(DevIssue issue)
    {
        await IssueService.WontFixAsync(issue.Id, "Won't fix");
        Toast.ShowInfo("Closed as won't fix");
        await LoadAsync();
    }

    private async Task ReopenAsync(int id)
    {
        await IssueService.ReopenAsync(id);
        Toast.ShowWarning("Reopened — back in queue");
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await IssueService.DeleteAsync(id);
        Toast.ShowInfo("Deleted");
        await LoadAsync();
    }

    // --- Prompt Generator ---

    private async Task CopyPromptAsync(DevIssue issue)
    {
        var prompt = GeneratePrompt(issue);
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", prompt);
            Toast.ShowSuccess("Prompt copied — paste into Copilot");
        }
        catch
        {
            Toast.ShowError("Copy failed — check browser permissions");
        }
    }

    private static string GeneratePrompt(DevIssue issue)
    {
        var sb = new System.Text.StringBuilder();

        // Header
        var typeTag = issue.Type switch
        {
            DevIssueType.Bug => "BUG FIX",
            DevIssueType.Change => "CHANGE REQUEST",
            DevIssueType.Styling => "STYLING FIX",
            DevIssueType.SchedulingIssue => "SCHEDULING ISSUE",
            _ => "ISSUE"
        };
        sb.AppendLine($"{typeTag}: {issue.Title}");
        sb.AppendLine();

        // Location context
        var hasArea = !string.IsNullOrWhiteSpace(issue.SystemArea);
        var hasPage = !string.IsNullOrWhiteSpace(issue.AffectedPage);
        var hasMachine = !string.IsNullOrWhiteSpace(issue.MachineContext);
        if (hasArea || hasPage || hasMachine)
        {
            if (hasArea) sb.AppendLine($"System area: {issue.SystemArea}");
            if (hasPage) sb.AppendLine($"Affected page: {issue.AffectedPage}");
            if (hasMachine) sb.AppendLine($"Machine: {issue.MachineContext}");
            sb.AppendLine();
        }

        // Core content (type-adaptive)
        switch (issue.Type)
        {
            case DevIssueType.Bug:
                AppendSection(sb, "What happens (bug):", issue.Description);
                AppendSection(sb, "Expected behavior:", issue.Expected);
                AppendSection(sb, "Steps to reproduce:", issue.StepsOrElement);
                break;
            case DevIssueType.Change:
                AppendSection(sb, "Current behavior:", issue.Description);
                AppendSection(sb, "Desired behavior:", issue.Expected);
                if (!string.IsNullOrWhiteSpace(issue.StepsOrElement))
                    AppendSection(sb, "Additional context:", issue.StepsOrElement);
                break;
            case DevIssueType.Styling:
                AppendSection(sb, "What looks wrong:", issue.Description);
                AppendSection(sb, "Affected element:", issue.StepsOrElement);
                if (!string.IsNullOrWhiteSpace(issue.Expected))
                    AppendSection(sb, "How it should look:", issue.Expected);
                if (!string.IsNullOrWhiteSpace(issue.EnvironmentContext))
                    sb.AppendLine($"Environment: {issue.EnvironmentContext}");
                break;
            case DevIssueType.SchedulingIssue:
                AppendSection(sb, "Scheduling problem:", issue.Description);
                AppendSection(sb, "Expected schedule:", issue.Expected);
                if (!string.IsNullOrWhiteSpace(issue.StepsOrElement))
                    AppendSection(sb, "How it was scheduled:", issue.StepsOrElement);
                AppendSchedulingSnapshot(sb, issue.ScheduleSnapshotJson);
                break;
        }

        // Related files
        if (!string.IsNullOrWhiteSpace(issue.RelatedFiles))
        {
            sb.AppendLine("Files to look at:");
            foreach (var file in issue.RelatedFiles.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                sb.AppendLine($"- {file}");
            }
            sb.AppendLine();
        }

        // Acceptance criteria
        if (!string.IsNullOrWhiteSpace(issue.AcceptanceCriteria))
        {
            sb.AppendLine("Done when:");
            foreach (var line in issue.AcceptanceCriteria.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                var trimmed = line.TrimStart('-', ' ');
                sb.AppendLine($"- {trimmed}");
            }
            sb.AppendLine();
        }

        sb.AppendLine($"Priority: {issue.Priority}");

        return sb.ToString().TrimEnd();
    }

    private static void AppendSection(System.Text.StringBuilder sb, string heading, string? content)
    {
        if (string.IsNullOrWhiteSpace(content)) return;
        sb.AppendLine(heading);
        sb.AppendLine(content);
        sb.AppendLine();
    }

    private static void AppendSchedulingSnapshot(System.Text.StringBuilder sb, string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return;

        SchedulingSnapshot? snapshot;
        try { snapshot = System.Text.Json.JsonSerializer.Deserialize<SchedulingSnapshot>(json); }
        catch { return; }
        if (snapshot is null) return;

        sb.AppendLine("═══ AUTO-CAPTURED SCHEDULING DIAGNOSTICS ═══");
        sb.AppendLine();

        // Machine info
        var m = snapshot.Machine;
        sb.AppendLine($"Machine: {m.Name} (Type: {m.MachineType}, Status: {m.Status}, Additive: {m.IsAdditive})");
        if (m.AutoChangeoverEnabled)
            sb.AppendLine($"  Changeover: {m.ChangeoverMinutes}min (auto-enabled)");
        sb.AppendLine($"  Hourly rate: ${m.HourlyRate}/hr");
        sb.AppendLine($"  Snapshot range: {snapshot.RangeStart:yyyy-MM-dd HH:mm} → {snapshot.RangeEnd:yyyy-MM-dd HH:mm}");
        sb.AppendLine($"  Captured at: {snapshot.CapturedAt:yyyy-MM-dd HH:mm:ss} UTC");
        sb.AppendLine();

        // Conflicts (most important — show first)
        if (snapshot.Conflicts.Count > 0)
        {
            sb.AppendLine($"⚠️ CONFLICTS DETECTED ({snapshot.Conflicts.Count}):");
            foreach (var c in snapshot.Conflicts)
            {
                sb.AppendLine($"  🔴 {c.DescriptionA}");
                sb.AppendLine($"     overlaps with {c.DescriptionB}");
                sb.AppendLine($"     Overlap window: {c.OverlapStart:MM/dd HH:mm}–{c.OverlapEnd:MM/dd HH:mm}");
            }
            sb.AppendLine();
        }

        // Programs on this machine
        if (snapshot.BuildPackages.Count > 0)
        {
            sb.AppendLine($"Programs on machine ({snapshot.BuildPackages.Count}):");
            foreach (var prog in snapshot.BuildPackages)
            {
                sb.AppendLine($"  [{prog.Status}] {prog.Name} — scheduled: {prog.ScheduledDate:MM/dd HH:mm}, " +
                    $"duration: {prog.EstimatedDurationHours:F1}h, material: {prog.Material ?? "—"}, " +
                    $"parts: {prog.PartCount}, locked: {prog.IsLocked}");
            }
            sb.AppendLine();
        }

        // Build timeline (print + changeover windows)
        if (snapshot.Timeline.Count > 0)
        {
            sb.AppendLine($"Build timeline ({snapshot.Timeline.Count} entries):");
            foreach (var t in snapshot.Timeline)
            {
                var co = t.ChangeoverStart.HasValue
                    ? $" → changeover {t.ChangeoverStart:HH:mm}–{t.ChangeoverEnd:HH:mm}"
                    : "";
                sb.AppendLine($"  {t.BuildName} [{t.Status}]: print {t.PrintStart:MM/dd HH:mm}–{t.PrintEnd:MM/dd HH:mm}{co}");
            }
            sb.AppendLine();
        }

        // Executions on this machine
        if (snapshot.Executions.Count > 0)
        {
            sb.AppendLine($"Stage executions on machine ({snapshot.Executions.Count}):");
            foreach (var e in snapshot.Executions)
            {
                var wo = !string.IsNullOrWhiteSpace(e.WorkOrderNumber) ? $" WO:{e.WorkOrderNumber}" : "";
                var build = e.MachineProgramId.HasValue ? $" Program#{e.MachineProgramId}" : "";
                var batch = !string.IsNullOrWhiteSpace(e.BatchGroupId) ? $" Batch:{e.BatchGroupId}" : "";
                sb.AppendLine($"  Exec#{e.Id} [{e.Status}] {e.StageName}: {e.PartNumber ?? "no-part"} " +
                    $"({e.ScheduledStart:MM/dd HH:mm}–{e.ScheduledEnd:MM/dd HH:mm}, " +
                    $"est: {e.EstimatedHours:F1}h){wo}{build}{batch}");
            }
            sb.AppendLine();
        }

        sb.AppendLine($"Unscheduled executions in system: {snapshot.UnscheduledCount}");
        sb.AppendLine();
    }

