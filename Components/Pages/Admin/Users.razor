@page "/admin/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject Vectrik.Data.TenantDbContext Db
@inject IAuthService AuthService
@inject IStageService StageService
@inject ToastService Toast
@using Microsoft.EntityFrameworkCore

<PageTitle>Users - Admin - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Users</h1>
    <button class="btn btn-primary" @onclick="NewUser">+ New User</button>
</div>

@if (_users == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (!_users.Any())
{
    <div class="empty-state">
        <div class="empty-state-text">No users configured. Click "+ New User" to add one.</div>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>Username</th><th>Full Name</th><th>Email</th><th>Role</th><th>Department</th><th>Stages</th><th>Active</th><th></th></tr></thead>
            <tbody>
                @foreach (var u in _users)
                {
                    <tr>
                        <td>@u.Username</td>
                        <td>@u.FullName</td>
                        <td>@(u.Email ?? "—")</td>
                        <td><span class="badge">@u.Role</span></td>
                        <td>@(u.Department ?? "—")</td>
                        <td>@(string.IsNullOrWhiteSpace(u.AssignedStageIds) ? "All" : u.AssignedStageIds.Split(',').Length.ToString())</td>
                        <td><span class="badge @(u.IsActive ? "badge-active" : "badge-cancelled")">@(u.IsActive ? "Yes" : "No")</span></td>
                        <td style="white-space: nowrap;">
                            <button class="btn btn-sm btn-secondary" @onclick="() => EditUser(u)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(u)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showForm && _edit != null)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" style="max-width: 650px; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">@(_edit.Id == 0 ? "New" : "Edit") User</span><button class="modal-close" @onclick="() => _showForm = false">&times;</button></div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group">
                    <label class="form-label">Username <span style="color:var(--danger);">*</span></label>
                    <input class="form-control @(_validationErrors.ContainsKey("Username") ? "is-invalid" : "")" @bind="_edit.Username" disabled="@(_edit.Id > 0)" />
                    @if (_validationErrors.ContainsKey("Username")) { <small style="color:var(--danger);">@_validationErrors["Username"]</small> }
                </div>
                <div class="form-group">
                    <label class="form-label">Full Name <span style="color:var(--danger);">*</span></label>
                    <input class="form-control @(_validationErrors.ContainsKey("FullName") ? "is-invalid" : "")" @bind="_edit.FullName" />
                    @if (_validationErrors.ContainsKey("FullName")) { <small style="color:var(--danger);">@_validationErrors["FullName"]</small> }
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control @(_validationErrors.ContainsKey("Email") ? "is-invalid" : "")" type="email" @bind="_edit.Email" />
                    @if (_validationErrors.ContainsKey("Email")) { <small style="color:var(--danger);">@_validationErrors["Email"]</small> }
                </div>
                <div class="form-group"><label class="form-label">Role</label>
                    <select class="form-control" @bind="_edit.Role">
                        @foreach (var r in _roles) { <option>@r</option> }
                    </select>
                </div>
                <div class="form-group"><label class="form-label">Department</label><input class="form-control" @bind="_edit.Department" /></div>
                <div class="form-group">
                    <label class="form-label"><input type="checkbox" @bind="_edit.IsActive" style="margin-right: 6px;" />Active</label>
                </div>
            </div>

            <div class="card" style="padding: 12px; margin-top: 12px;">
                <div class="form-group" style="margin-bottom: 8px;">
                    <label class="form-label">@(_edit.Id == 0 ? "Password" : "Reset Password") <span style="color:var(--danger);">@(_edit.Id == 0 ? "*" : "")</span></label>
                    <input class="form-control @(_validationErrors.ContainsKey("Password") ? "is-invalid" : "")" type="password" @bind="_newPassword" placeholder="@(_edit.Id == 0 ? "Required — min 8 characters" : "Leave blank to keep current")" />
                    @if (_validationErrors.ContainsKey("Password")) { <small style="color:var(--danger);">@_validationErrors["Password"]</small> }
                </div>
                @if (_edit.Id > 0 && !string.IsNullOrWhiteSpace(_newPassword))
                {
                    <button class="btn btn-sm btn-secondary" @onclick="ResetPassword">Reset Password</button>
                }
            </div>

            @if (_edit.Role == "Operator" && _allStages != null)
            {
                <div class="card" style="padding: 12px; margin-top: 12px;">
                    <div class="form-label" style="margin-bottom: 8px;">Assigned Stages (Operators see only these)</div>
                    @foreach (var s in _allStages)
                    {
                        <label style="display: block; padding: 4px 0;">
                            <input type="checkbox" checked="@IsStageAssigned(s.Id)" @onchange="e => ToggleStage(s.Id, (bool)(e.Value ?? false))" style="margin-right: 6px;" />
                            <span style="color: @s.StageColor">⚙</span> @s.Name
                        </label>
                    }
                </div>

                <div class="card" style="padding: 12px; margin-top: 12px;">
                    <div class="form-label" style="margin-bottom: 4px; font-weight: 600;">Operator Permissions</div>
                    <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 10px;">Fine-grained control over what this operator can do on the shop floor.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanPause" style="margin-right: 6px;" />Can Pause Work</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanFail" style="margin-right: 6px;" />Can Fail / NCR</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanTransfer" style="margin-right: 6px;" />Can Transfer Work</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanClaimWork" style="margin-right: 6px;" />Can Claim Unassigned Work</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanCompleteWithoutChecklist" style="margin-right: 6px;" />Can Skip Checklist</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanViewCostData" style="margin-right: 6px;" />Can View Cost Data</label>
                        <label class="form-label"><input type="checkbox" @bind="_permissions.CanAccessAllStages" style="margin-right: 6px;" />Access All Stages</label>
                    </div>
                    <div class="form-group" style="margin-top: 10px; max-width: 200px;">
                        <label class="form-label">Max Concurrent Jobs</label>
                        <input class="form-control" type="number" min="0" max="10" @bind="_permissions.MaxConcurrentJobs" />
                        <small style="color: var(--text-muted);">0 = unlimited</small>
                    </div>
                </div>
            }

            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    private List<User>? _users;
    private List<ProductionStage>? _allStages;
    private User? _edit;
    private bool _showForm, _saving;
    private string? _error, _newPassword;
    private HashSet<int> _assignedStageIds = new();
    private OperatorPermissions _permissions = new();
    private Dictionary<string, string> _validationErrors = new();
    private ConfirmDialog _confirm = null!;
    private readonly string[] _roles = ["Admin", "Manager", "Supervisor", "Scheduler", "Operator", "MaintenanceTech", "QCSpecialist", "Analyst"];

    protected override async Task OnInitializedAsync()
    {
        _users = await Db.Users.OrderBy(u => u.Username).ToListAsync();
        _allStages = await StageService.GetAllStagesAsync();
    }

    private void EditUser(User u)
    {
        _edit = u;
        _newPassword = null;
        _error = null;
        _validationErrors.Clear();
        _assignedStageIds = string.IsNullOrWhiteSpace(u.AssignedStageIds)
            ? new HashSet<int>()
            : u.AssignedStageIds.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(int.Parse).ToHashSet();
        _permissions = u.GetPermissions();
        _showForm = true;
    }

    private void NewUser()
    {
        _edit = new User { Role = "Operator", CreatedBy = "System", LastModifiedBy = "System" };
        _newPassword = null;
        _error = null;
        _validationErrors.Clear();
        _assignedStageIds = new();
        _permissions = new OperatorPermissions();
        _showForm = true;
    }

    private bool IsStageAssigned(int id) => _assignedStageIds.Contains(id);

    private void ToggleStage(int id, bool isChecked)
    {
        if (isChecked) _assignedStageIds.Add(id);
        else _assignedStageIds.Remove(id);
    }

    private bool Validate()
    {
        _validationErrors.Clear();
        if (string.IsNullOrWhiteSpace(_edit!.Username))
            _validationErrors["Username"] = "Username is required.";
        if (string.IsNullOrWhiteSpace(_edit.FullName))
            _validationErrors["FullName"] = "Full name is required.";
        if (!string.IsNullOrWhiteSpace(_edit.Email) && !_edit.Email.Contains('@'))
            _validationErrors["Email"] = "Invalid email format.";
        if (_edit.Id == 0 && string.IsNullOrWhiteSpace(_newPassword))
            _validationErrors["Password"] = "Password is required for new users.";
        if (!string.IsNullOrWhiteSpace(_newPassword) && _newPassword.Length < 8)
            _validationErrors["Password"] = "Password must be at least 8 characters.";
        return _validationErrors.Count == 0;
    }

    private async Task ResetPassword()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _edit?.Id == 0) return;
        if (_newPassword.Length < 8)
        {
            _validationErrors["Password"] = "Password must be at least 8 characters.";
            return;
        }
        try
        {
            _edit!.PasswordHash = AuthService.HashPassword(_newPassword);
            _edit.LastModifiedDate = DateTime.UtcNow;
            await Db.SaveChangesAsync();
            _newPassword = null;
            Toast.ShowSuccess("Password reset successfully.");
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    private async Task ConfirmDelete(User u)
    {
        if (u.Role == "Admin")
        {
            var adminCount = _users!.Count(x => x.Role == "Admin" && x.IsActive);
            if (adminCount <= 1)
            {
                Toast.ShowError("Cannot delete the last admin user.");
                return;
            }
        }
        if (await _confirm.ShowAsync($"Delete user '{u.Username}' ({u.FullName})? This cannot be undone.", "Delete User"))
        {
            try
            {
                Db.Users.Remove(u);
                await Db.SaveChangesAsync();
                Toast.ShowSuccess($"User '{u.Username}' deleted.");
                _users = await Db.Users.OrderBy(x => x.Username).ToListAsync();
            }
            catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        }
    }

    private async Task Save()
    {
        _error = null;
        if (!Validate()) return;

        _saving = true;
        try
        {
            _edit!.AssignedStageIds = _assignedStageIds.Any() ? string.Join(",", _assignedStageIds.OrderBy(x => x)) : null;
            _edit.SetPermissions(_permissions);

            if (_edit.Id == 0)
            {
                _edit.PasswordHash = AuthService.HashPassword(_newPassword!);
                _edit.CreatedDate = DateTime.UtcNow;
                Db.Users.Add(_edit);
            }
            _edit.LastModifiedDate = DateTime.UtcNow;
            await Db.SaveChangesAsync();
            _showForm = false;
            _users = await Db.Users.OrderBy(u => u.Username).ToListAsync();
            Toast.ShowSuccess($"User '{_edit.Username}' saved.");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
