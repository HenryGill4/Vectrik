@page "/admin/stages"
@inject IStageService StageService
@inject IMachineService MachineService
@inject ToastService Toast
@using System.Text.Json

<PageTitle>Production Stages - Admin - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Production Stages</h1>
    <button class="btn btn-primary" @onclick="NewStage">+ New Stage</button>
</div>

@if (_stages == null) { <div class="loading"><span class="spinner"></span></div> }
else if (!_stages.Any())
{
    <div class="card" style="padding: 32px; text-align: center; color: var(--text-muted);">
        No production stages defined. Click "+ New Stage" to create your manufacturing process stages.
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>Order</th><th>Name</th><th>Slug</th><th>Department</th><th>Duration</th><th>Rate</th><th>Machines</th><th>Active</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in _stages)
                {
                    <tr>
                        <td>@s.DisplayOrder</td>
                        <td><span style="color: @s.StageColor">@ResolveStageIcon(s.StageIcon)</span> @s.Name</td>
                        <td style="font-family: monospace;">@s.StageSlug</td>
                        <td>@s.Department</td>
                        <td>@s.DefaultDurationHours h</td>
                        <td>$@s.DefaultHourlyRate/hr</td>
                        <td>
                            @{
                                var assignedIds = s.GetAssignedMachineIntIds();
                            }
                            @if (assignedIds.Count == 0)
                            {
                                <span style="color: var(--text-muted); font-size: 0.8rem;">Any</span>
                            }
                            else
                            {
                                <span style="font-size: 0.8rem;">@string.Join(", ", _machines.Where(m => assignedIds.Contains(m.Id)).Select(m => m.Name))</span>
                            }
                        </td>
                        <td><span class="badge @(s.IsActive ? "badge-active" : "badge-cancelled")">@(s.IsActive ? "Yes" : "No")</span></td>
                        <td><button class="btn btn-sm btn-secondary" @onclick="() => Edit(s)">Edit</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showForm && _edit != null)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" style="max-width: 750px; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">@(_edit.Id == 0 ? "New Stage" : "Edit Stage")</span><button class="modal-close" @onclick="() => _showForm = false">&times;</button></div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <div class="content-tab-bar" style="margin-bottom: 16px;">
                <button class="tab @(_tab == "info" ? "active" : "")" @onclick='() => _tab = "info"'>Info</button>
                <button class="tab @(_tab == "options" ? "active" : "")" @onclick='() => _tab = "options"'>Options</button>
                <button class="tab @(_tab == "fields" ? "active" : "")" @onclick='() => _tab = "fields"'>Custom Fields (@_customFields.Count)</button>
                <button class="tab @(_tab == "ui" ? "active" : "")" @onclick='() => _tab = "ui"'>Operator UI</button>
                <button class="tab @(_tab == "layout" ? "active" : "")" @onclick='() => _tab = "layout"'>Page Layout</button>
            </div>

            @if (_tab == "info")
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group"><label class="form-label">Name</label><input class="form-control" @bind="_edit.Name" /></div>
                    <div class="form-group"><label class="form-label">Slug</label><input class="form-control" @bind="_edit.StageSlug" placeholder="e.g. anodizing" /></div>
                    <div class="form-group"><label class="form-label">Department</label><input class="form-control" @bind="_edit.Department" /></div>
                    <div class="form-group"><label class="form-label">Display Order</label><input class="form-control" type="number" @bind="_edit.DisplayOrder" /></div>
                    <div class="form-group"><label class="form-label">Default Duration (hrs)</label><input class="form-control" type="number" step="0.5" @bind="_edit.DefaultDurationHours" /></div>
                    <div class="form-group"><label class="form-label">Hourly Rate ($)</label><input class="form-control" type="number" step="1" @bind="_edit.DefaultHourlyRate" /></div>
                    <div class="form-group"><label class="form-label">Setup Minutes</label><input class="form-control" type="number" @bind="_edit.DefaultSetupMinutes" /></div>
                    <div class="form-group"><label class="form-label">Material Cost ($)</label><input class="form-control" type="number" step="0.01" @bind="_edit.DefaultMaterialCost" /></div>
                    <div class="form-group"><label class="form-label">Color</label><input class="form-control" type="color" @bind="_edit.StageColor" /></div>
                    <div class="form-group"><label class="form-label">Icon (emoji)</label><input class="form-control" @bind="_edit.StageIcon" placeholder="🖨️ or ⚙️" /></div>
                    <div class="form-group" style="grid-column: span 2;"><label class="form-label">Description</label><input class="form-control" @bind="_edit.Description" /></div>
                </div>
            }

            @if (_tab == "options")
            {
                <p style="color: var(--text-muted); margin-bottom: 12px; font-size: 0.85rem;">⚠️ Batch stage, build-level, and plate release settings have moved to the per-part Manufacturing Process editor.</p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <label class="form-label"><input type="checkbox" @bind="_edit.RequiresMachineAssignment" style="margin-right: 6px;" />Requires Machine</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.RequiresSerialNumber" style="margin-right: 6px;" />Requires Serial Number</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.RequiresQualityCheck" style="margin-right: 6px;" />Requires QC</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.HasBuiltInPage" style="margin-right: 6px;" />Has Built-In Page</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.AllowSkip" style="margin-right: 6px;" />Allow Skip</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.IsOptional" style="margin-right: 6px;" />Optional</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.AllowParallelExecution" style="margin-right: 6px;" />Parallel Execution</label>
                    <label class="form-label"><input type="checkbox" @bind="_edit.IsActive" style="margin-right: 6px;" />Active</label>
                </div>

                <div style="margin-top: 16px;">
                    <label class="form-label" style="font-weight: 600; margin-bottom: 8px; display: block;">Assigned Machines</label>
                    <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 8px;">Select which machines can execute this stage. Leave all unchecked to allow any machine.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px; max-height: 220px; overflow-y: auto; padding: 8px; border: 1px solid var(--border); border-radius: var(--radius-md);">
                        @foreach (var m in _machines.OrderBy(m => m.Department).ThenBy(m => m.Name))
                        {
                            var mid = m.Id;
                            var isSelected = _selectedMachineIds.Contains(mid);
                            <label style="display: flex; align-items: center; gap: 6px; font-size: 0.85rem; cursor: pointer;">
                                <input type="checkbox" checked="@isSelected" @onchange="e => ToggleMachine(mid, (bool)(e.Value ?? false))" />
                                <span style="color: var(--text-secondary); font-size: 0.75rem;">@(m.Department ?? "—")</span>
                                @m.Name
                            </label>
                        }
                    </div>
                    @if (_selectedMachineIds.Count > 0)
                    {
                        <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 6px;">@_selectedMachineIds.Count machine(s) selected</p>
                    }
                </div>
            }

            @if (_tab == "fields")
            {
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <p style="color: var(--text-muted); margin: 0;">Define the operator form fields for this stage. These appear on the shop floor when an operator processes work.</p>
                    <button class="btn btn-sm @(_previewFields ? "btn-primary" : "btn-secondary")" @onclick="() => _previewFields = !_previewFields">
                        @(_previewFields ? "Edit Mode" : "Preview")
                    </button>
                </div>

                @if (_previewFields)
                {
                    <div class="card" style="padding: 16px;">
                        <div class="card-header" style="margin-bottom: 12px;">📝 Form Preview (as operator sees it)</div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
                            @foreach (var f in _customFields)
                            {
                                <div class="form-group">
                                    <label class="form-label">@f.Label @(f.IsRequired ? "*" : "")</label>
                                    @switch (f.FieldType?.ToLower())
                                    {
                                        case "checkbox":
                                            <div><input type="checkbox" disabled style="width: 20px; height: 20px;" /></div>
                                            break;
                                        case "dropdown":
                                        case "select":
                                            <select class="form-control" disabled><option>Select...</option></select>
                                            break;
                                        case "textarea":
                                            <textarea class="form-control" rows="2" disabled placeholder="@(f.HelpText ?? "")"></textarea>
                                            break;
                                        case "measurement":
                                            <div style="display: flex; gap: 4px; align-items: center;">
                                                <input class="form-control" type="number" disabled placeholder="0.00" style="flex:1" />
                                                <span style="color: var(--text-muted); font-size: 0.85rem;">@(f.Unit ?? "")</span>
                                            </div>
                                            break;
                                        case "photo":
                                            <div style="padding: 8px; border: 1px dashed var(--border); border-radius: 6px; text-align: center; color: var(--text-muted);">📷 Photo capture</div>
                                            break;
                                        case "file":
                                            <div style="padding: 8px; border: 1px dashed var(--border); border-radius: 6px; text-align: center; color: var(--text-muted);">📎 File upload</div>
                                            break;
                                        case "signature":
                                            <input class="form-control" disabled placeholder="Type name to sign" />
                                            break;
                                        default:
                                            <input class="form-control" disabled placeholder="@(f.HelpText ?? "")" />
                                            break;
                                    }
                                    @if (!string.IsNullOrWhiteSpace(f.HelpText) && f.FieldType != "textarea")
                                    {
                                        <small style="color: var(--text-muted);">@f.HelpText</small>
                                    }
                                </div>
                            }
                        </div>
                        @if (!_customFields.Any())
                        {
                            <div class="empty-state"><div class="empty-state-text">No fields configured</div></div>
                        }
                    </div>
                }
                else
                {

                @for (var i = 0; i < _customFields.Count; i++)
                {
                    var idx = i;
                    var f = _customFields[idx];
                    <div class="card" style="padding: 12px; margin-bottom: 8px;">
                        <div style="display: grid; grid-template-columns: auto 1fr 1fr 1fr auto; gap: 8px; align-items: end;">
                            <div style="display: flex; flex-direction: column; gap: 2px;">
                                <button class="btn btn-sm btn-secondary" style="padding: 2px 6px; font-size: 0.7rem;" disabled="@(idx == 0)" @onclick="() => MoveFieldUp(idx)">▲</button>
                                <button class="btn btn-sm btn-secondary" style="padding: 2px 6px; font-size: 0.7rem;" disabled="@(idx == _customFields.Count - 1)" @onclick="() => MoveFieldDown(idx)">▼</button>
                            </div>
                            <div class="form-group" style="margin: 0;"><label class="form-label">Label</label><input class="form-control" value="@f.Label" @onchange="e => UpdateFieldLabel(idx, e)" /></div>
                            <div class="form-group" style="margin: 0;"><label class="form-label">Name (key)</label><input class="form-control" value="@f.Name" @onchange="e => UpdateFieldName(idx, e)" /></div>
                            <div class="form-group" style="margin: 0;"><label class="form-label">Type</label>
                                <select class="form-control" value="@f.FieldType" @onchange="e => UpdateFieldType(idx, e)">
                                    <option value="text">Text</option>
                                    <option value="textarea">Text Area</option>
                                    <option value="number">Number</option>
                                    <option value="measurement">Measurement</option>
                                    <option value="dropdown">Dropdown</option>
                                    <option value="checkbox">Checkbox</option>
                                    <option value="date">Date</option>
                                    <option value="photo">Photo</option>
                                    <option value="file">File Upload</option>
                                    <option value="signature">Signature</option>
                                </select>
                            </div>
                            <button class="btn btn-sm btn-danger" style="height: 38px;" @onclick="() => RemoveField(idx)">✕</button>
                        </div>
                        <div style="display: flex; gap: 12px; margin-top: 8px; align-items: center;">
                            <label style="font-size: 0.85rem;"><input type="checkbox" checked="@f.IsRequired" @onchange="e => UpdateFieldRequired(idx, e)" style="margin-right: 4px;" />Required</label>
                            @if (f.FieldType == "dropdown")
                            {
                                <div class="form-group" style="margin: 0; flex: 1;"><label class="form-label">Options (comma-separated)</label><input class="form-control" value="@(f.Options ?? "")" @onchange="e => UpdateFieldOptions(idx, e)" /></div>
                            }
                            @if (f.FieldType is "number" or "measurement")
                            {
                                <div class="form-group" style="margin: 0;"><label class="form-label">Min</label><input class="form-control" type="number" style="width: 80px;" value="@f.MinValue" @onchange="e => UpdateFieldMin(idx, e)" /></div>
                                <div class="form-group" style="margin: 0;"><label class="form-label">Max</label><input class="form-control" type="number" style="width: 80px;" value="@f.MaxValue" @onchange="e => UpdateFieldMax(idx, e)" /></div>
                            }
                            @if (f.FieldType == "measurement")
                            {
                                <div class="form-group" style="margin: 0;"><label class="form-label">Unit</label><input class="form-control" style="width: 70px;" value="@(f.Unit ?? "")" @onchange="e => _customFields[idx].Unit = e.Value?.ToString()" placeholder="mm" /></div>
                                <div class="form-group" style="margin: 0;"><label class="form-label">Tol Min</label><input class="form-control" type="number" step="any" style="width: 80px;" value="@f.ToleranceMin" @onchange="e => _customFields[idx].ToleranceMin = double.TryParse(e.Value?.ToString(), out var v) ? v : null" /></div>
                                <div class="form-group" style="margin: 0;"><label class="form-label">Tol Max</label><input class="form-control" type="number" step="any" style="width: 80px;" value="@f.ToleranceMax" @onchange="e => _customFields[idx].ToleranceMax = double.TryParse(e.Value?.ToString(), out var v) ? v : null" /></div>
                            }
                        </div>
                        <div style="display: flex; gap: 8px; margin-top: 8px; align-items: end;">
                            <div class="form-group" style="margin: 0; flex: 1;"><label class="form-label">Help Text</label><input class="form-control" value="@(f.HelpText ?? "")" @onchange="e => _customFields[idx].HelpText = e.Value?.ToString()" placeholder="Guidance shown below the field" /></div>
                            <button class="btn btn-sm btn-secondary" style="height: 38px;" @onclick="() => DuplicateField(idx)" title="Duplicate">⧉</button>
                        </div>
                    </div>
                }

                <button class="btn btn-sm btn-secondary" @onclick="AddField">+ Add Field</button>

                }
            }

            @if (_tab == "ui")
            {
                <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.85rem;">
                    Control what operators see and can do on the shop floor for this stage.
                </p>

                <div class="card" style="padding: 16px; margin-bottom: 12px;">
                    <h4 style="margin: 0 0 12px; font-size: 0.9rem; color: var(--text-primary); font-weight: 600;">Visible Sections</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowWorkInstructions" style="margin-right: 6px;" />Work Instructions</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowTimer" style="margin-right: 6px;" />Timer / Duration</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowSignOffChecklist" style="margin-right: 6px;" />Sign-Off Checklist</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowMachineStatus" style="margin-right: 6px;" />Machine Status</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowPartContext" style="margin-right: 6px;" />Part Context</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowMaterialLotTracking" style="margin-right: 6px;" />Material Lot Tracking</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowPreviousStageNotes" style="margin-right: 6px;" />Previous Stage Notes</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowPhotoCapture" style="margin-right: 6px;" />Photo Capture</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.ShowHistory" style="margin-right: 6px;" />History Tab</label>
                    </div>
                </div>

                <div class="card" style="padding: 16px; margin-bottom: 12px;">
                    <h4 style="margin: 0 0 12px; font-size: 0.9rem; color: var(--text-primary); font-weight: 600;">Required Before Completion</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.RequireChecklist" style="margin-right: 6px;" />All Checklist Items Signed</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.RequireQualityCheck" style="margin-right: 6px;" />Quality Check</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.RequireNotes" style="margin-right: 6px;" />Completion Notes</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.RequirePhoto" style="margin-right: 6px;" />Photo Evidence</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.RequireAllCustomFields" style="margin-right: 6px;" />All Custom Fields</label>
                    </div>
                </div>

                <div class="card" style="padding: 16px; margin-bottom: 12px;">
                    <h4 style="margin: 0 0 12px; font-size: 0.9rem; color: var(--text-primary); font-weight: 600;">Operator Actions</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowPause" style="margin-right: 6px;" />Pause / Delay</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowLogDelay" style="margin-right: 6px;" />Log Delay</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowFail" style="margin-right: 6px;" />Fail / NCR</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowTransfer" style="margin-right: 6px;" />Transfer to Operator</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowBatchComplete" style="margin-right: 6px;" />Batch Complete</label>
                        <label class="form-label"><input type="checkbox" @bind="_uiConfig.AllowSkip" style="margin-right: 6px;" />Skip Stage</label>
                    </div>
                </div>

                <div class="card" style="padding: 16px;">
                    <h4 style="margin: 0 0 12px; font-size: 0.9rem; color: var(--text-primary); font-weight: 600;">Workflow</h4>
                    <label class="form-label"><input type="checkbox" @bind="_uiConfig.AutoAdvanceToNext" style="margin-right: 6px;" />Auto-advance to next queue item after completion</label>
                </div>
            }

            @if (_tab == "layout")
            {
                <p style="color: var(--text-muted); margin-bottom: 12px; font-size: 0.85rem;">
                    Configure which widgets appear on the operator stage page and in what order. Drag to reorder.
                </p>

                <div class="form-group" style="max-width: 200px; margin-bottom: 16px;">
                    <label class="form-label">Layout Columns</label>
                    <select class="form-control" @bind="_pageLayout.Columns">
                        <option value="1">1 Column</option>
                        <option value="2">2 Columns</option>
                        <option value="3">3 Columns</option>
                    </select>
                </div>

                @for (var i = 0; i < _pageLayout.Widgets.Count; i++)
                {
                    var idx = i;
                    var w = _pageLayout.Widgets[idx];
                    <div class="card" style="padding: 10px; margin-bottom: 6px; display: flex; align-items: center; gap: 10px;">
                        <div style="display: flex; flex-direction: column; gap: 2px;">
                            <button class="btn btn-sm btn-secondary" style="padding: 1px 5px; font-size: 0.65rem;" disabled="@(idx == 0)" @onclick="() => MoveWidgetUp(idx)">▲</button>
                            <button class="btn btn-sm btn-secondary" style="padding: 1px 5px; font-size: 0.65rem;" disabled="@(idx == _pageLayout.Widgets.Count - 1)" @onclick="() => MoveWidgetDown(idx)">▼</button>
                        </div>
                        <select class="form-control" style="width: 180px;" value="@w.Type" @onchange="e => SetWidgetType(w, e)">
                            <option value="queue">Queue</option>
                            <option value="active-work">Active Work</option>
                            <option value="custom-form">Custom Form</option>
                            <option value="work-instructions">Work Instructions</option>
                            <option value="machine-status">Machine Status</option>
                            <option value="part-context">Part Context</option>
                            <option value="timer">Timer</option>
                            <option value="checklist">Sign-Off Checklist</option>
                            <option value="history">History</option>
                            <option value="shift-info">Shift Schedule</option>
                            <option value="notes">Completion Notes</option>
                        </select>
                        <input class="form-control" style="flex: 1;" value="@w.Title" @onchange="e => SetWidgetTitle(w, e)" placeholder="Widget title" />
                        <select class="form-control" style="width: 100px;" value="@w.Size" @onchange="e => SetWidgetSize(w, e)">
                            <option value="small">Small</option>
                            <option value="medium">Medium</option>
                            <option value="large">Large</option>
                            <option value="full">Full Width</option>
                        </select>
                        @if (_pageLayout.Columns > 1)
                        {
                            <select class="form-control" style="width: 80px;" value="@w.Column" @onchange="e => w.Column = int.TryParse(e.Value?.ToString(), out var c) ? c : 1">
                                @for (var c = 1; c <= _pageLayout.Columns; c++)
                                {
                                    <option value="@c">Col @c</option>
                                }
                            </select>
                        }
                        <label style="font-size: 0.8rem; white-space: nowrap;"><input type="checkbox" @bind="w.CollapsedByDefault" style="margin-right: 4px;" />Collapsed</label>
                        <button class="btn btn-sm btn-danger" style="padding: 4px 8px;" @onclick="() => _pageLayout.Widgets.RemoveAt(idx)">✕</button>
                    </div>
                }

                <button class="btn btn-sm btn-secondary" @onclick="AddWidget" style="margin-top: 4px;">+ Add Widget</button>

                <div class="card" style="padding: 12px; margin-top: 12px; background: var(--bg-tertiary);">
                    <div style="font-weight: 600; margin-bottom: 8px;">Quick Templates</div>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <button class="btn btn-sm btn-secondary" @onclick="ApplyManualTemplate">Manual Stage</button>
                        <button class="btn btn-sm btn-secondary" @onclick="ApplyMachineTemplate">Machine Stage</button>
                        <button class="btn btn-sm btn-secondary" @onclick="ApplyInspectionTemplate">Inspection</button>
                        <button class="btn btn-sm btn-secondary" @onclick="ApplyMinimalTemplate">Minimal</button>
                    </div>
                </div>
            }

            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save">Save</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductionStage>? _stages;
    private List<Machine> _machines = new();
    private ProductionStage? _edit;
    private bool _showForm;
    private string? _error;
    private string _tab = "info";
    private List<CustomFieldDefinition> _customFields = new();
    private HashSet<int> _selectedMachineIds = new();
    private StageUiConfig _uiConfig = new();
    private StagePageLayout _pageLayout = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stages = await StageService.GetAllStagesAsync(activeOnly: false);
            _machines = await MachineService.GetAllMachinesAsync(activeOnly: true);
        }
        catch (Exception ex) { Toast.ShowError($"Failed to load stages: {ex.Message}"); _stages = new(); }
    }

    private void NewStage()
    {
        _edit = new ProductionStage { CreatedBy = "System", LastModifiedBy = "System", CustomFieldsConfig = "[]" };
        _customFields = new();
        _selectedMachineIds = new();
        _uiConfig = new StageUiConfig();
        _pageLayout = new StagePageLayout();
        _tab = "info";
        _showForm = true;
    }

    private void Edit(ProductionStage s)
    {
        _edit = s;
        _tab = "info";
        try { _customFields = JsonSerializer.Deserialize<List<CustomFieldDefinition>>(s.CustomFieldsConfig) ?? new(); }
        catch { _customFields = new(); }
        _selectedMachineIds = s.GetAssignedMachineIntIds().ToHashSet();
        _uiConfig = s.GetUiConfig();
        _pageLayout = s.GetPageLayout();
        _showForm = true;
    }

    private bool _previewFields;

    private void AddField() => _customFields.Add(new CustomFieldDefinition { FieldType = "text" });
    private void RemoveField(int idx) => _customFields.RemoveAt(idx);

    private void DuplicateField(int idx)
    {
        var src = _customFields[idx];
        var copy = new CustomFieldDefinition
        {
            Label = src.Label + " (copy)", Name = src.Name + "_copy", FieldType = src.FieldType,
            IsRequired = src.IsRequired, Options = src.Options, MinValue = src.MinValue,
            MaxValue = src.MaxValue, Unit = src.Unit, ToleranceMin = src.ToleranceMin,
            ToleranceMax = src.ToleranceMax, HelpText = src.HelpText
        };
        _customFields.Insert(idx + 1, copy);
    }

    private void MoveFieldUp(int idx)
    {
        if (idx <= 0) return;
        (_customFields[idx - 1], _customFields[idx]) = (_customFields[idx], _customFields[idx - 1]);
    }

    private void MoveFieldDown(int idx)
    {
        if (idx >= _customFields.Count - 1) return;
        (_customFields[idx], _customFields[idx + 1]) = (_customFields[idx + 1], _customFields[idx]);
    }

    // ── Layout Builder ──
    private void SetWidgetType(LayoutWidget w, ChangeEventArgs e) => w.Type = e.Value?.ToString() ?? "queue";
    private void SetWidgetTitle(LayoutWidget w, ChangeEventArgs e) => w.Title = e.Value?.ToString() ?? "";
    private void SetWidgetSize(LayoutWidget w, ChangeEventArgs e) => w.Size = e.Value?.ToString() ?? "full";
    private void ApplyManualTemplate() => ApplyTemplate("manual");
    private void ApplyMachineTemplate() => ApplyTemplate("machine");
    private void ApplyInspectionTemplate() => ApplyTemplate("inspection");
    private void ApplyMinimalTemplate() => ApplyTemplate("minimal");

    private void AddWidget() => _pageLayout.Widgets.Add(new LayoutWidget { Type = "queue", Title = "New Widget" });

    private void MoveWidgetUp(int idx)
    {
        if (idx <= 0) return;
        (_pageLayout.Widgets[idx - 1], _pageLayout.Widgets[idx]) = (_pageLayout.Widgets[idx], _pageLayout.Widgets[idx - 1]);
    }

    private void MoveWidgetDown(int idx)
    {
        if (idx >= _pageLayout.Widgets.Count - 1) return;
        (_pageLayout.Widgets[idx], _pageLayout.Widgets[idx + 1]) = (_pageLayout.Widgets[idx + 1], _pageLayout.Widgets[idx]);
    }

    private void ApplyTemplate(string template)
    {
        _pageLayout.Widgets = template switch
        {
            "manual" => new()
            {
                new() { Type = "work-instructions", Title = "Work Instructions", Size = "full" },
                new() { Type = "custom-form", Title = "Stage Data", Size = "full" },
                new() { Type = "checklist", Title = "Sign-Off", Size = "full" },
                new() { Type = "timer", Title = "Timer", Size = "medium" },
                new() { Type = "notes", Title = "Notes", Size = "medium" },
            },
            "machine" => new()
            {
                new() { Type = "machine-status", Title = "Machine Status", Size = "full" },
                new() { Type = "active-work", Title = "Active Work", Size = "full" },
                new() { Type = "custom-form", Title = "Stage Data", Size = "full" },
                new() { Type = "queue", Title = "Queue", Size = "full", CollapsedByDefault = true },
            },
            "inspection" => new()
            {
                new() { Type = "part-context", Title = "Part Info", Size = "full" },
                new() { Type = "custom-form", Title = "Inspection Form", Size = "full" },
                new() { Type = "checklist", Title = "Inspection Checklist", Size = "full" },
                new() { Type = "notes", Title = "Inspector Notes", Size = "full" },
            },
            "minimal" => new()
            {
                new() { Type = "queue", Title = "Queue", Size = "full" },
                new() { Type = "active-work", Title = "Active Work", Size = "full" },
            },
            _ => StagePageLayout.Default.Widgets
        };
    }

    private void UpdateFieldLabel(int idx, ChangeEventArgs e) =>
        _customFields[idx].Label = e.Value?.ToString() ?? string.Empty;

    private void UpdateFieldName(int idx, ChangeEventArgs e) =>
        _customFields[idx].Name = e.Value?.ToString() ?? string.Empty;

    private void UpdateFieldType(int idx, ChangeEventArgs e) =>
        _customFields[idx].FieldType = e.Value?.ToString() ?? "text";

    private void UpdateFieldRequired(int idx, ChangeEventArgs e) =>
        _customFields[idx].IsRequired = (bool)(e.Value ?? false);

    private void UpdateFieldOptions(int idx, ChangeEventArgs e) =>
        _customFields[idx].Options = e.Value?.ToString();

    private void UpdateFieldMin(int idx, ChangeEventArgs e) =>
        _customFields[idx].MinValue = double.TryParse(e.Value?.ToString(), out var v) ? v : null;

    private void UpdateFieldMax(int idx, ChangeEventArgs e) =>
        _customFields[idx].MaxValue = double.TryParse(e.Value?.ToString(), out var v) ? v : null;

    private async Task Save()
    {
        _error = null;
        try
        {
            _edit!.CustomFieldsConfig = JsonSerializer.Serialize(_customFields);
            _edit.SetUiConfig(_uiConfig);
            _edit.SetPageLayout(_pageLayout);
            _edit.AssignedMachineIds = _selectedMachineIds.Count > 0
                ? string.Join(",", _selectedMachineIds.Order())
                : null;
            if (_edit.Id == 0) await StageService.CreateStageAsync(_edit);
            else await StageService.UpdateStageAsync(_edit);
            _showForm = false;
            _stages = await StageService.GetAllStagesAsync(activeOnly: false);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void ToggleMachine(int machineId, bool isChecked)
    {
        if (isChecked) _selectedMachineIds.Add(machineId);
        else _selectedMachineIds.Remove(machineId);
    }

    private static string ResolveStageIcon(string? icon)
    {
        if (string.IsNullOrEmpty(icon)) return "⚙️";
        if (!icon.StartsWith("fas ") && !icon.StartsWith("far ") && !icon.StartsWith("fa-")) return icon;
        return icon switch
        {
            "fas fa-print"           => "🖨️",
            "fas fa-wind"            => "💨",
            "fas fa-fire"            => "🔥",
            "fas fa-bolt"            => "⚡",
            "fas fa-cog"             => "⚙️",
            "fas fa-pen-nib"         => "✒️",
            "fas fa-spray-can"       => "🎨",
            "fas fa-clipboard-check" => "✅",
            "fas fa-truck"           => "🚚",
            _                        => "⚙️"
        };
    }
}
