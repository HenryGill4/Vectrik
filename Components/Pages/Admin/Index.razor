@page "/admin"
@inject Vectrik.Data.TenantDbContext Db
@inject SetupReadinessService ReadinessService
@using Microsoft.EntityFrameworkCore

<PageTitle>Admin - Vectrik</PageTitle>

<div class="page-header"><h1 class="page-title">Admin Panel</h1></div>

@if (_checks != null)
{
    <div class="card setup-readiness" style="margin-bottom: 20px; padding: 16px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div style="font-weight: 600; font-size: 1rem;">Setup Readiness</div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 1.25rem; font-weight: 700; color: @(_score >= 75 ? "var(--success)" : _score >= 50 ? "var(--warning)" : "var(--danger)");">@_score%</span>
                <a href="/admin/setup" class="btn btn-sm btn-secondary">Setup Wizard</a>
            </div>
        </div>
        <div class="progress-bar-container" style="margin-bottom: 12px;">
            <div class="progress-bar-fill" style="width: @(_score)%; background: @(_score >= 75 ? "var(--success)" : _score >= 50 ? "var(--warning)" : "var(--danger)");"></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px;">
            @foreach (var check in _checks)
            {
                <a href="@check.Link" class="setup-check @(check.Passed ? "setup-check--pass" : "setup-check--fail")" style="text-decoration: none; color: inherit;">
                    <span class="setup-check-icon">@(check.Passed ? "\u2713" : "\u2717")</span>
                    <span class="setup-check-label">@check.Label</span>
                </a>
            }
        </div>
    </div>
}

<p style="color: var(--text-muted); margin-bottom: 16px;">System-level configuration. Parts, Stages, Materials, and Machines are now in the main navigation.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px;">
    <a href="/admin/users" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">👥</div>
        <div style="font-weight: 600;">Users</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">User management, roles, stage assignment</div>
    </a>
    <a href="/admin/operator-roles" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🎭</div>
        <div style="font-weight: 600;">Operator Roles</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Role definitions, user-role assignments</div>
    </a>
    <a href="/admin/shifts" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🕐</div>
        <div style="font-weight: 600;">Shifts</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Shift schedules, machine & operator assignments</div>
    </a>
    <a href="/admin/operation-costs" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">💲</div>
        <div style="font-weight: 600;">Operation Costs</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">True cost per stage — labor, equipment, overhead, external</div>
    </a>
    <a href="/analytics/profit" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">💰</div>
        <div style="font-weight: 600;">Profit Dashboard</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Revenue, costs, margins — profit tracking by part, customer, trend</div>
    </a>
    <a href="/admin/workflows" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🔄</div>
        <div style="font-weight: 600;">Workflows</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Approval chains for WO release, quotes, NCRs</div>
    </a>
    <a href="/admin/work-instructions" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">📋</div>
        <div style="font-weight: 600;">Work Instructions</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Stage-level instructions, feedback review</div>
    </a>
    <a href="/admin/settings" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">⚙️</div>
        <div style="font-weight: 600;">Settings</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">System settings, branding, debug</div>
    </a>
    <a href="/admin/features" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🎛️</div>
        <div style="font-weight: 600;">Feature Flags</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Enable/disable modules and features</div>
    </a>
    <a href="/admin/custom-fields" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🧩</div>
        <div style="font-weight: 600;">Custom Fields</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Define custom fields for Parts, Work Orders</div>
    </a>
    <a href="/admin/numbering" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🔢</div>
        <div style="font-weight: 600;">Numbering</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Auto-numbering sequences</div>
    </a>
    <a href="/admin/branding" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🏷️</div>
        <div style="font-weight: 600;">Branding</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Logo, colors, company name</div>
    </a>
    <a href="/admin/dispatch-config" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">📡</div>
        <div style="font-weight: 600;">Dispatch Configuration</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Scoring weights, auto-dispatch, machine configs</div>
    </a>
    <a href="/admin/debug" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🛠️</div>
        <div style="font-weight: 600;">Debug Tools</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Diagnostics, data seeding, cache</div>
    </a>
    <a href="/admin/issues" class="card" style="text-decoration: none; color: inherit;">
        <div style="font-size: 2rem; margin-bottom: 8px;">🎯</div>
        <div style="font-weight: 600;">Issue Tracker</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">Track bugs, changes, styling — one at a time</div>
    </a>
</div>

@code {
    private List<ReadinessCheck>? _checks;
    private int _score;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _checks = await ReadinessService.GetChecksAsync(Db);
            _score = ReadinessService.CalculateScore(_checks);
        }
        catch { /* Readiness section is non-critical */ }
    }
}
