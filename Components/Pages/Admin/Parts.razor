@page "/admin/parts"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Manager")]
@inject IPartService PartService
@inject IStageService StageService
@inject ToastService Toast

<PageTitle>Parts - Admin - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Parts</h1>
    <button class="btn btn-primary" @onclick="NewPart">+ New Part</button>
</div>

@if (_parts == null)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (!_parts.Any())
{
    <div class="empty-state">
        <div class="empty-state-text">No parts configured yet. Click "+ New Part" to add your first part.</div>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>Part #</th><th>Name</th><th>Material</th><th>Stacking</th><th>Stages</th><th>Active</th><th></th></tr></thead>
            <tbody>
                @foreach (var p in _parts)
                {
                    <tr>
                        <td>@p.PartNumber</td>
                        <td>@p.Name</td>
                        <td>@p.Material</td>
                        <td>@(p.AllowStacking ? $"1x-{p.MaxStackCount}x" : "No")</td>
                        <td>@(p.StageRequirements?.Count ?? 0)</td>
                        <td><span class="badge @(p.IsActive ? "badge-active" : "badge-cancelled")">@(p.IsActive ? "Yes" : "No")</span></td>
                        <td><button class="btn btn-sm btn-secondary" @onclick="() => Edit(p)">Edit</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showForm && _editPart != null)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" style="max-width: 800px; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">@(_editPart.Id == 0 ? "New Part" : "Edit Part")</span><button class="modal-close" @onclick="() => _showForm = false">&times;</button></div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }

            <div class="tab-bar" style="margin-bottom: 16px;">
                <button class="tab @(_tab == "basic" ? "active" : "")" @onclick='() => _tab = "basic"'>Basic Info</button>
                <button class="tab @(_tab == "stacking" ? "active" : "")" @onclick='() => _tab = "stacking"'>Stacking</button>
                <button class="tab @(_tab == "batch" ? "active" : "")" @onclick='() => _tab = "batch"'>Batch Durations</button>
                @if (_editPart.Id > 0)
                {
                    <button class="tab @(_tab == "stages" ? "active" : "")" @onclick='() => _tab = "stages"'>Stage Requirements (@(_stageReqs?.Count ?? 0))</button>
                }
            </div>

            @if (_tab == "basic")
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group">
                        <label class="form-label">Part Number <span style="color:var(--danger);">*</span></label>
                        <input class="form-control @(_validationErrors.ContainsKey("PartNumber") ? "is-invalid" : "")" @bind="_editPart.PartNumber" />
                        @if (_validationErrors.ContainsKey("PartNumber")) { <small style="color:var(--danger);">@_validationErrors["PartNumber"]</small> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Name <span style="color:var(--danger);">*</span></label>
                        <input class="form-control @(_validationErrors.ContainsKey("Name") ? "is-invalid" : "")" @bind="_editPart.Name" />
                        @if (_validationErrors.ContainsKey("Name")) { <small style="color:var(--danger);">@_validationErrors["Name"]</small> }
                    </div>
                    <div class="form-group" style="grid-column: span 2;"><label class="form-label">Description</label><input class="form-control" @bind="_editPart.Description" /></div>
                    <div class="form-group"><label class="form-label">Material</label><input class="form-control" @bind="_editPart.Material" /></div>
                    <div class="form-group"><label class="form-label">Approach</label><input class="form-control" @bind="_editPart.ManufacturingApproach" /></div>
                    <div class="form-group">
                        <label class="form-label"><input type="checkbox" @bind="_editPart.IsActive" style="margin-right: 6px;" />Active</label>
                    </div>
                </div>
            }

            @if (_tab == "stacking")
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group">
                        <label class="form-label"><input type="checkbox" @bind="_editPart.AllowStacking" style="margin-right: 6px;" />Allow Stacking</label>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Max Stack Count</label>
                        <input class="form-control" type="number" min="1" max="10" @bind="_editPart.MaxStackCount" />
                    </div>
                    <div class="form-group"><label class="form-label">Parts/Build (Single)</label><input class="form-control" type="number" min="1" @bind="_editPart.PartsPerBuildSingle" /></div>
                    <div class="form-group"><label class="form-label">Single Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.SingleStackDurationHours" /></div>

                    <div class="form-group" style="grid-column: span 2;">
                        <label class="form-label"><input type="checkbox" @bind="_editPart.EnableDoubleStack" style="margin-right: 6px;" />Enable Double Stack</label>
                    </div>
                    @if (_editPart.EnableDoubleStack)
                    {
                        <div class="form-group"><label class="form-label">Parts/Build (Double)</label><input class="form-control" type="number" min="1" @bind="_editPart.PartsPerBuildDouble" /></div>
                        <div class="form-group"><label class="form-label">Double Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.DoubleStackDurationHours" /></div>
                    }

                    <div class="form-group" style="grid-column: span 2;">
                        <label class="form-label"><input type="checkbox" @bind="_editPart.EnableTripleStack" style="margin-right: 6px;" />Enable Triple Stack</label>
                    </div>
                    @if (_editPart.EnableTripleStack)
                    {
                        <div class="form-group"><label class="form-label">Parts/Build (Triple)</label><input class="form-control" type="number" min="1" @bind="_editPart.PartsPerBuildTriple" /></div>
                        <div class="form-group"><label class="form-label">Triple Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.TripleStackDurationHours" /></div>
                    }
                </div>
            }

            @if (_tab == "batch")
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group"><label class="form-label">SLS Build Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.SlsBuildDurationHours" /></div>
                    <div class="form-group"><label class="form-label">SLS Parts/Build</label><input class="form-control" type="number" min="0" @bind="_editPart.SlsPartsPerBuild" /></div>
                    <div class="form-group"><label class="form-label">Depowdering Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.DepowderingDurationHours" /></div>
                    <div class="form-group"><label class="form-label">Depowdering Parts/Batch</label><input class="form-control" type="number" min="0" @bind="_editPart.DepowderingPartsPerBatch" /></div>
                    <div class="form-group"><label class="form-label">Heat Treatment Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.HeatTreatmentDurationHours" /></div>
                    <div class="form-group"><label class="form-label">Heat Treatment Parts/Batch</label><input class="form-control" type="number" min="0" @bind="_editPart.HeatTreatmentPartsPerBatch" /></div>
                    <div class="form-group"><label class="form-label">Wire EDM Duration (hrs)</label><input class="form-control" type="number" step="0.1" min="0" @bind="_editPart.WireEdmDurationHours" /></div>
                    <div class="form-group"><label class="form-label">Wire EDM Parts/Session</label><input class="form-control" type="number" min="0" @bind="_editPart.WireEdmPartsPerSession" /></div>
                </div>
            }

            @if (_tab == "stages" && _editPart.Id > 0)
            {
                <div style="margin-bottom: 12px; display: flex; gap: 8px; align-items: center;">
                    <select class="form-control" style="width: auto;" @bind="_addStageId">
                        <option value="0">Add stage...</option>
                        @if (_allStages != null)
                        {
                            @foreach (var s in _allStages.Where(s => _stageReqs?.All(r => r.ProductionStageId != s.Id) ?? true))
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        }
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="AddStageReq" disabled="@(_addStageId == 0)">Add</button>
                </div>

                @if (_stageReqs != null && _stageReqs.Any())
                {
                    <table class="data-table">
                        <thead><tr><th>Order</th><th>Stage</th><th>Est. Hours</th><th>Required</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var r in _stageReqs.OrderBy(r => r.ExecutionOrder))
                            {
                                <tr>
                                    <td><input class="form-control" type="number" min="1" style="width: 70px;" value="@r.ExecutionOrder" @onchange="e => UpdateReqOrder(r, e)" /></td>
                                    <td>@(r.ProductionStage?.Name ?? $"Stage #{r.ProductionStageId}")</td>
                                    <td><input class="form-control" type="number" step="0.1" min="0" style="width: 100px;" value="@r.EstimatedHours" @onchange="e => UpdateReqHours(r, e)" /></td>
                                    <td><input type="checkbox" checked="@r.IsRequired" @onchange="e => UpdateReqRequired(r, e)" /></td>
                                    <td><button class="btn btn-sm btn-danger" @onclick="() => ConfirmRemoveStage(r)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state"><div class="empty-state-text">No stages assigned. Add stages above.</div></div>
                }
            }

            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    private List<Part>? _parts;
    private List<ProductionStage>? _allStages;
    private List<PartStageRequirement>? _stageReqs;
    private Part? _editPart;
    private bool _showForm, _saving;
    private string? _error;
    private string _tab = "basic";
    private int _addStageId;
    private Dictionary<string, string> _validationErrors = new();
    private ConfirmDialog _confirm = null!;

    protected override async Task OnInitializedAsync()
    {
        _parts = await PartService.GetAllPartsAsync(activeOnly: false);
        _allStages = await StageService.GetAllStagesAsync();
    }

    private async Task Edit(Part p)
    {
        _editPart = p;
        _tab = "basic";
        _error = null;
        _validationErrors.Clear();
        _stageReqs = await PartService.GetStageRequirementsAsync(p.Id);
        _showForm = true;
    }

    private void NewPart()
    {
        _editPart = new Part
        {
            Material = "Ti-6Al-4V Grade 5",
            ManufacturingApproach = "SLS-Based",
            PartsPerBuildSingle = 1,
            MaxStackCount = 1,
            RequiredStages = "[]",
            CreatedBy = "System",
            LastModifiedBy = "System"
        };
        _tab = "basic";
        _stageReqs = null;
        _error = null;
        _validationErrors.Clear();
        _showForm = true;
    }

    private bool Validate()
    {
        _validationErrors.Clear();
        if (string.IsNullOrWhiteSpace(_editPart!.PartNumber))
            _validationErrors["PartNumber"] = "Part Number is required.";
        if (string.IsNullOrWhiteSpace(_editPart.Name))
            _validationErrors["Name"] = "Name is required.";
        return _validationErrors.Count == 0;
    }

    private async Task Save()
    {
        _error = null;
        if (!Validate()) return;

        _saving = true;
        try
        {
            if (_editPart!.Id == 0)
            {
                _editPart = await PartService.CreatePartAsync(_editPart);
                Toast.ShowSuccess($"Part '{_editPart.PartNumber}' created.");
            }
            else
            {
                await PartService.UpdatePartAsync(_editPart);
                Toast.ShowSuccess($"Part '{_editPart.PartNumber}' updated.");
            }
            _showForm = false;
            _parts = await PartService.GetAllPartsAsync(activeOnly: false);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task AddStageReq()
    {
        if (_addStageId == 0 || _editPart?.Id == 0) return;
        try
        {
            var nextOrder = (_stageReqs?.Any() == true) ? _stageReqs.Max(r => r.ExecutionOrder) + 1 : 1;
            var stage = _allStages?.FirstOrDefault(s => s.Id == _addStageId);
            await PartService.AddStageRequirementAsync(new PartStageRequirement
            {
                PartId = _editPart!.Id,
                ProductionStageId = _addStageId,
                ExecutionOrder = nextOrder,
                EstimatedHours = stage?.DefaultDurationHours ?? 1.0,
                CreatedBy = "System",
                LastModifiedBy = "System"
            });
            _stageReqs = await PartService.GetStageRequirementsAsync(_editPart.Id);
            _addStageId = 0;
            Toast.ShowSuccess("Stage added to routing.");
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    private async Task ConfirmRemoveStage(PartStageRequirement r)
    {
        var stageName = r.ProductionStage?.Name ?? $"Stage #{r.ProductionStageId}";
        if (await _confirm.ShowAsync($"Remove '{stageName}' from routing?", "Remove Stage"))
        {
            await PartService.RemoveStageRequirementAsync(r.Id);
            _stageReqs = await PartService.GetStageRequirementsAsync(_editPart!.Id);
        }
    }

    private async Task UpdateReqOrder(PartStageRequirement r, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val >= 1)
        {
            r.ExecutionOrder = val;
            await PartService.UpdateStageRequirementAsync(r);
        }
    }

    private async Task UpdateReqHours(PartStageRequirement r, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val) && val >= 0)
        {
            r.EstimatedHours = val;
            await PartService.UpdateStageRequirementAsync(r);
        }
    }

    private async Task UpdateReqRequired(PartStageRequirement r, ChangeEventArgs e)
    {
        r.IsRequired = (bool)(e.Value ?? true);
        await PartService.UpdateStageRequirementAsync(r);
    }
}
