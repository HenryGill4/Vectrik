@page "/admin/parts"
@inject IPartService PartService
@rendermode InteractiveServer

<PageTitle>Parts - Admin - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Parts</h1>
    <button class="btn btn-primary" @onclick="NewPart">+ New Part</button>
</div>

@if (_parts == null) { <div class="loading"><span class="spinner"></span></div> }
else
{
    <div class="card">
        <table class="data-table">
            <thead><tr><th>Part #</th><th>Name</th><th>Material</th><th>Stacking</th><th>Active</th><th></th></tr></thead>
            <tbody>
                @foreach (var p in _parts)
                {
                    <tr>
                        <td>@p.PartNumber</td>
                        <td>@p.Name</td>
                        <td>@p.Material</td>
                        <td>@(p.AllowStacking ? $"1x-{p.MaxStackCount}x" : "No")</td>
                        <td><span class="badge @(p.IsActive ? "badge-active" : "badge-cancelled")">@(p.IsActive ? "Yes" : "No")</span></td>
                        <td><button class="btn btn-sm btn-secondary" @onclick="() => Edit(p)">Edit</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showForm && _editPart != null)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" style="max-width: 700px;" @onclick:stopPropagation>
            <div class="modal-header"><span class="modal-title">@(_editPart.Id == 0 ? "New Part" : "Edit Part")</span><button class="modal-close" @onclick="() => _showForm = false">&times;</button></div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group"><label class="form-label">Part Number</label><input class="form-control" @bind="_editPart.PartNumber" /></div>
                <div class="form-group"><label class="form-label">Name</label><input class="form-control" @bind="_editPart.Name" /></div>
                <div class="form-group" style="grid-column: span 2;"><label class="form-label">Description</label><input class="form-control" @bind="_editPart.Description" /></div>
                <div class="form-group"><label class="form-label">Material</label><input class="form-control" @bind="_editPart.Material" /></div>
                <div class="form-group"><label class="form-label">Approach</label><input class="form-control" @bind="_editPart.ManufacturingApproach" /></div>
            </div>
            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save">Save</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Part>? _parts;
    private Part? _editPart;
    private bool _showForm;
    private string? _error;

    protected override async Task OnInitializedAsync() => _parts = await PartService.GetAllPartsAsync();

    private void Edit(Part p) { _editPart = p; _showForm = true; }

    private void NewPart()
    {
        _editPart = new Part
        {
            Material = "Ti-6Al-4V Grade 5",
            ManufacturingApproach = "SLS-Based",
            PartsPerBuildSingle = 1,
            MaxStackCount = 1,
            RequiredStages = "[]",
            CreatedBy = "System",
            LastModifiedBy = "System"
        };
        _showForm = true;
    }

    private async Task Save()
    {
        _error = null;
        try
        {
            if (_editPart!.Id == 0) await PartService.CreatePartAsync(_editPart);
            else await PartService.UpdatePartAsync(_editPart);
            _showForm = false;
            _parts = await PartService.GetAllPartsAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
