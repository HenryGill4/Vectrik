@page "/admin/branding"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject Vectrik.Data.TenantDbContext Db
@inject ToastService Toast
@inject ITenantContext TenantContext
@inject IWebHostEnvironment Env
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.RegularExpressions
@using Vectrik.Components.Shared

<PageTitle>Company Branding - Admin - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Company Branding & Identity</h1>
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else
{
    <div class="card">
        <div class="card-header">Company Information</div>
        <div style="padding: 16px;">
            <div class="form-group">
                <label class="form-label">Company Name</label>
                <input class="form-control" @bind="_companyName" />
            </div>
            <div class="form-group">
                <label class="form-label">Address</label>
                <textarea class="form-control" rows="3" @bind="_companyAddress"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Company Logo</label>
                @if (!string.IsNullOrWhiteSpace(_logoUrl))
                {
                    <div class="branding-logo-preview">
                        <img src="@_logoUrl" alt="Company Logo" onerror="this.style.display='none'" />
                        <button class="btn btn-sm btn-danger" @onclick="RemoveLogo" title="Remove logo">Remove</button>
                    </div>
                }
                <div class="file-upload-zone" style="margin-top: 8px;">
                    <InputFile OnChange="OnLogoFileSelected" accept=".jpg,.jpeg,.png,.gif,.webp,.svg" />
                    <div class="file-upload-label">
                        @if (_uploadingLogo)
                        {
                            <span class="spinner" style="width: 16px; height: 16px;"></span> <span>Uploading...</span>
                        }
                        else
                        {
                            <span>Drop logo here or click to browse</span>
                            <small style="display: block; color: var(--text-muted); margin-top: 4px;">JPG, PNG, GIF, WebP, or SVG (max 5MB) — images open editor for crop/rotate</small>
                        }
                    </div>
                </div>

                <ImageEditor @ref="_imageEditor"
                             Visible="_showImageEditor"
                             FileName="@_editorFileName"
                             OnSave="OnEditorSave"
                             OnCancel="OnEditorCancel" />
                <details style="margin-top: 6px;">
                    <summary style="font-size: 0.8rem; color: var(--text-muted); cursor: pointer;">Or enter URL manually</summary>
                    <input class="form-control" style="margin-top: 4px;" @bind="_logoUrl" placeholder="/uploads/branding/logo.png" />
                </details>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top: 12px;">
        <div class="card-header">Navigation Icon Color</div>
        <div style="padding: 16px;">
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 12px;">
                Customize the color of sidebar navigation icons. Leave blank to use the default theme accent color.
            </p>
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                <input type="color" @bind="_navIconColor" style="width: 44px; height: 44px; padding: 2px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-tertiary); cursor: pointer;" />
                <input class="form-control" style="max-width: 140px;" @bind="_navIconColor" placeholder="#3B82F6" />
                <button class="btn btn-sm btn-secondary" @onclick="ResetIconColor">Reset to Default</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(_navIconColor))
            {
                <div style="margin-top: 12px; display: flex; align-items: center; gap: 12px;">
                    <span style="color: var(--text-muted); font-size: 0.85rem;">Preview:</span>
                    <svg viewBox="0 0 24 24" style="width:20px;height:20px;stroke:@_navIconColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;">
                        <rect x="3" y="3" width="7" height="7" rx="1" />
                        <rect x="14" y="3" width="7" height="4" rx="1" />
                        <rect x="3" y="14" width="7" height="7" rx="1" />
                        <rect x="14" y="11" width="7" height="10" rx="1" />
                    </svg>
                    <svg viewBox="0 0 24 24" style="width:20px;height:20px;stroke:@_navIconColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;">
                        <rect x="3" y="4" width="18" height="17" rx="2" /><line x1="3" y1="10" x2="21" y2="10" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="16" y1="2" x2="16" y2="6" />
                    </svg>
                    <svg viewBox="0 0 24 24" style="width:20px;height:20px;stroke:@_navIconColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;">
                        <circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="21" y2="21" />
                    </svg>
                </div>
            }
        </div>
    </div>

    <div class="card" style="margin-top: 12px;">
        <div class="card-header">Defense / Government Identifiers</div>
        <div style="padding: 16px;">
            <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label class="form-label">CAGE Code</label>
                    <input class="form-control @(_validationErrors.ContainsKey("cage") ? "is-invalid" : "")"
                           @bind="_cageCode" maxlength="5" placeholder="5 alphanumeric characters" />
                    @if (_validationErrors.ContainsKey("cage")) { <small style="color:var(--danger);">@_validationErrors["cage"]</small> }
                </div>
                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label class="form-label">DoDAAC</label>
                    <input class="form-control @(_validationErrors.ContainsKey("dodaac") ? "is-invalid" : "")"
                           @bind="_dodaac" maxlength="6" placeholder="6 characters" />
                    @if (_validationErrors.ContainsKey("dodaac")) { <small style="color:var(--danger);">@_validationErrors["dodaac"]</small> }
                </div>
                <div class="form-group" style="flex: 1; min-width: 200px;">
                    <label class="form-label">DUNS / SAM UEI</label>
                    <input class="form-control @(_validationErrors.ContainsKey("duns") ? "is-invalid" : "")"
                           @bind="_duns" placeholder="Unique Entity Identifier" />
                    @if (_validationErrors.ContainsKey("duns")) { <small style="color:var(--danger);">@_validationErrors["duns"]</small> }
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top: 16px;">
        <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
    </div>
}

@code {
    private bool _loading = true, _saving, _uploadingLogo;
    private string _companyName = "";
    private string _companyAddress = "";
    private string _logoUrl = "";
    private string _navIconColor = "";
    private string _cageCode = "";
    private string _dodaac = "";
    private string _duns = "";
    private Dictionary<string, string> _validationErrors = new();

    // Image editor
    private ImageEditor? _imageEditor;
    private bool _showImageEditor;
    private string? _editorFileName;
    private IBrowserFile? _pendingLogoFile;

    private static readonly HashSet<string> AllowedLogoExts = [".jpg", ".jpeg", ".png", ".gif", ".webp", ".svg"];
    private const long MaxLogoSizeBytes = 5 * 1024 * 1024; // 5MB

    protected override async Task OnInitializedAsync()
    {
        var settings = await Db.SystemSettings
            .Where(s => s.Category == "Branding" || s.Category == "Defense")
            .ToListAsync();

        _companyName = settings.FirstOrDefault(s => s.Key == "company.name")?.Value ?? "";
        _companyAddress = settings.FirstOrDefault(s => s.Key == "company.address")?.Value ?? "";
        _logoUrl = settings.FirstOrDefault(s => s.Key == "company.logo_url")?.Value ?? "";
        _navIconColor = settings.FirstOrDefault(s => s.Key == "branding.nav_icon_color")?.Value ?? "";
        _cageCode = settings.FirstOrDefault(s => s.Key == "company.cage_code")?.Value ?? "";
        _dodaac = settings.FirstOrDefault(s => s.Key == "company.dodaac")?.Value ?? "";
        _duns = settings.FirstOrDefault(s => s.Key == "company.duns")?.Value ?? "";
        _loading = false;
    }

    private bool Validate()
    {
        _validationErrors.Clear();
        if (!string.IsNullOrWhiteSpace(_cageCode) && !Regex.IsMatch(_cageCode, @"^[A-Z0-9]{5}$"))
            _validationErrors["cage"] = "CAGE code must be exactly 5 alphanumeric characters (uppercase).";
        if (!string.IsNullOrWhiteSpace(_dodaac) && !Regex.IsMatch(_dodaac, @"^[A-Z0-9]{6}$"))
            _validationErrors["dodaac"] = "DoDAAC must be exactly 6 alphanumeric characters.";
        if (!string.IsNullOrWhiteSpace(_duns) && !Regex.IsMatch(_duns, @"^\d{9,13}$"))
            _validationErrors["duns"] = "DUNS/UEI should be 9-13 digits.";
        return _validationErrors.Count == 0;
    }

    private async Task Save()
    {
        if (!Validate()) return;

        _saving = true;
        try
        {
            await UpsertSetting("company.name", _companyName, "Branding", "Company name on all documents");
            await UpsertSetting("company.address", _companyAddress, "Branding", "Address for documents");
            await UpsertSetting("company.logo_url", _logoUrl, "Branding", "Logo for reports/packing lists");
            await UpsertSetting("branding.nav_icon_color", _navIconColor.Trim(), "Branding", "Custom sidebar nav icon color");
            await UpsertSetting("company.cage_code", _cageCode.ToUpperInvariant(), "Defense", "CAGE code for DLMS transactions");
            await UpsertSetting("company.dodaac", _dodaac.ToUpperInvariant(), "Defense", "DoD Activity Address Code");
            await UpsertSetting("company.duns", _duns, "Defense", "DUNS/SAM UEI number");

            await Db.SaveChangesAsync();
            Toast.ShowSuccess("Branding saved.");
        }
        catch (Exception ex) { Toast.ShowError($"Save failed: {ex.Message}"); }
        finally { _saving = false; }
    }

    private async Task OnLogoFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!AllowedLogoExts.Contains(ext))
        {
            Toast.ShowError("Invalid file type. Use JPG, PNG, GIF, WebP, or SVG.");
            return;
        }
        if (file.Size > MaxLogoSizeBytes)
        {
            Toast.ShowError("File too large. Maximum 5MB.");
            return;
        }

        // SVGs can't be canvas-edited, upload directly
        if (ext == ".svg")
        {
            await UploadLogoBytes(file.Name, file.OpenReadStream(MaxLogoSizeBytes));
            return;
        }

        // Open image editor for raster images
        _pendingLogoFile = file;
        _editorFileName = file.Name;
        _showImageEditor = true;
        StateHasChanged();

        if (_imageEditor != null)
            await _imageEditor.LoadImageAsync(file);
    }

    private async Task OnEditorSave(ImageEditor.ImageEditorResult result)
    {
        _showImageEditor = false;
        using var ms = new MemoryStream(result.ImageData);
        await UploadLogoBytes(result.FileName, ms);
    }

    private void OnEditorCancel()
    {
        _showImageEditor = false;
        _pendingLogoFile = null;
    }

    private async Task UploadLogoBytes(string fileName, Stream dataStream)
    {
        _uploadingLogo = true;
        try
        {
            var ext = Path.GetExtension(fileName).ToLowerInvariant();
            var tenantCode = TenantContext.TenantCode;
            var uploadDir = Path.Combine(Env.WebRootPath, "uploads", "branding", tenantCode);
            Directory.CreateDirectory(uploadDir);

            var safeFileName = $"{Guid.NewGuid()}{ext}";
            var filePath = Path.Combine(uploadDir, safeFileName);
            var relativeUrl = $"/uploads/branding/{tenantCode}/{safeFileName}";

            await using var stream = new FileStream(filePath, FileMode.Create);
            await dataStream.CopyToAsync(stream);

            DeleteOldLogoFile();

            _logoUrl = relativeUrl;
            Toast.ShowSuccess("Logo uploaded.");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Upload failed: {ex.Message}");
        }
        finally
        {
            _uploadingLogo = false;
            _pendingLogoFile = null;
        }
    }

    private void RemoveLogo()
    {
        DeleteOldLogoFile();
        _logoUrl = "";
    }

    private void DeleteOldLogoFile()
    {
        if (string.IsNullOrWhiteSpace(_logoUrl) || !_logoUrl.StartsWith("/uploads/"))
            return;
        var fullPath = Path.Combine(Env.WebRootPath, _logoUrl.TrimStart('/'));
        if (File.Exists(fullPath))
            File.Delete(fullPath);
    }

    private void ResetIconColor() => _navIconColor = "";

    private async Task UpsertSetting(string key, string value, string category, string description)
    {
        var setting = await Db.SystemSettings.FirstOrDefaultAsync(s => s.Key == key);
        if (setting == null)
        {
            Db.SystemSettings.Add(new SystemSetting
            {
                Key = key,
                Value = value,
                Category = category,
                Description = description,
                LastModifiedBy = "Admin"
            });
        }
        else
        {
            setting.Value = value;
            setting.LastModifiedDate = DateTime.UtcNow;
            setting.LastModifiedBy = "Admin";
        }
    }
}
