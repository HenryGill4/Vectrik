@page "/parts/new"
@page "/parts/{Id:int}/edit"
@inject IPartService PartService
@inject IStageService StageService
@inject IMaterialService MaterialService
@inject IManufacturingApproachService ApproachService
@inject ICustomFieldService CustomFieldService
@inject ITenantFeatureService Features
@inject IMachineService MachineService
@inject IBuildPlanningService BuildPlanningService
@inject IInventoryService InventoryService
@inject NavigationManager Nav
@inject ToastService Toast
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@(_isNew ? "New Part" : $"Edit {_part?.PartNumber}") - OpCentrix</PageTitle>

<AuthorizeView>
    <Authorized>
        @{
            _currentUser = context.User.FindFirst("FullName")?.Value
                ?? context.User.FindFirst(ClaimTypes.Name)?.Value
                ?? "System";
        }

        @if (_loading)
        {
            <div class="loading"><span class="spinner"></span> Loading...</div>
        }
        else if (!_isNew && _part == null)
        {
            <div class="card" style="text-align: center; padding: 40px;">
                <p style="color: var(--text-muted);">Part not found.</p>
                <button class="btn btn-secondary" @onclick="GoBack">← Back to Parts</button>
            </div>
        }
        else
        {
            <div class="page-header">
                <div>
                    <button class="btn btn-sm btn-secondary" @onclick="GoBack" style="margin-bottom: 8px;">← Parts</button>
                    <h1 class="page-title">@(_isNew ? "New Part" : $"Edit {_part!.PartNumber} — {_part.Name}")</h1>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">@_error</div>
            }

            @if (_validationErrors.Count > 0)
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">
                    <strong>Please fix the following:</strong>
                    <ul style="margin: 8px 0 0 16px;">
                        @foreach (var err in _validationErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }

            <!-- Tab Bar -->
            <div class="tab-bar" style="margin-bottom: 16px;">
                <button class="tab @(_tab == "info" ? "active" : "")" @onclick='() => _tab = "info"'>Part Info</button>
                <button class="tab @(_tab == "pdm" ? "active" : "")" @onclick='() => _tab = "pdm"'>Drawing & Revision</button>
                <button class="tab @(_tab == "routing" ? "active" : "")" @onclick='() => _tab = "routing"'>Routing (@(_stageReqs?.Count ?? 0))</button>
                <button class="tab @(_tab == "bom" ? "active" : "")" @onclick='() => _tab = "bom"'>BOM / Materials (@(_bomItems?.Count ?? 0))</button>
                @if (ShowAdditiveTabs)
                {
                    <button class="tab @(_tab == "stacking" ? "active" : "")" @onclick='() => _tab = "stacking"'>Stacking</button>
                }
                @if (_showDlms)
                {
                    <button class="tab @(_tab == "defense" ? "active" : "")" @onclick='() => _tab = "defense"'>Defense / DLMS</button>
                }
                @if (_customFieldDefs.Count > 0)
                {
                    <button class="tab @(_tab == "custom" ? "active" : "")" @onclick='() => _tab = "custom"'>Custom Fields</button>
                }
            </div>

            <!-- Part Info Tab -->
            @if (_tab == "info")
            {
                <div class="card">
                    <h3 class="card-title">Basic Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label">Part Number <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.PartNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Name <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.Name" />
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="_part!.Description" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Material <span style="color:var(--danger)">*</span></label>
                            <select class="form-control" value="@_part!.Material" @onchange="OnMaterialChanged">
                                <option value="">Select material...</option>
                                @if (_materials != null)
                                {
                                    @foreach (var m in _materials)
                                    {
                                        <option value="@m.Name">@m.Name (@m.Category)</option>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(_part.Material) && _materials?.All(m => m.Name != _part.Material) == true)
                                {
                                    <option value="@_part.Material">@_part.Material (custom)</option>
                                }
                            </select>
                            <small style="color: var(--text-muted);">Or type a custom value below:</small>
                            <input class="form-control" @bind="_part!.Material" style="margin-top: 4px;" placeholder="Custom material name..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Manufacturing Approach</label>
                            <select class="form-control" value="@_part!.ManufacturingApproachId" @onchange="OnApproachChanged">
                                <option value="">Select approach...</option>
                                @foreach (var a in _approaches)
                                {
                                    <option value="@a.Id">@(a.IconEmoji) @a.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Raw Material Spec</label>
                            <input class="form-control" @bind="_part!.RawMaterialSpec" placeholder="e.g. AMS 4911" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Estimated Weight (kg)</label>
                            <input class="form-control" type="number" step="0.01" @bind="_part!.EstimatedWeightKg" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                <input type="checkbox" @bind="_part!.IsActive" style="margin-right: 6px;" />Active
                            </label>
                        </div>
                    </div>
                </div>
            }

            <!-- PDM / Drawing Tab -->
            @if (_tab == "pdm")
            {
                <div class="card">
                    <h3 class="card-title">Drawing & Revision Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label">Drawing Number</label>
                            <input class="form-control" @bind="_part!.DrawingNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Current Revision</label>
                            <input class="form-control" @bind="_part!.Revision" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Customer Part Number</label>
                            <input class="form-control" @bind="_part!.CustomerPartNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Revision Date</label>
                            <input class="form-control" type="date" @bind="_part!.RevisionDate" />
                        </div>
                    </div>
                    @if (!_isNew)
                    {
                        <p style="color: var(--text-muted); margin-top: 12px; font-size: 0.85rem;">
                            To formally bump the revision (with history tracking), use the "Bump Revision" button on the Part Detail page.
                            Drawings can be uploaded from the Part Detail → Drawings tab.
                        </p>
                    }
                </div>
            }

            <!-- Routing / Stage Requirements Tab -->
            @if (_tab == "routing")
            {
                <div class="card">
                    <h3 class="card-title">Stage Routing</h3>
                    <p style="color: var(--text-muted); margin-bottom: 12px;">
                        Define the production stages this part goes through. 
                        @if (SelectedApproach?.RequiresBuildPlate == true)
                        {
                            <span>Build-level stages run once for the entire build plate; per-part stages run after plate release.</span>
                        }
                    </p>

                    <div style="margin-bottom: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                        <select class="form-control" style="width: auto;" @bind="_addStageId">
                            <option value="0">Add stage...</option>
                            @if (_allStages != null)
                            {
                                @foreach (var s in _allStages.Where(s => _stageReqs?.All(r => r.ProductionStageId != s.Id) ?? true))
                                {
                                    <option value="@s.Id">@(s.IsBuildLevelStage ? "🔷 " : "")@s.Name (@(s.Department ?? "—"))</option>
                                }
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="AddStageReq" disabled="@(_addStageId == 0)">+ Add Stage</button>
                        @if (SelectedApproach != null && !string.IsNullOrWhiteSpace(SelectedApproach.DefaultRoutingTemplate) && SelectedApproach.DefaultRoutingTemplate != "[]")
                        {
                            <button class="btn btn-sm btn-secondary" @onclick="() => ApplyRoutingTemplateAsync()" title="Apply default routing from the selected manufacturing approach">
                                🛤️ Apply Template
                            </button>
                        }
                    </div>

                    @if (_stageReqs != null && _stageReqs.Any())
                    {
                        @* Build-Level Stages Section (only show if approach requires build plate) *@
                        @if (SelectedApproach?.RequiresBuildPlate == true)
                        {
                            var buildLevelReqs = _stageReqs.Where(r => r.ProductionStage?.IsBuildLevelStage == true).OrderBy(r => r.ExecutionOrder).ToList();
                            if (buildLevelReqs.Any())
                            {
                                <div style="margin-bottom: 20px;">
                                    <h4 style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                                        <span style="background: var(--accent); color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem;">BUILD</span>
                                        Build-Level Stages
                                        <span style="font-weight: normal; color: var(--text-muted);">— Shared across all parts on the plate</span>
                                    </h4>
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Order</th>
                                                <th>Stage</th>
                                                <th>Department</th>
                                                <th>Est. Hours</th>
                                                <th>Machine</th>
                                                <th>Required</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var r in buildLevelReqs)
                                            {
                                                var slug = r.ProductionStage?.StageSlug?.ToLowerInvariant() ?? "";
                                                var config = _part?.AdditiveBuildConfig;
                                                <tr>
                                                    <td><input class="form-control" type="number" min="1" style="width: 60px;" value="@r.ExecutionOrder" @onchange="e => UpdateReqField(r, nameof(r.ExecutionOrder), e)" /></td>
                                                    <td>
                                                        <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@(r.ProductionStage?.StageColor ?? "var(--accent)");margin-right:6px;"></span>
                                                        @(r.ProductionStage?.Name ?? $"Stage {r.ProductionStageId}")
                                                        @if (r.ProductionStage?.TriggerPlateRelease == true)
                                                        {
                                                            <span style="margin-left: 6px; font-size: 0.75rem; background: var(--warning); color: white; padding: 1px 6px; border-radius: 3px;">RELEASE</span>
                                                        }
                                                    </td>
                                                    <td>@(r.ProductionStage?.Department ?? "—")</td>
                                                    <td>
                                                        @if (_selectedBuildId > 0 && config != null)
                                                        {
                                                            @* Show editable input when a build is selected *@
                                                            @if (slug is "sls-printing" or "sls-print" or "printing" or "print")
                                                            {
                                                                <input class="form-control form-control-sm" type="number" step="0.1" min="0" style="width: 80px;"
                                                                       value="@config.SingleStackDurationHours"
                                                                       @onchange="e => config.SingleStackDurationHours = ParseNullableDouble(e.Value)" />
                                                            }
                                                            else if (slug is "depowder" or "depowdering")
                                                            {
                                                                <input class="form-control form-control-sm" type="number" step="0.1" min="0" style="width: 80px;"
                                                                       value="@config.DepowderingDurationHours"
                                                                       @onchange="e => config.DepowderingDurationHours = ParseNullableDouble(e.Value)" />
                                                            }
                                                            else if (slug is "heat-treat" or "heat-treatment")
                                                            {
                                                                <input class="form-control form-control-sm" type="number" step="0.1" min="0" style="width: 80px;"
                                                                       value="@config.HeatTreatmentDurationHours"
                                                                       @onchange="e => config.HeatTreatmentDurationHours = ParseNullableDouble(e.Value)" />
                                                            }
                                                            else if (slug is "wire-edm" or "edm")
                                                            {
                                                                <input class="form-control form-control-sm" type="number" step="0.1" min="0" style="width: 80px;"
                                                                       value="@config.WireEdmDurationHours"
                                                                       @onchange="e => config.WireEdmDurationHours = ParseNullableDouble(e.Value)" />
                                                            }
                                                            else
                                                            {
                                                                <span style="color: var(--text-muted); font-style: italic;">From build</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span style="color: var(--text-muted); font-style: italic;" title="Select a build above to edit durations">
                                                                From build
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span style="color: var(--text-muted);" title="Machine is assigned when the build is scheduled">
                                                            @(r.ProductionStage?.DefaultMachineId ?? "Build")
                                                        </span>
                                                    </td>
                                                    <td><input type="checkbox" checked="@r.IsRequired" @onchange="e => UpdateReqRequired(r, e)" /></td>
                                                    <td><button class="btn btn-sm btn-danger" @onclick="() => RemoveStageReq(r.Id)">✕</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    <div style="margin-top: 8px; padding: 8px 12px; background: var(--bg-tertiary); border-radius: 6px; font-size: 0.85rem; color: var(--text-muted);">
                                        ℹ️ Build-level stage durations are calculated when a build plate is created. Times depend on the number of parts and stack configuration.
                                    </div>

                                    @* Fill From Build Section *@
                                    @if (_buildsForPart?.Any() == true)
                                    {
                                        <div style="margin-top: 12px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; border: 1px solid var(--border-color);">
                                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                                                <label class="form-label" style="margin: 0; white-space: nowrap;">
                                                    📦 @(_selectedBuildId > 0 ? "Editing durations from:" : "Fill durations from existing build:")
                                                </label>
                                                <select class="form-control" style="flex: 1; min-width: 200px; max-width: 400px;" @bind="_selectedBuildId">
                                                    <option value="0">Select a build...</option>
                                                    @foreach (var build in _buildsForPart)
                                                    {
                                                        var statusIcon = build.Status switch
                                                        {
                                                            BuildPackageStatus.Completed => "✅",
                                                            BuildPackageStatus.PostPrint => "📦",
                                                            BuildPackageStatus.Printing => "🖨️",
                                                            BuildPackageStatus.Scheduled => "📅",
                                                            _ => "📝"
                                                        };
                                                        var durationInfo = build.EstimatedDurationHours.HasValue ? $" ({build.EstimatedDurationHours:F1}h)" : "";
                                                        <option value="@build.Id">@statusIcon @build.Name@durationInfo — @build.Status</option>
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-primary" @onclick="FillDurationsFromBuild" disabled="@(_selectedBuildId == 0)">
                                                    Apply
                                                </button>
                                            </div>
                                            @if (_selectedBuildId > 0)
                                            {
                                                <div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border-color); display: flex; align-items: center; gap: 12px;">
                                                    <span style="color: var(--text-muted); font-size: 0.85rem;">
                                                        ✏️ Edit durations in the table above, then save changes:
                                                    </span>
                                                    <button class="btn btn-sm btn-success" @onclick="SaveBuildDurations">
                                                        💾 Save Durations
                                                    </button>
                                                    <button class="btn btn-sm btn-secondary" @onclick="() => _selectedBuildId = 0">
                                                        Cancel
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <small style="color: var(--text-muted); display: block; margin-top: 6px;">
                                                    Copies print duration, depowdering, heat treatment, and wire EDM times from the selected build to this part's configuration.
                                                </small>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }

                        @* Per-Part Stages Section *@
                        var perPartReqs = _stageReqs.Where(r => r.ProductionStage?.IsBuildLevelStage != true).OrderBy(r => r.ExecutionOrder).ToList();
                        if (perPartReqs.Any())
                        {
                            <div>
                                @if (SelectedApproach?.RequiresBuildPlate == true)
                                {
                                    <h4 style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                                        <span style="background: var(--success); color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem;">PART</span>
                                        Per-Part Stages
                                        <span style="font-weight: normal; color: var(--text-muted);">— Individual jobs after plate release</span>
                                    </h4>
                                }
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Order</th>
                                            <th>Stage</th>
                                            <th>Department</th>
                                            <th>Est. Min</th>
                                            <th>Setup (min)</th>
                                            <th>Batch</th>
                                            <th>Rate $/hr</th>
                                            <th>Material $</th>
                                            <th>Machine</th>
                                            <th>Required</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in perPartReqs)
                                        {
                                            <tr>
                                                <td><input class="form-control" type="number" min="1" style="width: 60px;" value="@r.ExecutionOrder" @onchange="e => UpdateReqField(r, nameof(r.ExecutionOrder), e)" /></td>
                                                <td>
                                                    <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@(r.ProductionStage?.StageColor ?? "var(--accent)");margin-right:6px;"></span>
                                                    @(r.ProductionStage?.Name ?? $"Stage {r.ProductionStageId}")
                                                </td>
                                                <td>@(r.ProductionStage?.Department ?? "—")</td>
                                                <td><input class="form-control" type="number" min="1" style="width: 70px;" value="@r.EstimatedMinutes" @onchange="e => UpdateReqField(r, nameof(r.EstimatedMinutes), e)" placeholder="@((int)((r.ProductionStage?.DefaultDurationHours ?? 1) * 60))" /></td>
                                                <td><input class="form-control" type="number" style="width: 70px;" value="@r.SetupTimeMinutes" @onchange="e => UpdateReqField(r, nameof(r.SetupTimeMinutes), e)" /></td>
                                                <td>
                                                    <span style="color: var(--text-muted);" title="@(r.ProductionStage?.BatchCapacity ?? 1) part(s) at a time">
                                                        @(r.ProductionStage?.BatchCapacity ?? 1)×
                                                    </span>
                                                </td>
                                                <td><input class="form-control" type="number" step="1" style="width: 80px;" value="@r.HourlyRateOverride" @onchange="e => UpdateReqField(r, nameof(r.HourlyRateOverride), e)" placeholder="@(r.ProductionStage?.DefaultHourlyRate.ToString("F0") ?? "—")" /></td>
                                                <td><input class="form-control" type="number" step="0.01" style="width: 80px;" value="@r.MaterialCost" @onchange="e => UpdateReqField(r, nameof(r.MaterialCost), e)" /></td>
                                                <td>
                                                    <select class="form-control" style="width:auto;min-width:100px;" value="@(r.AssignedMachineId ?? "")" @onchange="e => UpdateReqMachine(r, e)">
                                                        <option value="">Any</option>
                                                        @if (_machines != null)
                                                        {
                                                            @foreach (var m in _machines.Where(m => r.ProductionStage?.Department == null || m.Department == r.ProductionStage.Department || string.IsNullOrEmpty(m.Department)))
                                                            {
                                                                <option value="@m.MachineId">@m.Name</option>
                                                            }
                                                        }
                                                    </select>
                                                </td>
                                                <td><input type="checkbox" checked="@r.IsRequired" @onchange="e => UpdateReqRequired(r, e)" /></td>
                                                <td><button class="btn btn-sm btn-danger" @onclick="() => RemoveStageReq(r.Id)">✕</button></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        @* Summary (only for per-part stages since build-level comes from build) *@
                        @if (perPartReqs.Any())
                        {
                            <div style="margin-top: 12px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; display: flex; gap: 24px;">
                                <div>
                                    <span class="form-label">Per-Part Est. Hours</span>
                                    <div style="font-weight: 600;">@perPartReqs.Sum(r => r.GetEffectiveEstimatedHours()).ToString("F1") hrs</div>
                                </div>
                                <div>
                                    <span class="form-label">Per-Part Est. Cost</span>
                                    <div style="font-weight: 600;">@perPartReqs.Sum(r => r.CalculateTotalEstimatedCost()).ToString("C")</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">⚙</div>
                            <div class="empty-state-text">
                                @if (SelectedApproach != null && !string.IsNullOrWhiteSpace(SelectedApproach.DefaultRoutingTemplate) && SelectedApproach.DefaultRoutingTemplate != "[]")
                                {
                                    <span>No stages assigned yet.</span>
                                    <button class="btn btn-sm btn-primary" style="margin-top: 8px;" @onclick="() => ApplyRoutingTemplateAsync()">
                                        🛤️ Apply @(SelectedApproach.Name) Template
                                    </button>
                                }
                                else if (SelectedApproach != null)
                                {
                                    <span>No stages assigned. Add stages manually using the dropdown above.</span>
                                }
                                else
                                {
                                    <span>No stages assigned. Select a manufacturing approach on the Part Info tab to auto-populate, or add stages manually.</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

                            <!-- BOM / Materials Tab -->
                            @if (_tab == "bom")
            {
                <div class="card">
                    <h3 class="card-title">Bill of Materials</h3>
                    <p style="color: var(--text-muted); margin-bottom: 12px;">Define raw materials, inventory items, and sub-parts required to produce one unit of this part.</p>

                    <!-- Add BOM Item Form -->
                    <div style="margin-bottom: 12px; display: flex; flex-direction: column; gap: 8px;">
                        <!-- Row 1: Type + Item picker + Qty + UoM -->
                        <div style="display: flex; gap: 8px; align-items: end; flex-wrap: wrap;">
                            <div class="form-group" style="width: 150px;">
                                <label class="form-label">Type</label>
                                <select class="form-control" @bind="_bomItemType">
                                    <option value="@BomItemType.RawMaterial">Raw Material</option>
                                    <option value="@BomItemType.InventoryItem">Inventory Item</option>
                                    <option value="@BomItemType.SubPart">Sub-Part</option>
                                </select>
                            </div>

                            @if (_bomItemType == BomItemType.RawMaterial)
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Material</label>
                                    <select class="form-control" @bind="_bomMaterialId">
                                        <option value="0">Select material...</option>
                                        @if (_materials != null)
                                        {
                                            @foreach (var m in _materials)
                                            {
                                                <option value="@m.Id">@m.Name (@m.Category)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            else if (_bomItemType == BomItemType.InventoryItem)
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Inventory Item</label>
                                    <select class="form-control" @bind="_bomInventoryItemId">
                                        <option value="0">Select item...</option>
                                        @if (_inventoryItems != null)
                                        {
                                            @foreach (var inv in _inventoryItems)
                                            {
                                                <option value="@inv.Id">@inv.ItemNumber — @inv.Name (@inv.ItemType)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Sub-Part</label>
                                    <select class="form-control" @bind="_bomChildPartId">
                                        <option value="0">Select part...</option>
                                        @if (_allParts != null)
                                        {
                                            @foreach (var p in _allParts.Where(p => p.Id != (_part?.Id ?? 0)))
                                            {
                                                <option value="@p.Id">@p.PartNumber — @p.Description</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }

                            <div class="form-group" style="width: 100px;">
                                <label class="form-label">Qty</label>
                                <input class="form-control" type="number" step="0.01" min="0.01" @bind="_bomQty" />
                            </div>
                            <div class="form-group" style="width: 80px;">
                                <label class="form-label">UoM</label>
                                <input class="form-control" @bind="_bomUom" placeholder="each" />
                            </div>
                        </div>

                        <!-- Row 2: Cost override + Scrap + Ref Designator + Add button -->
                        <div style="display: flex; gap: 8px; align-items: end; flex-wrap: wrap;">
                            <div class="form-group" style="width: 130px;">
                                <label class="form-label">Cost Override</label>
                                <input class="form-control" type="number" step="0.01" min="0" @bind="_bomUnitCostOverride" placeholder="Auto" />
                            </div>
                            <div class="form-group" style="width: 100px;">
                                <label class="form-label">Scrap %</label>
                                <input class="form-control" type="number" step="0.1" min="0" max="100" @bind="_bomScrapPct" />
                            </div>
                            @if (_bomItemType == BomItemType.SubPart)
                            {
                                <div class="form-group" style="width: 130px;">
                                    <label class="form-label">Ref Designator</label>
                                    <input class="form-control" @bind="_bomRefDesignator" placeholder="e.g. R1, C3" />
                                </div>
                            }
                            <button class="btn btn-sm btn-primary" @onclick="AddBomItem" disabled="@(!CanAddBomItem)" style="height: 36px;">+ Add</button>
                        </div>
                    </div>

                    @if (_bomItems != null && _bomItems.Any(b => b.IsActive))
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Type</th>
                                    <th>Item</th>
                                    <th style="text-align: right;">Qty</th>
                                    <th>UoM</th>
                                    <th style="text-align: right;">Unit Cost</th>
                                    <th style="text-align: right;">Scrap %</th>
                                    <th style="text-align: right;">Ext. Cost</th>
                                    <th>Notes</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _bomItems.Where(b => b.IsActive).OrderBy(b => b.SortOrder))
                                {
                                    <tr>
                                        <td>@item.SortOrder</td>
                                        <td>
                                            @switch (item.ItemType)
                                            {
                                                case BomItemType.RawMaterial:
                                                    <span class="badge badge-info">Material</span>
                                                    break;
                                                case BomItemType.InventoryItem:
                                                    <span class="badge badge-secondary">Inventory</span>
                                                    break;
                                                case BomItemType.SubPart:
                                                    <span class="badge badge-primary">Sub-Part</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @switch (item.ItemType)
                                            {
                                                case BomItemType.RawMaterial:
                                                    @(item.Material?.Name ?? $"Material #{item.MaterialId}")
                                                    break;
                                                case BomItemType.InventoryItem:
                                                    @(item.InventoryItem != null ? $"{item.InventoryItem.ItemNumber} — {item.InventoryItem.Name}" : $"Item #{item.InventoryItemId}")
                                                    break;
                                                case BomItemType.SubPart:
                                                    var childPart = item.ChildPart ?? _allParts?.FirstOrDefault(p => p.Id == item.ChildPartId);
                                                    @(childPart != null ? $"{childPart.PartNumber} — {childPart.Description}" : $"Part #{item.ChildPartId}")
                                                    if (!string.IsNullOrEmpty(item.ReferenceDesignator))
                                                    {
                                                        <span style="color: var(--text-muted); margin-left: 4px;">[@item.ReferenceDesignator]</span>
                                                    }
                                                    break;
                                            }
                                        </td>
                                        <td style="text-align: right;">@item.QuantityRequired.ToString("F2")</td>
                                        <td>@item.UnitOfMeasure</td>
                                        <td style="text-align: right;">
                                            @{ var unitCost = item.GetResolvedUnitCost(); }
                                            @if (item.UnitCost.HasValue)
                                            {
                                                <span title="Manual override">@item.UnitCost.Value.ToString("C2") ✏️</span>
                                            }
                                            else if (item.ItemType == BomItemType.SubPart)
                                            {
                                                <span style="color: var(--text-muted);" title="Resolved from sub-part BOM">roll-up</span>
                                            }
                                            else
                                            {
                                                @unitCost.ToString("C2")
                                            }
                                        </td>
                                        <td style="text-align: right;">@(item.ScrapFactorPct > 0 ? $"{item.ScrapFactorPct:F1}%" : "—")</td>
                                        <td style="text-align: right; font-weight: 600;">
                                            @if (item.ItemType == BomItemType.SubPart && !item.UnitCost.HasValue)
                                            {
                                                <span style="color: var(--text-muted);" title="Calculated from sub-part BOM tree">—</span>
                                            }
                                            else
                                            {
                                                @item.GetExtendedCost().ToString("C2")
                                            }
                                        </td>
                                        <td><input class="form-control" style="width: 120px;" value="@item.Notes" @onchange="async e => { item.Notes = e.Value?.ToString(); await UpdateBomNotes(item); }" placeholder="Notes..." /></td>
                                        <td><button class="btn btn-sm btn-danger" @onclick="() => RemoveBomItem(item)">✕</button></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="font-weight: 600; border-top: 2px solid var(--border);">
                                    <td colspan="7" style="text-align: right;">Total (excl. sub-part roll-ups):</td>
                                    <td style="text-align: right;">
                                        @{
                                            var directTotal = _bomItems!.Where(b => b.IsActive && b.ItemType != BomItemType.SubPart)
                                                .Sum(b => b.GetExtendedCost())
                                                + _bomItems!.Where(b => b.IsActive && b.ItemType == BomItemType.SubPart && b.UnitCost.HasValue)
                                                .Sum(b => b.GetExtendedCost());
                                        }
                                        @directTotal.ToString("C2")
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">📦</div>
                            <div class="empty-state-text">No BOM items. Add materials, inventory items, or sub-parts required to manufacture this part.</div>
                        </div>
                    }
                </div>
            }

                            <!-- Stacking Tab (approach-driven) -->
                            @if (_tab == "stacking" && ShowAdditiveTabs)
            {
                <div class="card">
                    <h3 class="card-title">SLS Stacking Configuration</h3>
                    <p style="color: var(--text-muted); margin-bottom: 12px;">Configure how this part can be stacked in SLS/LPBF builds. These are <strong>planning guidelines</strong> — actual per-build counts come from the slicer.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.AllowStacking" style="margin-right: 6px;" />Allow Stacking</label>
                        </div>
                        <div class="form-group"><label class="form-label">Max Stack Count</label><input class="form-control" type="number" min="1" max="10" @bind="_part!.AdditiveBuildConfig!.MaxStackCount" /></div>
                        <div class="form-group"><label class="form-label">Planned Parts/Build (Single)</label><input class="form-control" type="number" min="1" max="500" @bind="_part!.AdditiveBuildConfig!.PlannedPartsPerBuildSingle" /></div>
                        <div class="form-group"><label class="form-label">Single Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part!.AdditiveBuildConfig!.SingleStackDurationHours" /></div>

                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.EnableDoubleStack" style="margin-right: 6px;" />Enable Double Stack</label>
                        </div>
                        @if (_part!.AdditiveBuildConfig!.EnableDoubleStack)
                        {
                            <div class="form-group"><label class="form-label">Planned Parts/Build (Double)</label><input class="form-control" type="number" min="1" max="500" @bind="_part.AdditiveBuildConfig!.PlannedPartsPerBuildDouble" /></div>
                            <div class="form-group"><label class="form-label">Double Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part.AdditiveBuildConfig!.DoubleStackDurationHours" /></div>
                        }

                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.EnableTripleStack" style="margin-right: 6px;" />Enable Triple Stack</label>
                        </div>
                        @if (_part!.AdditiveBuildConfig!.EnableTripleStack)
                        {
                            <div class="form-group"><label class="form-label">Planned Parts/Build (Triple)</label><input class="form-control" type="number" min="1" max="500" @bind="_part.AdditiveBuildConfig!.PlannedPartsPerBuildTriple" /></div>
                            <div class="form-group"><label class="form-label">Triple Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part.AdditiveBuildConfig!.TripleStackDurationHours" /></div>
                        }
                    </div>
                </div>
            }

            <!-- Defense / DLMS Tab -->
            @if (_tab == "defense" && _showDlms)
            {
                <div class="card">
                    <h3 class="card-title">🛡️ Defense & Export Classification</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label"><input type="checkbox" @bind="_part!.IsDefensePart" style="margin-right: 6px;" />Defense Part</label>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ITAR Classification</label>
                            <select class="form-control" @bind="_part!.ItarClassification">
                                @foreach (var c in Enum.GetValues<ItarClassification>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            }

            <!-- Custom Fields Tab -->
            @if (_tab == "custom" && _customFieldDefs.Count > 0)
            {
                <div class="card">
                    <h3 class="card-title">Custom Fields</h3>
                    <CustomFieldsEditor FieldDefinitions="_customFieldDefs" Values="_customFieldValues" ValuesChanged="OnCustomFieldsChanged" />
                </div>
            }

            <!-- Action Buttons -->
            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
                    @(_isNew ? "Create Part" : "Save Changes")
                </button>
                <button class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                @if (!_isNew)
                {
                    <button class="btn btn-sm btn-secondary" @onclick="ViewDetail" style="margin-left: auto;">View Part Detail →</button>
                }
            </div>
        }
    </Authorized>
</AuthorizeView>

@if (_showRoutingTemplateConfirm && SelectedApproach != null)
{
    var templateSlugs = _pendingTemplateSlugs ?? [];
    <div class="modal-overlay" @onclick="CancelReplaceRouting">
        <div class="modal-content" style="max-width: 500px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Replace Routing?</span>
                <button class="modal-close" @onclick="CancelReplaceRouting">&times;</button>
            </div>
            <div style="padding: 16px;">
                <p>This part already has <strong>@(_stageReqs?.Count ?? 0) stage(s)</strong> in its routing.</p>
                <p>The <strong>@(SelectedApproach.IconEmoji) @(SelectedApproach.Name)</strong> template would replace them with:</p>
                <div style="margin: 12px 0; display: flex; flex-wrap: wrap; gap: 6px;">
                    @foreach (var slug in templateSlugs)
                    {
                        var stage = _allStages?.FirstOrDefault(s => s.StageSlug == slug);
                        <span style="padding: 3px 10px; border-radius: 4px; font-size: 0.85rem; background: @(stage?.StageColor ?? "#666")20; border: 1px solid @(stage?.StageColor ?? "#ccc"); color: var(--text-primary);">
                            @(stage?.StageIcon ?? "❓") @(stage?.Name ?? slug)
                        </span>
                    }
                </div>
                <p style="color: var(--text-muted); font-size: 0.85rem;">Existing stages will be removed and replaced with the template stages.</p>
            </div>
            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="ConfirmReplaceRouting">Replace Routing</button>
                <button class="btn btn-secondary" @onclick="CancelReplaceRouting">Keep Existing</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public int Id { get; set; }

    private bool _isNew => Id == 0;
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private List<string> _validationErrors = new();
    private string _tab = "info";
    private string _currentUser = "System";
    private ConfirmDialog _confirm = null!;

    // Feature flags
    private bool _showDlms;

    // Part data
    private Part? _part;
    private List<PartStageRequirement>? _stageReqs;

    // Reference data
    private List<Material>? _materials;
    private List<ProductionStage>? _allStages;
    private List<Machine>? _machines;

    // Custom fields
    private List<CustomFieldDefinition> _customFieldDefs = new();
    private Dictionary<string, string> _customFieldValues = new();

    // BOM
    private List<PartBomItem>? _bomItems;
    private BomItemType _bomItemType = BomItemType.RawMaterial;
    private int _bomMaterialId;
    private int _bomInventoryItemId;
    private int _bomChildPartId;
    private decimal _bomQty = 1;
    private string _bomUom = "kg";
    private decimal? _bomUnitCostOverride;
    private decimal _bomScrapPct;
    private string? _bomRefDesignator;
    private List<InventoryItem>? _inventoryItems;
    private List<Part>? _allParts;

    // Stage requirement form state
    private int _addStageId;

    // Builds for this part (for "Fill from Build" feature)
    private List<BuildPackage>? _buildsForPart;
    private int _selectedBuildId;

    // Manufacturing approaches (DB-backed)
    private List<ManufacturingApproach> _approaches = new();

    private ManufacturingApproach? SelectedApproach =>
        _approaches.FirstOrDefault(a => a.Id == _part?.ManufacturingApproachId);

    private bool ShowAdditiveTabs => SelectedApproach?.IsAdditive == true;

    protected override async Task OnInitializedAsync()
    {
        _showDlms = Features.IsEnabled("dlms");

        // Load reference data
        _materials = await MaterialService.GetAllMaterialsAsync();
        _approaches = await ApproachService.GetAllAsync();
        _allStages = await StageService.GetAllStagesAsync();
        _machines = await MachineService.GetAllMachinesAsync(true);
        _inventoryItems = await InventoryService.GetAllItemsAsync();
        _allParts = await PartService.GetAllPartsAsync();

        if (_isNew)
        {
            _part = new Part
            {
                Material = "",
                IsActive = true,
                CreatedBy = _currentUser,
                LastModifiedBy = _currentUser
            };
            _stageReqs = new();
            _bomItems = new();
        }
        else
        {
            _part = await PartService.GetPartByIdAsync(Id);
            if (_part != null)
            {
                _stageReqs = await PartService.GetStageRequirementsAsync(Id);
                _bomItems = await PartService.GetBomItemsAsync(Id);

                // Backfill MaterialId from Material string if not set
                if (_part.MaterialId == null && !string.IsNullOrEmpty(_part.Material))
                {
                    var match = _materials?.FirstOrDefault(m => m.Name == _part.Material);
                    if (match != null) _part.MaterialId = match.Id;
                }

                // Load builds containing this part (for "Fill from Build" feature)
                _buildsForPart = await BuildPlanningService.GetBuildsForPartAsync(Id);
            }
        }

        // Ensure AdditiveBuildConfig exists when approach is additive
        EnsureAdditiveBuildConfig();

        // Load custom field definitions for "Part" entity
        _customFieldDefs = await CustomFieldService.GetFieldDefinitionsAsync("Part");
        if (_part != null && !string.IsNullOrEmpty(_part.CustomFieldValues))
        {
            try
            {
                _customFieldValues = JsonSerializer.Deserialize<Dictionary<string, string>>(_part.CustomFieldValues) ?? new();
            }
            catch { _customFieldValues = new(); }
        }

        _loading = false;
    }

    private void OnMaterialChanged(ChangeEventArgs e)
    {
        var selectedName = e.Value?.ToString() ?? "";
        _part!.Material = selectedName;
        var match = _materials?.FirstOrDefault(m => m.Name == selectedName);
        _part.MaterialId = match?.Id;
    }

    private bool _showRoutingTemplateConfirm;
    private List<string>? _pendingTemplateSlugs;

    private async Task OnApproachChanged(ChangeEventArgs e)
    {
        int? previousApproachId = _part!.ManufacturingApproachId;

        if (int.TryParse(e.Value?.ToString(), out var id))
            _part!.ManufacturingApproachId = id;
        else
            _part!.ManufacturingApproachId = null;

        EnsureAdditiveBuildConfig();

        // Auto-apply routing template when approach changes
        if (_part.ManufacturingApproachId != previousApproachId)
        {
            await ApplyRoutingTemplateAsync();
        }
    }

    /// <summary>
    /// Auto-applies the DefaultRoutingTemplate from the selected ManufacturingApproach.
    /// If routing is empty, applies immediately. If routing has stages, shows confirmation.
    /// </summary>
    private async Task ApplyRoutingTemplateAsync(bool forceReplace = false)
    {
        if (_part == null || _allStages == null) return;

        var approach = SelectedApproach;
        if (approach == null || string.IsNullOrWhiteSpace(approach.DefaultRoutingTemplate)) return;

        try
        {
            var stageSlugs = JsonSerializer.Deserialize<List<string>>(approach.DefaultRoutingTemplate);
            if (stageSlugs == null || stageSlugs.Count == 0) return;

            // Option C: if routing has stages and not forcing, show confirmation
            if (_stageReqs?.Any() == true && !forceReplace)
            {
                _pendingTemplateSlugs = stageSlugs;
                _showRoutingTemplateConfirm = true;
                return;
            }

            // Clear existing routing if replacing
            if (forceReplace && _stageReqs?.Any() == true)
            {
                if (!_isNew)
                {
                    foreach (var existing in _stageReqs.ToList())
                    {
                        await PartService.RemoveStageRequirementAsync(existing.Id);
                    }
                }
                _stageReqs = new();
            }

            _stageReqs ??= new();
            int order = 1;

            foreach (var slug in stageSlugs)
            {
                var stage = _allStages.FirstOrDefault(s => s.StageSlug == slug);
                if (stage == null) continue;

                if (_stageReqs.Any(r => r.ProductionStageId == stage.Id)) continue;

                var req = new PartStageRequirement
                {
                    PartId = _part.Id,
                    ProductionStageId = stage.Id,
                    ProductionStage = stage,
                    ExecutionOrder = order++,
                    EstimatedMinutes = stage.IsBuildLevelStage ? null : (int)(stage.DefaultDurationHours * 60),
                    SetupTimeMinutes = stage.IsBuildLevelStage ? null : stage.DefaultSetupMinutes,
                    IsRequired = true,
                    CreatedBy = _currentUser,
                    LastModifiedBy = _currentUser
                };

                if (_isNew)
                {
                    _stageReqs.Add(req);
                }
                else
                {
                    await PartService.AddStageRequirementAsync(req);
                }
            }

            if (!_isNew && _stageReqs.Count > 0)
            {
                _stageReqs = await PartService.GetStageRequirementsAsync(_part.Id);
            }
        }
        catch (JsonException)
        {
            // Invalid JSON in template, ignore
        }
    }

    private async Task ConfirmReplaceRouting()
    {
        _showRoutingTemplateConfirm = false;
        _pendingTemplateSlugs = null;
        await ApplyRoutingTemplateAsync(forceReplace: true);
    }

    private void CancelReplaceRouting()
    {
        _showRoutingTemplateConfirm = false;
        _pendingTemplateSlugs = null;
    }

    /// <summary>
    /// Creates or removes AdditiveBuildConfig based on the selected ManufacturingApproach.
    /// </summary>
    private void EnsureAdditiveBuildConfig()
    {
        if (_part == null) return;

        if (ShowAdditiveTabs && _part.AdditiveBuildConfig == null)
        {
            _part.AdditiveBuildConfig = new PartAdditiveBuildConfig
            {
                PartId = _part.Id,
                PlannedPartsPerBuildSingle = 1,
                MaxStackCount = 1
            };
        }
    }

    private async Task Save()
    {
        _error = null;
        _validationErrors.Clear();

        // Validate
        var errors = await PartService.ValidatePartAsync(_part!);
        if (errors.Count > 0)
        {
            _validationErrors = errors;
            return;
        }

        _saving = true;
        try
        {
            // Serialize custom field values
            if (_customFieldValues.Count > 0)
            {
                _part!.CustomFieldValues = JsonSerializer.Serialize(_customFieldValues);
            }

            _part!.LastModifiedBy = _currentUser;

            if (_isNew)
            {
                _part.CreatedBy = _currentUser;
                _part = await PartService.CreatePartAsync(_part);

                // Persist in-memory routing
                foreach (var req in _stageReqs ?? [])
                {
                    req.PartId = _part.Id;
                    await PartService.AddStageRequirementAsync(req);
                }
                // Persist in-memory BOM
                foreach (var item in (_bomItems ?? []).Where(b => b.IsActive))
                {
                    item.PartId = _part.Id;
                    await PartService.AddBomItemAsync(item);
                }

                Toast.ShowSuccess("Part created successfully");
                Nav.NavigateTo($"/parts/{_part.Id}/edit");
            }
            else
            {
                await PartService.UpdatePartAsync(_part);
                Toast.ShowSuccess("Part saved");
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    // Stage requirement CRUD
    private async Task AddStageReq()
    {
        if (_addStageId == 0 || _part == null) return;
        var nextOrder = (_stageReqs?.Any() == true) ? _stageReqs.Max(r => r.ExecutionOrder) + 1 : 1;
        var stage = _allStages?.FirstOrDefault(s => s.Id == _addStageId);
        var req = new PartStageRequirement
        {
            PartId = _part.Id,
            ProductionStageId = _addStageId,
            ProductionStage = stage!,
            ExecutionOrder = nextOrder,
            // Convert default hours to minutes (or null for build-level stages)
            EstimatedMinutes = stage?.IsBuildLevelStage == true ? null : (int)((stage?.DefaultDurationHours ?? 1.0) * 60),
            SetupTimeMinutes = stage?.DefaultSetupMinutes,
            IsRequired = true,
            CreatedBy = _currentUser,
            LastModifiedBy = _currentUser
        };

        if (_isNew)
        {
            _stageReqs ??= new();
            _stageReqs.Add(req);
        }
        else
        {
            await PartService.AddStageRequirementAsync(req);
            _stageReqs = await PartService.GetStageRequirementsAsync(_part.Id);
        }
        _addStageId = 0;
    }

    private async Task RemoveStageReq(int id)
    {
        var item = _stageReqs?.FirstOrDefault(r => r.Id == id);
        var stageName = item?.ProductionStage?.Name ?? "this stage";
        if (!await _confirm.ShowAsync($"Remove '{stageName}' from the routing?")) return;

        if (_isNew)
        {
            if (item != null) _stageReqs?.Remove(item);
        }
        else
        {
            await PartService.RemoveStageRequirementAsync(id);
            _stageReqs = await PartService.GetStageRequirementsAsync(_part!.Id);
        }
    }

    private async Task UpdateReqField(PartStageRequirement r, string field, ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        switch (field)
        {
            case nameof(r.ExecutionOrder):
                if (int.TryParse(val, out var order)) r.ExecutionOrder = order;
                break;
            case nameof(r.EstimatedMinutes):
                r.EstimatedMinutes = int.TryParse(val, out var mins) ? mins : null;
                break;
            case nameof(r.SetupTimeMinutes):
                r.SetupTimeMinutes = int.TryParse(val, out var setup) ? setup : null;
                break;
            case nameof(r.HourlyRateOverride):
                r.HourlyRateOverride = decimal.TryParse(val, out var rate) ? rate : null;
                break;
            case nameof(r.MaterialCost):
                r.MaterialCost = decimal.TryParse(val, out var mc) ? mc : 0;
                break;
        }
        r.LastModifiedBy = _currentUser;
        if (!_isNew)
        {
            try
            {
                await PartService.UpdateStageRequirementAsync(r);
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to save: {ex.Message}");
            }
        }
    }

    private async Task UpdateReqMachine(PartStageRequirement r, ChangeEventArgs e)
    {
