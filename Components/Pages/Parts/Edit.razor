@page "/parts/new"
@page "/parts/{Id:int}/edit"
@inject IPartService PartService
@inject IStageService StageService
@inject IMaterialService MaterialService
@inject IManufacturingApproachService ApproachService
@inject IManufacturingProcessService ProcessService
@inject IMachineProgramService MachineProgramService
@inject IBuildPlanningService BuildPlanningService
@inject ICustomFieldService CustomFieldService
@inject ITenantFeatureService Features
@inject IMachineService MachineService
@inject IInventoryService InventoryService
@inject NavigationManager Nav
@inject ToastService Toast
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@(_isNew ? "New Part" : $"Edit {_part?.PartNumber}") - OpCentrix</PageTitle>

<AuthorizeView>
    <Authorized>
        @{
            _currentUser = context.User.FindFirst("FullName")?.Value
                ?? context.User.FindFirst(ClaimTypes.Name)?.Value
                ?? "System";
        }

        @if (_loading)
        {
            <div class="loading"><span class="spinner"></span> Loading...</div>
        }
        else if (!_isNew && _part == null)
        {
            <div class="card" style="text-align: center; padding: 40px;">
                <p style="color: var(--text-muted);">Part not found.</p>
                <button class="btn btn-secondary" @onclick="GoBack">← Back to Parts</button>
            </div>
        }
        else if (_isNew)
        {
            @* ═══════════════════════════════════════════════════════════════
               NEW PART WIZARD — 3-step guided creation flow
               ═══════════════════════════════════════════════════════════════ *@
            <div class="page-header">
                <div>
                    <button class="btn btn-sm btn-secondary" @onclick="GoBack" style="margin-bottom: 8px;">← Parts</button>
                    <h1 class="page-title">New Part</h1>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">@_error</div>
            }
            @if (_validationErrors.Count > 0)
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">
                    <strong>Please fix the following:</strong>
                    <ul style="margin: 8px 0 0 16px;">
                        @foreach (var err in _validationErrors) { <li>@err</li> }
                    </ul>
                </div>
            }

            <!-- Wizard Step Indicator -->
            <div class="wizard-steps" style="display:flex; gap:0; margin-bottom:24px; border-bottom:2px solid var(--border);">
                <button class="wizard-step @(_wizardStep == 1 ? "wizard-step-active" : "") @(_wizardStep > 1 ? "wizard-step-done" : "")"
                        @onclick="() => { if (_wizardStep > 1) _wizardStep = 1; }" style="flex:1; padding:12px 16px; border:none; background:none; cursor:pointer; text-align:center; font-weight:600; border-bottom:3px solid @(_wizardStep == 1 ? "var(--primary)" : _wizardStep > 1 ? "var(--success)" : "transparent"); color:@(_wizardStep >= 1 ? "var(--text)" : "var(--text-muted)");">
                    <span style="display:inline-block;width:24px;height:24px;border-radius:50%;background:@(_wizardStep > 1 ? "var(--success)" : _wizardStep == 1 ? "var(--primary)" : "var(--border)");color:white;line-height:24px;font-size:0.8em;margin-right:6px;">@(_wizardStep > 1 ? "✓" : "1")</span>
                    Part Info
                </button>
                <button class="wizard-step @(_wizardStep == 2 ? "wizard-step-active" : "") @(_wizardStep > 2 ? "wizard-step-done" : "")"
                        @onclick="() => { if (_wizardStep > 2) _wizardStep = 2; }" disabled="@(_wizardStep < 2)" style="flex:1; padding:12px 16px; border:none; background:none; cursor:pointer; text-align:center; font-weight:600; border-bottom:3px solid @(_wizardStep == 2 ? "var(--primary)" : _wizardStep > 2 ? "var(--success)" : "transparent"); color:@(_wizardStep >= 2 ? "var(--text)" : "var(--text-muted)");">
                    <span style="display:inline-block;width:24px;height:24px;border-radius:50%;background:@(_wizardStep > 2 ? "var(--success)" : _wizardStep == 2 ? "var(--primary)" : "var(--border)");color:white;line-height:24px;font-size:0.8em;margin-right:6px;">@(_wizardStep > 2 ? "✓" : "2")</span>
                    Manufacturing Approach
                </button>
                <button class="wizard-step @(_wizardStep == 3 ? "wizard-step-active" : "")"
                        disabled="@(_wizardStep < 3)" style="flex:1; padding:12px 16px; border:none; background:none; cursor:pointer; text-align:center; font-weight:600; border-bottom:3px solid @(_wizardStep == 3 ? "var(--primary)" : "transparent"); color:@(_wizardStep >= 3 ? "var(--text)" : "var(--text-muted)");">
                    <span style="display:inline-block;width:24px;height:24px;border-radius:50%;background:@(_wizardStep == 3 ? "var(--primary)" : "var(--border)");color:white;line-height:24px;font-size:0.8em;margin-right:6px;">3</span>
                    Review & Create
                </button>
            </div>

            @* ── STEP 1: Basic Part Information ── *@
            @if (_wizardStep == 1)
            {
                <div class="card">
                    <h3 class="card-title">Basic Information</h3>
                    <p style="color:var(--text-muted);margin-bottom:12px;">Enter the core details for this part. You can add drawings, BOM, and other details after creation.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label">Part Number <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.PartNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Name <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.Name" />
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="_part!.Description" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Material <span style="color:var(--danger)">*</span></label>
                            <select class="form-control" value="@_part!.Material" @onchange="OnMaterialChanged">
                                <option value="">Select material...</option>
                                @if (_materials != null)
                                {
                                    @foreach (var m in _materials)
                                    {
                                        <option value="@m.Name">@m.Name (@m.Category)</option>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(_part.Material) && _materials?.All(m => m.Name != _part.Material) == true)
                                {
                                    <option value="@_part.Material">@_part.Material (custom)</option>
                                }
                            </select>
                            <small style="color: var(--text-muted);">Or type a custom value below:</small>
                            <input class="form-control" @bind="_part!.Material" style="margin-top: 4px;" placeholder="Custom material name..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Raw Material Spec</label>
                            <input class="form-control" @bind="_part!.RawMaterialSpec" placeholder="e.g. AMS 4911" />
                        </div>
                    </div>
                </div>

                <div style="display: flex; gap: 8px; margin-top: 16px;">
                    <button class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                    <button class="btn btn-primary" style="margin-left:auto;" @onclick="WizardNext" disabled="@(!WizardCanAdvance)">Next: Select Approach →</button>
                </div>
            }

            @* ── STEP 2: Manufacturing Approach Selection ── *@
            @if (_wizardStep == 2)
            {
                <div class="card">
                    <h3 class="card-title">Select Manufacturing Approach</h3>
                    <p style="color:var(--text-muted);margin-bottom:16px;">Choose how this part will be manufactured. This determines the default process stages, batch handling, and scheduling behavior.</p>

                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:12px;">
                        @foreach (var approach in _approaches.Where(a => a.IsActive).OrderBy(a => a.DisplayOrder))
                        {
                            var isSelected = _part!.ManufacturingApproachId == approach.Id;
                            var template = approach.ParsedRoutingTemplate;
                            <div class="card approach-card" style="cursor:pointer; padding:16px; border:2px solid @(isSelected ? "var(--primary)" : "var(--border)"); background:@(isSelected ? "var(--primary-bg, rgba(0,123,255,0.05))" : "var(--bg-card)"); transition:all 0.15s;"
                                 @onclick="() => SelectApproach(approach.Id)">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                                    <span style="font-size:1.5em;">@(approach.IconEmoji ?? "📦")</span>
                                    <div>
                                        <strong style="font-size:1.05em;">@approach.Name</strong>
                                        @if (!string.IsNullOrEmpty(approach.Description))
                                        {
                                            <div style="font-size:0.85em;color:var(--text-muted);">@approach.Description</div>
                                        }
                                    </div>
                                    @if (isSelected)
                                    {
                                        <span style="margin-left:auto;color:var(--primary);font-size:1.2em;">✓</span>
                                    }
                                </div>
                                <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;">
                                    @if (approach.IsAdditive) { <span class="badge badge-info" style="font-size:0.75em;">Additive</span> }
                                    @if (approach.RequiresBuildPlate) { <span class="badge badge-warning" style="font-size:0.75em;">Build Plate</span> }
                                    @if (approach.DefaultBatchCapacity > 0) { <span class="badge badge-secondary" style="font-size:0.75em;">Batch: @(approach.DefaultBatchCapacity)/crate</span> }
                                </div>
                                @if (template.Count > 0)
                                {
                                    <div style="display:flex;flex-wrap:wrap;gap:3px;align-items:center;">
                                        @for (int i = 0; i < template.Count; i++)
                                        {
                                            var entry = template[i];
                                            var stage = _allStages?.FirstOrDefault(s => s.StageSlug == entry.Slug);
                                            if (i > 0) { <span style="color:var(--text-muted);font-size:0.8em;">→</span> }
                                            <span style="font-size:0.8em;padding:2px 6px;border-radius:4px;background:@(stage?.StageColor ?? "#666")20;border:1px solid @(stage?.StageColor ?? "#ccc");white-space:nowrap;">
                                                @(stage?.StageIcon ?? "❓") @(stage?.Name ?? entry.Slug)
                                                <span style="font-size:0.7em;color:var(--text-muted);margin-left:2px;">@entry.Level.ToString()[0]</span>
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="font-size:0.85em;color:var(--text-muted);font-style:italic;">No default routing</span>
                                }
                            </div>
                        }
                    </div>

                    @if (SelectedApproach != null)
                    {
                        <div style="margin-top:16px;padding:12px;background:var(--bg-surface);border-radius:8px;border:1px solid var(--border);">
                            <strong>Selected:</strong> @SelectedApproach.IconEmoji @SelectedApproach.Name
                            @{ var selectedTemplate = SelectedApproach.ParsedRoutingTemplate; }
                            @if (selectedTemplate.Count > 0)
                            {
                                <span style="color:var(--text-muted);margin-left:8px;">— @selectedTemplate.Count stages will be auto-created in the manufacturing process</span>
                            }
                        </div>
                    }
                </div>

                <div style="display: flex; gap: 8px; margin-top: 16px;">
                    <button class="btn btn-secondary" @onclick="WizardBack">← Back</button>
                    <button class="btn btn-primary" style="margin-left:auto;" @onclick="WizardNext">Next: Review →</button>
                </div>
            }

            @* ── STEP 3: Review & Create ── *@
            @if (_wizardStep == 3)
            {
                <div class="card">
                    <h3 class="card-title">Review & Create</h3>
                    <p style="color:var(--text-muted);margin-bottom:16px;">Review the part details below. After creation you can configure the process stages, add BOM items, drawings, and more.</p>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div>
                            <h4 style="margin-bottom:8px;">Part Details</h4>
                            <table style="width:100%;">
                                <tr><td style="padding:4px 8px;color:var(--text-muted);width:140px;">Part Number</td><td style="padding:4px 8px;font-weight:600;">@_part!.PartNumber</td></tr>
                                <tr><td style="padding:4px 8px;color:var(--text-muted);">Name</td><td style="padding:4px 8px;">@_part.Name</td></tr>
                                @if (!string.IsNullOrEmpty(_part.Description))
                                {
                                    <tr><td style="padding:4px 8px;color:var(--text-muted);">Description</td><td style="padding:4px 8px;">@_part.Description</td></tr>
                                }
                                <tr><td style="padding:4px 8px;color:var(--text-muted);">Material</td><td style="padding:4px 8px;">@(string.IsNullOrEmpty(_part.Material) ? "—" : _part.Material)</td></tr>
                                @if (!string.IsNullOrEmpty(_part.RawMaterialSpec))
                                {
                                    <tr><td style="padding:4px 8px;color:var(--text-muted);">Raw Material Spec</td><td style="padding:4px 8px;">@_part.RawMaterialSpec</td></tr>
                                }
                            </table>
                        </div>
                        <div>
                            <h4 style="margin-bottom:8px;">Manufacturing Approach</h4>
                            @if (SelectedApproach != null)
                            {
                                var reviewTemplate = SelectedApproach.ParsedRoutingTemplate;
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                                    <span style="font-size:1.3em;">@SelectedApproach.IconEmoji</span>
                                    <strong>@SelectedApproach.Name</strong>
                                </div>
                                @if (reviewTemplate.Count > 0)
                                {
                                    <p style="font-size:0.9em;color:var(--text-muted);margin-bottom:8px;">
                                        @reviewTemplate.Count process stages will be auto-created:
                                    </p>
                                    <div style="display:flex;flex-direction:column;gap:4px;">
                                        @for (int i = 0; i < reviewTemplate.Count; i++)
                                        {
                                            var entry = reviewTemplate[i];
                                            var stage = _allStages?.FirstOrDefault(s => s.StageSlug == entry.Slug);
                                            <div style="display:flex;align-items:center;gap:6px;font-size:0.9em;">
                                                <span style="width:20px;text-align:right;color:var(--text-muted);">@(i + 1).</span>
                                                <span style="padding:2px 6px;border-radius:4px;background:@(stage?.StageColor ?? "#666")20;border:1px solid @(stage?.StageColor ?? "#ccc");">
                                                    @(stage?.StageIcon ?? "❓") @(stage?.Name ?? entry.Slug)
                                                </span>
                                                <span class="badge badge-secondary" style="font-size:0.75em;">@entry.Level</span>
                                                @if (entry.IsPlateReleaseTrigger) { <span class="badge badge-warning" style="font-size:0.7em;">Plate Release</span> }
                                                @if (entry.DurationFromBuildConfig) { <span class="badge badge-info" style="font-size:0.7em;">Slicer Data</span> }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p style="color:var(--text-muted);font-style:italic;">No approach selected — you can configure the process manually after creation.</p>
                            }
                        </div>
                    </div>
                </div>

                <div style="display: flex; gap: 8px; margin-top: 16px;">
                    <button class="btn btn-secondary" @onclick="WizardBack">← Back</button>
                    <button class="btn btn-primary" style="margin-left:auto;" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
                        Create Part
                    </button>
                </div>
            }
        }
        else
        {
            @* ═══════════════════════════════════════════════════════════════
               EDIT EXISTING PART — tabbed interface (unchanged)
               ═══════════════════════════════════════════════════════════════ *@
            <div class="page-header">
                <div>
                    <button class="btn btn-sm btn-secondary" @onclick="GoBack" style="margin-bottom: 8px;">← Parts</button>
                    <h1 class="page-title">Edit @_part!.PartNumber — @_part.Name</h1>
                </div>
                <div style="display: flex; gap: 8px; align-items: center;">
                    <a href="/parts/@Id" class="btn btn-sm btn-secondary">👁️ Detail</a>
                    <a href="/builds" class="btn btn-sm btn-secondary">📦 Builds</a>
                    @if (_buildsForPart?.Any() == true)
                    {
                        <span class="badge badge-info" style="font-size: 0.75rem;">@_buildsForPart.Count build@(_buildsForPart.Count != 1 ? "s" : "")</span>
                    }
                    @if (ShowAdditiveTabs)
                    {
                        <a href="/builds?newForPart=@Id" class="btn btn-sm btn-primary">+ New Build</a>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">@_error</div>
            }

            @if (_validationErrors.Count > 0)
            {
                <div class="alert alert-danger" style="margin-bottom: 12px;">
                    <strong>Please fix the following:</strong>
                    <ul style="margin: 8px 0 0 16px;">
                        @foreach (var err in _validationErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }

            <!-- Tab Bar -->
            <div class="tab-bar" style="margin-bottom: 16px;">
                <button class="tab @(_tab == "info" ? "active" : "")" @onclick='() => _tab = "info"'>Part Info</button>
                <button class="tab @(_tab == "pdm" ? "active" : "")" @onclick='() => _tab = "pdm"'>Drawing & Revision</button>
                <button class="tab @(_tab == "process" ? "active" : "")" @onclick='() => _tab = "process"'>Process</button>
                <button class="tab @(_tab == "pricing" ? "active" : "")" @onclick='() => _tab = "pricing"'>💰 Pricing</button>
                <button class="tab @(_tab == "programs" ? "active" : "")" @onclick='() => _tab = "programs"'>Programs (@(_partPrograms?.Count ?? 0))</button>
                <button class="tab @(_tab == "builds" ? "active" : "")" @onclick='() => _tab = "builds"'>Builds (@(_buildsForPart?.Count ?? 0))</button>
                <button class="tab @(_tab == "bom" ? "active" : "")" @onclick='() => _tab = "bom"'>BOM / Materials (@(_bomItems?.Count ?? 0))</button>
                @if (ShowAdditiveTabs)
                {
                    <button class="tab @(_tab == "stacking" ? "active" : "")" @onclick='() => _tab = "stacking"'>Stacking</button>
                }
                @if (_showDlms)
                {
                    <button class="tab @(_tab == "defense" ? "active" : "")" @onclick='() => _tab = "defense"'>Defense / DLMS</button>
                }
                @if (_customFieldDefs.Count > 0)
                {
                    <button class="tab @(_tab == "custom" ? "active" : "")" @onclick='() => _tab = "custom"'>Custom Fields</button>
                }
            </div>

            <!-- Part Info Tab -->
            @if (_tab == "info")
            {
                <div class="card">
                    <h3 class="card-title">Basic Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label">Part Number <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.PartNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Name <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="_part!.Name" />
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="_part!.Description" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Material <span style="color:var(--danger)">*</span></label>
                            <select class="form-control" value="@_part!.Material" @onchange="OnMaterialChanged">
                                <option value="">Select material...</option>
                                @if (_materials != null)
                                {
                                    @foreach (var m in _materials)
                                    {
                                        <option value="@m.Name">@m.Name (@m.Category)</option>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(_part.Material) && _materials?.All(m => m.Name != _part.Material) == true)
                                {
                                    <option value="@_part.Material">@_part.Material (custom)</option>
                                }
                            </select>
                            <small style="color: var(--text-muted);">Or type a custom value below:</small>
                            <input class="form-control" @bind="_part!.Material" style="margin-top: 4px;" placeholder="Custom material name..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Manufacturing Approach</label>
                            <select class="form-control" value="@_part!.ManufacturingApproachId" @onchange="OnApproachChanged">
                                <option value="">Select approach...</option>
                                @foreach (var a in _approaches)
                                {
                                    <option value="@a.Id">@(a.IconEmoji) @a.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Raw Material Spec</label>
                            <input class="form-control" @bind="_part!.RawMaterialSpec" placeholder="e.g. AMS 4911" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Estimated Weight (kg)</label>
                            <input class="form-control" type="number" step="0.01" @bind="_part!.EstimatedWeightKg" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                <input type="checkbox" @bind="_part!.IsActive" style="margin-right: 6px;" />Active
                            </label>
                        </div>
                    </div>
                </div>
            }

            <!-- PDM / Drawing Tab -->
            @if (_tab == "pdm")
            {
                <div class="card">
                    <h3 class="card-title">Drawing & Revision Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label">Drawing Number</label>
                            <input class="form-control" @bind="_part!.DrawingNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Current Revision</label>
                            <input class="form-control" @bind="_part!.Revision" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Customer Part Number</label>
                            <input class="form-control" @bind="_part!.CustomerPartNumber" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Revision Date</label>
                            <input class="form-control" type="date" @bind="_part!.RevisionDate" />
                        </div>
                    </div>
                    <p style="color: var(--text-muted); margin-top: 12px; font-size: 0.85rem;">
                        To formally bump the revision (with history tracking), use the "Bump Revision" button on the Part Detail page.
                        Drawings can be uploaded from the Part Detail → Drawings tab.
                    </p>
                </div>
            }

            <!-- Manufacturing Process Tab -->
            @if (_tab == "process")
            {
                <ProcessEditor PartId="@Id" CurrentUser="@_currentUser" />
            }

            @if (_tab == "pricing")
            {
                <PartPricingEditor PartId="@Id" />
            }

            <!-- Builds Tab -->
            @if (_tab == "builds")
            {
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <h3 class="card-title" style="margin: 0;">Builds</h3>
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <a href="/builds" class="btn btn-sm btn-secondary">📦 All Builds</a>
                            <a href="/parts/@Id" class="btn btn-sm btn-secondary">👁️ Part Detail</a>
                            @if (ShowAdditiveTabs)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="ShowCreateBuild">+ New Build</button>
                            }
                        </div>
                    </div>

                    @if (_buildsForPart == null || !_buildsForPart.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">🏗️</div>
                            <div class="empty-state-text">No builds contain this part yet.</div>
                            @if (ShowAdditiveTabs)
                            {
                                <div style="margin-top: 12px;">
                                    <button class="btn btn-primary" @onclick="ShowCreateBuild">+ Create a Build for This Part</button>
                                    <div style="color: var(--text-muted); font-size: 0.8rem; margin-top: 6px;">
                                        Or go to <a href="/builds" style="color: var(--primary);">Build Planning</a> to add this part to an existing build.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div style="color: var(--text-muted); font-size: 0.85rem; margin-top: 8px;">
                                    This part's manufacturing approach doesn't use build plates.
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        @* Build summary stats *@
                        var completedBuilds = _buildsForPart.Count(b => b.Status == BuildPackageStatus.Completed);
                        var activeBuilds = _buildsForPart.Count(b => b.Status != BuildPackageStatus.Completed && b.Status != BuildPackageStatus.Cancelled);
                        <div style="display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap;">
                            <div style="background: var(--bg-secondary); padding: 8px 14px; border-radius: 8px;">
                                <div style="font-size: 0.7rem; color: var(--text-muted);">Total Builds</div>
                                <div style="font-weight: 600;">@_buildsForPart.Count</div>
                            </div>
                            <div style="background: var(--bg-secondary); padding: 8px 14px; border-radius: 8px;">
                                <div style="font-size: 0.7rem; color: var(--text-muted);">Active</div>
                                <div style="font-weight: 600;">@activeBuilds</div>
                            </div>
                            <div style="background: var(--bg-secondary); padding: 8px 14px; border-radius: 8px;">
                                <div style="font-size: 0.7rem; color: var(--text-muted);">Completed</div>
                                <div style="font-weight: 600;">@completedBuilds</div>
                            </div>
                        </div>

                        @* Build selector dropdown *@
                        <div style="margin-bottom: 16px;">
                            <label class="form-label">Select Build</label>
                            <div style="display: flex; gap: 8px; align-items: center;">
                                <select class="form-control" style="max-width: 400px;" @bind="_selectedBuildId">
                                    <option value="0">— Select a build —</option>
                                    @foreach (var build in _buildsForPart)
                                    {
                                        var statusIcon = build.Status switch
                                        {
                                            BuildPackageStatus.Draft => "📝",
                                            BuildPackageStatus.Sliced => "📐",
                                            BuildPackageStatus.Ready => "✅",
                                            BuildPackageStatus.Scheduled => "📅",
                                            BuildPackageStatus.Printing => "🖨️",
                                            BuildPackageStatus.PostPrint => "🔥",
                                            BuildPackageStatus.Completed => "✔️",
                                            BuildPackageStatus.Cancelled => "❌",
                                            _ => "📦"
                                        };
                                        <option value="@build.Id">@statusIcon @build.Name — @build.Status (@(build.Machine?.Name ?? "No machine"))</option>
                                    }
                                </select>
                                @if (_selectedBuildId > 0)
                                {
                                    <a href="/builds" class="btn btn-sm btn-primary">Open in Build Planning →</a>
                                }
                            </div>
                        </div>

                        @* Selected build detail *@
                        @if (_selectedBuildId > 0)
                        {
                            var selected = _buildsForPart.FirstOrDefault(b => b.Id == _selectedBuildId);
                            @if (selected != null)
                            {
                                <div style="background: var(--bg-tertiary); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                        <h4 style="margin: 0; font-size: 1rem;">@selected.Name</h4>
                                        <span class="badge @(selected.Status switch { BuildPackageStatus.Completed => "badge-active", BuildPackageStatus.Cancelled => "badge-cancelled", BuildPackageStatus.Printing => "badge-warning", _ => "badge-info" })">
                                            @selected.Status
                                        </span>
                                    </div>
                                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; font-size: 0.85rem;">
                                        <div>
                                            <span class="form-label">Machine</span>
                                            <div>@(selected.Machine?.Name ?? "—")</div>
                                        </div>
                                        <div>
                                            <span class="form-label">Total Parts</span>
                                            <div>@selected.TotalPartCount</div>
                                        </div>
                                        <div>
                                            <span class="form-label">Est. Duration</span>
                                            <div>@(selected.EstimatedDurationHours.HasValue ? $"{selected.EstimatedDurationHours.Value:F1} hrs" : "—")</div>
                                        </div>
                                        @if (selected.ScheduledDate.HasValue)
                                        {
                                            <div>
                                                <span class="form-label">Scheduled</span>
                                                <div>@selected.ScheduledDate.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                            </div>
                                        }
                                        @if (selected.PrintStartedAt.HasValue)
                                        {
                                            <div>
                                                <span class="form-label">Print Started</span>
                                                <div>@selected.PrintStartedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                            </div>
                                        }
                                        @if (selected.PrintCompletedAt.HasValue)
                                        {
                                            <div>
                                                <span class="form-label">Print Completed</span>
                                                <div>@selected.PrintCompletedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                            </div>
                                        }
                                    </div>
                                    @if (selected.Parts.Any())
                                    {
                                        <div style="margin-top: 12px;">
                                            <span class="form-label" style="display: block; margin-bottom: 6px;">Nested Parts</span>
                                            <table class="data-table" style="font-size: 0.85rem;">
                                                <thead>
                                                    <tr>
                                                        <th>Part</th>
                                                        <th style="text-align: right; width: 70px;">Qty</th>
                                                        <th style="text-align: right; width: 70px;">Stack</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var pp in selected.Parts)
                                                    {
                                                        var isCurrent = pp.PartId == Id;
                                                        <tr style="@(isCurrent ? "background: var(--primary-bg); font-weight: 600;" : "")">
                                                            <td>
                                                                @if (isCurrent)
                                                                {
                                                                    <span>@(pp.Part?.PartNumber ?? $"#{pp.PartId}") — @(pp.Part?.Name ?? "") (this part)</span>
                                                                }
                                                                else
                                                                {
                                                                    <a href="/parts/@pp.PartId/edit" style="text-decoration: none; color: var(--primary);">@(pp.Part?.PartNumber ?? $"#{pp.PartId}") — @(pp.Part?.Name ?? "")</a>
                                                                }
                                                            </td>
                                                            <td style="text-align: right;">@pp.Quantity</td>
                                                            <td style="text-align: right;">@(pp.StackLevel)x</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        @* Builds table *@
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Build</th>
                                    <th>Machine</th>
                                    <th>Status</th>
                                    <th style="text-align: right;">Qty in Build</th>
                                    <th style="text-align: right;">Print Time</th>
                                    <th>Scheduled</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var build in _buildsForPart)
                                {
                                    var partEntry = build.Parts.FirstOrDefault(p => p.PartId == Id);
                                    <tr style="cursor: pointer; @(_selectedBuildId == build.Id ? "background: var(--primary-bg);" : "")" @onclick="() => _selectedBuildId = build.Id">
                                        <td>
                                            <a href="/builds" style="font-weight: 600; text-decoration: none; color: var(--primary);" @onclick:stopPropagation>@build.Name</a>
                                        </td>
                                        <td>@(build.Machine?.Name ?? "—")</td>
                                        <td>
                                            <span class="badge @(build.Status switch { BuildPackageStatus.Completed => "badge-active", BuildPackageStatus.Cancelled => "badge-cancelled", BuildPackageStatus.Printing => "badge-warning", _ => "badge-info" })">
                                                @build.Status
                                            </span>
                                        </td>
                                        <td style="text-align: right;">@(partEntry?.Quantity ?? 0)</td>
                                        <td style="text-align: right;">@(build.EstimatedDurationHours.HasValue ? $"{build.EstimatedDurationHours.Value:F1} hrs" : "—")</td>
                                        <td>@(build.ScheduledDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }

            <!-- Programs Tab -->
            @if (_tab == "programs")
            {
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <h3 class="card-title" style="margin: 0;">Machine Programs</h3>
                        <a href="/programs" class="btn btn-sm btn-primary">+ Manage All Programs</a>
                    </div>

                    @if (_partPrograms == null || !_partPrograms.Any())
                    {
                        <div class="empty-state" style="padding: 24px;">
                            <div class="empty-state-text">No machine programs linked to this part yet.</div>
                            <a href="/programs" class="btn btn-sm btn-secondary" style="margin-top: 8px;">Go to Machine Programs →</a>
                        </div>
                    }
                    else
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Program #</th>
                                    <th>Name</th>
                                    <th>Machine</th>
                                    <th>Status</th>
                                    <th style="text-align: right;">Setup</th>
                                    <th style="text-align: right;">Run/Part</th>
                                    <th style="text-align: right;">Cycle</th>
                                    <th style="text-align: right;">Files</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prog in _partPrograms)
                                {
                                    <tr>
                                        <td><a href="/programs" style="font-weight: 600; text-decoration: none; color: var(--primary);">@prog.ProgramNumber</a></td>
                                        <td>@prog.Name</td>
                                        <td>@(prog.Machine?.Name ?? prog.MachineType ?? "—")</td>
                                        <td><span class="badge badge-@prog.Status.ToString().ToLower()">@prog.Status</span></td>
                                        <td style="text-align: right;">@(prog.SetupTimeMinutes?.ToString("F0") ?? "—") min</td>
                                        <td style="text-align: right;">@(prog.RunTimeMinutes?.ToString("F1") ?? "—") min</td>
                                        <td style="text-align: right;">@(prog.CycleTimeMinutes?.ToString("F1") ?? "—") min</td>
                                        <td style="text-align: right;">@(prog.Files?.Count ?? 0)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }

            <!-- BOM / Materials Tab -->
            @if (_tab == "bom")
            {
                <div class="card">
                    <h3 class="card-title">Bill of Materials</h3>
                    <p style="color: var(--text-muted); margin-bottom: 12px;">Define raw materials, inventory items, and sub-parts required to produce one unit of this part.</p>

                    <!-- Add BOM Item Form -->
                    <div style="margin-bottom: 12px; display: flex; flex-direction: column; gap: 8px;">
                        <!-- Row 1: Type + Item picker + Qty + UoM -->
                        <div style="display: flex; gap: 8px; align-items: end; flex-wrap: wrap;">
                            <div class="form-group" style="width: 150px;">
                                <label class="form-label">Type</label>
                                <select class="form-control" @bind="_bomItemType">
                                    <option value="@BomItemType.RawMaterial">Raw Material</option>
                                    <option value="@BomItemType.InventoryItem">Inventory Item</option>
                                    <option value="@BomItemType.SubPart">Sub-Part</option>
                                </select>
                            </div>

                            @if (_bomItemType == BomItemType.RawMaterial)
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Material</label>
                                    <select class="form-control" @bind="_bomMaterialId">
                                        <option value="0">Select material...</option>
                                        @if (_materials != null)
                                        {
                                            @foreach (var m in _materials)
                                            {
                                                <option value="@m.Id">@m.Name (@m.Category)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            else if (_bomItemType == BomItemType.InventoryItem)
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Inventory Item</label>
                                    <select class="form-control" @bind="_bomInventoryItemId">
                                        <option value="0">Select item...</option>
                                        @if (_inventoryItems != null)
                                        {
                                            @foreach (var inv in _inventoryItems)
                                            {
                                                <option value="@inv.Id">@inv.ItemNumber — @inv.Name (@inv.ItemType)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div class="form-group" style="flex: 1; min-width: 200px;">
                                    <label class="form-label">Sub-Part</label>
                                    <select class="form-control" @bind="_bomChildPartId">
                                        <option value="0">Select part...</option>
                                        @if (_allParts != null)
                                        {
                                            @foreach (var p in _allParts.Where(p => p.Id != (_part?.Id ?? 0)))
                                            {
                                                <option value="@p.Id">@p.PartNumber — @p.Description</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }

                            <div class="form-group" style="width: 100px;">
                                <label class="form-label">Qty</label>
                                <input class="form-control" type="number" step="0.01" min="0.01" @bind="_bomQty" />
                            </div>
                            <div class="form-group" style="width: 80px;">
                                <label class="form-label">UoM</label>
                                <input class="form-control" @bind="_bomUom" placeholder="each" />
                            </div>
                        </div>

                        <!-- Row 2: Cost override + Scrap + Ref Designator + Add button -->
                        <div style="display: flex; gap: 8px; align-items: end; flex-wrap: wrap;">
                            <div class="form-group" style="width: 130px;">
                                <label class="form-label">Cost Override</label>
                                <input class="form-control" type="number" step="0.01" min="0" @bind="_bomUnitCostOverride" placeholder="Auto" />
                            </div>
                            <div class="form-group" style="width: 100px;">
                                <label class="form-label">Scrap %</label>
                                <input class="form-control" type="number" step="0.1" min="0" max="100" @bind="_bomScrapPct" />
                            </div>
                            @if (_bomItemType == BomItemType.SubPart)
                            {
                                <div class="form-group" style="width: 130px;">
                                    <label class="form-label">Ref Designator</label>
                                    <input class="form-control" @bind="_bomRefDesignator" placeholder="e.g. R1, C3" />
                                </div>
                            }
                            <button class="btn btn-sm btn-primary" @onclick="AddBomItem" disabled="@(!CanAddBomItem)" style="height: 36px;">+ Add</button>
                        </div>
                    </div>

                    @if (_bomItems != null && _bomItems.Any(b => b.IsActive))
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Type</th>
                                    <th>Item</th>
                                    <th style="text-align: right;">Qty</th>
                                    <th>UoM</th>
                                    <th style="text-align: right;">Unit Cost</th>
                                    <th style="text-align: right;">Scrap %</th>
                                    <th style="text-align: right;">Ext. Cost</th>
                                    <th>Notes</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _bomItems.Where(b => b.IsActive).OrderBy(b => b.SortOrder))
                                {
                                    <tr>
                                        <td>@item.SortOrder</td>
                                        <td>
                                            @switch (item.ItemType)
                                            {
                                                case BomItemType.RawMaterial:
                                                    <span class="badge badge-info">Material</span>
                                                    break;
                                                case BomItemType.InventoryItem:
                                                    <span class="badge badge-secondary">Inventory</span>
                                                    break;
                                                case BomItemType.SubPart:
                                                    <span class="badge badge-primary">Sub-Part</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @switch (item.ItemType)
                                            {
                                                case BomItemType.RawMaterial:
                                                    @(item.Material?.Name ?? $"Material #{item.MaterialId}")
                                                    break;
                                                case BomItemType.InventoryItem:
                                                    @(item.InventoryItem != null ? $"{item.InventoryItem.ItemNumber} — {item.InventoryItem.Name}" : $"Item #{item.InventoryItemId}")
                                                    break;
                                                case BomItemType.SubPart:
                                                    var childPart = item.ChildPart ?? _allParts?.FirstOrDefault(p => p.Id == item.ChildPartId);
                                                    @(childPart != null ? $"{childPart.PartNumber} — {childPart.Description}" : $"Part #{item.ChildPartId}")
                                                    if (!string.IsNullOrEmpty(item.ReferenceDesignator))
                                                    {
                                                        <span style="color: var(--text-muted); margin-left: 4px;">[@item.ReferenceDesignator]</span>
                                                    }
                                                    break;
                                            }
                                        </td>
                                        <td style="text-align: right;">@item.QuantityRequired.ToString("F2")</td>
                                        <td>@item.UnitOfMeasure</td>
                                        <td style="text-align: right;">
                                            @{ var unitCost = item.GetResolvedUnitCost(); }
                                            @if (item.UnitCost.HasValue)
                                            {
                                                <span title="Manual override">@item.UnitCost.Value.ToString("C2") ✏️</span>
                                            }
                                            else if (item.ItemType == BomItemType.SubPart)
                                            {
                                                <span style="color: var(--text-muted);" title="Resolved from sub-part BOM">roll-up</span>
                                            }
                                            else
                                            {
                                                @unitCost.ToString("C2")
                                            }
                                        </td>
                                        <td style="text-align: right;">@(item.ScrapFactorPct > 0 ? $"{item.ScrapFactorPct:F1}%" : "—")</td>
                                        <td style="text-align: right; font-weight: 600;">
                                            @if (item.ItemType == BomItemType.SubPart && !item.UnitCost.HasValue)
                                            {
                                                <span style="color: var(--text-muted);" title="Calculated from sub-part BOM tree">—</span>
                                            }
                                            else
                                            {
                                                @item.GetExtendedCost().ToString("C2")
                                            }
                                        </td>
                                        <td><input class="form-control" style="width: 120px;" value="@item.Notes" @onchange="async e => { item.Notes = e.Value?.ToString(); await UpdateBomNotes(item); }" placeholder="Notes..." /></td>
                                        <td><button class="btn btn-sm btn-danger" @onclick="() => RemoveBomItem(item)">✕</button></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="font-weight: 600; border-top: 2px solid var(--border);">
                                    <td colspan="7" style="text-align: right;">Total (excl. sub-part roll-ups):</td>
                                    <td style="text-align: right;">
                                        @{
                                            var directTotal = _bomItems!.Where(b => b.IsActive && b.ItemType != BomItemType.SubPart)
                                                .Sum(b => b.GetExtendedCost())
                                                + _bomItems!.Where(b => b.IsActive && b.ItemType == BomItemType.SubPart && b.UnitCost.HasValue)
                                                .Sum(b => b.GetExtendedCost());
                                        }
                                        @directTotal.ToString("C2")
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">📦</div>
                            <div class="empty-state-text">No BOM items. Add materials, inventory items, or sub-parts required to manufacture this part.</div>
                        </div>
                    }
                </div>
            }

            <!-- Stacking Tab (approach-driven) -->
            @if (_tab == "stacking" && ShowAdditiveTabs)
            {
                <div class="card">
                    <h3 class="card-title">SLS Stacking Configuration</h3>
                    <p style="color: var(--text-muted); margin-bottom: 12px;">Configure how this part can be stacked in SLS/LPBF builds. These are <strong>planning guidelines</strong> — actual per-build counts come from the slicer.</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.AllowStacking" style="margin-right: 6px;" />Allow Stacking</label>
                        </div>
                        <div class="form-group"><label class="form-label">Max Stack Count</label><input class="form-control" type="number" min="1" max="10" @bind="_part!.AdditiveBuildConfig!.MaxStackCount" /></div>
                        <div class="form-group"><label class="form-label">Planned Parts/Build (Single)</label><input class="form-control" type="number" min="1" max="500" @bind="_part!.AdditiveBuildConfig!.PlannedPartsPerBuildSingle" /></div>
                        <div class="form-group"><label class="form-label">Single Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part!.AdditiveBuildConfig!.SingleStackDurationHours" /></div>

                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.EnableDoubleStack" style="margin-right: 6px;" />Enable Double Stack</label>
                        </div>
                        @if (_part!.AdditiveBuildConfig!.EnableDoubleStack)
                        {
                            <div class="form-group"><label class="form-label">Planned Parts/Build (Double)</label><input class="form-control" type="number" min="1" max="500" @bind="_part.AdditiveBuildConfig!.PlannedPartsPerBuildDouble" /></div>
                            <div class="form-group"><label class="form-label">Double Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part.AdditiveBuildConfig!.DoubleStackDurationHours" /></div>
                        }

                        <div class="form-group" style="grid-column: span 2;">
                            <label class="form-label"><input type="checkbox" @bind="_part!.AdditiveBuildConfig!.EnableTripleStack" style="margin-right: 6px;" />Enable Triple Stack</label>
                        </div>
                        @if (_part!.AdditiveBuildConfig!.EnableTripleStack)
                        {
                            <div class="form-group"><label class="form-label">Planned Parts/Build (Triple)</label><input class="form-control" type="number" min="1" max="500" @bind="_part.AdditiveBuildConfig!.PlannedPartsPerBuildTriple" /></div>
                            <div class="form-group"><label class="form-label">Triple Stack Duration (hrs)</label><input class="form-control" type="number" step="0.1" @bind="_part.AdditiveBuildConfig!.TripleStackDurationHours" /></div>
                        }
                    </div>
                </div>
            }

            <!-- Defense / DLMS Tab -->
            @if (_tab == "defense" && _showDlms)
            {
                <div class="card">
                    <h3 class="card-title">🛡️ Defense & Export Classification</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label class="form-label"><input type="checkbox" @bind="_part!.IsDefensePart" style="margin-right: 6px;" />Defense Part</label>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ITAR Classification</label>
                            <select class="form-control" @bind="_part!.ItarClassification">
                                @foreach (var c in Enum.GetValues<ItarClassification>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            }

            <!-- Custom Fields Tab -->
            @if (_tab == "custom" && _customFieldDefs.Count > 0)
            {
                <div class="card">
                    <h3 class="card-title">Custom Fields</h3>
                    <CustomFieldsEditor FieldDefinitions="_customFieldDefs" Values="_customFieldValues" ValuesChanged="OnCustomFieldsChanged" />
                </div>
            }

            <!-- Action Buttons -->
            <div style="display: flex; gap: 8px; margin-top: 16px;">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
                    Save Changes
                </button>
                <button class="btn btn-secondary" @onclick="GoBack">Cancel</button>
                <button class="btn btn-sm btn-secondary" @onclick="ViewDetail" style="margin-left: auto;">View Part Detail →</button>
            </div>
        }
    </Authorized>
</AuthorizeView>

@* ── Create Build Modal ── *@
@if (_showCreateBuild)
{
    <div class="modal-overlay" @onclick="() => _showCreateBuild = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">New Build for @(_part?.PartNumber ?? "Part")</span>
                <button class="modal-close" @onclick="() => _showCreateBuild = false">&times;</button>
            </div>
            <div class="form-group">
                <label class="form-label">Build Name *</label>
                <input class="form-control" @bind="_newBuildName" placeholder="e.g. Build-SUP-TUBE-0115" />
            </div>
            <div class="form-group">
                <label class="form-label">Machine *</label>
                <select class="form-control" @bind="_newBuildMachineId">
                    <option value="0">Select machine...</option>
                    @if (_machines != null)
                    {
                        @foreach (var m in _machines)
                        {
                            <option value="@m.Id">@m.Name (@m.MachineId)</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Notes</label>
                <textarea class="form-control" @bind="_newBuildNotes"></textarea>
            </div>
            <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px;">
                This will create a new build and add <strong>@(_part?.PartNumber)</strong> to it.
            </div>
            <div style="display: flex; gap: 8px;">
                <button class="btn btn-primary" @onclick="CreateBuildForPart" disabled="@_creatingBuild">
                    @if (_creatingBuild) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
                    Create Build
                </button>
                <button class="btn btn-secondary" @onclick="() => _showCreateBuild = false">Cancel</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public int Id { get; set; }

    private bool _isNew => Id == 0;
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private List<string> _validationErrors = new();
    private string _tab = "info";
    private int _wizardStep = 1;
    private string _currentUser = "System";
    private ConfirmDialog _confirm = null!;

    // Feature flags
    private bool _showDlms;

    // Reference data
    private List<Material>? _materials;
    private List<ProductionStage>? _allStages;
    private List<Machine>? _machines;

    // Custom fields
    private List<CustomFieldDefinition> _customFieldDefs = new();
    private Dictionary<string, string> _customFieldValues = new();

    // BOM
    private List<PartBomItem>? _bomItems;
    private BomItemType _bomItemType = BomItemType.RawMaterial;
    private int _bomMaterialId;
    private int _bomInventoryItemId;
    private int _bomChildPartId;
    private decimal _bomQty = 1;
    private string _bomUom = "kg";
    private decimal? _bomUnitCostOverride;
    private decimal _bomScrapPct;
    private string? _bomRefDesignator;
    private List<InventoryItem>? _inventoryItems;
    private List<Part>? _allParts;

    // Part being edited
    private Part? _part;

    // Builds for this part
    private List<BuildPackage>? _buildsForPart;
    private int _selectedBuildId;
    private bool _showCreateBuild;
    private string _newBuildName = "";
    private int _newBuildMachineId;
    private string? _newBuildNotes;
    private bool _creatingBuild;

    // Programs for this part
    private List<MachineProgram>? _partPrograms;

    // Manufacturing approaches (DB-backed)
    private List<ManufacturingApproach> _approaches = new();

    private ManufacturingApproach? SelectedApproach =>
        _approaches.FirstOrDefault(a => a.Id == _part?.ManufacturingApproachId);

    private bool ShowAdditiveTabs => SelectedApproach?.IsAdditive == true;

    protected override async Task OnInitializedAsync()
    {
        _showDlms = Features.IsEnabled("dlms");

        // Load reference data
        _materials = await MaterialService.GetAllMaterialsAsync();
        _approaches = await ApproachService.GetAllAsync();
        _allStages = await StageService.GetAllStagesAsync();
        _machines = await MachineService.GetAllMachinesAsync(true);
        _inventoryItems = await InventoryService.GetAllItemsAsync();
        _allParts = await PartService.GetAllPartsAsync();

        if (_isNew)
        {
            _part = new Part
            {
                Material = "",
                IsActive = true,
                CreatedBy = _currentUser,
                LastModifiedBy = _currentUser
            };
            _bomItems = new();
        }
        else
        {
            _part = await PartService.GetPartByIdAsync(Id);
            if (_part != null)
            {
                _bomItems = await PartService.GetBomItemsAsync(Id);

                // Backfill MaterialId from Material string if not set
                if (_part.MaterialId == null && !string.IsNullOrEmpty(_part.Material))
                {
                    var match = _materials?.FirstOrDefault(m => m.Name == _part.Material);
                    if (match != null) _part.MaterialId = match.Id;
                }

                // Load builds containing this part
                try
                {
                    _buildsForPart = await BuildPlanningService.GetBuildsForPartAsync(Id);
                }
                catch
                {
                    _buildsForPart = [];
                }

                // Load machine programs for this part
                try
                {
                    _partPrograms = await MachineProgramService.GetProgramsForPartAsync(Id);
                }
                catch
                {
                    _partPrograms = [];
                }
            }
        }

        // Ensure AdditiveBuildConfig exists when approach is additive
        EnsureAdditiveBuildConfig();

        // Load custom field definitions for "Part" entity
        _customFieldDefs = await CustomFieldService.GetFieldDefinitionsAsync("Part");
        if (_part != null && !string.IsNullOrEmpty(_part.CustomFieldValues))
        {
            try
            {
                _customFieldValues = JsonSerializer.Deserialize<Dictionary<string, string>>(_part.CustomFieldValues) ?? new();
            }
            catch { _customFieldValues = new(); }
        }

        _loading = false;
    }

    private void OnMaterialChanged(ChangeEventArgs e)
    {
        var selectedName = e.Value?.ToString() ?? "";
        _part!.Material = selectedName;
        var match = _materials?.FirstOrDefault(m => m.Name == selectedName);
        _part.MaterialId = match?.Id;
    }

    private async Task OnApproachChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            _part!.ManufacturingApproachId = id;
        else
            _part!.ManufacturingApproachId = null;

        EnsureAdditiveBuildConfig();
    }

    private void SelectApproach(int approachId)
    {
        _part!.ManufacturingApproachId = _part.ManufacturingApproachId == approachId ? null : approachId;
        EnsureAdditiveBuildConfig();
    }

    private bool WizardCanAdvance => _wizardStep switch
    {
        1 => !string.IsNullOrWhiteSpace(_part?.PartNumber) && !string.IsNullOrWhiteSpace(_part?.Name),
        _ => true
    };

    private void WizardNext()
    {
        _error = null;
        _validationErrors.Clear();
        if (_wizardStep < 3) _wizardStep++;
    }

    private void WizardBack()
    {
        _error = null;
        _validationErrors.Clear();
        if (_wizardStep > 1) _wizardStep--;
    }

    /// <summary>
    /// Creates or removes AdditiveBuildConfig based on the selected ManufacturingApproach.
    /// </summary>
    private void EnsureAdditiveBuildConfig()
    {
        if (_part == null) return;

        if (ShowAdditiveTabs && _part.AdditiveBuildConfig == null)
        {
            _part.AdditiveBuildConfig = new PartAdditiveBuildConfig
            {
                PartId = _part.Id,
                PlannedPartsPerBuildSingle = 1,
                MaxStackCount = 1
            };
        }
    }

    private async Task Save()
    {
        _error = null;
        _validationErrors.Clear();

        // Validate
        var errors = await PartService.ValidatePartAsync(_part!);
        if (errors.Count > 0)
        {
            _validationErrors = errors;
            return;
        }

        _saving = true;
        try
        {
            // Serialize custom field values
            if (_customFieldValues.Count > 0)
            {
                _part!.CustomFieldValues = JsonSerializer.Serialize(_customFieldValues);
            }

            _part!.LastModifiedBy = _currentUser;

            if (_isNew)
            {
                _part.CreatedBy = _currentUser;
                _part = await PartService.CreatePartAsync(_part);

                // Persist in-memory BOM
                foreach (var item in (_bomItems ?? []).Where(b => b.IsActive))
                {
                    item.PartId = _part.Id;
                    await PartService.AddBomItemAsync(item);
                }

                // Auto-scaffold manufacturing process from approach template
                if (_part.ManufacturingApproachId.HasValue)
                {
                    try
                    {
                        await ProcessService.CreateProcessFromApproachAsync(
                            _part.Id, _part.ManufacturingApproachId.Value, _currentUser);
                    }
                    catch (Exception ex)
                    {
                        Toast.ShowWarning($"Part created but process scaffold failed: {ex.Message}");
                    }
                }

                Toast.ShowSuccess("Part created successfully");
                Nav.NavigateTo($"/parts/{_part.Id}/edit", forceLoad: true);
            }
            else
            {
                await PartService.UpdatePartAsync(_part);
                Toast.ShowSuccess("Part saved");
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private void OnCustomFieldsChanged(Dictionary<string, string> values)
    {
        _customFieldValues = values;
    }

    // BOM CRUD
    private bool CanAddBomItem => _part != null && _bomItemType switch
    {
        BomItemType.RawMaterial => _bomMaterialId != 0,
        BomItemType.InventoryItem => _bomInventoryItemId != 0,
        BomItemType.SubPart => _bomChildPartId != 0,
        _ => false
    };

    private async Task AddBomItem()
    {
        if (_part == null || !CanAddBomItem) return;

        // Circular reference check for sub-parts
        if (_bomItemType == BomItemType.SubPart && !_isNew)
        {
            if (await PartService.WouldCreateCircularBomAsync(_part.Id, _bomChildPartId))
            {
                Toast.ShowError("Cannot add: this would create a circular BOM reference.");
                return;
            }
        }

        var nextOrder = (_bomItems?.Any() == true) ? _bomItems.Max(b => b.SortOrder) + 1 : 1;
        var item = new PartBomItem
        {
            PartId = _part.Id,
            ItemType = _bomItemType,
            MaterialId = _bomItemType == BomItemType.RawMaterial ? _bomMaterialId : null,
            Material = _bomItemType == BomItemType.RawMaterial ? _materials?.FirstOrDefault(m => m.Id == _bomMaterialId) : null,
            InventoryItemId = _bomItemType == BomItemType.InventoryItem ? _bomInventoryItemId : null,
            InventoryItem = _bomItemType == BomItemType.InventoryItem ? _inventoryItems?.FirstOrDefault(i => i.Id == _bomInventoryItemId) : null,
            ChildPartId = _bomItemType == BomItemType.SubPart ? _bomChildPartId : null,
            ChildPart = _bomItemType == BomItemType.SubPart ? _allParts?.FirstOrDefault(p => p.Id == _bomChildPartId) : null,
            QuantityRequired = _bomQty,
            UnitOfMeasure = _bomUom,
            UnitCost = _bomUnitCostOverride,
            ScrapFactorPct = _bomScrapPct,
            ReferenceDesignator = _bomItemType == BomItemType.SubPart ? _bomRefDesignator : null,
            SortOrder = nextOrder,
            CreatedBy = _currentUser
        };

        if (_isNew)
        {
            _bomItems ??= new();
            _bomItems.Add(item);
        }
        else
        {
            await PartService.AddBomItemAsync(item);
            _bomItems = await PartService.GetBomItemsAsync(_part.Id);
        }

        // Reset form
        _bomMaterialId = 0;
        _bomInventoryItemId = 0;
        _bomChildPartId = 0;
        _bomQty = 1;
        _bomUom = _bomItemType == BomItemType.RawMaterial ? "kg" : "each";
        _bomUnitCostOverride = null;
        _bomScrapPct = 0;
        _bomRefDesignator = null;
    }

    private async Task RemoveBomItem(PartBomItem item)
    {
        var name = item.ItemType switch
        {
            BomItemType.RawMaterial => item.Material?.Name ?? $"Material #{item.MaterialId}",
            BomItemType.InventoryItem => item.InventoryItem?.Name ?? $"Item #{item.InventoryItemId}",
            BomItemType.SubPart => item.ChildPart?.PartNumber ?? _allParts?.FirstOrDefault(p => p.Id == item.ChildPartId)?.PartNumber ?? $"Part #{item.ChildPartId}",
            _ => $"Item #{item.Id}"
        };
        if (!await _confirm.ShowAsync($"Remove '{name}' from the BOM?")) return;

        if (_isNew)
        {
            _bomItems?.Remove(item);
        }
        else
        {
            item.IsActive = false;
            item.LastModifiedDate = DateTime.UtcNow;
            await PartService.RemoveBomItemAsync(item.Id);
            _bomItems?.Remove(item);
        }
    }

    private async Task UpdateBomNotes(PartBomItem item)
    {
        if (!_isNew)
        {
            try
            {
                item.LastModifiedDate = DateTime.UtcNow;
                await PartService.UpdateBomItemAsync(item);
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to save notes: {ex.Message}");
            }
        }
    }

    // Navigation
    private void GoBack() => Nav.NavigateTo("/parts");
    private void ViewDetail() => Nav.NavigateTo($"/parts/{Id}");

    // Build management
    private void ShowCreateBuild()
    {
        _newBuildName = $"Build-{_part?.PartNumber ?? "NEW"}-{DateTime.UtcNow:MMdd}";
        _newBuildMachineId = 0;
        _newBuildNotes = null;
        _showCreateBuild = true;
    }

    private async Task CreateBuildForPart()
    {
        if (string.IsNullOrWhiteSpace(_newBuildName))
        {
            Toast.ShowError("Build name is required.");
            return;
        }
        if (_newBuildMachineId <= 0)
        {
            Toast.ShowError("Machine is required.");
            return;
        }

        _creatingBuild = true;
        try
        {
            var package = await BuildPlanningService.CreatePackageAsync(new BuildPackage
            {
                Name = _newBuildName,
                MachineId = _newBuildMachineId,
                Notes = _newBuildNotes,
                CreatedBy = _currentUser,
                LastModifiedBy = _currentUser
            });

            await BuildPlanningService.AddPartToPackageAsync(package.Id, Id, 1);

            _showCreateBuild = false;
            Toast.ShowSuccess($"Build '{_newBuildName}' created with this part.");

            // Reload builds list
            _buildsForPart = await BuildPlanningService.GetBuildsForPartAsync(Id);
            _selectedBuildId = package.Id;
            _tab = "builds";
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to create build: {ex.Message}");
        }
        finally
        {
            _creatingBuild = false;
        }
    }
}
