@page "/parts/{Id:int}"
@inject IPartService PartService
@inject IPartFileService FileService
@inject ICustomFieldService CustomFieldService
@inject ITenantFeatureService Features
@inject IBuildPlanningService BuildPlanningService
@inject NavigationManager Nav
@inject ToastService Toast
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@(_part?.Name ?? "Part Detail") - OpCentrix</PageTitle>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading part...</div>
}
else if (_part == null)
{
    <div class="card" style="text-align: center; padding: 40px;">
        <p style="color: var(--text-muted);">Part not found.</p>
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/parts")'>← Back to Parts</button>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <button class="btn btn-sm btn-secondary" @onclick='() => Nav.NavigateTo("/parts")' style="margin-bottom: 8px;">← Parts</button>
            <h1 class="page-title" style="margin: 0;">@_part.PartNumber — @_part.Name</h1>
            <div style="display: flex; gap: 8px; margin-top: 4px; align-items: center;">
                <span class="badge @(_part.IsActive ? "badge-active" : "badge-cancelled")">@(_part.IsActive ? "Active" : "Inactive")</span>
                @if (!string.IsNullOrEmpty(_part.Revision))
                {
                    <span class="badge badge-info">Rev @_part.Revision</span>
                }
                @if (_part.IsDefensePart)
                {
                    <span class="badge badge-warning">🛡️ Defense</span>
                }
            </div>
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="btn btn-secondary" @onclick="GoToEdit">✏️ Edit</button>
            <button class="btn btn-secondary" @onclick="ShowCloneModal">📋 Clone</button>
            <button class="btn btn-primary" @onclick="ShowRevisionBump">📝 Bump Revision</button>
        </div>
    </div>

    <!-- Tab Bar -->
    <div class="tab-bar" style="margin-bottom: 16px;">
        <button class="tab @(_tab == "overview" ? "active" : "")" @onclick='() => _tab = "overview"'>Overview</button>
        <button class="tab @(_tab == "routing" ? "active" : "")" @onclick='() => _tab = "routing"'>Routing (@(_part.StageRequirements?.Count ?? 0))</button>
        <button class="tab @(_tab == "bom" ? "active" : "")" @onclick='() => _tab = "bom"'>BOM (@(_bomItems?.Count ?? 0))</button>
        <button class="tab @(_tab == "drawings" ? "active" : "")" @onclick='() => _tab = "drawings"'>Drawings (@(_drawings?.Count ?? 0))</button>
        @if (HasAdditiveConfig())
        {
            <button class="tab @(_tab == "sls" ? "active" : "")" @onclick='() => _tab = "sls"'>Additive Config</button>
        }
        <button class="tab @(_tab == "revisions" ? "active" : "")" @onclick='() => _tab = "revisions"'>Revisions (@(_part.RevisionHistory?.Count ?? 0))</button>
        <button class="tab @(_tab == "notes" ? "active" : "")" @onclick='() => _tab = "notes"'>Notes (@(_part.Notes?.Count ?? 0))</button>
        <button class="tab @(_tab == "usage" ? "active" : "")" @onclick="LoadUsageTab">Usage</button>
    </div>

    <!-- Overview Tab -->
    @if (_tab == "overview")
    {
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="card">
                <h3 class="card-title">Part Information</h3>
                <div class="detail-grid">
                    <div class="detail-label">Part Number</div><div class="detail-value">@_part.PartNumber</div>
                    <div class="detail-label">Name</div><div class="detail-value">@_part.Name</div>
                    <div class="detail-label">Description</div><div class="detail-value">@(_part.Description ?? "—")</div>
                    <div class="detail-label">Material</div><div class="detail-value">@_part.Material</div>
                    <div class="detail-label">Raw Material Spec</div><div class="detail-value">@(_part.RawMaterialSpec ?? "—")</div>
                    <div class="detail-label">Approach</div><div class="detail-value">@(_part.ManufacturingApproach?.IconEmoji) @(_part.ManufacturingApproach?.Name ?? "—")</div>
                    <div class="detail-label">Est. Weight (kg)</div><div class="detail-value">@(_part.EstimatedWeightKg?.ToString("F2") ?? "—")</div>
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Drawing & Revision</h3>
                <div class="detail-grid">
                    <div class="detail-label">Drawing Number</div><div class="detail-value">@(_part.DrawingNumber ?? "—")</div>
                    <div class="detail-label">Current Revision</div><div class="detail-value">@(_part.Revision ?? "—")</div>
                    <div class="detail-label">Revision Date</div><div class="detail-value">@(_part.RevisionDate?.ToString("yyyy-MM-dd") ?? "—")</div>
                    <div class="detail-label">Customer P/N</div><div class="detail-value">@(_part.CustomerPartNumber ?? "—")</div>
                    @if (_showDlms)
                    {
                        <div class="detail-label">ITAR Classification</div><div class="detail-value">@_part.ItarClassification</div>
                    }
                </div>
            </div>

            <div class="card" style="grid-column: span 2;">
                <h3 class="card-title">Audit</h3>
                <div class="detail-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
                    <div class="detail-label">Created</div><div class="detail-value">@_part.CreatedDate.ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="detail-label">Created By</div><div class="detail-value">@_part.CreatedBy</div>
                    <div class="detail-label">Modified</div><div class="detail-value">@_part.LastModifiedDate.ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="detail-label">Modified By</div><div class="detail-value">@_part.LastModifiedBy</div>
                </div>
            </div>

            @if (_customFieldDefs.Count > 0 && _customFieldValues.Any())
            {
                <div class="card" style="grid-column: span 2;">
                    <h3 class="card-title">Custom Fields</h3>
                    <div class="detail-grid">
                        @foreach (var def in _customFieldDefs)
                        {
                            <div class="detail-label">@def.Label</div>
                            <div class="detail-value">@(_customFieldValues.TryGetValue(def.Name, out var v) ? v : "—")</div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- Routing Tab -->
    @if (_tab == "routing")
    {
        var routingBuild = _routingBuildId > 0 ? _buildsForPart?.FirstOrDefault(b => b.Id == _routingBuildId) : null;

        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 class="card-title" style="margin: 0;">Stage Routing</h3>

                @* Build duration selector for additive parts *@
                @if (_buildsForPart?.Any() == true)
                {
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <label style="font-size: 0.85rem; color: var(--text-muted); white-space: nowrap;">
                            📦 Show durations from:
                        </label>
                        <select class="form-control form-control-sm" style="width: auto; min-width: 200px;" @bind="_routingBuildId">
                            <option value="0">— Config defaults —</option>
                            @foreach (var build in _buildsForPart.OrderByDescending(b => b.CreatedDate))
                            {
                                var statusIcon = build.Status switch
                                {
                                    BuildPackageStatus.Completed => "✅",
                                    BuildPackageStatus.PostPrint => "📦",
                                    BuildPackageStatus.Printing => "🖨️",
                                    BuildPackageStatus.Scheduled => "📅",
                                    _ => "📝"
                                };
                                var partQty = build.Parts?.FirstOrDefault(p => p.PartId == _part!.Id)?.Quantity ?? 0;
                                <option value="@build.Id">@statusIcon @build.Name (@partQty pcs) — @build.Status</option>
                            }
                        </select>
                    </div>
                }
                else if (HasAdditiveConfig() && _part.StageRequirements?.Any(sr => sr.ProductionStage?.IsBuildLevelStage == true) == true)
                {
                    <div style="display: flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--warning-bg, rgba(245, 158, 11, 0.1)); border: 1px solid var(--warning-border, rgba(245, 158, 11, 0.3)); border-radius: 6px;">
                        <span style="font-size: 0.85rem; color: var(--text-muted);">⚠️ No builds exist — build stage durations use defaults</span>
                        <button class="btn btn-sm btn-accent" @onclick='() => Nav.NavigateTo("/scheduler?tab=orders")'>📦 Create Build</button>
                    </div>
                }
            </div>

            @if (_part.StageRequirements == null || !_part.StageRequirements.Any())
            {
                <p style="color: var(--text-muted);">No routing stages defined. Edit this part to add stages.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Stage</th>
                            <th>Department</th>
                            <th>Est. Duration</th>
                            <th>Setup (min)</th>
                            <th>Batch</th>
                            <th>Est. Cost</th>
                            <th>Material Cost</th>
                            <th>Machine</th>
                            <th>Required</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sr in _part.StageRequirements.OrderBy(s => s.ExecutionOrder))
                        {
                            var slug = sr.ProductionStage?.StageSlug?.ToLowerInvariant() ?? "";
                            <tr>
                                <td>@sr.ExecutionOrder</td>
                                <td>
                                    <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: @(sr.ProductionStage?.StageColor ?? "var(--accent)"); margin-right: 6px;"></span>
                                    @(sr.ProductionStage?.Name ?? $"Stage {sr.ProductionStageId}")
                                    @if (sr.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        <span style="margin-left: 4px; font-size: 0.7rem; background: var(--accent); color: white; padding: 1px 4px; border-radius: 3px;">BUILD</span>
                                    }
                                </td>
                                <td>@(sr.ProductionStage?.Department ?? "—")</td>
                                <td>
                                    @if (sr.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        @* Show build-level durations from selected build or config *@
                                        @if (routingBuild != null)
                                        {
                                            var buildDuration = GetBuildStageDuration(routingBuild, slug);
                                            @if (buildDuration.HasValue)
                                            {
                                                <span style="color: var(--primary); font-weight: 500;" title="From build: @routingBuild.Name">
                                                    @FormatDurationFromHours(buildDuration.Value)
                                                    <span style="font-size: 0.7rem; margin-left: 4px;">📦</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: var(--text-muted);">— (not set)</span>
                                            }
                                        }
                                        else
                                        {
                                            @* Fall back to config or default *@
                                            var configDuration = GetConfigStageDuration(slug);
                                            @if (configDuration.HasValue)
                                            {
                                                <span title="From part config">
                                                    @FormatDurationFromHours(configDuration.Value)
                                                </span>
                                            }
                                            else
                                            {
                                                <span title="Stage default">
                                                    @FormatDurationFromHours(sr.ProductionStage?.DefaultDurationHours ?? 1)
                                                </span>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        @FormatDuration(sr.EstimatedMinutes ?? (sr.ProductionStage?.DefaultDurationHours ?? 1) * 60)
                                    }
                                </td>
                                <td>@(sr.SetupTimeMinutes.HasValue ? FormatDuration(sr.SetupTimeMinutes.Value) : "—")</td>
                                <td>@(sr.ProductionStage?.BatchCapacity ?? 1)×</td>
                                <td>
                                    @{
                                        decimal stageCost;
                                        if (sr.ProductionStage?.IsBuildLevelStage == true && routingBuild != null)
                                        {
                                            // Use build duration for cost calculation
                                            var buildDurationHours = GetBuildStageDuration(routingBuild, slug);
                                            var hourlyRate = sr.HourlyRateOverride ?? sr.ProductionStage?.DefaultHourlyRate ?? 85.00m;
                                            stageCost = buildDurationHours.HasValue 
                                                ? (hourlyRate * (decimal)buildDurationHours.Value) + sr.MaterialCost 
                                                : 0;
                                        }
                                        else
                                        {
                                            stageCost = sr.CalculateTotalEstimatedCost();
                                        }
                                    }
                                    @(stageCost > 0 ? stageCost.ToString("C") : "—")
                                </td>
                                <td>@(sr.MaterialCost > 0 ? sr.MaterialCost.ToString("C") : "—")</td>
                                <td>@(sr.AssignedMachineId ?? "Any")</td>
                                <td><span class="badge @(sr.IsRequired ? "badge-active" : "badge-info")">@(sr.IsRequired ? "Required" : "Optional")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* Cost per part summary *@

                @if (routingBuild != null)
                {
                    var totalBuildHours = (routingBuild.EstimatedDurationHours ?? 0) +
                                          (routingBuild.DepowderingHours ?? 0) +
                                          (routingBuild.HeatTreatmentHours ?? 0) +
                                          (routingBuild.WireEdmHours ?? 0);
                    var bpq = routingBuild.Parts?.FirstOrDefault(p => p.PartId == _part!.Id)?.Quantity ?? 0;

                    <div style="margin-top: 16px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Build:</span>
                            <span style="font-weight: 600;">@routingBuild.Name</span>
                            <span class="badge badge-info" style="margin-left: 4px;">@routingBuild.Status</span>
                        </div>
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Print:</span>
                            <span>@(routingBuild.EstimatedDurationHours.HasValue ? FormatDurationFromHours(routingBuild.EstimatedDurationHours.Value) : "—")</span>
                        </div>
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Depowder:</span>
                            <span>@(routingBuild.DepowderingHours.HasValue ? FormatDurationFromHours(routingBuild.DepowderingHours.Value) : "—")</span>
                        </div>
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Heat Treat:</span>
                            <span>@(routingBuild.HeatTreatmentHours.HasValue ? FormatDurationFromHours(routingBuild.HeatTreatmentHours.Value) : "—")</span>
                        </div>
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Wire EDM:</span>
                            <span>@(routingBuild.WireEdmHours.HasValue ? FormatDurationFromHours(routingBuild.WireEdmHours.Value) : "—")</span>
                        </div>
                        <div style="border-left: 1px solid var(--border-color); padding-left: 24px;">
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Total Build:</span>
                            <span style="font-weight: 600;">@FormatDurationFromHours(totalBuildHours)</span>
                            @if (bpq > 0)
                            {
                                <span style="margin-left: 8px; color: var(--text-muted);">(@bpq parts)</span>
                            }
                        </div>
                    </div>
                }

                @* Total cost per part *@
                <div style="margin-top: 16px; padding: 16px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px;">
                    @{ var costSummary = CalculateRoutingCostPerPart(routingBuild); }
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                        <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">Total Time / Part:</span>
                                <span style="font-weight: 600; margin-left: 4px;">@FormatDuration(costSummary.durationMinutes)</span>
                            </div>
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">Stages:</span>
                                <span style="margin-left: 4px;">@_part.StageRequirements.Count</span>
                            </div>
                            @if (_bomCost != null && _bomCost.TotalBomCost > 0)
                            {
                                <div>
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">BOM Material:</span>
                                    <span style="margin-left: 4px;">@_bomCost.TotalBomCost.ToString("C2")</span>
                                </div>
                            }
                            @if (routingBuild != null)
                            {
                                var pqty = routingBuild.Parts?.FirstOrDefault(p => p.PartId == _part!.Id)?.Quantity ?? 0;
                                <div>
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">Using build:</span>
                                    <span style="margin-left: 4px;">@routingBuild.Name (@pqty pcs)</span>
                                </div>
                            }
                        </div>
                        <div style="text-align: right;">
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Est. Cost / Part</span>
                            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">
                                @{
                                    var totalWithBom = costSummary.cost + (_bomCost?.TotalBomCost ?? 0);
                                }
                                @(totalWithBom > 0 ? totalWithBom.ToString("C") : "—")
                            </div>
                            @if (_bomCost != null && _bomCost.TotalBomCost > 0 && costSummary.cost > 0)
                            {
                                <div style="font-size: 0.75rem; color: var(--text-muted);">
                                    Routing: @costSummary.cost.ToString("C2") + BOM: @_bomCost.TotalBomCost.ToString("C2")
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- BOM Tab -->
    @if (_tab == "bom")
    {
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <h3 class="card-title" style="margin: 0;">Bill of Materials</h3>
                <button class="btn btn-sm btn-secondary" @onclick="GoToEdit">✏️ Edit BOM</button>
            </div>
            @if (_bomItems == null || !_bomItems.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📦</div>
                    <div class="empty-state-text">No BOM items defined. Edit this part to add materials.</div>
                </div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Type</th>
                            <th>Item</th>
                            <th style="text-align: right;">Qty</th>
                            <th>UoM</th>
                            <th style="text-align: right;">Unit Cost</th>
                            <th style="text-align: right;">Scrap %</th>
                            <th style="text-align: right;">Ext. Cost</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _bomItems)
                        {
                            <tr>
                                <td>@item.SortOrder</td>
                                <td>
                                    @switch (item.ItemType)
                                    {
                                        case BomItemType.RawMaterial:
                                            <span class="badge badge-info">Material</span>
                                            break;
                                        case BomItemType.InventoryItem:
                                            <span class="badge badge-secondary">Inventory</span>
                                            break;
                                        case BomItemType.SubPart:
                                            <span class="badge badge-primary">Sub-Part</span>
                                            break;
                                    }
                                </td>
                                <td style="font-weight: 600;">
                                    @switch (item.ItemType)
                                    {
                                        case BomItemType.RawMaterial:
                                            @(item.Material?.Name ?? $"Material #{item.MaterialId}")
                                            break;
                                        case BomItemType.InventoryItem:
                                            @(item.InventoryItem != null ? $"{item.InventoryItem.ItemNumber} — {item.InventoryItem.Name}" : $"Item #{item.InventoryItemId}")
                                            break;
                                        case BomItemType.SubPart:
                                            @if (item.ChildPart != null)
                                            {
                                                <a href="/parts/@item.ChildPartId">@item.ChildPart.PartNumber — @item.ChildPart.Description</a>
                                            }
                                            else
                                            {
                                                @($"Part #{item.ChildPartId}")
                                            }
                                            @if (!string.IsNullOrEmpty(item.ReferenceDesignator))
                                            {
                                                <span style="color: var(--text-muted); margin-left: 4px;">[@item.ReferenceDesignator]</span>
                                            }
                                            break;
                                    }
                                </td>
                                <td style="text-align: right;">@item.QuantityRequired.ToString("F2")</td>
                                <td>@item.UnitOfMeasure</td>
                                <td style="text-align: right;">
                                    @if (item.UnitCost.HasValue)
                                    {
                                        <span title="Manual override">@item.UnitCost.Value.ToString("C2") ✏️</span>
                                    }
                                    else if (item.ItemType == BomItemType.SubPart)
                                    {
                                        <span style="color: var(--text-muted);" title="Resolved from sub-part BOM">roll-up</span>
                                    }
                                    else
                                    {
                                        @item.GetResolvedUnitCost().ToString("C2")
                                    }
                                </td>
                                <td style="text-align: right;">@(item.ScrapFactorPct > 0 ? $"{item.ScrapFactorPct:F1}%" : "—")</td>
                                <td style="text-align: right; font-weight: 600;">
                                    @if (item.ItemType == BomItemType.SubPart && !item.UnitCost.HasValue)
                                    {
                                        @if (_bomCost != null)
                                        {
                                            var childNode = _bomCost.TreeDepth > 0 ? null : _bomCost; // Use full summary
                                            <span style="color: var(--text-muted);" title="See total below">incl.</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--text-muted);">—</span>
                                        }
                                    }
                                    else
                                    {
                                        @item.GetExtendedCost().ToString("C2")
                                    }
                                </td>
                                <td style="color: var(--text-muted);">@(item.Notes ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* BOM Cost Summary *@
                <div style="margin-top: 16px; padding: 16px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                        <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap; font-size: 0.85rem;">
                            <div>
                                <span style="color: var(--text-muted);">Items:</span>
                                <span style="font-weight: 600; margin-left: 4px;">@_bomItems.Count</span>
                            </div>
                            @if (_bomCost != null)
                            {
                                <div>
                                    <span style="color: var(--text-muted);">Raw Material:</span>
                                    <span style="margin-left: 4px;">@_bomCost.RawMaterialCost.ToString("C2")</span>
                                </div>
                                <div>
                                    <span style="color: var(--text-muted);">Inventory:</span>
                                    <span style="margin-left: 4px;">@_bomCost.InventoryItemCost.ToString("C2")</span>
                                </div>
                                @if (_bomCost.SubPartCost > 0)
                                {
                                    <div>
                                        <span style="color: var(--text-muted);">Sub-Parts:</span>
                                        <span style="margin-left: 4px;">@_bomCost.SubPartCost.ToString("C2")</span>
                                    </div>
                                }
                            }
                        </div>
                        <div style="text-align: right;">
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Total BOM Cost</span>
                            <div style="font-size: 1.3rem; font-weight: 700; color: var(--primary);">
                                @(_bomCost != null ? _bomCost.TotalBomCost.ToString("C2") : "—")
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Additive Configuration Tab -->
    @if (_tab == "sls" && HasAdditiveConfig())
    {
        var cfg = _part.AdditiveBuildConfig!;
        var selectedBuild = _selectedBuildId > 0 ? _buildsForPart?.FirstOrDefault(b => b.Id == _selectedBuildId) : null;

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="card">
                <h3 class="card-title">Stacking Configuration</h3>
                <div class="detail-grid">
                    <div class="detail-label">Allow Stacking</div><div class="detail-value">@(cfg.AllowStacking ? "Yes" : "No")</div>
                    <div class="detail-label">Max Stack Count</div><div class="detail-value">@cfg.MaxStackCount</div>
                    <div class="detail-label">Planned Parts/Build (Single)</div><div class="detail-value">@cfg.PlannedPartsPerBuildSingle</div>
                    @if (cfg.SingleStackDurationHours.HasValue)
                    {
                        <div class="detail-label">Single Stack Duration</div><div class="detail-value">@cfg.SingleStackDurationHours.Value.ToString("F1") hrs</div>
                    }
                    @if (cfg.EnableDoubleStack)
                    {
                        <div class="detail-label">Double Stack</div><div class="detail-value">Enabled — @(cfg.PlannedPartsPerBuildDouble ?? 0) parts · @(cfg.DoubleStackDurationHours?.ToString("F1") ?? "—") hrs</div>
                    }
                    @if (cfg.EnableTripleStack)
                    {
                        <div class="detail-label">Triple Stack</div><div class="detail-value">Enabled — @(cfg.PlannedPartsPerBuildTriple ?? 0) parts · @(cfg.TripleStackDurationHours?.ToString("F1") ?? "—") hrs</div>
                    }
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Post-Print Batch Durations</h3>
                <div class="detail-grid">
                    @if (cfg.DepowderingDurationHours.HasValue)
                    {
                        <div class="detail-label">Depowdering</div><div class="detail-value">@cfg.DepowderingDurationHours.Value.ToString("F1") hrs (@(cfg.DepowderingPartsPerBatch ?? 0) parts/batch)</div>
                    }
                    @if (cfg.HeatTreatmentDurationHours.HasValue)
                    {
                        <div class="detail-label">Heat Treatment</div><div class="detail-value">@cfg.HeatTreatmentDurationHours.Value.ToString("F1") hrs (@(cfg.HeatTreatmentPartsPerBatch ?? 0) parts/batch)</div>
                    }
                    @if (cfg.WireEdmDurationHours.HasValue)
                    {
                        <div class="detail-label">Wire EDM</div><div class="detail-value">@cfg.WireEdmDurationHours.Value.ToString("F1") hrs (@(cfg.WireEdmPartsPerSession ?? 0) parts/session)</div>
                    }
                    @if (!cfg.DepowderingDurationHours.HasValue && !cfg.HeatTreatmentDurationHours.HasValue && !cfg.WireEdmDurationHours.HasValue)
                    {
                        <div class="detail-label" style="grid-column: span 2;">No batch durations configured — defaults will be used.</div>
                    }
                </div>
            </div>

            @* Build Comparison Section *@
            @if (_buildsForPart?.Any() == true)
            {
                <div class="card" style="grid-column: span 2;">
                    <h3 class="card-title">📊 Build Comparison</h3>
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <label class="form-label" style="margin: 0; white-space: nowrap;">
                            Compare with build:
                        </label>
                        <select class="form-control" style="max-width: 400px;" @bind="_selectedBuildId">
                            <option value="0">Select a build...</option>
                            @foreach (var build in _buildsForPart)
                            {
                                var statusIcon = build.Status switch
                                {
                                    BuildPackageStatus.Completed => "✅",
                                    BuildPackageStatus.PostPrint => "📦",
                                    BuildPackageStatus.Printing => "🖨️",
                                    BuildPackageStatus.Scheduled => "📅",
                                    _ => "📝"
                                };
                                var partCount = build.Parts?.Sum(p => p.Quantity) ?? 0;
                                <option value="@build.Id">@statusIcon @build.Name — @partCount parts — @build.Status</option>
                            }
                        </select>
                    </div>

                    @if (selectedBuild != null)
                    {
                        var buildPartQty = selectedBuild.Parts?.FirstOrDefault(p => p.PartId == _part.Id)?.Quantity ?? 0;
                        var printCostPerPart = selectedBuild.EstimatedDurationHours.HasValue && buildPartQty > 0
                            ? selectedBuild.EstimatedDurationHours.Value / buildPartQty
                            : (double?)null;
                        var depowderCostPerPart = selectedBuild.DepowderingHours.HasValue && buildPartQty > 0
                            ? selectedBuild.DepowderingHours.Value / buildPartQty
                            : (double?)null;
                        var heatTreatCostPerPart = selectedBuild.HeatTreatmentHours.HasValue && buildPartQty > 0
                            ? selectedBuild.HeatTreatmentHours.Value / buildPartQty
                            : (double?)null;
                        var edmCostPerPart = selectedBuild.WireEdmHours.HasValue && buildPartQty > 0
                            ? selectedBuild.WireEdmHours.Value / buildPartQty
                            : (double?)null;
                        var totalBuildHours = (selectedBuild.EstimatedDurationHours ?? 0) +
                                              (selectedBuild.DepowderingHours ?? 0) +
                                              (selectedBuild.HeatTreatmentHours ?? 0) +
                                              (selectedBuild.WireEdmHours ?? 0);
                        var totalCostPerPart = buildPartQty > 0 ? totalBuildHours / buildPartQty : (double?)null;

                        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;">
                            <div style="background: var(--bg-secondary); padding: 12px; border-radius: 8px;">
                                <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 4px;">Build Details</div>
                                <div class="detail-grid" style="gap: 4px 12px;">
                                    <div class="detail-label">Name</div><div class="detail-value" style="font-weight: 600;">@selectedBuild.Name</div>
                                    <div class="detail-label">Status</div><div class="detail-value"><span class="badge badge-info">@selectedBuild.Status</span></div>
                                    <div class="detail-label">Machine</div><div class="detail-value">@(selectedBuild.Machine?.Name ?? "Not assigned")</div>
                                    <div class="detail-label">Parts of this type</div><div class="detail-value">@buildPartQty</div>
                                </div>
                            </div>

                            <div style="background: var(--bg-secondary); padding: 12px; border-radius: 8px;">
                                <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 4px;">Build Durations (Total)</div>
                                <div class="detail-grid" style="gap: 4px 12px;">
                                    <div class="detail-label">Print</div><div class="detail-value">@(selectedBuild.EstimatedDurationHours?.ToString("F1") ?? "—") hrs</div>
                                    <div class="detail-label">Depowdering</div><div class="detail-value">@(selectedBuild.DepowderingHours?.ToString("F1") ?? "—") hrs</div>
                                    <div class="detail-label">Heat Treatment</div><div class="detail-value">@(selectedBuild.HeatTreatmentHours?.ToString("F1") ?? "—") hrs</div>
                                    <div class="detail-label">Wire EDM</div><div class="detail-value">@(selectedBuild.WireEdmHours?.ToString("F1") ?? "—") hrs</div>
                                    <div class="detail-label" style="font-weight: 600;">Total</div><div class="detail-value" style="font-weight: 600;">@totalBuildHours.ToString("F1") hrs</div>
                                </div>
                            </div>

                            <div style="background: var(--bg-secondary); padding: 12px; border-radius: 8px;">
                                <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 4px;">Cost Per Part (hrs/part)</div>
                                <div class="detail-grid" style="gap: 4px 12px;">
                                    <div class="detail-label">Print</div><div class="detail-value">@(printCostPerPart?.ToString("F2") ?? "—") hrs</div>
                                    <div class="detail-label">Depowdering</div><div class="detail-value">@(depowderCostPerPart?.ToString("F2") ?? "—") hrs</div>
                                    <div class="detail-label">Heat Treatment</div><div class="detail-value">@(heatTreatCostPerPart?.ToString("F2") ?? "—") hrs</div>
                                    <div class="detail-label">Wire EDM</div><div class="detail-value">@(edmCostPerPart?.ToString("F2") ?? "—") hrs</div>
                                    <div class="detail-label" style="font-weight: 600;">Total/Part</div><div class="detail-value" style="font-weight: 600; color: var(--primary);">@(totalCostPerPart?.ToString("F2") ?? "—") hrs</div>
                                </div>
                            </div>
                        </div>

                        @* Comparison vs Config *@
                        @if (cfg.SingleStackDurationHours.HasValue && buildPartQty > 0)
                        {
                            var configCostPerPart = cfg.SingleStackDurationHours.Value / cfg.PlannedPartsPerBuildSingle;
                            var diff = (totalCostPerPart ?? 0) - configCostPerPart;
                            var diffPct = configCostPerPart > 0 ? (diff / configCostPerPart) * 100 : 0;
                            var diffColor = diff < 0 ? "var(--success)" : (diff > 0 ? "var(--danger)" : "var(--text-muted)");
                            var diffIcon = diff < 0 ? "📉" : (diff > 0 ? "📈" : "➖");

                            <div style="margin-top: 12px; padding: 10px; background: var(--bg-tertiary); border-radius: 6px; display: flex; align-items: center; gap: 12px;">
                                <span>@diffIcon</span>
                                <span style="color: var(--text-muted);">vs Config Estimate:</span>
                                <span style="font-weight: 600;">@configCostPerPart.ToString("F2") hrs/part</span>
                                <span style="color: @diffColor; font-weight: 600;">
                                    @(diff >= 0 ? "+" : "")@diff.ToString("F2") hrs/part (@(diffPct >= 0 ? "+" : "")@diffPct.ToString("F1")%)
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <p style="color: var(--text-muted); font-style: italic;">Select a build to compare durations and cost per part.</p>
                    }
                </div>
            }
        </div>
    }

    <!-- Drawings Tab -->
    @if (_tab == "drawings")
    {
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <h3 class="card-title" style="margin: 0;">Drawings & Files</h3>
                <button class="btn btn-sm btn-primary" @onclick="() => _showUpload = !_showUpload">@(_showUpload ? "Cancel" : "+ Upload")</button>
            </div>

            @if (_showUpload)
            {
                <div style="margin-bottom: 16px; padding: 16px; border: 1px solid var(--border); border-radius: 8px;">
                    <FileUpload OnFilesChanged="OnFilesSelected" />
                    <div style="display: flex; gap: 8px; margin-top: 12px;">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Description</label>
                            <input class="form-control" @bind="_uploadDescription" />
                        </div>
                        <div class="form-group" style="width: 120px;">
                            <label class="form-label">Revision</label>
                            <input class="form-control" @bind="_uploadRevision" />
                        </div>
                    </div>
                    @if (_uploadFiles.Count > 0)
                    {
                        <button class="btn btn-primary" style="margin-top: 8px;" @onclick="UploadDrawings" disabled="@_uploading">
                            @(_uploading ? "Uploading..." : $"Upload {_uploadFiles.Count} file(s)")
                        </button>
                    }
                </div>
            }

            @if (_drawings == null || !_drawings.Any())
            {
                <p style="color: var(--text-muted);">No drawings uploaded yet.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th></th>
                            <th>File Name</th>
                            <th>Type</th>
                            <th>Revision</th>
                            <th>Size</th>
                            <th>Uploaded</th>
                            <th>By</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _drawings)
                        {
                            <tr>
                                <td>@(d.IsPrimary ? "⭐" : "")</td>
                                <td>
                                    <a href="@d.FilePath" target="_blank">@d.FileName</a>
                                </td>
                                <td><span class="badge badge-info">@d.FileType</span></td>
                                <td>@(d.Revision ?? "—")</td>
                                <td>@FormatSize(d.FileSizeBytes)</td>
                                <td>@d.UploadedDate.ToString("yyyy-MM-dd")</td>
                                <td>@d.UploadedBy</td>
                                <td style="display: flex; gap: 4px;">
                                    @if (!d.IsPrimary)
                                    {
                                        <button class="btn btn-sm btn-secondary" @onclick="() => SetPrimary(d.Id)" title="Set as primary">⭐</button>
                                    }
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteDrawing(d)">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- Revisions Tab -->
    @if (_tab == "revisions")
    {
        <div class="card">
            <h3 class="card-title">Revision History</h3>
            @if (_part.RevisionHistory == null || !_part.RevisionHistory.Any())
            {
                <p style="color: var(--text-muted);">No revision history yet.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Revision</th>
                            <th>Previous</th>
                            <th>Change Description</th>
                            <th>Drawing #</th>
                            <th>Date</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rev in _part.RevisionHistory.OrderByDescending(r => r.RevisionDate))
                        {
                            <tr>
                                <td><strong>@rev.Revision</strong></td>
                                <td>@(rev.PreviousRevision ?? "—")</td>
                                <td>@(rev.ChangeDescription ?? "—")</td>
                                <td>@(rev.DrawingNumber ?? "—")</td>
                                <td>@rev.RevisionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@rev.CreatedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <!-- Notes Tab -->
    @if (_tab == "notes")
    {
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <h3 class="card-title" style="margin: 0;">Engineering Notes</h3>
                <button class="btn btn-sm btn-primary" @onclick="NewNote">+ Add Note</button>
            </div>

            @if (_part.Notes == null || !_part.Notes.Any())
            {
                <p style="color: var(--text-muted);">No notes yet.</p>
            }
            else
            {
                @foreach (var note in _part.Notes.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedDate))
                {
                    <div class="note-card" style="border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin-bottom: 8px;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                @if (note.IsPinned) { <span>📌</span> }
                                <strong>@note.Title</strong>
                                <span class="badge badge-info" style="margin-left: 8px;">@note.NoteType</span>
                            </div>
                            <div style="display: flex; gap: 4px;">
                                <button class="btn btn-sm btn-secondary" @onclick="() => EditNote(note)">✏️</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteNote(note)">🗑️</button>
                            </div>
                        </div>
                        <p style="margin: 8px 0 4px 0; color: var(--text-secondary);">@note.Content</p>
                        <small style="color: var(--text-muted);">@note.CreatedBy — @note.CreatedDate.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                }
            }
        </div>
    }

    <!-- Usage Tab -->
    @if (_tab == "usage")
    {
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="card">
                <h3 class="card-title">Active Work Orders</h3>
                @if (_usage == null)
                {
                    <div class="loading"><span class="spinner"></span> Loading...</div>
                }
                else if (_usage.ActiveWorkOrderLines.Count == 0)
                {
                    <p style="color: var(--text-muted);">No active work orders reference this part.</p>
                }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>WO #</th><th>Customer</th><th>Qty</th><th>Status</th><th>Due</th></tr></thead>
                        <tbody>
                            @foreach (var line in _usage.ActiveWorkOrderLines)
                            {
                                <tr>
                                    <td><a href="/workorders/@line.WorkOrder.Id">@line.WorkOrder.OrderNumber</a></td>
                                    <td>@line.WorkOrder.CustomerName</td>
                                    <td>@line.Quantity</td>
                                    <td><span class="badge badge-info">@line.WorkOrder.Status</span></td>
                                    <td>@line.WorkOrder.DueDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="card">
                <h3 class="card-title">Active Jobs</h3>
                @if (_usage == null)
                {
                    <div class="loading"><span class="spinner"></span> Loading...</div>
                }
                else if (_usage.ActiveJobs.Count == 0)
                {
                    <p style="color: var(--text-muted);">No active jobs for this part.</p>
                }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Part #</th><th>Qty</th><th>Status</th><th>Scheduled</th></tr></thead>
                        <tbody>
                            @foreach (var job in _usage.ActiveJobs)
                            {
                                <tr>
                                    <td>@job.PartNumber</td>
                                    <td>@job.Quantity</td>
                                    <td><span class="badge badge-info">@job.Status</span></td>
                                    <td>@job.ScheduledStart.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="card">
                <h3 class="card-title">Recent Quotes</h3>
                @if (_usage == null)
                {
                    <div class="loading"><span class="spinner"></span> Loading...</div>
                }
                else if (_usage.RecentQuoteLines.Count == 0)
                {
                    <p style="color: var(--text-muted);">No quotes reference this part.</p>
                }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Quote #</th><th>Qty</th><th>Unit Price</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var ql in _usage.RecentQuoteLines)
                            {
                                <tr>
                                    <td><a href="/quotes/@ql.Quote.Id">@ql.Quote.QuoteNumber</a></td>
                                    <td>@ql.Quantity</td>
                                    <td>@ql.QuotedPricePerPart.ToString("C")</td>
                                    <td><span class="badge badge-info">@ql.Quote.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="card">
                <h3 class="card-title">Quality Summary</h3>
                @if (_usage == null)
                {
                    <div class="loading"><span class="spinner"></span> Loading...</div>
                }
                else
                {
                    <div class="detail-grid">
                        <div class="detail-label">NCRs</div><div class="detail-value">@_usage.NcrCount</div>
                        <div class="detail-label">Inspections</div><div class="detail-value">@_usage.InspectionCount</div>
                        <div class="detail-label">SPC Data Points</div><div class="detail-value">@_usage.SpcDataPointCount</div>
                    </div>
                }
            </div>
        </div>
    }
}

<!-- Revision Bump Modal -->
<AppModal Visible="_showRevisionModal" VisibleChanged="v => _showRevisionModal = v" Title="Bump Revision" Size="sm">
    <ChildContent>
        <div class="form-group">
            <label class="form-label">New Revision</label>
            <input class="form-control" @bind="_newRevision" placeholder="e.g. B, C, 2.0" />
        </div>
        <div class="form-group">
            <label class="form-label">Change Description</label>
            <textarea class="form-control" @bind="_revisionDescription" rows="3"></textarea>
        </div>
    </ChildContent>
    <Footer>
        <button class="btn btn-secondary" @onclick="() => _showRevisionModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="ConfirmRevisionBump" disabled="@_bumpingRevision">
            @if (_bumpingRevision) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
            Bump Revision
        </button>
    </Footer>
</AppModal>

<!-- Note Modal -->
<AppModal Visible="_showNoteModal" VisibleChanged="v => _showNoteModal = v" Title="@(_editNote?.Id > 0 ? "Edit Note" : "Add Note")" Size="md">
    <ChildContent>
        @if (_editNote != null)
        {
            <div class="form-group">
                <label class="form-label">Title</label>
                <input class="form-control" @bind="_editNote.Title" />
            </div>
            <div class="form-group">
                <label class="form-label">Type</label>
                <select class="form-control" @bind="_editNote.NoteType">
                    <option value="Engineering">Engineering</option>
                    <option value="Quality">Quality</option>
                    <option value="Manufacturing">Manufacturing</option>
                    <option value="General">General</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Content</label>
                <textarea class="form-control" @bind="_editNote.Content" rows="5"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">
                    <input type="checkbox" @bind="_editNote.IsPinned" style="margin-right: 6px;" />Pinned
                </label>
            </div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-secondary" @onclick="() => _showNoteModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveNote">Save</button>
    </Footer>
</AppModal>

<!-- Clone Part Modal -->
<AppModal Visible="_showCloneModal" VisibleChanged="v => _showCloneModal = v" Title="Clone Part" Size="sm">
    <ChildContent>
        <p style="color: var(--text-muted); margin-bottom: 12px;">This will create a copy of <strong>@_part?.PartNumber</strong> with its routing, but without drawings, revision history, or notes.</p>
        <div class="form-group">
            <label class="form-label">New Part Number <span style="color:var(--danger)">*</span></label>
            <input class="form-control" @bind="_clonePartNumber" placeholder="e.g. PART-002" />
        </div>
        @if (!string.IsNullOrEmpty(_cloneError))
        {
            <div class="alert alert-danger" style="margin-top: 8px;">@_cloneError</div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-secondary" @onclick="() => _showCloneModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="ConfirmClone" disabled="@_cloning">
            @if (_cloning) { <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span> }
            Clone Part
        </button>
    </Footer>
</AppModal>

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private Part? _part;
    private string _tab = "overview";
    private bool _showDlms;
    private string _userName = "System";
    private ConfirmDialog _confirm = null!;

    // BOM
    private List<PartBomItem>? _bomItems;
    private BomCostSummary? _bomCost;

    // Drawings
    private List<PartDrawing> _drawings = new();
    private bool _showUpload;
    private bool _uploading;
    private IReadOnlyList<Microsoft.AspNetCore.Components.Forms.IBrowserFile> _uploadFiles = new List<Microsoft.AspNetCore.Components.Forms.IBrowserFile>();
    private string? _uploadDescription;
    private string? _uploadRevision;

    // Revision bump
    private bool _showRevisionModal;
    private bool _bumpingRevision;
    private string _newRevision = string.Empty;
    private string _revisionDescription = string.Empty;

    // Notes
    private bool _showNoteModal;
    private PartNote? _editNote;

    // Usage
    private PartUsageSummary? _usage;

    // Clone
    private bool _showCloneModal;
    private bool _cloning;
    private string _clonePartNumber = string.Empty;
    private string? _cloneError;

    // Custom fields
    private List<CustomFieldDefinition> _customFieldDefs = new();
    private Dictionary<string, string> _customFieldValues = new();

    // Build comparison
    private List<BuildPackage>? _buildsForPart;
    private int _selectedBuildId;
    private int _routingBuildId; // For routing tab, defaults to latest build

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _userName = state.User?.FindFirst("FullName")?.Value
                ?? state.User?.Identity?.Name ?? "System";
        }
        _showDlms = Features.IsEnabled("dlms");
        _part = await PartService.GetPartDetailAsync(Id);
        _customFieldDefs = await CustomFieldService.GetFieldDefinitionsAsync("Part");
        if (_part != null)
        {
            _drawings = await FileService.GetDrawingsAsync(Id);
            _bomItems = await PartService.GetBomItemsAsync(Id);
            try { _bomCost = await PartService.CalculateBomCostAsync(Id); } catch { /* BOM cost optional */ }
            if (!string.IsNullOrEmpty(_part.CustomFieldValues))
            {
                try { _customFieldValues = JsonSerializer.Deserialize<Dictionary<string, string>>(_part.CustomFieldValues) ?? new(); }
                catch { _customFieldValues = new(); }
            }

            // Load builds for comparison (additive parts only)
            if (HasAdditiveConfig())
            {
                _buildsForPart = await BuildPlanningService.GetBuildsForPartAsync(Id);
                // Default routing tab to latest completed/printing build
                var latestBuild = _buildsForPart
                    .Where(b => b.Status == BuildPackageStatus.Completed || b.Status == BuildPackageStatus.Printing || b.Status == BuildPackageStatus.PostPrint)
                    .OrderByDescending(b => b.CreatedDate)
                    .FirstOrDefault();
                _routingBuildId = latestBuild?.Id ?? (_buildsForPart.FirstOrDefault()?.Id ?? 0);
            }
        }
        _loading = false;
    }

    // Drawing methods
    private void OnFilesSelected(IReadOnlyList<Microsoft.AspNetCore.Components.Forms.IBrowserFile> files)
    {
        _uploadFiles = files;
    }

    private async Task UploadDrawings()
    {
        if (_part == null || !_uploadFiles.Any()) return;
        _uploading = true;

        try
        {
            var uploadCount = _uploadFiles.Count;
            foreach (var file in _uploadFiles)
            {
                using var stream = file.OpenReadStream(50 * 1024 * 1024);
                await FileService.UploadDrawingAsync(_part.Id, file.Name, stream, file.Size, _userName, _uploadDescription, _uploadRevision);
            }
            _drawings = await FileService.GetDrawingsAsync(_part.Id);
            _showUpload = false;
            _uploadFiles = new List<Microsoft.AspNetCore.Components.Forms.IBrowserFile>();
            _uploadDescription = null;
            _uploadRevision = null;
            Toast.ShowSuccess($"Uploaded {uploadCount} file(s)");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Upload failed: {ex.Message}");
        }
        finally
        {
            _uploading = false;
        }
    }

