    /// <summary>
    /// Gets the duration (in hours) for a build-level stage from the selected build.
    /// </summary>
    private double? GetBuildStageDuration(BuildPackage build, string stageSlug)
    {
        return stageSlug switch
        {
            "sls-printing" or "sls-print" or "printing" or "print" => build.EstimatedDurationHours,
            "depowder" or "depowdering" => build.DepowderingHours,
            "heat-treat" or "heat-treatment" => build.HeatTreatmentHours,
            "wire-edm" or "edm" => build.WireEdmHours,
            _ => null
        };
    }

    /// <summary>
    /// Gets the duration (in hours) for a build-level stage from the part's AdditiveBuildConfig.
    /// </summary>
    private double? GetConfigStageDuration(string stageSlug)
    {
        var config = _part?.AdditiveBuildConfig;
        if (config == null) return null;

        return stageSlug switch
        {
            "sls-printing" or "sls-print" or "printing" or "print" => config.SingleStackDurationHours,
            "depowder" or "depowdering" => config.DepowderingDurationHours,
            "heat-treat" or "heat-treatment" => config.HeatTreatmentDurationHours,
            "wire-edm" or "edm" => config.WireEdmDurationHours,
            _ => null
        };
    }

    /// <summary>
    /// Formats minutes as "Xh Ym" if >= 60, otherwise "X min".
    /// </summary>
    private static string FormatDuration(double minutes)
    {
        if (minutes < 60)
            return $"{minutes:F0} min";

        var hours = (int)(minutes / 60);
        var mins = (int)(minutes % 60);
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }

    /// <summary>
    /// Formats hours as "Xh Ym" if has fractional part, otherwise "Xh".
    /// </summary>
    private static string FormatDurationFromHours(double hours)
    {
        return FormatDuration(hours * 60);
    }

    /// <summary>
    /// Calculates total cost per part and total duration per part across all routing stages.
    /// Build-level stage costs are divided by the build's part quantity.
    /// </summary>
    private (decimal cost, double durationMinutes) CalculateRoutingCostPerPart(BuildPackage? build)
    {
        if (_part?.StageRequirements == null) return (0, 0);

        decimal totalCost = 0;
        double totalMinutes = 0;
        int buildPartQty = build?.Parts?.FirstOrDefault(p => p.PartId == _part.Id)?.Quantity ?? 1;

        foreach (var sr in _part.StageRequirements)
        {
            var slug = sr.ProductionStage?.StageSlug?.ToLowerInvariant() ?? "";

            if (sr.ProductionStage?.IsBuildLevelStage == true)
            {
                double? durationHours = build != null
                    ? GetBuildStageDuration(build, slug)
                    : GetConfigStageDuration(slug) ?? sr.ProductionStage?.DefaultDurationHours;

                if (durationHours.HasValue)
                {
                    var rate = sr.HourlyRateOverride ?? sr.ProductionStage?.DefaultHourlyRate ?? 85.00m;
                    var buildStageCost = (rate * (decimal)durationHours.Value) + sr.MaterialCost;
                    totalCost += buildPartQty > 0 ? buildStageCost / buildPartQty : 0;
                    totalMinutes += buildPartQty > 0 ? (durationHours.Value * 60) / buildPartQty : 0;
                }
            }
            else
            {
                totalCost += sr.CalculateTotalEstimatedCost();
                totalMinutes += sr.EstimatedMinutes ?? (sr.ProductionStage?.DefaultDurationHours ?? 1) * 60;
            }
        }

        return (totalCost, totalMinutes);
    }
