    private async Task OnDrawingEditorSave(ImageEditor.ImageEditorResult result)
    {
        _showDrawingImageEditor = false;
        _editedImageFiles[result.FileName] = result.ImageData;
        Toast.ShowSuccess($"Edits applied to {result.FileName} — click Upload to save.");
        await Task.CompletedTask;
    }

    private void OnDrawingEditorCancel() => _showDrawingImageEditor = false;

    private async Task UploadDrawings()
    {
        if (_part == null || !_uploadFiles.Any()) return;
        _uploading = true;

        try
        {
            var uploadCount = _uploadFiles.Count;
            foreach (var file in _uploadFiles)
            {
                // Check if this file was edited in the image editor
                if (_editedImageFiles.TryGetValue(file.Name, out var editedBytes)
                    || _editedImageFiles.TryGetValue(Path.GetFileNameWithoutExtension(file.Name) + ".png", out editedBytes)
                    || _editedImageFiles.TryGetValue(Path.GetFileNameWithoutExtension(file.Name) + ".jpg", out editedBytes))
                {
                    var editedName = _editedImageFiles.Keys.FirstOrDefault(k => k.StartsWith(Path.GetFileNameWithoutExtension(file.Name))) ?? file.Name;
                    using var ms = new MemoryStream(editedBytes);
                    await FileService.UploadDrawingAsync(_part.Id, editedName, ms, editedBytes.Length, _userName, _uploadDescription, _uploadRevision);
                }
                else
                {
                    using var stream = file.OpenReadStream(50 * 1024 * 1024);
                    await FileService.UploadDrawingAsync(_part.Id, file.Name, stream, file.Size, _userName, _uploadDescription, _uploadRevision);
                }
            }
            _drawings = await FileService.GetDrawingsAsync(_part.Id);
            _showUpload = false;
            _uploadFiles = new List<Microsoft.AspNetCore.Components.Forms.IBrowserFile>();
            _uploadDescription = null;
            _uploadRevision = null;
            _editedImageFiles.Clear();
            Toast.ShowSuccess($"Uploaded {uploadCount} file(s)");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Upload failed: {ex.Message}");
        }
        finally
        {
            _uploading = false;
        }
    }

