    /// <summary>
    /// Parses a comma-separated string of machine IDs into a list of ints.
    /// </summary>
    private static List<int> ParseMachineIds(string? csv)
    {
        if (string.IsNullOrWhiteSpace(csv)) return [];
        return csv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => int.TryParse(s, out var id) ? id : 0)
            .Where(id => id > 0)
            .ToList();
    }

    /// <summary>
    /// Formats minutes as "Xh Ym" if >= 60, otherwise "X min".
    /// </summary>
    private static string FormatDuration(double minutes)
    {
        if (minutes < 60)
            return $"{minutes:F0} min";

        var hours = (int)(minutes / 60);
        var mins = (int)(minutes % 60);
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }

    /// <summary>
    /// Formats hours as "Xh Ym" if has fractional part, otherwise "Xh".
    /// </summary>
    private static string FormatDurationFromHours(double hours)
    {
        return FormatDuration(hours * 60);
    }

    /// <summary>
    /// Calculates a summary of cost and duration for the process (single part scenario).
    /// </summary>
    private (decimal cost, double totalMinutes) CalculateProcessCostSummary()
    {
        if (_process == null || !_processStages.Any()) return (0, 0);

        decimal totalCost = 0;
        double totalMinutes = 0;

        var batchCapacity = _process.DefaultBatchCapacity;

        foreach (var stage in _processStages)
        {
            var dur = ProcessService.CalculateStageDuration(stage, partCount: 1, batchCount: 1, buildConfigHours: null);
            totalMinutes += dur.TotalMinutes;

            var rate = stage.HourlyRateOverride ?? stage.ProductionStage?.DefaultHourlyRate ?? 85.00m;
            var laborCost = rate * (decimal)(dur.TotalMinutes / 60.0);
            var materialCost = stage.MaterialCost ?? 0;
            totalCost += laborCost + materialCost;
        }

        return (totalCost, totalMinutes);
    }

    /// <summary>
    /// Recalculates the full cost breakdown for the Cost Calculation tab.
    /// </summary>
    private async Task RecalculateCost()
    {
        _costLines.Clear();
        _costTotalMinutes = 0;
        _costGrandTotal = 0;

        if (_process == null || !_processStages.Any() || _costQuantity <= 0) return;

        var batchCapacity = _costBatchCapacity > 0 ? _costBatchCapacity : _process.DefaultBatchCapacity;
        var batchCount = (int)Math.Ceiling((double)_costQuantity / batchCapacity);

        foreach (var stage in _processStages)
        {
            var dur = ProcessService.CalculateStageDuration(stage, _costQuantity, batchCount, buildConfigHours: null);
            var durationHours = dur.TotalMinutes / 60.0;
            var stageId = stage.ProductionStageId;

            // Use the full cost engine (labor, equipment, overhead, external, tooling)
            var estimate = await StageCostService.EstimateCostAsync(stageId, durationHours, _costQuantity, batchCount);
            var materialCost = (stage.MaterialCost ?? 0) * _costQuantity;
            var stageTotal = estimate.TotalCost + materialCost;
            var costPerPart = _costQuantity > 0 ? stageTotal / _costQuantity : 0;

            _costLines.Add(new CostLineItem
            {
                ExecutionOrder = stage.ExecutionOrder,
                StageName = stage.ProductionStage?.Name ?? $"Stage #{stage.ProductionStageId}",
                StageColor = stage.ProductionStage?.StageColor ?? "var(--accent)",
                Level = stage.ProcessingLevel,
                IsPlateRelease = _process.PlateReleaseStageId == stage.Id,
                SetupMinutes = dur.SetupMinutes,
                RunMinutes = dur.RunMinutes,
                TotalMinutes = dur.TotalMinutes,
                HourlyRate = estimate.FullyLoadedHourlyRate,
                LaborCost = estimate.LaborCost,
                EquipmentCost = estimate.EquipmentCost,
                OverheadCost = estimate.OverheadCost,
                ExternalCost = estimate.ExternalCost + estimate.ToolingCost + estimate.PerPartCost,
                MaterialCost = materialCost,
                StageTotalCost = stageTotal,
                CostPerPart = costPerPart,
                UsedCostProfile = estimate.UsedCostProfile
            });

            _costTotalMinutes += dur.TotalMinutes;
        }

        var processCostTotal = _costLines.Sum(l => l.StageTotalCost);
        _costBomTotal = (_bomCost?.TotalBomCost ?? 0) * _costQuantity;
        _costGrandTotal = processCostTotal + _costBomTotal;

        // Pre-compute price breaks
        _priceBreaks.Clear();
        foreach (var qty in new[] { 1, 10, 25, 50, 100, 250, 500 })
        {
            if (qty == _costQuantity) continue;
            var qtyBatches = batchCapacity > 0 ? (int)Math.Ceiling((double)qty / batchCapacity) : 1;
            _priceBreaks[qty] = await CalculateQuickCostPerPartAsync(qty, qtyBatches);
        }
    }

    /// <summary>
    /// Quick calculation of cost per part for the price-break display.
    /// </summary>
    private async Task<decimal> CalculateQuickCostPerPartAsync(int quantity, int batchCount)
    {
        if (_process == null || !_processStages.Any() || quantity <= 0) return 0;

        decimal total = 0;
        foreach (var stage in _processStages)
        {
            var dur = ProcessService.CalculateStageDuration(stage, quantity, batchCount, buildConfigHours: null);
            var estimate = await StageCostService.EstimateCostAsync(stage.ProductionStageId, dur.TotalMinutes / 60.0, quantity, batchCount);
            total += estimate.TotalCost;
            total += (stage.MaterialCost ?? 0) * quantity;
        }
        total += (_bomCost?.TotalBomCost ?? 0) * quantity;

        return total / quantity;
    }

    /// <summary>
    /// Renders a read-only process stage table for the Process tab.
    /// </summary>
    private RenderFragment RenderProcessStageTable(List<ProcessStage> stages) => __builder =>
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Order</th>
                    <th>Stage</th>
                    <th>Department</th>
                    <th>Setup</th>
                    <th>Run</th>
                    <th>Machine</th>
                    <th>Rate/hr</th>
                    <th>Material</th>
                    <th>Flags</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in stages)
                {
                    <tr>
                        <td>@s.ExecutionOrder</td>
                        <td>
                            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@(s.ProductionStage?.StageColor ?? "var(--accent)");margin-right:6px;"></span>
                            @(s.ProductionStage?.Name ?? $"Stage #{s.ProductionStageId}")
                            @if (_process?.PlateReleaseStageId == s.Id)
                            {
                                <span style="margin-left: 6px; font-size: 0.7rem; background: var(--warning); color: white; padding: 1px 4px; border-radius: 3px;">RELEASE</span>
                            }
                        </td>
                        <td>@(s.ProductionStage?.Department ?? "—")</td>
                        <td>
                            @if (s.SetupTimeMinutes.HasValue && s.SetupDurationMode != DurationMode.None)
                            {
                                <span>@FormatDuration(s.SetupTimeMinutes.Value) <span style="font-size:0.7rem;color:var(--text-muted);">(@s.SetupDurationMode)</span></span>
                            }
                            else
                            {
                                <span style="color: var(--text-muted);">—</span>
                            }
                        </td>
                        <td>
                            @if (s.RunTimeMinutes.HasValue)
                            {
                                <span>@FormatDuration(s.RunTimeMinutes.Value) <span style="font-size:0.7rem;color:var(--text-muted);">(@s.RunDurationMode)</span></span>
                            }
                            else if (s.DurationFromBuildConfig)
                            {
                                <span class="badge badge-info">From Build</span>
                            }
                            else
                            {
                                <span style="color: var(--text-muted);">—</span>
                            }
                        </td>
                        <td>@(s.AssignedMachine?.Name ?? "Any")</td>
                        <td>@((s.HourlyRateOverride ?? s.ProductionStage?.DefaultHourlyRate ?? 85m).ToString("C2"))</td>
                        <td>@(s.MaterialCost > 0 ? s.MaterialCost.Value.ToString("C2") : "—")</td>
                        <td style="font-size: 0.8rem; white-space: nowrap;">
                            @if (s.IsRequired) { <span title="Required">✓</span> }
                            @if (s.RequiresQualityCheck) { <span title="QC">🔍</span> }
                            @if (s.AllowSkip) { <span title="Skippable">⏭️</span> }
                            @if (s.IsExternalOperation) { <span title="External">🏢</span> }
                            @if (s.RequiresSerialNumber) { <span title="Serial #">🔢</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private record CostLineItem
    {
        public int ExecutionOrder { get; init; }
        public string StageName { get; init; } = "";
        public string StageColor { get; init; } = "var(--accent)";
        public ProcessingLevel Level { get; init; }
        public bool IsPlateRelease { get; init; }
        public double SetupMinutes { get; init; }
        public double RunMinutes { get; init; }
        public double TotalMinutes { get; init; }
        public decimal HourlyRate { get; init; }
        public decimal LaborCost { get; init; }
        public decimal EquipmentCost { get; init; }
        public decimal OverheadCost { get; init; }
        public decimal ExternalCost { get; init; }
        public decimal MaterialCost { get; init; }
        public decimal StageTotalCost { get; init; }
        public decimal CostPerPart { get; init; }
        public bool UsedCostProfile { get; init; }
    }
