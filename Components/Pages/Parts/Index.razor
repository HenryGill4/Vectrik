@page "/parts"
@rendermode InteractiveServer
@inject IPartService PartService
@inject ITenantFeatureService Features
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Parts - OpCentrix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Parts Library</h1>
    <div style="display: flex; gap: 8px; align-items: center;">
        <div class="search-box" style="position: relative;">
            <input class="form-control" placeholder="Search parts..." @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" style="min-width: 280px;" />
        </div>
        <button class="btn btn-primary" @onclick="GoToNewPart">+ New Part</button>
    </div>
</div>

<!-- Filter Tabs -->
<div class="tab-bar" style="margin-bottom: 16px;">
    <button class="tab @(_filter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All (@_allParts.Count)</button>
    <button class="tab @(_filter == "active" ? "active" : "")" @onclick='() => SetFilter("active")'>Active (@_allParts.Count(p => p.IsActive))</button>
    <button class="tab @(_filter == "inactive" ? "active" : "")" @onclick='() => SetFilter("inactive")'>Inactive (@_allParts.Count(p => !p.IsActive))</button>
    @if (_showDefenseFilter)
    {
        <button class="tab @(_filter == "defense" ? "active" : "")" @onclick='() => SetFilter("defense")'>Defense (@_allParts.Count(p => p.IsDefensePart))</button>
    }
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading parts...</div>
}
else if (!_filteredParts.Any())
{
    <div class="card" style="text-align: center; padding: 40px;">
        <p style="color: var(--text-muted); font-size: 1.1rem;">No parts found.</p>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Part #</th>
                    <th>Name</th>
                    <th>Revision</th>
                    <th>Material</th>
                    <th>Customer P/N</th>
                    <th>Drawing #</th>
                    <th>Stages</th>
                    <th>Drawings</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _pagedParts)
                {
                    <tr class="clickable-row" @onclick="() => ViewPart(p.Id)">
                        <td><strong>@p.PartNumber</strong></td>
                        <td>@p.Name</td>
                        <td>@(p.Revision ?? "—")</td>
                        <td>@p.Material</td>
                        <td>@(p.CustomerPartNumber ?? "—")</td>
                        <td>@(p.DrawingNumber ?? "—")</td>
                        <td>@(p.StageRequirements?.Count ?? 0)</td>
                        <td>@(p.Drawings?.Count ?? 0)</td>
                        <td>
                            <span class="badge @(p.IsActive ? "badge-active" : "badge-cancelled")">@(p.IsActive ? "Active" : "Inactive")</span>
                            @if (p.IsDefensePart)
                            {
                                <span class="badge badge-warning" style="margin-left: 4px;">🛡️ Defense</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_filteredParts.Count > _pageSize)
    {
        <Pagination CurrentPage="_currentPage" TotalItems="_filteredParts.Count" PageSize="_pageSize" OnPageChanged="OnPageChanged" />
    }
}

@code {
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private string _filter = "active";
    private int _currentPage = 1;
    private int _pageSize = 25;
    private bool _showDefenseFilter;

    private List<Part> _allParts = new();
    private List<Part> _filteredParts = new();
    private List<Part> _pagedParts = new();

    protected override async Task OnInitializedAsync()
    {
        _showDefenseFilter = Features.IsEnabled("dlms");
        _allParts = await PartService.GetAllPartsAsync(activeOnly: false);
        ApplyFilters();
        _loading = false;
    }

    private void SetFilter(string filter)
    {
        _filter = filter;
        _currentPage = 1;
        ApplyFilters();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (!string.IsNullOrWhiteSpace(_searchTerm) && _searchTerm.Length >= 2)
        {
            _allParts = await PartService.SearchPartsAsync(_searchTerm, activeOnly: false);
        }
        else if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            _allParts = await PartService.GetAllPartsAsync(activeOnly: false);
        }
        _currentPage = 1;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filteredParts = _filter switch
        {
            "active" => _allParts.Where(p => p.IsActive).ToList(),
            "inactive" => _allParts.Where(p => !p.IsActive).ToList(),
            "defense" => _allParts.Where(p => p.IsDefensePart).ToList(),
            _ => _allParts
        };

        _pagedParts = _filteredParts.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private void OnPageChanged(int page)
    {
        _currentPage = page;
        ApplyFilters();
    }

    private void ViewPart(int id)
    {
        Nav.NavigateTo($"/parts/{id}");
    }

    private void GoToNewPart()
    {
        Nav.NavigateTo("/admin/parts");
    }
}
