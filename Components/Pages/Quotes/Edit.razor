@page "/quotes/new"
@page "/quotes/{Id:int}/edit"
@inject IQuoteService QuoteService
@inject IPartService PartService
@inject IPricingEngineService PricingEngine
@inject ISmartPricingService SmartPricing
@inject ITenantFeatureService Features
@inject ICustomFieldService CustomFieldService
@inject NavigationManager Nav
@inject ToastService Toast
@using Microsoft.AspNetCore.Components.Routing
@using System.Text.Json

<PageTitle>@(_isNew ? "New Quote" : "Edit Quote") - Vectrik</PageTitle>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else
{
    <div class="page-header">
        <div>
            <button class="btn btn-sm btn-secondary" @onclick="GoBack" style="margin-bottom: 8px;">← Quotes</button>
            <h1 class="page-title">@(_isNew ? "New Quote" : $"Edit {_quote.QuoteNumber}")</h1>
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="btn btn-primary" @onclick="SaveQuote">💾 Save</button>
            @if (!_isNew)
            {
                <button class="btn btn-secondary" @onclick="SaveRevision">📝 Save as Revision</button>
            }
        </div>
    </div>

    <!-- Customer & Quote Info -->
    <div class="card" style="margin-bottom: 16px;">
        <h3 class="card-title">Quote Information</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;">
            <div class="form-group">
                <label class="form-label">Customer Name <span style="color:var(--danger)">*</span></label>
                <input class="form-control" @bind="_quote.CustomerName" />
            </div>
            <div class="form-group">
                <label class="form-label">Customer Email</label>
                <input class="form-control" @bind="_quote.CustomerEmail" />
            </div>
            <div class="form-group">
                <label class="form-label">Customer Phone</label>
                <input class="form-control" @bind="_quote.CustomerPhone" />
            </div>
            <div class="form-group">
                <label class="form-label">Expiration Date</label>
                <input class="form-control" type="date" @bind="_quote.ExpirationDate" />
            </div>
            <div class="form-group">
                <label class="form-label">Target Margin %</label>
                <input class="form-control" type="number" step="0.1" @bind="_quote.TargetMarginPct" />
            </div>
            @if (_showDlms)
            {
                <div class="form-group">
                    <label class="form-label">Contract Number</label>
                    <input class="form-control" @bind="_quote.ContractNumber" />
                </div>
            }
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-control" @bind="_quote.Notes" rows="2"></textarea>
        </div>
    </div>

    <!-- Line Items BOM Builder -->
    <div class="card" style="margin-bottom: 16px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <h3 class="card-title" style="margin: 0;">Line Items</h3>
            <button class="btn btn-sm btn-primary" @onclick="ShowAddLine">+ Add Part</button>
        </div>

        @if (_quote.Lines.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Part</th>
                        <th>Qty</th>
                        <th>Labor (min)</th>
                        <th>Setup $/ea</th>
                        <th>Material $/ea</th>
                        <th>Overhead $/ea</th>
                        <th>Est. Cost/Part</th>
                        <th>Quoted $/Part</th>
                        <th>Line Total</th>
                        <th>Margin</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in _quote.Lines)
                    {
                        <tr>
                            <td>
                                @(line.Part?.PartNumber ?? "—") — @(line.Part?.Name ?? "")
                                @if (line.StackLevel.HasValue && line.StackLevel > 1)
                                {
                                    <span class="badge badge-info" style="margin-left: 4px; font-size: 0.7rem;">@(line.StackLevel)x Stack</span>
                                }
                            </td>
                            <td>@line.Quantity</td>
                            <td>@line.LaborMinutes.ToString("F0")</td>
                            <td>@line.SetupCostEach.ToString("C")</td>
                            <td>@line.MaterialCostEach.ToString("C")</td>
                            <td>@line.OverheadCostEach.ToString("C")</td>
                            <td>@line.EstimatedCostPerPart.ToString("C")</td>
                            <td>@line.QuotedPricePerPart.ToString("C")</td>
                            <td>@((line.QuotedPricePerPart * line.Quantity).ToString("C"))</td>
                            <td>
                                @if (line.QuotedPricePerPart > 0)
                                {
                                    var lineMargin = (line.QuotedPricePerPart - line.EstimatedCostPerPart) / line.QuotedPricePerPart * 100;
                                    <span style="color: @(lineMargin >= 0 ? "var(--success)" : "var(--danger)")">@lineMargin.ToString("F1")%</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveLine(line.Id)">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="color: var(--text-muted); text-align: center; padding: 20px;">No line items. Click "+ Add Part" to build your quote.</p>
        }
    </div>

    <!-- Live Margin Summary -->
    <div class="card">
        <h3 class="card-title">Quote Summary</h3>
        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; text-align: center;">
            <div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Est. Cost</div>
                <div style="font-size: 1.2rem; font-weight: 600;">@_quote.TotalEstimatedCost.ToString("C")</div>
            </div>
            <div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Quoted Price</div>
                <div style="font-size: 1.2rem; font-weight: 600;">@(_quote.QuotedPrice?.ToString("C") ?? "$0.00")</div>
            </div>
            <div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Markup</div>
                <div style="font-size: 1.2rem; font-weight: 600; color: @(_quote.Markup >= 0 ? "var(--success)" : "var(--danger)")">@(_quote.Markup?.ToString("C") ?? "$0.00")</div>
            </div>
            <div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Margin %</div>
                <div style="font-size: 1.2rem; font-weight: 600; color: @(ComputedMarginPct >= _quote.TargetMarginPct ? "var(--success)" : "var(--warning)")">@ComputedMarginPct.ToString("F1")%</div>
            </div>
            <div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Target</div>
                <div style="font-size: 1.2rem; font-weight: 600;">@_quote.TargetMarginPct.ToString("F1")%</div>
            </div>
        </div>
    </div>

    @if (_customFieldDefs.Count > 0)
    {
        <div class="card" style="margin-top: 16px;">
            <h3 class="card-title">Custom Fields</h3>
            <CustomFieldsEditor FieldDefinitions="_customFieldDefs" Values="_customFieldValues"
                                ValuesChanged="OnCustomFieldsChanged" />
        </div>
    }
}

<!-- Add Line Modal -->
<AppModal Visible="_showAddLine" VisibleChanged="v => _showAddLine = v" Title="Add Part to Quote" Size="lg">
    <ChildContent>
        <div class="form-group">
            <label class="form-label">Part</label>
            <select class="form-control" @bind="_linePartId" @bind:after="OnPartSelected">
                <option value="0">Select a part...</option>
                @foreach (var p in _parts)
                {
                    <option value="@p.Id">@p.PartNumber — @p.Name</option>
                }
            </select>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
            <div class="form-group">
                <label class="form-label">Quantity</label>
                <input class="form-control" type="number" min="1" @bind="_lineQty" @bind:after="OnQuantityChanged" />
            </div>
            <div class="form-group">
                <label class="form-label">Quoted Price/Part</label>
                <input class="form-control" type="number" step="0.01" @bind="_linePrice" />
            </div>
        </div>

        @if (_lineEstimate != null)
        {
            <!-- AI-Powered Cost Breakdown -->
            <div style="background: var(--bg-tertiary); border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Cost Breakdown</div>
                    @if (_lineEstimate.PricingTier != null)
                    {
                        <span class="badge badge-info">@_lineEstimate.PricingTier</span>
                    }
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4px; font-size: 0.85rem;">
                    <span>Labor (@_lineEstimate.CostBreakdown.TotalLaborMinutes.ToString("F0") min):</span>
                    <span>@_lineEstimate.CostBreakdown.LaborCost.ToString("C")</span>
                    <span>Setup (@_lineEstimate.CostBreakdown.TotalSetupMinutes.ToString("F0") min):</span>
                    <span>@_lineEstimate.CostBreakdown.SetupCost.ToString("C")</span>
                    <span>Material:</span>
                    <span>@_lineEstimate.CostBreakdown.EffectiveMaterialCost.ToString("C")</span>
                    <span>Overhead:</span>
                    <span>@_lineEstimate.CostBreakdown.OverheadCost.ToString("C")</span>
                    @if (_lineEstimate.CostBreakdown.OutsideProcessCost > 0)
                    {
                        <span>Outside Process:</span>
                        <span>@_lineEstimate.CostBreakdown.OutsideProcessCost.ToString("C")</span>
                    }
                    @if (_lineEstimate.CostBreakdown.StageMaterialCost > 0)
                    {
                        <span>Consumables/Tooling:</span>
                        <span>@_lineEstimate.CostBreakdown.StageMaterialCost.ToString("C")</span>
                    }
                </div>
                <div style="border-top: 1px solid var(--border-color); margin-top: 8px; padding-top: 8px; display: grid; grid-template-columns: 1fr 1fr; gap: 4px;">
                    <strong>Total Cost (@_lineQty units):</strong>
                    <strong>@_lineEstimate.CostBreakdown.TotalCost.ToString("C")</strong>
                    <strong>Cost/Part:</strong>
                    <strong>@((_lineQty > 0 ? _lineEstimate.CostBreakdown.TotalCost / _lineQty : 0).ToString("C"))</strong>
                </div>
            </div>

            <!-- Pricing Suggestion -->
            <div style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(16, 185, 129, 0.08)); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                <div style="font-size: 0.85rem; font-weight: 600; margin-bottom: 8px;">Suggested Pricing</div>
                <div style="display: grid; grid-template-columns: 1fr auto auto; gap: 8px; align-items: center; font-size: 0.85rem;">
                    @if (_lineEstimate.PartPricingSellPrice.HasValue && _lineEstimate.PartPricingSellPrice > 0)
                    {
                        <span>Configured Sell Price:</span>
                        <strong style="color: var(--accent);">@_lineEstimate.PartPricingSellPrice.Value.ToString("C")/part</strong>
                        <button class="btn btn-sm btn-primary" @onclick="() => UsePrice(_lineEstimate.PartPricingSellPrice.Value)">Use</button>
                    }
                    <span>Target Margin (@_quote.TargetMarginPct.ToString("F0")%) Price:</span>
                    <strong style="color: var(--success);">@_lineEstimate.TargetMarginPrice.ToString("C")/part</strong>
                    <button class="btn btn-sm btn-secondary" @onclick="() => UsePrice(_lineEstimate.TargetMarginPrice)">Use</button>
                </div>
            </div>

            <!-- Stacking Options (SLS Parts Only) -->
            @if (_lineEstimate.IsAdditivePart && _lineEstimate.StackingOptions.Count > 1)
            {
                <div style="background: var(--bg-tertiary); border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                    <div style="font-size: 0.85rem; font-weight: 600; margin-bottom: 8px;">Build Stacking Options</div>
                    <table class="data-table" style="font-size: 0.82rem;">
                        <thead>
                            <tr>
                                <th>Config</th>
                                <th>Parts/Build</th>
                                <th>Build Hrs</th>
                                <th>Builds Req.</th>
                                <th>Machine $/Part</th>
                                <th>Total $/Part</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var opt in _lineEstimate.StackingOptions)
                            {
                                <tr style="@(opt.IsRecommended ? "background: rgba(16, 185, 129, 0.08);" : "")">
                                    <td>
                                        @opt.Label
                                        @if (opt.IsRecommended)
                                        {
                                            <span class="badge badge-active" style="margin-left: 4px; font-size: 0.7rem;">Best</span>
                                        }
                                    </td>
                                    <td>@opt.PartsPerBuild</td>
                                    <td>@opt.BuildDurationHours.ToString("F1")</td>
                                    <td>@opt.BuildsRequired</td>
                                    <td>@opt.MachineCostPerPart.ToString("C")</td>
                                    <td><strong>@opt.TotalCostPerPart.ToString("C")</strong></td>
                                    <td>
                                        @if (!opt.IsRecommended)
                                        {
                                            <button class="btn btn-sm btn-secondary" style="font-size: 0.75rem; padding: 2px 8px;"
                                                    @onclick="() => SelectStackOption(opt)">Select</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Volume Break Pricing -->
            @if (_lineEstimate.QuantityBreaks.Count > 1)
            {
                <details style="margin-bottom: 12px;">
                    <summary style="cursor: pointer; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); padding: 8px 0;">
                        Volume Break Pricing
                    </summary>
                    <div style="background: var(--bg-tertiary); border-radius: 8px; padding: 12px;">
                        <table class="data-table" style="font-size: 0.82rem;">
                            <thead>
                                <tr>
                                    <th>Qty</th>
                                    <th>Setup/Part</th>
                                    <th>Cost/Part</th>
                                    <th>Total Cost</th>
                                    <th>Suggested Price/Part</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var qb in _lineEstimate.QuantityBreaks)
                                {
                                    <tr style="@(qb.Quantity == _lineQty ? "background: rgba(99, 102, 241, 0.08); font-weight: 600;" : "")">
                                        <td>@qb.Quantity</td>
                                        <td>@qb.SetupCostPerPart.ToString("C")</td>
                                        <td>@qb.CostPerPart.ToString("C")</td>
                                        <td>@qb.TotalCost.ToString("C")</td>
                                        <td>@qb.SuggestedPrice.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </details>
            }

            <!-- AI-Powered Smart Pricing -->
            @if (_smartPrice != null)
            {
                <div style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.06), rgba(59, 130, 246, 0.06)); border: 1px solid rgba(139, 92, 246, 0.2); border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <div style="font-size: 0.85rem; font-weight: 600;">AI-Powered Estimate</div>
                        <div style="display: flex; gap: 6px; align-items: center;">
                            <span class="badge @(_smartPrice.ConfidenceScore >= 50 ? "badge-active" : _smartPrice.ConfidenceScore >= 25 ? "badge-warning" : "badge-cancelled")"
                                  style="font-size: 0.7rem;">
                                @_smartPrice.ConfidenceLabel Confidence (@_smartPrice.ConfidenceScore%)
                            </span>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 10px; text-align: center;">
                        <div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Parametric</div>
                            <div style="font-size: 1rem; font-weight: 600;">@_smartPrice.ParametricCostPerPart.ToString("C")</div>
                        </div>
                        @if (_smartPrice.SimilarPartCostPerPart.HasValue)
                        {
                            <div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">Similar Parts Avg</div>
                                <div style="font-size: 1rem; font-weight: 600;">@_smartPrice.SimilarPartCostPerPart.Value.ToString("C")</div>
                            </div>
                        }
                        <div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">AI Blended</div>
                            <div style="font-size: 1.1rem; font-weight: 700; color: var(--accent);">@_smartPrice.AiEstimatedCostPerPart.ToString("C")</div>
                        </div>
                    </div>

                    @if (_smartPrice.RecommendedSellPrice > 0)
                    {
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 6px 10px; background: rgba(16, 185, 129, 0.08); border-radius: 6px; margin-bottom: 8px;">
                            <span style="font-size: 0.85rem;">AI Recommended Price:</span>
                            <div style="display: flex; gap: 8px; align-items: center;">
                                <strong style="color: var(--success); font-size: 1rem;">@_smartPrice.RecommendedSellPrice.ToString("C")/part</strong>
                                <button class="btn btn-sm btn-primary" @onclick="() => UsePrice(_smartPrice.RecommendedSellPrice)">Use</button>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_smartPrice.AccuracyAdjustmentNote))
                    {
                        <div style="font-size: 0.78rem; color: var(--warning); padding: 4px 0;">
                            @_smartPrice.AccuracyAdjustmentNote
                        </div>
                    }

                    <!-- Complexity Badge -->
                    @if (_smartPrice.Complexity.Score > 0)
                    {
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Complexity:</span>
                            <span class="badge @(_smartPrice.Complexity.Tier == "Simple" ? "badge-active" : _smartPrice.Complexity.Tier == "Moderate" ? "badge-info" : _smartPrice.Complexity.Tier == "Complex" ? "badge-warning" : "badge-cancelled")">
                                @_smartPrice.Complexity.Tier (@_smartPrice.Complexity.Score.ToString("F1")/10)
                            </span>
                        </div>
                    }

                    <!-- Similar Parts -->
                    @if (_smartPrice.SimilarParts.Any(s => s.CompletedJobCount > 0))
                    {
                        <details>
                            <summary style="cursor: pointer; font-size: 0.82rem; font-weight: 600; color: var(--text-primary); padding: 4px 0;">
                                Similar Parts (@_smartPrice.SimilarParts.Count(s => s.CompletedJobCount > 0) with actuals)
                            </summary>
                            <table class="data-table" style="font-size: 0.78rem; margin-top: 6px;">
                                <thead>
                                    <tr>
                                        <th>Part</th>
                                        <th>Match</th>
                                        <th>Actual $/Part</th>
                                        <th>Est. $/Part</th>
                                        <th>Accuracy</th>
                                        <th>Jobs</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sp in _smartPrice.SimilarParts.Where(s => s.CompletedJobCount > 0).Take(5))
                                    {
                                        <tr>
                                            <td>@sp.PartNumber — @sp.PartName</td>
                                            <td>
                                                <span style="color: @(sp.SimilarityScore >= 70 ? "var(--success)" : sp.SimilarityScore >= 40 ? "var(--warning)" : "var(--text-muted)")">
                                                    @sp.SimilarityScore.ToString("F0")%
                                                </span>
                                            </td>
                                            <td>@sp.ActualCostPerPart.ToString("C")</td>
                                            <td>@sp.EstimatedCostPerPart.ToString("C")</td>
                                            <td>@(sp.CostAccuracyRatio > 0 ? sp.CostAccuracyRatio.ToString("F2") + "x" : "—")</td>
                                            <td>@sp.CompletedJobCount</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </details>
                    }
                </div>
            }
            else if (_linePartId > 0 && !_estimateLoading && _lineEstimate != null)
            {
                <div style="text-align: center; padding: 8px; color: var(--text-muted); font-size: 0.82rem;">
                    <span class="spinner" style="width: 14px; height: 14px;"></span> Loading AI pricing...
                </div>
            }
        }
        else if (_linePartId > 0 && _estimateLoading)
        {
            <div style="text-align: center; padding: 20px; color: var(--text-muted);">
                <span class="spinner"></span> Calculating estimate...
            </div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-secondary" @onclick="() => _showAddLine = false">Cancel</button>
        <button class="btn btn-primary" @onclick="AddLine" disabled="@(_linePartId == 0 || _estimateLoading)">Add Line</button>
    </Footer>
</AppModal>

<!-- Revision Notes Modal -->
<AppModal Visible="_showRevisionModal" VisibleChanged="v => _showRevisionModal = v" Title="Save Revision" Size="sm">
    <ChildContent>
        <div class="form-group">
            <label class="form-label">Change Notes</label>
            <textarea class="form-control" @bind="_revisionNotes" rows="3" placeholder="Describe what changed..."></textarea>
        </div>
    </ChildContent>
    <Footer>
        <button class="btn btn-secondary" @onclick="() => _showRevisionModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="ConfirmRevision">Save Revision</button>
    </Footer>
</AppModal>

<ConfirmDialog @ref="_confirm" />
<NavigationLock OnBeforeInternalNavigation="OnBeforeNavigation" ConfirmExternalNavigation="_hasChanges" />

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _isNew;
    private bool _showDlms;
    private Quote _quote = new();
    private List<Part> _parts = new();
    private ConfirmDialog _confirm = null!;

    // Custom fields
    private List<CustomFieldDefinition> _customFieldDefs = new();
    private Dictionary<string, string> _customFieldValues = new();

    // Add line
    private bool _showAddLine;
    private int _linePartId;
    private int _lineQty = 1;
    private decimal _linePrice;
    private QuoteLineEstimate? _lineEstimate;
    private SmartPriceRecommendation? _smartPrice;
    private bool _estimateLoading;

    // Revision
    private bool _showRevisionModal;
    private string _revisionNotes = string.Empty;

    // Unsaved changes tracking
    private bool _hasChanges;
    private string _originalCustomerName = string.Empty;

    private decimal ComputedMarginPct => _quote.QuotedPrice > 0
        ? (_quote.QuotedPrice.Value - _quote.TotalEstimatedCost) / _quote.QuotedPrice.Value * 100
        : 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _showDlms = Features.IsEnabled("dlms");
            _parts = await PartService.GetAllPartsAsync();

            if (Id > 0)
            {
                _quote = await QuoteService.GetQuoteByIdAsync(Id) ?? new Quote();
                _isNew = false;
            }
            else
            {
                _isNew = true;
                _quote = new Quote
                {
                    QuoteNumber = await QuoteService.GenerateQuoteNumberAsync(),
                    TargetMarginPct = 25,
                    ExpirationDate = DateTime.UtcNow.AddDays(30)
                };
            }
            _customFieldDefs = await CustomFieldService.GetFieldDefinitionsAsync("Quote");
            if (!string.IsNullOrEmpty(_quote.CustomFieldValues))
            {
                try { _customFieldValues = JsonSerializer.Deserialize<Dictionary<string, string>>(_quote.CustomFieldValues) ?? new(); }
                catch { _customFieldValues = new(); }
            }

            _originalCustomerName = _quote.CustomerName ?? "";
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPartSelected()
    {
        if (_linePartId > 0)
        {
            await RefreshEstimate();
        }
        else
        {
            _lineEstimate = null;
        }
    }

    private async Task OnQuantityChanged()
    {
        if (_linePartId > 0 && _lineQty > 0)
            await RefreshEstimate();
    }

    private async Task RefreshEstimate()
    {
        _estimateLoading = true;
        _smartPrice = null;
        StateHasChanged();
        try
        {
            _lineEstimate = await PricingEngine.GetQuoteLineEstimateAsync(
                _linePartId, Math.Max(1, _lineQty), _quote.TargetMarginPct);

            // Auto-set price: prefer PartPricing sell price, then target margin price
            if (_lineEstimate.PartPricingSellPrice.HasValue && _lineEstimate.PartPricingSellPrice > 0)
                _linePrice = _lineEstimate.PartPricingSellPrice.Value;
            else if (_lineEstimate.TargetMarginPrice > 0)
                _linePrice = _lineEstimate.TargetMarginPrice;
            else
                _linePrice = 0;
        }
        catch
        {
            _lineEstimate = null;
            _linePrice = 0;
        }
        finally
        {
            _estimateLoading = false;
        }

        // Fetch AI-powered smart pricing in the background (non-blocking)
        _ = LoadSmartPriceAsync();
    }

    private async Task LoadSmartPriceAsync()
    {
        try
        {
            _smartPrice = await SmartPricing.GetSmartPriceAsync(
                _linePartId, Math.Max(1, _lineQty), _quote.TargetMarginPct);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _smartPrice = null;
        }
    }

    private void UsePrice(decimal price)
    {
        _linePrice = price;
    }

    private void SelectStackOption(StackingOption opt)
    {
        // Recalculate price using this stacking option's cost
        _linePrice = _quote.TargetMarginPct < 100
            ? Math.Round(opt.TotalCostPerPart / (1 - _quote.TargetMarginPct / 100m), 2)
            : 0;
    }

    private void ShowAddLine()
    {
        _linePartId = 0;
        _lineQty = 1;
        _linePrice = 0;
        _lineEstimate = null;
        _smartPrice = null;
        _estimateLoading = false;
        _showAddLine = true;
    }

    private async Task AddLine()
    {
        if (_linePartId == 0) return;
        if (_lineQty <= 0)
        {
            Toast.ShowError("Quantity must be greater than 0.");
            return;
        }
        if (_lineQty > 999999)
        {
            Toast.ShowError("Quantity exceeds maximum allowed (999,999).");
            return;
        }
        if (_linePrice < 0)
        {
            Toast.ShowError("Quoted price cannot be negative.");
            return;
        }
        try
        {
            await QuoteService.AddLineAsync(_quote.Id > 0 ? _quote.Id : 0, _linePartId, _lineQty, _linePrice);
            if (_quote.Id == 0)
            {
                // Save the quote first if new
                _quote = await QuoteService.CreateQuoteAsync(_quote);
                await QuoteService.AddLineAsync(_quote.Id, _linePartId, _lineQty, _linePrice);
            }
            _quote = await QuoteService.GetQuoteByIdAsync(_quote.Id) ?? _quote;
            _showAddLine = false;
            _hasChanges = true;
            Toast.ShowSuccess("Line added");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task RemoveLine(int lineId)
    {
        if (!await _confirm.ShowAsync("Remove this line item?")) return;
        try
        {
            await QuoteService.RemoveLineAsync(lineId);
            _quote = await QuoteService.GetQuoteByIdAsync(_quote.Id) ?? _quote;
            Toast.ShowSuccess("Line removed");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task SaveQuote()
    {
        if (string.IsNullOrWhiteSpace(_quote.CustomerName))
        {
            Toast.ShowError("Customer name is required.");
            return;
        }

        if (!_isNew && !_quote.Lines.Any())
        {
            Toast.ShowError("At least one line item is required.");
            return;
        }

        if (_customFieldValues.Count > 0)
            _quote.CustomFieldValues = JsonSerializer.Serialize(_customFieldValues);

        try
        {
            if (_isNew)
            {
                _quote = await QuoteService.CreateQuoteAsync(_quote);
                _isNew = false;
                _hasChanges = false;
                Toast.ShowSuccess("Quote created");
                Nav.NavigateTo($"/quotes/{_quote.Id}/edit", replace: true);
            }
            else
            {
                _quote = await QuoteService.UpdateQuoteAsync(_quote);
                _hasChanges = false;
                Toast.ShowSuccess("Quote saved");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private void SaveRevision()
    {
        _revisionNotes = string.Empty;
        _showRevisionModal = true;
    }

    private async Task ConfirmRevision()
    {
        try
        {
            await QuoteService.UpdateQuoteAsync(_quote);
            await QuoteService.CreateRevisionAsync(_quote.Id, _revisionNotes, _quote.LastModifiedBy ?? "System");
            _quote = await QuoteService.GetQuoteByIdAsync(_quote.Id) ?? _quote;
            _showRevisionModal = false;
            Toast.ShowSuccess($"Revision R{_quote.RevisionNumber} saved");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private void OnCustomFieldsChanged(Dictionary<string, string> values) => _customFieldValues = values;

    private void GoBack() => Nav.NavigateTo("/quotes");

    private async Task OnBeforeNavigation(LocationChangingContext context)
    {
        if (_hasChanges || _quote.CustomerName != _originalCustomerName)
        {
            var confirmed = await _confirm.ShowAsync("You have unsaved changes. Leave this page?");
            if (!confirmed)
                context.PreventNavigation();
        }
    }
}
