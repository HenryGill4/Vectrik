@page "/quotes/{Id:int}"
@inject IQuoteService QuoteService
@inject IPartService PartService
@inject ITenantFeatureService Features
@inject ICustomFieldService CustomFieldService
@inject IDocumentTemplateService TemplateService
@inject IJSRuntime JS
@inject IWorkflowEngine WorkflowEngine
@inject NavigationManager Nav
@inject ToastService Toast
@using System.Text.Json

<PageTitle>@(_quote?.QuoteNumber ?? "Quote") - Vectrik</PageTitle>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading quote...</div>
}
else if (_quote == null)
{
    <div class="card" style="text-align: center; padding: 40px;">
        <p style="color: var(--text-muted);">Quote not found.</p>
        <button class="btn btn-secondary" @onclick="GoBack">← Back to Quotes</button>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <button class="btn btn-sm btn-secondary" @onclick="GoBack" style="margin-bottom: 8px;">← Quotes</button>
            <h1 class="page-title">@_quote.QuoteNumber — @_quote.CustomerName</h1>
            <div style="display: flex; gap: 8px; margin-top: 4px; align-items: center;">
                <span class="badge @GetStatusBadge(_quote.Status)">@_quote.Status</span>
                <span class="badge badge-info">Rev @_quote.RevisionNumber</span>
                @if (_quote.IsDefenseContract)
                {
                    <span class="badge badge-warning">🛡️ Defense</span>
                }
            </div>
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="btn btn-secondary" @onclick="PrintQuote">🖨️ Print Quote</button>
            @if (_quote.Status == QuoteStatus.Draft)
            {
                <button class="btn btn-secondary" @onclick="GoToEdit">✏️ Edit</button>
                <button class="btn btn-primary" @onclick="MarkSent">📤 Mark Sent</button>
            }
            @if (_quote.Status == QuoteStatus.Sent)
            {
                <button class="btn btn-success" @onclick="AcceptAndConvert">✅ Accept & Convert to WO</button>
                <button class="btn btn-danger" @onclick="Reject">❌ Reject</button>
            }
        </div>
    </div>

    @if (_pendingApproval != null)
    {
        <ApprovalStatus Instance="_pendingApproval" OnApproved="HandleQuoteApproved" OnRejected="HandleQuoteRejected" />
    }

    <!-- Tab Bar -->
    <div class="content-tab-bar" style="margin-bottom: 16px;">
        <button class="tab @(_tab == "summary" ? "active" : "")" @onclick='() => _tab = "summary"'>Summary</button>
        <button class="tab @(_tab == "lines" ? "active" : "")" @onclick='() => _tab = "lines"'>Lines (@_quote.Lines.Count)</button>
        <button class="tab @(_tab == "revisions" ? "active" : "")" @onclick='() => _tab = "revisions"'>Revisions (@(_quote.Revisions?.Count ?? 0))</button>
    </div>

    <!-- Summary Tab -->
    @if (_tab == "summary")
    {
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="card">
                <h3 class="card-title">Customer</h3>
                <div class="detail-grid">
                    <div class="detail-label">Name</div><div class="detail-value">@_quote.CustomerName</div>
                    <div class="detail-label">Email</div><div class="detail-value">@(_quote.CustomerEmail ?? "—")</div>
                    <div class="detail-label">Phone</div><div class="detail-value">@(_quote.CustomerPhone ?? "—")</div>
                    <div class="detail-label">Created</div><div class="detail-value">@_quote.CreatedDate.ToString("yyyy-MM-dd")</div>
                    <div class="detail-label">Expiration</div><div class="detail-value">@(_quote.ExpirationDate?.ToString("yyyy-MM-dd") ?? "—")</div>
                    @if (_quote.SentAt.HasValue)
                    {
                        <div class="detail-label">Sent At</div><div class="detail-value">@_quote.SentAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                    }
                    @if (_quote.AcceptedAt.HasValue)
                    {
                        <div class="detail-label">Accepted At</div><div class="detail-value">@_quote.AcceptedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                    }
                </div>
            </div>

            <div class="card">
                <h3 class="card-title">Financials</h3>
                <div class="detail-grid">
                    <div class="detail-label">Est. Labor Cost</div><div class="detail-value">@_quote.EstimatedLaborCost.ToString("C")</div>
                    <div class="detail-label">Est. Material Cost</div><div class="detail-value">@_quote.EstimatedMaterialCost.ToString("C")</div>
                    <div class="detail-label">Est. Overhead Cost</div><div class="detail-value">@_quote.EstimatedOverheadCost.ToString("C")</div>
                    <div class="detail-label">Total Est. Cost</div><div class="detail-value"><strong>@_quote.TotalEstimatedCost.ToString("C")</strong></div>
                    <div class="detail-label">Quoted Price</div><div class="detail-value"><strong>@(_quote.QuotedPrice?.ToString("C") ?? "—")</strong></div>
                    <div class="detail-label">Markup</div>
                    <div class="detail-value" style="color: @(_quote.Markup >= 0 ? "var(--success)" : "var(--danger)")">
                        @(_quote.Markup?.ToString("C") ?? "—")
                    </div>
                    <div class="detail-label">Target Margin</div><div class="detail-value">@_quote.TargetMarginPct.ToString("F1")%</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_quote.Notes))
            {
                <div class="card" style="grid-column: span 2;">
                    <h3 class="card-title">Notes</h3>
                    <p style="color: var(--text-secondary);">@_quote.Notes</p>
                </div>
            }

            @if (_customFieldDefs.Count > 0 && _customFieldValues.Any())
            {
                <div class="card" style="grid-column: span 2;">
                    <h3 class="card-title">Custom Fields</h3>
                    <div class="detail-grid">
                        @foreach (var def in _customFieldDefs)
                        {
                            <div class="detail-label">@def.Label</div>
                            <div class="detail-value">@(_customFieldValues.TryGetValue(def.Name, out var v) ? v : "—")</div>
                        }
                    </div>
                </div>
            }

            @if (_quote.ConvertedWorkOrderId.HasValue)
            {
                <div class="card" style="grid-column: span 2; background: rgba(16, 185, 129, 0.08); border-color: var(--success);">
                    <p style="margin: 0;">✅ Converted to <a href="/workorders/@_quote.ConvertedWorkOrderId" style="color: var(--accent); font-weight: 600;">Work Order</a></p>
                </div>
            }
        </div>
    }

    <!-- Lines Tab -->
    @if (_tab == "lines")
    {
        <div class="card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Part</th>
                        <th>Qty</th>
                        <th>Labor (min)</th>
                        <th>Setup (min)</th>
                        <th>Material $/ea</th>
                        <th>Est. Cost/Part</th>
                        <th>Quoted $/Part</th>
                        <th>Line Total</th>
                        <th>Margin</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in _quote.Lines)
                    {
                        <tr>
                            <td><strong>@(l.Part?.PartNumber ?? "—")</strong> — @(l.Part?.Name ?? "")</td>
                            <td>@l.Quantity</td>
                            <td>@l.LaborMinutes.ToString("F0")</td>
                            <td>@l.SetupMinutes.ToString("F0")</td>
                            <td>@l.MaterialCostEach.ToString("C")</td>
                            <td>@l.EstimatedCostPerPart.ToString("C")</td>
                            <td>@l.QuotedPricePerPart.ToString("C")</td>
                            <td>@((l.QuotedPricePerPart * l.Quantity).ToString("C"))</td>
                            <td>
                                @if (l.QuotedPricePerPart > 0)
                                {
                                    var m = (l.QuotedPricePerPart - l.EstimatedCostPerPart) / l.QuotedPricePerPart * 100;
                                    <span style="color: @(m >= 0 ? "var(--success)" : "var(--danger)")">@m.ToString("F1")%</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="font-weight: 600;">
                        <td>Totals</td>
                        <td>@_quote.Lines.Sum(l => l.Quantity)</td>
                        <td colspan="3"></td>
                        <td>@_quote.TotalEstimatedCost.ToString("C")</td>
                        <td></td>
                        <td>@(_quote.QuotedPrice?.ToString("C") ?? "—")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }

    <!-- Revisions Tab -->
    @if (_tab == "revisions")
    {
        <div class="card">
            <h3 class="card-title">Revision History</h3>
            @if (_quote.Revisions == null || !_quote.Revisions.Any())
            {
                <p style="color: var(--text-muted);">No revision history yet.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Rev #</th>
                            <th>Est. Cost</th>
                            <th>Quoted Price</th>
                            <th>Change Notes</th>
                            <th>Date</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rev in _quote.Revisions.OrderByDescending(r => r.RevisionNumber))
                        {
                            <tr>
                                <td><strong>R@(rev.RevisionNumber)</strong></td>
                                <td>@rev.TotalEstimatedCost.ToString("C")</td>
                                <td>@(rev.QuotedPrice?.ToString("C") ?? "—")</td>
                                <td>@(rev.ChangeNotes ?? "—")</td>
                                <td>@rev.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@rev.CreatedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

<ConfirmDialog @ref="_confirm" />

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private Quote? _quote;
    private string _tab = "summary";
    private ConfirmDialog _confirm = null!;

    // Workflow
    private WorkflowInstance? _pendingApproval;

    // Custom fields
    private List<CustomFieldDefinition> _customFieldDefs = new();
    private Dictionary<string, string> _customFieldValues = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _quote = await QuoteService.GetQuoteDetailAsync(Id);
            _customFieldDefs = await CustomFieldService.GetFieldDefinitionsAsync("Quote");
            if (_quote != null && !string.IsNullOrEmpty(_quote.CustomFieldValues))
            {
                try { _customFieldValues = JsonSerializer.Deserialize<Dictionary<string, string>>(_quote.CustomFieldValues) ?? new(); }
                catch { _customFieldValues = new(); }
            }
            if (_quote != null)
                _pendingApproval = await WorkflowEngine.GetPendingAsync("Quote", _quote.Id);
        }
        catch
        {
            _quote = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task MarkSent()
    {
        if (_quote == null) return;
        try
        {
            _quote.SentAt = DateTime.UtcNow;
            await QuoteService.UpdateQuoteAsync(_quote);
            await QuoteService.UpdateStatusAsync(Id, QuoteStatus.Sent);
            _quote = await QuoteService.GetQuoteDetailAsync(Id);
            Toast.ShowSuccess("Quote marked as sent");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task AcceptAndConvert()
    {
        if (_quote == null) return;
        if (!await _confirm.ShowAsync("Accept this quote and create a Work Order?")) return;
        try
        {
            var instance = await WorkflowEngine.StartAsync("Quote", Id);
            if (instance != null)
            {
                _pendingApproval = instance;
                Toast.ShowInfo("Acceptance requires approval. Workflow started.");
                return;
            }

            _quote.AcceptedAt = DateTime.UtcNow;
            await QuoteService.UpdateQuoteAsync(_quote);
            var wo = await QuoteService.ConvertToWorkOrderAsync(Id, _quote.LastModifiedBy ?? "System");
            Toast.ShowSuccess("Work Order created");
            Nav.NavigateTo($"/workorders/{wo.Id}");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task HandleQuoteApproved(WorkflowInstance result)
    {
        if (_quote == null) return;
        if (result.Status == "Approved")
        {
            try
            {
                _quote.AcceptedAt = DateTime.UtcNow;
                await QuoteService.UpdateQuoteAsync(_quote);
                var wo = await QuoteService.ConvertToWorkOrderAsync(Id, result.LastActionBy ?? "System");
                Toast.ShowSuccess("Approved! Work Order created.");
                Nav.NavigateTo($"/workorders/{wo.Id}");
            }
            catch (Exception ex) { Toast.ShowError(ex.Message); }
        }
        else
        {
            _pendingApproval = result;
            Toast.ShowSuccess("Step approved. Awaiting next approval.");
        }
    }

    private Task HandleQuoteRejected(WorkflowInstance result)
    {
        _pendingApproval = null;
        Toast.ShowWarning("Workflow rejected. Acceptance cancelled.");
        return Task.CompletedTask;
    }

    private async Task Reject()
    {
        if (_quote == null) return;
        if (!await _confirm.ShowAsync("Reject this quote?")) return;
        try
        {
            await QuoteService.UpdateStatusAsync(Id, QuoteStatus.Rejected);
            _quote = await QuoteService.GetQuoteDetailAsync(Id);
            Toast.ShowSuccess("Quote rejected");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task PrintQuote()
    {
        if (_quote == null) return;
        var template = await TemplateService.GetDefaultTemplateAsync("Quote");
        if (template == null)
        {
            Toast.ShowError("No default quote template configured. Go to Admin → Document Templates.");
            return;
        }

        var linesHtml = "<table><thead><tr><th>Part</th><th>Qty</th><th>Est. Cost/Part</th><th>Quoted $/Part</th><th>Line Total</th></tr></thead><tbody>";
        foreach (var l in _quote.Lines)
        {
            linesHtml += $"<tr><td>{l.Part?.PartNumber ?? "—"} — {l.Part?.Name ?? ""}</td><td>{l.Quantity}</td><td>{l.EstimatedCostPerPart:C}</td><td>{l.QuotedPricePerPart:C}</td><td>{(l.QuotedPricePerPart * l.Quantity):C}</td></tr>";
        }
        linesHtml += "</tbody></table>";

        var fields = new Dictionary<string, string>
        {
            ["QuoteNumber"] = _quote.QuoteNumber ?? "",
            ["RevisionNumber"] = _quote.RevisionNumber.ToString(),
            ["CustomerName"] = _quote.CustomerName ?? "",
            ["CustomerEmail"] = _quote.CustomerEmail ?? "",
            ["CustomerPhone"] = _quote.CustomerPhone ?? "",
            ["CreatedDate"] = _quote.CreatedDate.ToString("yyyy-MM-dd"),
            ["ExpirationDate"] = _quote.ExpirationDate?.ToString("yyyy-MM-dd") ?? "—",
            ["Status"] = _quote.Status.ToString(),
            ["TargetMarginPct"] = _quote.TargetMarginPct.ToString("F1"),
            ["TotalEstimatedCost"] = _quote.TotalEstimatedCost.ToString("C"),
            ["QuotedPrice"] = _quote.QuotedPrice?.ToString("C") ?? "—",
            ["Notes"] = _quote.Notes ?? "",
            ["LinesTable"] = linesHtml,
            ["CompanyAddress"] = ""
        };

        var html = TemplateService.RenderHtml(template, fields);
        await JS.InvokeVoidAsync("vectrik.printHtml", html, $"Quote {_quote.QuoteNumber}");
    }

    private void GoToEdit() => Nav.NavigateTo($"/quotes/{Id}/edit");
    private void GoBack() => Nav.NavigateTo("/quotes");

    private static string GetStatusBadge(QuoteStatus status) => status switch
    {
        QuoteStatus.Draft => "badge-info",
        QuoteStatus.Sent => "badge-warning",
        QuoteStatus.Accepted => "badge-active",
        QuoteStatus.Rejected => "badge-cancelled",
        QuoteStatus.Expired => "badge-cancelled",
        _ => ""
    };
}
