@page "/quality/capa"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IQualityService QualityService
@inject IWorkflowEngine WorkflowEngine
@inject NavigationManager Nav
@inject ToastService Toast
@inject ITenantFeatureService Features
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>CAPA Board - Vectrik</PageTitle>

<FeatureGate Feature="module.quality" ModuleName="Quality Management">

<div class="page-header">
    <h1 class="page-title">🔧 CAPA Board</h1>
    <div style="display: flex; gap: 8px;">
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/quality")'>← Dashboard</button>
        <button class="btn btn-primary" @onclick="ShowCreate">+ New CAPA</button>
    </div>
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else
{
    <!-- Kanban Board -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; overflow-x: auto;">
        @foreach (var status in Enum.GetValues<CapaStatus>())
        {
            var capasInColumn = _capas.Where(c => c.Status == status).ToList();
            <div class="card" style="min-height: 200px;">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <span>@GetColumnTitle(status)</span>
                    <span class="badge @GetCapaBadge(status)">@capasInColumn.Count</span>
                </div>
                <div style="display: flex; flex-direction: column; gap: 10px; padding: 8px;">
                    @foreach (var capa in capasInColumn)
                    {
                        <div class="card" style="padding: 12px; cursor: pointer; border-left: 3px solid @GetBorderColor(capa);" @onclick="() => ShowEdit(capa)">
                            <div style="font-weight: 700; font-size: 0.85rem; margin-bottom: 4px;">@capa.CapaNumber</div>
                            <div style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 6px; max-height: 40px; overflow: hidden;">@capa.ProblemStatement</div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted);">
                                <span>@capa.Type</span>
                                <span>@capa.OwnerId</span>
                            </div>
                            @if (capa.DueDate.HasValue)
                            {
                                var isOverdue = capa.DueDate < DateTime.UtcNow && capa.Status != CapaStatus.Closed;
                                <div style="font-size: 0.75rem; margin-top: 4px; color: @(isOverdue ? "var(--danger)" : "var(--text-muted)");">
                                    Due: @capa.DueDate.Value.ToString("MMM dd") @(isOverdue ? "⚠️ OVERDUE" : "")
                                </div>
                            }
                        </div>
                    }
                    @if (capasInColumn.Count == 0)
                    {
                        <div style="padding: 16px; text-align: center; color: var(--text-muted); font-size: 0.85rem;">None</div>
                    }
                </div>
            </div>
        }
    </div>
}

@if (_showForm && _edit != null)
{
    <div class="modal-overlay" @onclick="() => _showForm = false">
        <div class="modal-content" style="max-width: 700px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(_edit.Id == 0 ? "New" : "Edit") CAPA</span>
                <button class="modal-close" @onclick="() => _showForm = false">&times;</button>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group">
                    <label class="form-label">Type</label>
                    <select class="form-control" @bind="_edit.Type">
                        @foreach (var t in Enum.GetValues<CapaType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control" @bind="_edit.Status">
                        @foreach (var s in Enum.GetValues<CapaStatus>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Owner</label>
                    <input class="form-control" @bind="_edit.OwnerId" placeholder="Responsible person" />
                </div>
                <div class="form-group">
                    <label class="form-label">Due Date</label>
                    <input class="form-control" type="date" @bind="_edit.DueDate" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Problem Statement *</label>
                <textarea class="form-control" rows="2" @bind="_edit.ProblemStatement" placeholder="Describe the problem..."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Root Cause Analysis</label>
                <textarea class="form-control" rows="2" @bind="_edit.RootCauseAnalysis" placeholder="5-Why, Fishbone, etc."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Immediate Action</label>
                <textarea class="form-control" rows="2" @bind="_edit.ImmediateAction" placeholder="Containment actions taken..."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Long-Term Action</label>
                <textarea class="form-control" rows="2" @bind="_edit.LongTermAction" placeholder="Permanent corrective action..."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Preventive Action</label>
                <textarea class="form-control" rows="2" @bind="_edit.PreventiveAction" placeholder="Steps to prevent recurrence..."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Effectiveness Verification</label>
                <textarea class="form-control" rows="2" @bind="_edit.EffectivenessVerification" placeholder="How was effectiveness verified?"></textarea>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 12px;">
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveCapa">Save</button>
            </div>
        </div>
    </div>
}

</FeatureGate>

@code {
    private bool _loading = true;
    private List<CorrectiveAction> _capas = new();
    private CorrectiveAction? _edit;
    private bool _showForm;

    protected override async Task OnInitializedAsync()
    {
        _capas = await QualityService.GetAllCapasAsync();
        _loading = false;
    }

    private void ShowCreate()
    {
        _edit = new CorrectiveAction { OwnerId = "System" };
        _showForm = true;
    }

    private void ShowEdit(CorrectiveAction capa)
    {
        _edit = capa;
        _showForm = true;
    }

    private async Task SaveCapa()
    {
        if (_edit == null) return;

        if (string.IsNullOrWhiteSpace(_edit.ProblemStatement))
        {
            Toast.ShowError("Problem statement is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_edit.OwnerId))
        {
            Toast.ShowError("Owner is required.");
            return;
        }

        if (_edit.Status == CapaStatus.Closed && string.IsNullOrWhiteSpace(_edit.EffectivenessVerification))
        {
            Toast.ShowError("Effectiveness verification is required before closing a CAPA.");
            return;
        }

        try
        {
            if (_edit.Id == 0)
            {
                await QualityService.CreateCapaAsync(_edit);
                Toast.ShowSuccess("CAPA created.");
            }
            else
            {
                // Check for workflow approval on closure
                if (_edit.Status == CapaStatus.Closed && await WorkflowEngine.HasWorkflowAsync("CAPA"))
                {
                    var pending = await WorkflowEngine.GetPendingAsync("CAPA", _edit.Id);
                    if (pending == null)
                    {
                        await WorkflowEngine.StartAsync("CAPA", _edit.Id);
                        Toast.ShowInfo("CAPA closure submitted for approval.");
                        _showForm = false;
                        return;
                    }
                    if (pending.Status == "Pending")
                    {
                        Toast.ShowWarning("CAPA is awaiting approval before it can be closed.");
                        return;
                    }
                }

                await QualityService.UpdateCapaAsync(_edit);
                Toast.ShowSuccess("CAPA updated.");
            }

            _capas = await QualityService.GetAllCapasAsync();
            _showForm = false;
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private static string GetColumnTitle(CapaStatus s) => s switch
    {
        CapaStatus.Open => "🔴 Open",
        CapaStatus.InProgress => "🟡 In Progress",
        CapaStatus.PendingVerification => "🔵 Pending Verification",
        CapaStatus.Closed => "🟢 Closed",
        _ => s.ToString()
    };

    private static string GetCapaBadge(CapaStatus s) => s switch
    {
        CapaStatus.Open => "badge-danger",
        CapaStatus.InProgress => "badge-warning",
        CapaStatus.PendingVerification => "badge-info",
        CapaStatus.Closed => "badge-success",
        _ => "badge-secondary"
    };

    private static string GetBorderColor(CorrectiveAction capa)
    {
        if (capa.DueDate.HasValue && capa.DueDate < DateTime.UtcNow && capa.Status != CapaStatus.Closed)
            return "var(--danger)";
        return capa.Status switch
        {
            CapaStatus.Open => "var(--danger)",
            CapaStatus.InProgress => "var(--warning)",
            CapaStatus.PendingVerification => "var(--accent)",
            _ => "var(--success)"
        };
    }
}
