@page "/settings/display"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@inject IUserSettingsService SettingsService
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>Display Settings - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Display Settings</h1>
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else
{
    <div class="card" style="max-width: 600px;">
        <div class="card-header">Theme</div>
        <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 16px;">
            Choose how Vectrik looks for your account. This setting is saved to your profile and applies on any device you sign in to.
        </p>

        <div class="theme-picker">
            <button class="theme-option @(_selectedTheme == "dark" ? "theme-option-active" : "")"
                    @onclick='() => SelectTheme("dark")'>
                <div class="theme-preview theme-preview-dark">
                    <div class="theme-preview-sidebar"></div>
                    <div class="theme-preview-content">
                        <div class="theme-preview-bar"></div>
                        <div class="theme-preview-block"></div>
                        <div class="theme-preview-block short"></div>
                    </div>
                </div>
                <span class="theme-option-label">🌙 Dark</span>
            </button>

            <button class="theme-option @(_selectedTheme == "light" ? "theme-option-active" : "")"
                    @onclick='() => SelectTheme("light")'>
                <div class="theme-preview theme-preview-light">
                    <div class="theme-preview-sidebar"></div>
                    <div class="theme-preview-content">
                        <div class="theme-preview-bar"></div>
                        <div class="theme-preview-block"></div>
                        <div class="theme-preview-block short"></div>
                    </div>
                </div>
                <span class="theme-option-label">☀️ Light</span>
            </button>

            <button class="theme-option @(_selectedTheme == "system" ? "theme-option-active" : "")"
                    @onclick='() => SelectTheme("system")'>
                <div class="theme-preview theme-preview-system">
                    <div class="theme-preview-half-dark">
                        <div class="theme-preview-sidebar"></div>
                        <div class="theme-preview-content">
                            <div class="theme-preview-bar"></div>
                            <div class="theme-preview-block"></div>
                        </div>
                    </div>
                    <div class="theme-preview-half-light">
                        <div class="theme-preview-sidebar"></div>
                        <div class="theme-preview-content">
                            <div class="theme-preview-bar"></div>
                            <div class="theme-preview-block"></div>
                        </div>
                    </div>
                </div>
                <span class="theme-option-label">💻 System</span>
            </button>
        </div>
    </div>

    <div class="card" style="max-width: 600px;">
        <div class="card-header">Default Views</div>
        <div class="form-group">
            <label class="form-label">Default Scheduler View</label>
            <select class="form-control" @bind="_defaultView">
                <option value="">— Default —</option>
                <option value="gantt">📊 Machine Gantt</option>
                <option value="path">🔀 Part Path</option>
                <option value="table">📋 Table</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Notifications</label>
            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:0.875rem;">
                <input type="checkbox" @bind="_notificationsEnabled" style="width:18px; height:18px;" />
                Enable toast notifications for job and schedule updates
            </label>
        </div>
        <div style="display:flex; justify-content:flex-end; padding-top:8px;">
            <button class="btn btn-primary" @onclick="SavePreferences" disabled="@_saving">
                @(_saving ? "Saving…" : "Save Preferences")
            </button>
        </div>
    </div>

    <div class="card" style="max-width: 600px;">
        <div class="card-header">🛠️ Debug Feedback</div>
        <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 16px;">
            Show a floating feedback button on every page. Use it to report bugs, request changes, or flag styling issues with full context capture.
        </p>
        <div class="form-group">
            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:0.875rem;">
                <input type="checkbox" @bind="_debugFabEnabled" style="width:18px; height:18px;" />
                Enable debug feedback button
            </label>
        </div>
        <div style="display:flex; justify-content:flex-end; padding-top:8px;">
            <button class="btn btn-primary" @onclick="SaveDebugFab" disabled="@_savingDebug">
                @(_savingDebug ? "Saving…" : "Save")
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private int _userId;
    private bool _loading = true;
    private bool _saving;
    private bool _savingDebug;
    private string _selectedTheme = "dark";
    private string? _defaultView;
    private bool _notificationsEnabled = true;
    private bool _debugFabEnabled;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var userIdClaim = state.User.FindFirst("UserId")?.Value;
            if (int.TryParse(userIdClaim, out var uid))
                _userId = uid;
        }

        if (_userId > 0)
        {
            var settings = await SettingsService.GetSettingsAsync(_userId);
            _selectedTheme = settings.Theme;
            _defaultView = settings.DefaultView;
            _notificationsEnabled = settings.NotificationsEnabled;
            _debugFabEnabled = settings.DebugFabEnabled;
        }

        _loading = false;
    }

    private async Task SelectTheme(string theme)
    {
        _selectedTheme = theme;
        await JS.InvokeVoidAsync("opcentrix.setTheme", theme);

        if (_userId > 0)
        {
            try
            {
                await SettingsService.SaveThemeAsync(_userId, theme);
                Toast.ShowSuccess($"Theme set to {theme}");
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to save theme: {ex.Message}");
            }
        }
    }

    private async Task SavePreferences()
    {
        if (_userId == 0) return;
        _saving = true;

        try
        {
            var settings = await SettingsService.GetSettingsAsync(_userId);
            settings.DefaultView = _defaultView;
            settings.NotificationsEnabled = _notificationsEnabled;
            await SettingsService.SaveSettingsAsync(settings);
            Toast.ShowSuccess("Display settings saved");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to save: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveDebugFab()
    {
        if (_userId == 0) return;
        _savingDebug = true;

        try
        {
            await SettingsService.SaveDebugFabAsync(_userId, _debugFabEnabled);
            await JS.InvokeVoidAsync("opcentrix.debugFab.setEnabled", _debugFabEnabled);
            Toast.ShowSuccess(_debugFabEnabled ? "Debug button enabled — navigate to any page to see it" : "Debug button disabled");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to save: {ex.Message}");
        }
        finally
        {
            _savingDebug = false;
        }
    }
}
