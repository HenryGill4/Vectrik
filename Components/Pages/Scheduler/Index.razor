@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _scheduling;
    private bool _creatingJob;
    private System.Threading.Timer? _autoRefreshTimer;
    private DateTime _lastRefresh = DateTime.UtcNow;
    private bool _autoRefreshEnabled = true;
    private List<StageExecution> _executions = new();
    private List<StageExecution> _unscheduled = new();
    private List<Machine> _machines = new();
    private List<Part>? _parts;
    private List<ProductionStage> _stages = new();
    private HashSet<int> _expandedStages = new();
    [SupplyParameterFromQuery(Name = "view")]
    public string? ViewParam { get; set; }

    private string _viewMode = "gantt";
    private string _userName = "System";

    // Viewport (infinite scroll + fluid zoom)
    private ElementReference _ganttContainerRef;
    private DotNetObjectReference<Index>? _dotNetRef;
    private IJSObjectReference? _ganttViewportModule;
    private double _pixelsPerHour = 6.0;
    private DateTime _viewportStart = DateTime.UtcNow.Date;
    private DateTime _viewportEnd = DateTime.UtcNow.Date.AddDays(14);
    private DateTime _dataRangeStart = DateTime.UtcNow.Date.AddDays(-7);
    private DateTime _dataRangeEnd = DateTime.UtcNow.Date.AddDays(21);

    // Part Path filters
    private int _pathFilterPartId;
    private string? _pathFilterPriority;
    private string _pathSortMode = "schedule";

    // Table view sorting & filtering
    private string _tableSortCol = "Start";
    private bool _tableSortAsc = true;
    private StageExecutionStatus? _tableFilterStatus;
    private string _tableSearch = "";

    // Build packages
    private List<BuildPackage> _buildPackages = new();
    private Dictionary<int, List<MachineTimelineEntry>> _machineTimelines = new();

    // Work orders
    private List<WorkOrder> _workOrders = new();
    private bool _showWoBuildModal;
    private bool _showWoJobModal;
    private bool _creatingFromWo;
    private WorkOrderLine? _selectedWoLine;
    private WorkOrder? _selectedWo;
    private string _woBuildName = "";
    private string _woBuildMachineId = "";
    private int _woBuildQuantity;

    // Build templates (Phase B)
    private List<BuildTemplate> _buildTemplates = new();
    private bool _showQuickScheduleModal;

    // Build suggestions (Phase C)
    private BuildSuggestionResult? _suggestions;
    private HashSet<string> _dismissedSuggestions = new();
    private BuildTemplate? _selectedTemplate;
    private WorkOrderLine? _quickScheduleWoLine;
    private WorkOrder? _quickScheduleWo;
    private string _quickScheduleMachineId = "";
    private DateTime? _quickScheduleStartAfter;

    // Create job
    private bool _showCreate;
    private Job _newJob = new() { ScheduledStart = DateTime.UtcNow, EstimatedHours = 8, Quantity = 1, Priority = JobPriority.Normal };
    private List<PartStageRequirement> _selectedPartRouting = new();
    private string? _error;

    // Reschedule
    private bool _showReschedule;
    private StageExecution? _rescheduleExec;
    private string _rescheduleMachineId = "";
    private DateTime _rescheduleStart;
    private DateTime _rescheduleEnd;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(ViewParam))
            _viewMode = ViewParam;

        if (AuthState != null)
        {
            var state = await AuthState;
            _userName = state.User?.Identity?.Name ?? "System";
        }
        try
        {
            _parts = await PartService.GetAllPartsAsync();
            _machines = await MachineService.GetAllMachinesAsync(activeOnly: true);
            _stages = await StageService.GetAllStagesAsync(activeOnly: true);
            _buildPackages = await BuildPlanning.GetAllPackagesAsync();
            await LoadData();
            StartAutoRefreshTimer();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load scheduler: {ex.Message}");
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _ganttViewportModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/gantt-viewport.js");
        }
    }

