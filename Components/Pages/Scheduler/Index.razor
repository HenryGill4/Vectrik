@page "/scheduler"
@inject IStageService StageService
@inject IPartService PartService
@inject IMachineService MachineService
@inject ISchedulingService Scheduler
@inject IProgramSchedulingService ProgramScheduling
@inject IWorkOrderService WorkOrderService
@inject IMachineProgramService ProgramService
@inject IShiftManagementService ShiftService
@inject IBuildAdvisorService BuildAdvisor
@inject IProgramPlanningService ProgramPlanning
@inject IBuildTemplateService TemplateService
@inject Vectrik.Data.TenantDbContext Db
@inject ToastService Toast
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Vectrik.Components.Pages.Scheduler.Components
@using Vectrik.Components.Pages.Scheduler.Views
@using Vectrik.Models.Enums

<PageTitle>Production Scheduler - Vectrik</PageTitle>

<div class="sched-page">
<SchedulerToolbar ViewMode="@_viewMode"
                 ViewportStart="_viewportStart"
                 ViewportEnd="_viewportEnd"
                 PixelsPerHour="_pixelsPerHour"
                 Scheduling="_scheduling"
                 AutoRefreshEnabled="_autoRefreshEnabled"
                 LastRefresh="_lastRefresh"
                 ShowAutoSchedule="@(_unscheduled.Any() || _programs.Any(p => p.ScheduleStatus == ProgramScheduleStatus.Ready))"
                 AutoScheduleCount="@(_unscheduled.Count + _programs.Count(p => p.ScheduleStatus == ProgramScheduleStatus.Ready))"
                 ShowConflictsOnly="_showConflictsOnly"
                 ProgramStatusFilter="_programStatusFilter"
                 ShowOverdueOnly="_showOverdueOnly"
                 OnViewModeChanged="OnViewModeChangedAsync"
                 OnShiftViewport="ShiftViewportAsync"
                 OnScrollToNow="ScrollToNowAsync"
                 OnZoomIn="ZoomInAsync"
                 OnZoomOut="ZoomOutAsync"
                 OnManualRefresh="ManualRefreshAsync"
                 OnToggleAutoRefresh="ToggleAutoRefresh"
                 OnAutoScheduleAll="AutoScheduleAll"
                 ShowSmartReschedule="@(_programs.Any(p => p.ScheduleStatus == ProgramScheduleStatus.Scheduled || p.ScheduleStatus == ProgramScheduleStatus.Ready))"
                 OnSmartReschedule="SmartRescheduleAll"
                 OnNewBuild="OpenBuildAdvisor"
                 OnNewCncJob="OpenCncWizard"
                 OnShowConflictsOnlyChanged="v => _showConflictsOnly = v"
                 OnProgramStatusFilterChanged="v => _programStatusFilter = v"
                 OnShowOverdueOnlyChanged="v => _showOverdueOnly = v" />

<div>
@if (_loading && !_refreshing)
{
    <div class="loading"><span class="spinner"></span> Loading schedule...</div>
}
else if (_viewMode == "gantt")
{
    <KpiStrip Executions="_executions"
              Unscheduled="_unscheduled"
              Machines="_machines"
              WorkOrders="_workOrders"
              BottleneckReport="_bottleneckReport" />
    <GanttView @ref="_ganttView"
               Executions="_executions"
               Unscheduled="_unscheduled"
               Machines="_machines"
               Stages="_stages"
               BuildPrograms="_programs"
               MachineTimelines="_programTimelines"
               Shifts="_shifts"
               WorkOrders="_workOrders"
               UserName="@_userName"
               DataRangeStart="_dataRangeStart"
               DataRangeEnd="_dataRangeEnd"
               PixelsPerHour="_pixelsPerHour"
               ShowConflictsOnly="_showConflictsOnly"
               OnShowReschedule="ShowReschedule"
               OnBuildAction="HandleBuildActionAsync"
               OnBatchDeleteBuilds="HandleBatchDeleteAsync"
               OnBatchRescheduleBuilds="HandleBatchRescheduleAsync"
               OnScheduleRequested="OpenBuildAdvisor"
               OnAutoSchedule="AutoScheduleSingle"
               OnNextBuildRequested="OpenBuildAdvisorForMachine"
               OnPixelsPerHourChanged="HandlePixelsPerHourChanged"
               OnViewportBoundsChanged="HandleViewportBoundsChanged"
               OnDataRangeExtensionNeeded="ExtendDataRangeAsync"
               ProgramStatusFilter="_programStatusFilter"
               OnBarDragCompleted="HandleBarDragAsync" />
}
else if (_viewMode == "demand")
{
    <WorkOrdersView WorkOrders="_workOrders"
                     Programs="_programs"
                     SlsMachines="SlsMachines"
                     UserName="@_userName"
                     ShowOverdueOnly="_showOverdueOnly"
                     OnRefreshRequested="() => LoadData(isBackgroundRefresh: true)" />
}
else if (_viewMode == "dispatch")
{
    <DispatchView DemandSummaries="_dispatchDemand"
                  MachineAvailability="_machineAvailability"
                  Recommendations="_dispatchRecommendations"
                  Templates="_dispatchTemplates"
                  DraftPrograms="_draftPrograms"
                  OnOpenAdvisorForMachine="OpenBuildAdvisorForMachine"
                  OnOpenAdvisorForPart="OpenBuildAdvisorForPart"
                  OnInstantiateTemplate="HandleInstantiateTemplateAsync"
                  OnRefreshRequested="() => LoadData(isBackgroundRefresh: true)" />
}
else if (_viewMode == "data")
{
    <div class="sched-data-toggle" style="margin-bottom: 8px;">
        <button class="btn btn-sm @(_dataSubView == "table" ? "btn-primary" : "btn-secondary")" @onclick='() => _dataSubView = "table"'>Table</button>
        <button class="btn btn-sm @(_dataSubView == "path" ? "btn-primary" : "btn-secondary")" @onclick='() => _dataSubView = "path"'>Part Path</button>
    </div>
    @if (_dataSubView == "path")
    {
        <PartPathView @ref="_partPathView"
                      Executions="_executions"
                      Unscheduled="_unscheduled"
                      Parts="_parts"
                      DataRangeStart="_dataRangeStart"
                      DataRangeEnd="_dataRangeEnd"
                      PixelsPerHour="_pixelsPerHour"
                      OnShowReschedule="ShowReschedule"
                      OnManualSchedule="ManualScheduleSingle"
                      OnAutoSchedule="AutoScheduleSingle"
                      OnPixelsPerHourChanged="HandlePixelsPerHourChanged"
                      OnViewportBoundsChanged="HandleViewportBoundsChanged"
                      OnDataRangeExtensionNeeded="ExtendDataRangeAsync" />
    }
    else
    {
        <TableView Executions="_executions"
                   Unscheduled="_unscheduled"
                   OnShowReschedule="ShowReschedule"
                   OnAutoSchedule="AutoScheduleSingle"
                   OnRefreshRequested="() => LoadData(isBackgroundRefresh: true)" />
    }
}
</div>
</div>

@* ── Modals ── *@
<Vectrik.Components.Pages.Scheduler.Modals.JobDetailModal
    IsVisible="_showJobDetail"
    Execution="_jobDetailExec"
    Build="_jobDetailBuild"
    Machines="_machines"
    UserName="@_userName"
    OnClose="() => { _showJobDetail = false; _jobDetailExec = null; _jobDetailBuild = null; }"
    OnChanged="OnModalConfirmedAsync"
    OnBuildAction="HandleBuildActionAsync" />

<Vectrik.Components.Pages.Scheduler.Modals.UnifiedScheduleWizard
    IsVisible="_showScheduleWizard"
    Machines="_machines"
    UserName="@_userName"
    OnClose="() => { _showScheduleWizard = false; }"
    OnScheduled="OnModalConfirmedAsync" />

<Vectrik.Components.Pages.Scheduler.Modals.NextBuildAdvisor
    IsVisible="_showBuildAdvisor"
    Machines="_machines"
    InitialMachineId="_advisorMachineId"
    InitialPartId="_advisorPartId"
    UserName="@_userName"
    OnClose="() => { _showBuildAdvisor = false; }"
    OnScheduled="OnModalConfirmedAsync" />

<ConfirmDialog @ref="_confirmDialog" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromQuery(Name = "view")] public string? ViewParam { get; set; }

    private bool _loading = true;
    private bool _refreshing;
    private bool _scheduling;
    private bool _disposed;
    private System.Threading.Timer? _autoRefreshTimer;
    private DateTime _lastRefresh = DateTime.UtcNow;
    private bool _autoRefreshEnabled = true;
    private string _viewMode = "gantt";
    private string _userName = "System";

    private List<StageExecution> _executions = new();
    private List<StageExecution> _unscheduled = new();
    private List<Machine> _machines = new();
    private List<Part>? _parts;
    private List<ProductionStage> _stages = new();
    private Dictionary<int, List<ProgramTimelineEntry>> _programTimelines = new();
    private List<WorkOrder> _workOrders = new();
    private List<MachineProgram> _programs = new();
    private List<OperatingShift> _shifts = new();
    private BottleneckReport? _bottleneckReport;

    // Dispatch view data
    private List<DemandSummary> _dispatchDemand = new();
    private List<MachineAvailabilitySummary> _machineAvailability = new();
    private List<BuildRecommendation> _dispatchRecommendations = new();
    private List<BuildTemplate> _dispatchTemplates = new();
    private List<MachineProgram> _draftPrograms = new();

    private GanttView? _ganttView;
    private PartPathView? _partPathView;
    private string _dataSubView = "table";
    private double _pixelsPerHour = 6.0;
    private DateTime _viewportStart = DateTime.UtcNow.Date;
    private DateTime _viewportEnd = DateTime.UtcNow.Date.AddDays(14);
    private DateTime _dataRangeStart = DateTime.UtcNow.Date.AddDays(-7);
    private DateTime _dataRangeEnd = DateTime.UtcNow.Date.AddDays(21);

    private int _autoRefreshSeconds = 30;
    private readonly Dictionary<string, DateTime> _tabLastLoaded = new();

    private bool _showScheduleWizard;
    private bool _showBuildAdvisor;
    private int? _advisorMachineId;
    private int? _advisorPartId;
    private ConfirmDialog _confirmDialog = null!;

    // Job detail modal (replaces old RescheduleModal)
    private bool _showJobDetail;
    private StageExecution? _jobDetailExec;
    private MachineProgram? _jobDetailBuild;

    private bool _showConflictsOnly;
    private ProgramScheduleStatus? _programStatusFilter;
    private bool _showOverdueOnly;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(ViewParam))
        {
            _viewMode = ViewParam switch
            {
                "orders" => "demand",
                "stages" or "floor" => "gantt",
                "table" or "path" => "data",
                "builds" or "programs" => "gantt",
                "dispatch" or "setup" => "dispatch",
                _ => ViewParam
            };
        }

        if (AuthState != null)
        {
            var state = await AuthState;
            _userName = state.User?.Identity?.Name ?? "System";
        }
        try
        {
            await LoadSchedulerSettingsAsync();
            _parts = await PartService.GetAllPartsAsync();
            _machines = await MachineService.GetAllMachinesAsync(activeOnly: true);
            _stages = await StageService.GetAllStagesAsync(activeOnly: true);
            _shifts = await ShiftService.GetAllShiftsAsync();
            await LoadData();
            StartAutoRefreshTimer();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load scheduler: {ex.Message}");
            _loading = false;
        }
    }

    private async Task LoadData(bool isBackgroundRefresh = false)
    {
        if (isBackgroundRefresh)
        {
            _refreshing = true;
            if (ActiveViewport != null)
                await ActiveViewport.SaveStateAsync();
        }
        else
        {
            _loading = true;
        }
        StateHasChanged();
        try
        {
            await LoadSharedDataAsync();
            await LoadActiveTabDataAsync();

            _ganttView?.Viewport?.RequestReinit();
            _partPathView?.Viewport?.RequestReinit();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load schedule data: {ex.Message}");
        }
        finally
        {
            _loading = false;
            _refreshing = false;
            _lastRefresh = DateTime.UtcNow;
        }
    }

    private void StartAutoRefreshTimer()
    {
        _autoRefreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed || !_autoRefreshEnabled || _loading || _refreshing || _scheduling
                || _showBuildAdvisor || _showScheduleWizard || _showJobDetail) return;
            try
            {
                await InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    await LoadData(isBackgroundRefresh: true);
                    StateHasChanged();
                });
            }
            catch (ObjectDisposedException) { /* Component disposed during refresh — safe to ignore */ }
            catch (TaskCanceledException) { /* Circuit disconnected — safe to ignore */ }
            catch (OperationCanceledException) { /* Circuit disconnected — safe to ignore */ }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* JS runtime torn down */ }
        }, null, TimeSpan.FromSeconds(_autoRefreshSeconds), TimeSpan.FromSeconds(_autoRefreshSeconds));
    }

    private void ToggleAutoRefresh() => _autoRefreshEnabled = !_autoRefreshEnabled;

    private Task ManualRefreshAsync() => LoadData(isBackgroundRefresh: true);

    private async Task LoadSchedulerSettingsAsync()
    {
        try
        {
            var settingsList = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(
                Db.SystemSettings.Where(s => s.Key.StartsWith("scheduler.") || s.Key.StartsWith("scheduling.")));
            var settings = settingsList.ToDictionary(s => s.Key, s => s.Value);

            if (settings.TryGetValue("scheduler.auto_refresh_seconds", out var refreshVal) && int.TryParse(refreshVal, out var refreshSec))
                _autoRefreshSeconds = refreshSec;
            if (settings.TryGetValue("scheduler.gantt_lookback_days", out var lookbackVal) && int.TryParse(lookbackVal, out var lookback))
                _dataRangeStart = DateTime.UtcNow.Date.AddDays(-lookback);
            if (settings.TryGetValue("scheduler.gantt_lookahead_days", out var lookaheadVal) && int.TryParse(lookaheadVal, out var lookahead))
                _viewportEnd = DateTime.UtcNow.Date.AddDays(lookahead);
            if (settings.TryGetValue("scheduler.gantt_data_range_days", out var dataRangeVal) && int.TryParse(dataRangeVal, out var dataRange))
                _dataRangeEnd = DateTime.UtcNow.Date.AddDays(dataRange);
            if (settings.TryGetValue("scheduler.gantt_default_zoom", out var zoomVal) && double.TryParse(zoomVal, out var zoom))
                _pixelsPerHour = zoom;
        }
        catch (Exception ex) { Console.WriteLine($"Settings load failed: {ex.Message}"); }
    }

    private async Task LoadSharedDataAsync()
    {
        _unscheduled = await StageService.GetUnscheduledExecutionsAsync();
    }

    private async Task LoadActiveTabDataAsync()
    {
        switch (_viewMode)
        {
            case "gantt":
                await LoadProductionDataAsync();
                break;
            case "demand":
                await LoadDemandDataAsync();
                break;
            case "dispatch":
                await LoadDispatchDataAsync();
                break;
            case "data":
                await LoadDataViewAsync();
                break;
        }
        _tabLastLoaded[_viewMode] = DateTime.UtcNow;
    }

    private async Task LoadProductionDataAsync()
    {
        _executions = await StageService.GetScheduledExecutionsAsync(_dataRangeStart, _dataRangeEnd);
        _workOrders = await WorkOrderService.GetWorkOrdersByStatusesAsync(WorkOrderStatus.Released, WorkOrderStatus.InProgress);
        _programs = await ProgramService.GetBuildPlateProgramsAsync();
        await LoadProgramTimelinesAsync();

        try { _bottleneckReport = await BuildAdvisor.AnalyzeBottlenecksAsync(_dataRangeStart, _dataRangeEnd); }
        catch { _bottleneckReport = null; }
    }

    private async Task LoadDemandDataAsync()
    {
        _workOrders = await WorkOrderService.GetWorkOrdersByStatusesAsync(WorkOrderStatus.Released, WorkOrderStatus.InProgress);
        _programs = await ProgramService.GetBuildPlateProgramsAsync();
    }

    private async Task LoadDataViewAsync()
    {
        _executions = await StageService.GetScheduledExecutionsAsync(_dataRangeStart, _dataRangeEnd);
    }

    private async Task LoadDispatchDataAsync()
    {
        _dispatchDemand = await BuildAdvisor.GetAggregateDemandAsync();
        _machineAvailability = await BuildAdvisor.GetMachineAvailabilitySummaryAsync();
        _draftPrograms = await ProgramScheduling.GetDraftProgramsAwaitingScheduleAsync();

        // Load templates matched to current demand
        var demandPartIds = _dispatchDemand.Where(d => d.IsAdditive && d.NetRemaining > 0).Select(d => d.PartId).ToList();
        _dispatchTemplates = await TemplateService.GetTemplatesWithDemandMatchAsync(demandPartIds);

        // Get recommendations for each SLS machine (in parallel)
        var recTasks = SlsMachines.Select(async m =>
        {
            try { return await BuildAdvisor.RecommendNextBuildAsync(m.Id); }
            catch { return null; }
        });
        _dispatchRecommendations = (await Task.WhenAll(recTasks))
            .Where(r => r != null && r.Plate.Parts.Any())
            .ToList()!;
    }

    private async Task OnViewModeChangedAsync(string newMode)
    {
        if (_viewMode == newMode) return;
        _viewMode = newMode;

        if (!_tabLastLoaded.TryGetValue(newMode, out var lastLoaded)
            || (DateTime.UtcNow - lastLoaded).TotalSeconds > _autoRefreshSeconds)
        {
            await LoadData(isBackgroundRefresh: true);
        }
    }

    private List<Machine> SlsMachines => _machines
        .Where(m => m.IsAvailableForScheduling && m.IsAdditiveMachine)
        .ToList();

    /// <summary>Loads ProgramTimelineEntry per machine for Gantt and Programs views.</summary>
    private async Task LoadProgramTimelinesAsync()
    {
        var timelines = new Dictionary<int, List<ProgramTimelineEntry>>();

        var machineIds = _executions
            .Where(e => e.MachineProgramId != null && e.MachineId.HasValue)
            .Select(e => e.MachineId!.Value)
            .Distinct()
            .ToHashSet();

        foreach (var m in SlsMachines)
            machineIds.Add(m.Id);

        var tasks = machineIds.Select(async machineId =>
        {
            try
            {
                var timeline = await ProgramScheduling.GetMachineTimelineAsync(machineId, _dataRangeStart, _dataRangeEnd);
                return (machineId, Timeline: timeline);
            }
            catch
            {
                return (machineId, Timeline: new List<ProgramTimelineEntry>());
            }
        });

        var results = await Task.WhenAll(tasks);
        foreach (var (machineId, timeline) in results)
            timelines[machineId] = timeline;

        _programTimelines = timelines;
    }

    private void HandlePixelsPerHourChanged(double newPph) => _pixelsPerHour = newPph;

    private void HandleViewportBoundsChanged(GanttViewport.ViewportBoundsChangedArgs args)
    {
        _viewportStart = args.Start;
        _viewportEnd = args.End;
    }

    private async Task ExtendDataRangeAsync()
    {
        var newStart = _viewportStart.AddDays(-7);
        var newEnd = _viewportEnd.AddDays(7);
        if (newStart >= _dataRangeStart && newEnd <= _dataRangeEnd) return;

        _dataRangeStart = newStart < _dataRangeStart ? newStart : _dataRangeStart;
        _dataRangeEnd = newEnd > _dataRangeEnd ? newEnd : _dataRangeEnd;

        try
        {
            _executions = await StageService.GetScheduledExecutionsAsync(_dataRangeStart, _dataRangeEnd);
            await LoadProgramTimelinesAsync();

            if (_ganttView?.Viewport != null)
                await _ganttView.Viewport.UpdateDataRangeInJsAsync();
            if (_partPathView?.Viewport != null)
                await _partPathView.Viewport.UpdateDataRangeInJsAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to extend data range: {ex.Message}");
        }
    }

    private GanttViewport? ActiveViewport => _viewMode switch
    {
        "gantt" => _ganttView?.Viewport,
        "data" => _dataSubView == "path" ? _partPathView?.Viewport : null,
        _ => null
    };

    private Task ScrollToNowAsync() => ActiveViewport?.ScrollToTimeAsync(DateTime.UtcNow) ?? Task.CompletedTask;
    private Task ShiftViewportAsync(int dir) => ActiveViewport?.ShiftViewportAsync(dir) ?? Task.CompletedTask;
    private Task ZoomInAsync() => ActiveViewport?.ZoomInAsync() ?? Task.CompletedTask;
    private Task ZoomOutAsync() => ActiveViewport?.ZoomOutAsync() ?? Task.CompletedTask;

    private async Task OnModalConfirmedAsync()
    {
        _showJobDetail = false;
        _jobDetailExec = null;
        _jobDetailBuild = null;
        _showScheduleWizard = false;
        await LoadData(isBackgroundRefresh: true);
    }

    private void ShowReschedule(StageExecution exec)
    {
        _jobDetailExec = exec;
        _jobDetailBuild = null;
        _showJobDetail = true;
    }

    private void ShowBuildDetail(MachineProgram build)
    {
        _jobDetailBuild = build;
        _jobDetailExec = null;
        _showJobDetail = true;
    }

    private void ManualScheduleSingle(StageExecution exec)
    {
        _jobDetailExec = exec;
        _jobDetailBuild = null;
        _showJobDetail = true;
    }

    private void OpenBuildAdvisor()
    {
        _advisorMachineId = null;
        _advisorPartId = null;
        _showBuildAdvisor = true;
    }

    private async Task HandleInstantiateTemplateAsync(int templateId)
    {
        try
        {
            var firstMachine = SlsMachines.FirstOrDefault();
            if (firstMachine == null) { Toast.ShowError("No SLS machines available."); return; }
            var program = await TemplateService.InstantiateAsync(templateId, firstMachine.Id, _userName);
            Toast.ShowSuccess($"Created program '{program.Name}' from template. Opening scheduler...");
            _advisorMachineId = firstMachine.Id;
            _advisorPartId = null;
            _showBuildAdvisor = true;
            await LoadData(isBackgroundRefresh: true);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to instantiate template: {ex.Message}");
        }
    }

    private void OpenBuildAdvisorForPart(int partId)
    {
        _advisorMachineId = null;
        _advisorPartId = partId;
        _showBuildAdvisor = true;
    }

    private void OpenCncWizard()
    {
        _showScheduleWizard = true;
    }

    private void OpenBuildAdvisorForMachine(int machineId)
    {
        _advisorMachineId = machineId;
        _advisorPartId = null;
        _showBuildAdvisor = true;
    }

    private async Task HandleBarDragAsync(GanttViewport.BarDragResult drag)
    {
        try
        {
            if (drag.BarType is "exec" or "group")
            {
                await Scheduler.AutoScheduleExecutionAsync(drag.EntityId, drag.NewStart);
            }
            else if (drag.BarType == "build")
            {
                int targetMachineId;
                ProgramScheduleResult schedResult;
                if (drag.TargetMachineId.HasValue && drag.TargetMachineId.Value > 0)
                {
                    targetMachineId = drag.TargetMachineId.Value;
                    schedResult = await ProgramScheduling.ScheduleBuildPlateAsync(drag.EntityId, targetMachineId, drag.NewStart);
                }
                else
                {
                    schedResult = await ProgramScheduling.ScheduleBuildPlateAutoMachineAsync(drag.EntityId, drag.NewStart);
                    targetMachineId = schedResult.Slot.MachineId;
                }

                // Auto-cascade: shift downstream builds that now overlap
                await ProgramScheduling.CascadeRescheduleAsync(targetMachineId, drag.EntityId);
            }

            // Reload data FIRST, then show toast so UI is already updated
            await LoadData(isBackgroundRefresh: true);
            Toast.ShowSuccess($"Rescheduled to {drag.NewStart:MMM d HH:mm}");
        }
        catch (TaskCanceledException) { /* Circuit disconnected — safe to ignore */ }
        catch (ObjectDisposedException) { /* Component disposed — safe to ignore */ }
        catch (Exception ex)
        {
            Toast.ShowError($"Reschedule failed: {ex.Message}");
            try { await LoadData(isBackgroundRefresh: true); } catch { }
        }
    }

    private async Task HandleBuildActionAsync((MachineProgram Build, string Action) args)
    {
        var (build, action) = args;

        if (action == "detail")
        {
            ShowBuildDetail(build);
            return;
        }

        try
        {
            switch (action)
            {
                case "start-print":
                    build.ScheduleStatus = ProgramScheduleStatus.Printing;
                    build.PrintStartedAt = DateTime.UtcNow;
                    await ProgramPlanning.UpdateBuildPlateAsync(build, _userName);
                    Toast.ShowSuccess($"Print started: {build.Name}");
                    break;

                case "post-print":
                    build.ScheduleStatus = ProgramScheduleStatus.PostPrint;
                    build.PrintCompletedAt = DateTime.UtcNow;
                    await ProgramPlanning.UpdateBuildPlateAsync(build, _userName);
                    Toast.ShowSuccess($"Moved to post-print: {build.Name}");
                    break;

                case "release-plate":
                    await ProgramScheduling.ReleasePlateAsync(build.Id, _userName);
                    Toast.ShowSuccess($"Plate released: {build.Name}");
                    break;

                case "reschedule":
                    await ProgramScheduling.UnlockProgramAsync(build.Id, _userName, "Rescheduled from Gantt");
                    await ProgramScheduling.ScheduleBuildPlateAutoMachineAsync(build.Id);
                    Toast.ShowSuccess($"Build rescheduled: {build.Name}");
                    break;

                case "delete":
                    await ProgramPlanning.DeleteBuildWithDownstreamAsync(build.Id, _userName);
                    Toast.ShowSuccess($"Build deleted with downstream work: {build.Name}");
                    break;
            }

            await LoadData(isBackgroundRefresh: true);
        }
        catch (TaskCanceledException) { }
        catch (ObjectDisposedException) { }
        catch (Exception ex)
        {
            Toast.ShowError($"Action failed: {ex.Message}");
            try { await LoadData(isBackgroundRefresh: true); } catch { }
        }
    }

    private async Task HandleBatchDeleteAsync(List<int> buildIds)
    {
        var count = 0;
        foreach (var id in buildIds)
        {
            try
            {
                await ProgramPlanning.DeleteBuildWithDownstreamAsync(id, _userName);
                count++;
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to delete build {id}: {ex.Message}");
            }
        }
        if (count > 0)
            Toast.ShowSuccess($"Deleted {count} build(s) with downstream work");
        await LoadData(isBackgroundRefresh: true);
    }

    private async Task HandleBatchRescheduleAsync(List<int> buildIds)
    {
        var count = 0;
        foreach (var id in buildIds)
        {
            try
            {
                await ProgramScheduling.UnlockProgramAsync(id, _userName, "Batch rescheduled");
                await ProgramScheduling.ScheduleBuildPlateAutoMachineAsync(id);
                count++;
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to reschedule build {id}: {ex.Message}");
            }
        }
        if (count > 0)
            Toast.ShowSuccess($"Rescheduled {count} build(s)");
        await LoadData(isBackgroundRefresh: true);
    }

    private async Task AutoScheduleSingle(int executionId)
    {
        try
        {
            await Scheduler.AutoScheduleExecutionAsync(executionId);
            Toast.ShowSuccess("Task auto-scheduled");
            await LoadData(isBackgroundRefresh: true);
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task AutoScheduleAll()
    {
        _scheduling = true;
        StateHasChanged();
        try
        {
            var count = await Scheduler.AutoScheduleAllAsync();

            // Also auto-schedule any Ready programs
            var readyPrograms = _programs.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Ready).ToList();
            var programCount = 0;
            foreach (var prog in readyPrograms)
            {
                try
                {
                    await ProgramScheduling.ScheduleBuildPlateAutoMachineAsync(prog.Id);
                    programCount++;
                }
                catch (Exception ex) { Toast.ShowError($"Failed to schedule {prog.Name ?? prog.ProgramNumber}: {ex.Message}"); }
            }

            var msg = $"Auto-scheduled {count} job(s)";
            if (programCount > 0) msg += $" + {programCount} program(s)";
            Toast.ShowSuccess(msg);
            await LoadData(isBackgroundRefresh: true);
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _scheduling = false; }
    }

    private async Task SmartRescheduleAll()
    {
        _scheduling = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var result = await ProgramScheduling.SmartRescheduleBuildsAsync(_userName);

            if (result.HasChanges)
                Toast.ShowSuccess(result.Summary);
            else
                Toast.ShowInfo("Schedule is already optimal — no changes needed.");

            await LoadData(isBackgroundRefresh: true);
        }
        catch (TaskCanceledException) { }
        catch (ObjectDisposedException) { }
        catch (Exception ex)
        {
            Toast.ShowError($"Smart reschedule failed: {ex.Message}");
        }
        finally { _scheduling = false; }
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        _autoRefreshTimer?.Dispose();
        return ValueTask.CompletedTask;
    }
}
