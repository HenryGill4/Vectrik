    private async Task AutoScheduleAll()
    {
        _scheduling = true;
        StateHasChanged();
        try
        {
            var count = await Scheduler.AutoScheduleAllAsync();

            // Also schedule any Ready builds on SLS machines with load balancing
            var readyBuilds = ReadyBuilds.Where(b => b.Status == BuildPackageStatus.Ready).ToList();
            var buildCount = 0;
            var slsMachineList = SlsMachines;
            foreach (var build in readyBuilds)
            {
                try
                {
                    // Find the SLS machine with the earliest available slot
                    Machine? bestMachine = null;
                    var bestEnd = DateTime.MaxValue;
                    foreach (var machine in slsMachineList)
                    {
                        var slot = await BuildScheduling.FindEarliestBuildSlotAsync(
                            machine.Id,
                            build.EstimatedDurationHours ?? 24,
                            DateTime.UtcNow);
                        if (slot.PrintEnd < bestEnd)
                        {
                            bestMachine = machine;
                            bestEnd = slot.PrintEnd;
                        }
                    }
                    if (bestMachine != null)
                    {
                        await BuildScheduling.ScheduleBuildAsync(build.Id, bestMachine.Id);
                        buildCount++;
                    }
                }
                catch { /* skip builds that can't be scheduled */ }
            }

            var msg = $"Auto-scheduled {count} job(s)";
            if (buildCount > 0) msg += $" + {buildCount} build(s)";
            Toast.ShowSuccess(msg);
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _scheduling = false; }
    }

