            <div class="form-group">
                <label class="form-label">Earliest Start</label>
                <input class="form-control" type="datetime-local" @bind="_newJob.ScheduledStart" />
            </div>
            <div class="form-group">
                <label class="form-label">Notes</label>
                <textarea class="form-control" @bind="_newJob.Notes" rows="2" placeholder="Optional notes..."></textarea>
            </div>
            <button class="btn btn-primary" @onclick="CreateJob" disabled="@(_creatingJob)">
                @if (_creatingJob) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
