@page "/scheduler"
@inject IStageService StageService
@inject IJobService JobService
@inject IPartService PartService
@inject IMachineService MachineService
@inject ISchedulingService Scheduler
@inject IBuildPlanningService BuildPlanning
@inject IBuildSchedulingService BuildScheduling
@inject IWorkOrderService WorkOrderService
@inject IBuildTemplateService BuildTemplateService
@inject IBuildSuggestionService BuildSuggestionService
@inject ToastService Toast
@inject IJSRuntime JS
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Production Scheduler - OpCentrix</PageTitle>

<div class="sched-page">
<div class="page-header">
    <h1 class="page-title">📅 Production Scheduler</h1>
    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="/builds" class="btn btn-secondary">📦 Builds</a>
        <a href="scheduler/capacity" class="btn btn-secondary">📊 Capacity</a>
        @if (_unscheduled.Any() || ReadyBuilds.Any(b => b.Status == BuildPackageStatus.Ready))
        {
            <button class="btn btn-warning" @onclick="AutoScheduleAll" disabled="@_scheduling">
                @if (_scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                ⚡ Auto-Schedule (@(_unscheduled.Count + ReadyBuilds.Count(b => b.Status == BuildPackageStatus.Ready)))
            </button>
        }
        <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Job</button>
    </div>
</div>

@* ── Controls Bar ── *@
<div class="sched-controls">
    <div class="sched-controls-left">
        <div class="sched-viewport-info">
            <span class="sched-viewport-date" title="Click to jump to a date">
                @_viewportStart.ToString("MMM d") — @_viewportEnd.ToString("MMM d, yyyy")
            </span>
            <span class="sched-viewport-zoom" title="Zoom level">
                @(_pixelsPerHour.ToString("F1")) px/hr
            </span>
        </div>
        <div class="sched-nav-btns">
            <button class="btn btn-sm btn-secondary" @onclick="() => ShiftViewportAsync(-1)" title="Pan back">◀</button>
            <button class="btn btn-sm btn-secondary" @onclick="ScrollToNowAsync" title="Jump to now">Now</button>
            <button class="btn btn-sm btn-secondary" @onclick="() => ShiftViewportAsync(1)" title="Pan forward">▶</button>
        </div>
    </div>
    <div class="sched-controls-right">
        <div class="sched-view-toggle">
            <button class="btn btn-sm @(_viewMode == "gantt" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "gantt"'>📊 Machines</button>
            <button class="btn btn-sm @(_viewMode == "builds" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "builds"'>📦 SLS Builds</button>
            <button class="btn btn-sm @(_viewMode == "orders" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "orders"'>📋 Work Orders</button>
            <button class="btn btn-sm @(_viewMode == "path" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "path"'>🔀 Part Path</button>
            <button class="btn btn-sm @(_viewMode == "stages" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "stages"'>🔧 Stages</button>
            <button class="btn btn-sm @(_viewMode == "table" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "table"'>📋 Table</button>
        </div>
        <button class="btn btn-secondary btn-sm" @onclick="LoadData" title="Refresh now">🔄</button>
        <button class="btn btn-sm @(_autoRefreshEnabled ? "btn-accent" : "btn-secondary")" @onclick="ToggleAutoRefresh"
                title="@(_autoRefreshEnabled ? "Auto-refresh ON (30s)" : "Auto-refresh OFF")">
            @(_autoRefreshEnabled ? "⏱ ON" : "⏱ OFF")
        </button>
        <span style="font-size: 0.7rem; color: var(--text-muted); white-space: nowrap;">@_lastRefresh.ToLocalTime().ToString("HH:mm:ss")</span>
    </div>
</div>

<div>
@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading schedule...</div>
}
else if (_viewMode == "gantt")
{
    <div class="sched-layout">
        @* ── Gantt Chart ── *@
        <div class="sched-gantt-panel">
            <div class="card sched-gantt-card">
                @if (!_machines.Any())
                {
                    <div class="empty-state"><div class="empty-state-text">No machines configured for scheduling</div></div>
                }
                else
                {
                    <div class="gantt-container gantt-viewport" @ref="_ganttContainerRef">
                        <div class="gantt-inner" data-data-end="@_dataRangeEnd.ToString("o")" style="width: @(GetTotalInnerWidthPx())px; position: relative;">
                            @* ── Time Header ── *@
                            <div class="gantt-time-header">
                                @foreach (var tick in GenerateTimeHeaders())
                                {
                                    var tickLeft = GetBarLeftPx(tick.Time);
                                    <div class="gantt-tick @(tick.IsMajor ? "gantt-tick-major" : "")" style="left: @(tickLeft)px;">
                                        <span class="gantt-tick-label">@tick.Label</span>
                                    </div>
                                }
                            </div>

                            @* ── Today line ── *@
                            <div class="gantt-today-line" style="left: @(GetBarLeftPx(DateTime.UtcNow))px;"></div>

                            @* ── Machine rows (grouped by type, ordered by priority) ── *@
                            @{
                                var orderedMachines = GetOrderedMachines();
                                string? lastGroup = null;
                            }
                            @foreach (var machine in orderedMachines)
                            {
                                var groupLabel = IsSls(machine) ? "SLS / Additive" : (machine.MachineType ?? "Other");
                                if (groupLabel != lastGroup)
                                {
                                    lastGroup = groupLabel;
                                    <div class="gantt-group-header">
                                        <span class="gantt-group-label">@groupLabel</span>
                                    </div>
                                }
                                var machineExecs = _executions.Where(e => e.MachineId == machine.Id).ToList();
                                <div class="gantt-row">
                                    <div class="gantt-resource-label">
                                        <span class="gantt-machine-status gantt-status-@machine.Status.ToString().ToLower()"></span>
                                        <div class="gantt-machine-info">
                                            <span class="gantt-machine-name">@machine.Name</span>
                                            <span class="gantt-machine-type">@machine.MachineType</span>
                                        </div>
                                    </div>
                                    <div class="gantt-track">
                                        @{
                                            var buildGroups = machineExecs
                                                .Where(e => e.BuildPackageId != null && e.ProductionStage?.IsBuildLevelStage == true)
                                                .GroupBy(e => new { e.BuildPackageId, e.ProductionStageId })
                                                .ToList();
                                            var buildGroupExecIds = buildGroups.SelectMany(g => g.Select(e => e.Id)).ToHashSet();
                                            var individualExecs = machineExecs.Where(e => !buildGroupExecIds.Contains(e.Id)).ToList();
                                        }
                                        @foreach (var group in buildGroups)
                                        {
                                            var first = group.OrderBy(e => e.ScheduledStartAt ?? DateTime.MaxValue).First();
                                            var last = group.OrderByDescending(e => e.ScheduledEndAt ?? DateTime.MinValue).First();
                                            var start = first.ScheduledStartAt ?? first.Job?.ScheduledStart ?? _dataRangeStart;
                                            var end = last.ScheduledEndAt ?? last.Job?.ScheduledEnd ?? start.AddHours(first.EstimatedHours ?? 4);
                                            var barLeft = GetBarLeftPx(start);
                                            var barWidth = GetBarWidthPx(start, end);
                                            var stageColor = first.ProductionStage?.StageColor ?? "";
                                            var partList = string.Join(", ", group.Select(e => e.Job?.Part?.PartNumber ?? "?").Distinct());
                                            var pkgName = first.BuildPackage?.Name ?? $"Build #{first.BuildPackageId}";
                                            <div class="gantt-bar gantt-bar-normal"
                                                 style="left: @(barLeft)px; width: @(barWidth)px; @(string.IsNullOrEmpty(stageColor) ? "" : $"--bar-accent: {stageColor};") border: 2px solid var(--accent);"
                                                 title="📦 @pkgName — @(first.ProductionStage?.Name ?? "Stage")&#10;Parts: @partList&#10;@start.ToString("MM/dd HH:mm") → @end.ToString("MM/dd HH:mm")&#10;Est: @(first.EstimatedHours?.ToString("F1") ?? "?")h"
                                                 @onclick="() => ShowReschedule(first)">
                                                <span class="gantt-bar-text">📦 @pkgName · @(first.ProductionStage?.Name ?? "")</span>
                                            </div>
                                        }
                                        @foreach (var exec in individualExecs)
                                        {
                                            var start = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? _dataRangeStart;
                                            var end = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? start.AddHours(exec.EstimatedHours ?? 4);
                                            var barLeft = GetBarLeftPx(start);
                                            var barWidth = GetBarWidthPx(start, end);
                                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                                            var stageColor = exec.ProductionStage?.StageColor ?? "";
                                            var isConflict = HasOverlap(machine.Id, exec, machineExecs);
                                            <div class="gantt-bar gantt-bar-@priorityClass @(isConflict ? "gantt-bar-conflict" : "")"
                                                 style="left: @(barLeft)px; width: @(barWidth)px; @(string.IsNullOrEmpty(stageColor) ? "" : $"--bar-accent: {stageColor};")"
                                                 title="@(exec.Job?.Part?.PartNumber ?? "?") — @(exec.ProductionStage?.Name ?? "Stage")&#10;@start.ToString("MM/dd HH:mm") → @end.ToString("MM/dd HH:mm")&#10;Est: @(exec.EstimatedHours?.ToString("F1") ?? "?")h | Priority: @(exec.Job?.Priority)"
                                                 @onclick="() => ShowReschedule(exec)">
                                                <span class="gantt-bar-text">@(exec.Job?.Part?.PartNumber ?? $"J{exec.JobId}") · @(exec.ProductionStage?.Name ?? "")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @* ── Unassigned row ── *@
                            @{
                                var unassignedScheduled = _executions.Where(e => e.MachineId == null && e.ScheduledStartAt != null).ToList();
                            }
                            @if (unassignedScheduled.Any())
                            {
                                <div class="gantt-row gantt-row-unassigned">
                                    <div class="gantt-resource-label">
                                        <span class="gantt-machine-status" style="background: var(--warning);"></span>
                                        <div class="gantt-machine-info">
                                            <span class="gantt-machine-name">Unassigned</span>
                                            <span class="gantt-machine-type">@unassignedScheduled.Count tasks</span>
                                        </div>
                                    </div>
                                    <div class="gantt-track">
                                        @foreach (var exec in unassignedScheduled)
                                        {
                                            var start = exec.ScheduledStartAt ?? _dataRangeStart;
                                            var end = exec.ScheduledEndAt ?? start.AddHours(exec.EstimatedHours ?? 4);
                                            <div class="gantt-bar gantt-bar-unassigned" style="left: @(GetBarLeftPx(start))px; width: @(GetBarWidthPx(start, end))px;"
                                                 title="UNASSIGNED — @(exec.Job?.Part?.PartNumber ?? "?") · @(exec.ProductionStage?.Name ?? "")"
                                                 @onclick="() => ShowReschedule(exec)">
                                                <span class="gantt-bar-text">@(exec.Job?.Part?.PartNumber ?? $"J{exec.JobId}") · @(exec.ProductionStage?.Name ?? "")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* Legend *@
                    <div class="gantt-legend">
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-emergency"></span> Emergency</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-rush"></span> Rush</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-high"></span> High</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-normal"></span> Normal</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-low"></span> Low</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-conflict"></span> Conflict</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-unassigned"></span> Unassigned</span>
                    </div>
                }
            </div>
        </div>

        @* ── Sidebar: Unscheduled Work ── *@
        @if (_unscheduled.Any())
        {
            <div class="sched-sidebar">
                <div class="card">
                    <div class="card-header sched-sidebar-header">
                        📋 Unscheduled (@_unscheduled.Count)
                    </div>
                    <div class="sched-sidebar-list">
                        @foreach (var exec in _unscheduled)
                        {
                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                            <div class="sched-sidebar-item">
                                <div class="sched-sidebar-priority sched-priority-@priorityClass"></div>
                                <div class="sched-sidebar-info">
                                    <span class="sched-sidebar-part">@(exec.Job?.Part?.PartNumber ?? $"Job {exec.JobId}")</span>
                                    <span class="sched-sidebar-stage">@(exec.ProductionStage?.Name ?? "—")</span>
                                    <span class="sched-sidebar-est">@(exec.EstimatedHours?.ToString("F1") ?? "?")h est</span>
                                </div>
                                <span class="sched-sidebar-action" title="Manual schedule" @onclick="() => ManualScheduleSingle(exec)" @onclick:stopPropagation>📅</span>
                                <span class="sched-sidebar-action" title="Auto-schedule" @onclick="() => AutoScheduleSingle(exec.Id)" @onclick:stopPropagation>⚡</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_viewMode == "builds")
{
    @* ── SLS Builds View: build pipeline + per-machine timelines ── *@
    <div class="sched-layout">
        <div class="sched-gantt-panel">
            @* ── Build Pipeline Summary ── *@
            @{
                var active = ActiveBuilds;
                var ready = ReadyBuilds;
                var printing = _buildPackages.Where(b => b.Status == BuildPackageStatus.Printing).ToList();
                var postPrint = _buildPackages.Where(b => b.Status == BuildPackageStatus.PostPrint).ToList();
                var slsMachineList = SlsMachines;
            }
            <div class="builds-pipeline-summary">
                <div class="builds-pipeline-stat">
                    <span class="builds-pipeline-count">@active.Count</span>
                    <span class="builds-pipeline-label">Active Builds</span>
                </div>
                <div class="builds-pipeline-stat builds-pipeline-stat--ready">
                    <span class="builds-pipeline-count">@ready.Count</span>
                    <span class="builds-pipeline-label">Ready to Schedule</span>
                </div>
                <div class="builds-pipeline-stat builds-pipeline-stat--printing">
                    <span class="builds-pipeline-count">@printing.Count</span>
                    <span class="builds-pipeline-label">Printing</span>
                </div>
                <div class="builds-pipeline-stat builds-pipeline-stat--post">
                    <span class="builds-pipeline-count">@postPrint.Count</span>
                    <span class="builds-pipeline-label">Post-Print</span>
                </div>
                <div class="builds-pipeline-stat">
                    <span class="builds-pipeline-count">@slsMachineList.Count</span>
                    <span class="builds-pipeline-label">SLS Machines</span>
                </div>
            </div>

            @* ── Per-Machine Build Timelines ── *@
            <div class="card sched-gantt-card">
                @if (!slsMachineList.Any())
                {
                    <div class="empty-state"><div class="empty-state-icon">🖨️</div><div class="empty-state-text">No SLS machines configured for scheduling</div></div>
                }
                else
                {
                    <div class="gantt-container gantt-viewport">
                        <div class="gantt-inner" data-data-end="@_dataRangeEnd.ToString("o")" style="width: @(GetTotalInnerWidthPx())px; position: relative;">
                            @* ── Time Header ── *@
                            <div class="gantt-time-header">
                                @foreach (var tick in GenerateTimeHeaders())
                                {
                                    var tickLeft = GetBarLeftPx(tick.Time);
                                    <div class="gantt-tick @(tick.IsMajor ? "gantt-tick-major" : "")" style="left: @(tickLeft)px;">
                                        <span class="gantt-tick-label">@tick.Label</span>
                                    </div>
                                }
                            </div>

                            @* ── Today line ── *@
                            <div class="gantt-today-line" style="left: @(GetBarLeftPx(DateTime.UtcNow))px;"></div>

                            @* ── SLS machine rows with build bars ── *@
                            @foreach (var machine in slsMachineList)
                            {
                                var timeline = _machineTimelines.GetValueOrDefault(machine.Id) ?? [];
                                <div class="gantt-row">
                                    <div class="gantt-resource-label">
                                        <span class="gantt-machine-status gantt-status-@machine.Status.ToString().ToLower()"></span>
                                        <div class="gantt-machine-info">
                                            <span class="gantt-machine-name">@machine.Name</span>
                                            <span class="gantt-machine-type">@(machine.LaserCount != null ? $"{machine.LaserCount} laser" : "SLS") · @(machine.BuildPlateCapacity) plate</span>
                                        </div>
                                    </div>
                                    <div class="gantt-track">
                                        @foreach (var entry in timeline)
                                        {
                                            var barLeft = GetBarLeftPx(entry.PrintStart);
                                            var barWidth = GetBarWidthPx(entry.PrintStart, entry.PrintEnd);
                                            var statusClass = entry.Status switch
                                            {
                                                BuildPackageStatus.Printing => "builds-bar--printing",
                                                BuildPackageStatus.PostPrint => "builds-bar--postprint",
                                                BuildPackageStatus.Completed => "builds-bar--completed",
                                                BuildPackageStatus.Scheduled => "builds-bar--scheduled",
                                                _ => "builds-bar--ready"
                                            };
                                            var tooltip = $"{entry.BuildName}\nStatus: {entry.Status}\n{entry.PrintStart:MM/dd HH:mm} → {entry.PrintEnd:MM/dd HH:mm}";
                                            if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                                tooltip += $"\nChangeover: {entry.ChangeoverStart:HH:mm} → {entry.ChangeoverEnd:HH:mm}";
                                            <div class="gantt-bar @statusClass"
                                                 style="left: @(barLeft)px; width: @(barWidth)px;"
                                                 title="@tooltip">
                                                <span class="gantt-bar-text">📦 @entry.BuildName · @entry.Status</span>
                                            </div>
                                            @if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                            {
                                                var coLeft = GetBarLeftPx(entry.ChangeoverStart.Value);
                                                var coWidth = GetBarWidthPx(entry.ChangeoverStart.Value, entry.ChangeoverEnd.Value);
                                                <div class="builds-changeover-bar"
                                                     style="left: @(coLeft)px; width: @(coWidth)px;"
                                                     title="Changeover: @entry.ChangeoverStart.Value.ToString("HH:mm") → @entry.ChangeoverEnd.Value.ToString("HH:mm")">
                                                    <span class="gantt-bar-text">🔄 Changeover</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* Build status legend *@
                    <div class="gantt-legend">
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--scheduled"></span> Scheduled</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--printing"></span> Printing</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--postprint"></span> Post-Print</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--completed"></span> Completed</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-changeover-bar"></span> Changeover</span>
                    </div>
                }
            </div>

            @* ── Ready Builds Cards ── *@
            @if (ready.Any())
            {
                <div class="builds-ready-section">
                    <h3 class="builds-ready-title">✅ Ready to Schedule (@ready.Count)</h3>
                    <div class="builds-ready-grid">
                        @foreach (var build in ready)
                        {
                            <div class="builds-ready-card">
                                <div class="builds-ready-card-header">
                                    <span class="builds-ready-card-name">📦 @(build.Name ?? $"Build #{build.Id}")</span>
                                    <span class="badge badge-@BuildStatusBadgeClass(build.Status)">@BuildStatusIcon(build.Status) @build.Status</span>
                                </div>
                                <div class="builds-ready-card-meta">
                                    <span>@(build.TotalPartCount) parts</span>
                                    <span>@(build.EstimatedDurationHours?.ToString("F1") ?? "?")h est</span>
                                    @if (build.ScheduledDate != null)
                                    {
                                        <span>📅 @build.ScheduledDate.Value.ToString("MM/dd")</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── Sidebar: Unscheduled Build Work ── *@
        @if (_unscheduled.Any(e => e.ProductionStage?.IsBuildLevelStage == true))
        {
            <div class="sched-sidebar">
                <div class="card">
                    <div class="card-header sched-sidebar-header">
                        📋 Unscheduled Build Stages
                    </div>
                    <div class="sched-sidebar-list">
                        @foreach (var exec in _unscheduled.Where(e => e.ProductionStage?.IsBuildLevelStage == true))
                        {
                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                            <div class="sched-sidebar-item" @onclick="() => AutoScheduleSingle(exec.Id)">
                                <div class="sched-sidebar-priority sched-priority-@priorityClass"></div>
                                <div class="sched-sidebar-info">
                                    <span class="sched-sidebar-part">📦 @(exec.BuildPackage?.Name ?? exec.Job?.Part?.PartNumber ?? $"Job {exec.JobId}")</span>
                                    <span class="sched-sidebar-stage">@(exec.ProductionStage?.Name ?? "—")</span>
                                    <span class="sched-sidebar-est">@(exec.EstimatedHours?.ToString("F1") ?? "?")h est</span>
                                </div>
                                <span class="sched-sidebar-action" title="Auto-schedule this task">⚡</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_viewMode == "orders")
{
    @* ── Work Orders Command Center ── *@
    <div class="wo-demand-view">
        @{
            var woAllLines = _workOrders.SelectMany(w => w.Lines).ToList();
            var woTotalOutstanding = woAllLines.Sum(l => GetOutstanding(l));
            var woTotalInBuilds = woAllLines.Sum(l => GetInBuildQty(l));
            var woAddLines = woAllLines.Where(l => IsAdditiveLine(l) && GetOutstanding(l) > 0).ToList();
            var woCncLines = woAllLines.Where(l => !IsAdditiveLine(l) && GetOutstanding(l) > 0).ToList();
            var woUnscheduledLines = woAllLines.Where(l => GetOutstanding(l) > 0 && GetInBuildQty(l) == 0 && !HasExistingJobs(l)).ToList();
            var templatesAvailable = _buildTemplates.Count(t => t.IsCertified);
            var templatesNeedingRecert = _buildTemplates.Count(t => t.NeedsRecertification);
        }

        @if (!_workOrders.Any())
        {
            <div class="empty-state"><div class="empty-state-icon">📋</div><div class="empty-state-text">No released work orders. Release a work order to see demand here.</div></div>
        }
        else
        {
            <div class="wo-demand-stats">
                <div class="wo-demand-stat">
                    <span class="wo-demand-stat-count">@_workOrders.Count</span>
                    <span class="wo-demand-stat-label">Active Orders</span>
                </div>
                <div class="wo-demand-stat wo-demand-stat--outstanding">
                    <span class="wo-demand-stat-count">@woTotalOutstanding</span>
                    <span class="wo-demand-stat-label">Parts Outstanding</span>
                </div>
                <div class="wo-demand-stat wo-demand-stat--additive">
                    <span class="wo-demand-stat-count">@woAddLines.Count</span>
                    <span class="wo-demand-stat-label">Need Builds (SLS)</span>
                </div>
                <div class="wo-demand-stat wo-demand-stat--cnc">
                    <span class="wo-demand-stat-count">@woCncLines.Count</span>
                    <span class="wo-demand-stat-label">Need Machining</span>
                </div>
                @if (woTotalInBuilds > 0)
                {
                    <div class="wo-demand-stat wo-demand-stat--inbuilds">
                        <span class="wo-demand-stat-count">@woTotalInBuilds</span>
                        <span class="wo-demand-stat-label">In Builds</span>
                    </div>
                }
                <div class="wo-demand-stat wo-demand-stat--unscheduled">
                    <span class="wo-demand-stat-count">@woUnscheduledLines.Count</span>
                    <span class="wo-demand-stat-label">Not Yet Scheduled</span>
                </div>
                <div class="wo-demand-stat">
                    <span class="wo-demand-stat-count">@templatesAvailable</span>
                    <span class="wo-demand-stat-label">Templates Available</span>
                </div>
                @if (templatesNeedingRecert > 0)
                {
                    <div class="wo-demand-stat wo-demand-stat--outstanding">
                        <span class="wo-demand-stat-count">@templatesNeedingRecert</span>
                        <span class="wo-demand-stat-label">⚠️ Needing Re-cert</span>
                    </div>
                }
            </div>

            @* ── Build Suggestions (Phase C) ── *@
            @if (_suggestions != null && (_suggestions.TemplateSuggestions.Any(s => !_dismissedSuggestions.Contains($"t-{s.BuildTemplateId}-{s.PartId}")) || _suggestions.MixedBuildSuggestions.Any(s => !_dismissedSuggestions.Contains($"m-{string.Join(",", s.Parts.Select(p => p.PartId))}"))))
            {
                <div class="wo-suggestions-section">
                    <h3 class="wo-suggestions-title">💡 Build Suggestions</h3>

                    @foreach (var suggestion in _suggestions.TemplateSuggestions)
                    {
                        var key = $"t-{suggestion.BuildTemplateId}-{suggestion.PartId}";
                        if (_dismissedSuggestions.Contains(key)) continue;

                        <div class="wo-suggestion-card">
                            <div class="wo-suggestion-card-info">
                                <div class="wo-suggestion-card-header">
                                    <span class="badge badge-success">✅ Template</span>
                                    <strong>@suggestion.TemplateName</strong>
                                </div>
                                <div class="wo-suggestion-card-detail">
                                    @suggestion.PartNumber — @suggestion.SuggestedQuantity pc · @suggestion.EstimatedDurationHours.ToString("F1")h · Used @suggestion.UseCount×
                                </div>
                                <div class="wo-suggestion-card-rationale">@suggestion.Rationale</div>
                                @if (suggestion.FulfillsWorkOrders.Any())
                                {
                                    <div class="wo-suggestion-card-wos">
                                        Fulfills: @string.Join(", ", suggestion.FulfillsWorkOrders.Select(w => $"{w.OrderNumber} ({w.QuantityFulfilled}pc)"))
                                    </div>
                                }
                            </div>
                            <div class="wo-suggestion-card-actions">
                                <button class="btn btn-sm btn-primary" @onclick="() => ScheduleFromSuggestion(suggestion)" title="Schedule using this certified template">
                                    📅 Schedule from Template
                                </button>
                                <button class="btn btn-sm btn-secondary" @onclick='() => _dismissedSuggestions.Add(key)' title="Dismiss this suggestion">
                                    ✕
                                </button>
                            </div>
                        </div>
                    }

                    @foreach (var suggestion in _suggestions.MixedBuildSuggestions)
                    {
                        var key = $"m-{string.Join(",", suggestion.Parts.Select(p => p.PartId))}";
                        if (_dismissedSuggestions.Contains(key)) continue;

                        <div class="wo-suggestion-card wo-suggestion-card--mixed">
                            <div class="wo-suggestion-card-info">
                                <div class="wo-suggestion-card-header">
                                    <span class="badge badge-info">🔀 Mixed Build</span>
                                    @if (suggestion.MatchingTemplateName != null)
                                    {
                                        <strong>@suggestion.MatchingTemplateName</strong>
                                    }
                                </div>
                                <div class="wo-suggestion-card-detail">
                                    @string.Join(" + ", suggestion.Parts.Select(p => $"{p.PartNumber} ({p.SuggestedQuantity})")) · @suggestion.EstimatedDurationHours.ToString("F1")h
                                </div>
                                <div class="wo-suggestion-card-rationale">@suggestion.Rationale</div>
                                @if (suggestion.FulfillsWorkOrders.Any())
                                {
                                    <div class="wo-suggestion-card-wos">
                                        Fulfills: @string.Join(", ", suggestion.FulfillsWorkOrders.Select(w => $"{w.OrderNumber} ({w.QuantityFulfilled}pc)"))
                                    </div>
                                }
                            </div>
                            <div class="wo-suggestion-card-actions">
                                @if (suggestion.MatchingTemplateId.HasValue)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => ScheduleFromMixedSuggestion(suggestion)" title="Schedule using the matching template">
                                        📅 Schedule from Template
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-accent" @onclick="() => CreateMixedBuild(suggestion)" title="Create a new mixed build plate">
                                        🆕 Create Mixed Build
                                    </button>
                                }
                                <button class="btn btn-sm btn-secondary" @onclick='() => _dismissedSuggestions.Add(key)' title="Dismiss this suggestion">
                                    ✕
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

            @* ── Work Order Cards ── *@
            <div class="wo-demand-list">
                @foreach (var wo in _workOrders.OrderBy(w => w.DueDate))
                {
                    var daysUntilDue = (wo.DueDate.Date - DateTime.UtcNow.Date).Days;
                    var dueClass = daysUntilDue < 0 ? "wo-card--overdue" : (daysUntilDue <= 3 ? "wo-card--urgent" : "");
                    var woOutstanding = wo.Lines.Sum(l => GetOutstanding(l));

                    <div class="wo-demand-card @dueClass">
                        <div class="wo-card-header">
                            <div class="wo-card-title">
                                <a href="/workorders/@wo.Id" class="wo-card-number">@wo.OrderNumber</a>
                                <span class="wo-card-customer">@wo.CustomerName</span>
                            </div>
                            <div class="wo-card-meta">
                                <span class="badge badge-@wo.Priority.ToString().ToLower()">@wo.Priority</span>
                                <span class="badge badge-@(wo.Status == WorkOrderStatus.Released ? "primary" : "info")">@wo.Status</span>
                                @if (daysUntilDue < 0)
                                {
                                    <span class="badge badge-danger">@Math.Abs(daysUntilDue)d OVERDUE</span>
                                }
                                else if (daysUntilDue <= 3)
                                {
                                    <span class="badge badge-warning">Due in @(daysUntilDue)d</span>
                                }
                                else
                                {
                                    <span class="wo-card-due">Due @wo.DueDate.ToString("MM/dd")</span>
                                }
                            </div>
                        </div>

                        @if (woOutstanding <= 0)
                        {
                            <div class="wo-card-fulfilled">
                                <span>✅ All parts produced or scheduled</span>
                            </div>
                        }
                        else
                        {
                            <div class="wo-card-lines">
                                @foreach (var line in wo.Lines.OrderByDescending(l => GetOutstanding(l)))
                                {
                                    var outstanding = GetOutstanding(line);
                                    var isAdditive = IsAdditiveLine(line);
                                    var hasJobs = HasExistingJobs(line);
                                    var inBuilds = GetInBuildQty(line);
                                    var progressPct = line.Quantity > 0 ? Math.Min(100, line.ProducedQuantity * 100.0 / line.Quantity) : 0;
                                    var buildPct = line.Quantity > 0 ? Math.Min(100, inBuilds * 100.0 / line.Quantity) : 0;

                                    <div class="wo-line-row @(outstanding <= 0 ? "wo-line-row--done" : "")">
                                        <div class="wo-line-info">
                                            <div class="wo-line-part">
                                                <span class="wo-line-type-badge @(isAdditive ? "wo-line-type--sls" : "wo-line-type--cnc")">
                                                    @(isAdditive ? "🖨️ SLS" : "⚙️ CNC")
                                                </span>
                                                <span class="wo-line-partnum">@(line.Part?.PartNumber ?? "?")</span>
                                                <span class="wo-line-partname">@(line.Part?.Name ?? "")</span>
                                            </div>
                                            <div class="wo-line-qty">
                                                <span class="wo-line-qty-detail">@line.ProducedQuantity / @line.Quantity</span>
                                                @if (inBuilds > 0)
                                                {
                                                    <span style="color: var(--accent); font-size: 0.75rem;">🖨️ @inBuilds in builds</span>
                                                }
                                                @if (outstanding > 0)
                                                {
                                                    <span class="wo-line-outstanding">@outstanding remaining</span>
                                                }
                                                else
                                                {
                                                    <span class="wo-line-complete">✅ Covered</span>
                                                }
                                            </div>
                                        </div>

                                        @* Progress bar with produced (green) + build coverage (accent) *@
                                        <div class="wo-line-progress">
                                            <div style="display: flex; height: 100%;">
                                                @if (progressPct > 0)
                                                {
                                                    <div class="wo-line-progress-fill" style="width: @progressPct.ToString("F0")%;"></div>
                                                }
                                                @if (buildPct > 0)
                                                {
                                                    <div style="width: @buildPct.ToString("F0")%; background: var(--accent); opacity: 0.6; border-radius: 0 4px 4px 0;"></div>
                                                }
                                            </div>
                                        </div>

                                        @* Actions *@
                                        @if (outstanding > 0)
                                        {
                                            <div class="wo-line-actions">
                                                @if (hasJobs)
                                                {
                                                    <span class="badge badge-info" style="font-size:0.7rem;">Jobs exist</span>
                                                }
                                                @if (isAdditive)
                                                {
                                                    @* ── Certified Template Cards for SLS Lines ── *@
                                                    var matchingTemplates = GetMatchingTemplates(line.PartId);
                                                    var recertTemplates = GetRecertTemplates(line.PartId);
                                                    @if (matchingTemplates.Any())
                                                    {
                                                        @foreach (var template in matchingTemplates)
                                                        {
                                                            <div class="wo-template-card">
                                                                <div class="wo-template-card-info">
                                                                    <span class="wo-template-card-name" title="@template.Name">✅ @template.Name</span>
                                                                    <span class="wo-template-card-detail">@template.TotalPartCount parts · @template.EstimatedDurationHours.ToString("F1")h · Used @template.UseCount×</span>
                                                                </div>
                                                                <button class="btn btn-sm btn-primary" @onclick="() => ShowQuickScheduleModal(wo, line, template)" title="Schedule using this certified template">
                                                                    📅 Schedule This Build
                                                                </button>
                                                            </div>
                                                        }
                                                    }
                                                    @if (recertTemplates.Any())
                                                    {
                                                        @foreach (var template in recertTemplates)
                                                        {
                                                            <div class="wo-template-card wo-template-card--recert">
                                                                <div class="wo-template-card-info">
                                                                    <span class="wo-template-card-name">⚠️ @template.Name</span>
                                                                    <span class="wo-template-card-detail">Needs re-certification (part updated)</span>
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                    @if (!matchingTemplates.Any())
                                                    {
                                                        <button class="btn btn-sm btn-accent" @onclick='() => NavigateToNewBuild(line)' title="Create a new build for this part on the Builds page">
                                                            🆕 New Build
                                                        </button>
                                                    }
                                                    <button class="btn btn-sm btn-secondary" @onclick="() => ShowWoBuildModal(wo, line)" title="Create a build plate for this part">
                                                        🖨️ Create Build
                                                    </button>
                                                }
                                                else
                                                {
                                                    @if (!hasJobs)
                                                    {
                                                        <button class="btn btn-sm btn-accent" @onclick="() => ShowWoJobModal(wo, line)" title="Generate and auto-schedule a job for this part">
                                                            ⚙️ Schedule Job
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-secondary" @onclick="() => ShowWoJobModal(wo, line)" title="Create another job for remaining quantity">
                                                            ⚙️ Add Job
                                                        </button>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
else if (_viewMode == "path")
{
    @* ── Part Path View: rows = jobs, bars = stage executions colored by stage ── *@
    <div class="sched-layout">
        <div class="sched-gantt-panel">
            @* Filter bar *@
            <div class="sched-path-filters">
                <select class="form-control" @bind="_pathFilterPartId" @bind:after="StateHasChanged">
                    <option value="0">All Parts</option>
                    @if (_parts != null) { @foreach (var p in _parts) { <option value="@p.Id">@p.PartNumber — @p.Name</option> } }
                </select>
                <select class="form-control" @bind="_pathFilterPriority" @bind:after="StateHasChanged">
                    <option value="">All Priorities</option>
                    @foreach (var p in Enum.GetValues<JobPriority>()) { <option value="@p">@p</option> }
                </select>
                <select class="form-control" @bind="_pathSortMode" @bind:after="StateHasChanged">
                    <option value="schedule">Sort: Schedule</option>
                    <option value="priority">Sort: Priority</option>
                    <option value="part">Sort: Part Number</option>
                </select>
            </div>

            <div class="card sched-gantt-card">
                @{
                    // Group executions by JobId for part-path rows
                    var jobGroups = _executions
                        .Where(e => e.JobId.HasValue)
                        .GroupBy(e => e.JobId!.Value)
                        .Select(g => new { JobId = g.Key, Job = g.First().Job, Execs = g.OrderBy(e => e.SortOrder).ToList() })
                        .Where(g => g.Job != null)
                        .ToList();

                    // Apply filters
                    if (_pathFilterPartId > 0)
                        jobGroups = jobGroups.Where(g => g.Job!.PartId == _pathFilterPartId).ToList();
                    if (!string.IsNullOrEmpty(_pathFilterPriority) && Enum.TryParse<JobPriority>(_pathFilterPriority, out var filterPri))
                        jobGroups = jobGroups.Where(g => g.Job!.Priority == filterPri).ToList();

                    // Apply sort
                    jobGroups = _pathSortMode switch
                    {
                        "priority" => jobGroups.OrderByDescending(g => g.Job!.Priority).ThenBy(g => g.Job!.ScheduledStart).ToList(),
                        "part" => jobGroups.OrderBy(g => g.Job!.PartNumber).ThenBy(g => g.Job!.ScheduledStart).ToList(),
                        _ => jobGroups.OrderBy(g => g.Execs.Min(e => e.ScheduledStartAt ?? DateTime.MaxValue)).ToList()
                    };
                }

                @if (!jobGroups.Any())
                {
                    <div class="empty-state"><div class="empty-state-icon">🔀</div><div class="empty-state-text">No scheduled jobs in this date range</div></div>
                }
                else
                {
                    <div class="gantt-container gantt-viewport">
                        <div class="gantt-inner" data-data-end="@_dataRangeEnd.ToString("o")" style="width: @(GetTotalInnerWidthPx())px; position: relative;">
                            @* ── Time Header ── *@
                            <div class="gantt-time-header">
                                @foreach (var tick in GenerateTimeHeaders())
                                {
                                    var tickLeft = GetBarLeftPx(tick.Time);
                                    <div class="gantt-tick @(tick.IsMajor ? "gantt-tick-major" : "")" style="left: @(tickLeft)px;">
                                        <span class="gantt-tick-label">@tick.Label</span>
                                    </div>
                                }
                            </div>

                            @* ── Today line ── *@
                            <div class="gantt-today-line" style="left: @(GetBarLeftPx(DateTime.UtcNow))px;"></div>

                            @* ── Job rows ── *@
                            @foreach (var group in jobGroups)
                            {
                                var job = group.Job!;
                                var isOverdue = job.IsOverdue;
                                var woId = job.WorkOrderLineId.HasValue ? job.WorkOrderLine?.WorkOrderId : (int?)null;
                                <div class="gantt-row @(isOverdue ? "gantt-row-overdue" : "")">
                                    <div class="gantt-path-label">
                                        <span class="gantt-path-part">@(job.PartNumber ?? $"Part #{job.PartId}")</span>
                                        @if (woId.HasValue)
                                        {
                                            <a class="gantt-path-job" href="/workorders/@woId/jobs/@job.Id">@(job.JobNumber ?? $"J#{job.Id}")</a>
                                        }
                                        else
                                        {
                                            <span class="gantt-path-job" style="cursor:default;">@(job.JobNumber ?? $"J#{job.Id}")</span>
                                        }
                                        <span class="gantt-path-meta">
                                            <span class="badge badge-@job.Priority.ToString().ToLower()" style="font-size:0.6rem;padding:1px 6px;">@job.Priority</span>
                                            @(job.Quantity) qty
                                        </span>
                                    </div>
                                    <div class="gantt-track">
                                        @foreach (var exec in group.Execs)
                                        {
                                            var start = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? _dataRangeStart;
                                            var end = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? start.AddHours(exec.EstimatedHours ?? 4);
                                            var barLeft = GetBarLeftPx(start);
                                            var barWidth = GetBarWidthPx(start, end);
                                            var stageColor = exec.ProductionStage?.StageColor ?? "#3B82F6";
                                            var statusClass = exec.Status switch
                                            {
                                                StageExecutionStatus.Completed => "gantt-bar-completed",
                                                StageExecutionStatus.InProgress => "gantt-bar-inprogress",
                                                StageExecutionStatus.Failed => "gantt-bar-failed",
                                                StageExecutionStatus.NotStarted => "gantt-bar-notstarted",
                                                _ => ""
                                            };
                                            var machineName = exec.Machine?.Name ?? "Unassigned";
                                            var stageName = exec.ProductionStage?.Name ?? "Stage";
                                            var tooltip = $"{stageName}\nMachine: {machineName}\n{start:MM/dd HH:mm} \u2192 {end:MM/dd HH:mm}\nEst: {exec.EstimatedHours?.ToString("F1") ?? "?"}h\nStatus: {exec.Status}";
                                            if (exec.OperatorName != null) tooltip += $"\nOperator: {exec.OperatorName}";
                                            <div class="gantt-bar gantt-bar-stage @statusClass"
                                                 style="left: @(barLeft)px; width: @(barWidth)px; --bar-accent: @stageColor;"
                                                 title="@tooltip"
                                                 @onclick="() => ShowReschedule(exec)">
                                                <span class="gantt-bar-text">@stageName<span class="gantt-bar-machine">@machineName</span></span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* Stage color legend *@
                    <div class="gantt-path-legend">
                        @foreach (var stage in _executions
                            .Where(e => e.ProductionStage != null)
                            .Select(e => e.ProductionStage!)
                            .DistinctBy(s => s.Id)
                            .OrderBy(s => s.DisplayOrder))
                        {
                            <span class="gantt-legend-item"><span class="gantt-path-legend-swatch" style="background:@stage.StageColor;"></span> @stage.Name</span>
                        }
                    </div>
                }
            </div>
        </div>

        @* ── Sidebar: Unscheduled Work ── *@
        @if (_unscheduled.Any())
        {
            <div class="sched-sidebar">
                <div class="card">
                    <div class="card-header sched-sidebar-header">
                        📋 Unscheduled (@_unscheduled.Count)
                    </div>
                    <div class="sched-sidebar-list">
                        @foreach (var exec in _unscheduled)
                        {
                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                            <div class="sched-sidebar-item">
                                <div class="sched-sidebar-priority sched-priority-@priorityClass"></div>
                                <div class="sched-sidebar-info">
                                    <span class="sched-sidebar-part">@(exec.Job?.Part?.PartNumber ?? $"Job {exec.JobId}")</span>
                                    <span class="sched-sidebar-stage">@(exec.ProductionStage?.Name ?? "—")</span>
                                    <span class="sched-sidebar-est">@(exec.EstimatedHours?.ToString("F1") ?? "?")h est</span>
                                </div>
                                <span class="sched-sidebar-action" title="Manual schedule" @onclick="() => ManualScheduleSingle(exec)" @onclick:stopPropagation>📅</span>
                                <span class="sched-sidebar-action" title="Auto-schedule" @onclick="() => AutoScheduleSingle(exec.Id)" @onclick:stopPropagation>⚡</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_viewMode == "stages")
{
    @* ── Stage Queue View ── *@
    <div class="stage-queue-grid">
        @foreach (var stage in _stages.OrderBy(s => s.DisplayOrder))
        {
            var stageId = stage.Id;
            var allForStage = _executions.Concat(_unscheduled)
                .Where(e => e.ProductionStageId == stageId)
                .ToList();
            var waiting = allForStage.Where(e => e.Status == StageExecutionStatus.NotStarted).ToList();
            var active = allForStage.Where(e => e.Status == StageExecutionStatus.InProgress).ToList();
            var completed = allForStage.Where(e => e.Status == StageExecutionStatus.Completed).ToList();
            var failed = allForStage.Where(e => e.Status == StageExecutionStatus.Failed).ToList();
            var queuedHours = waiting.Sum(e => e.EstimatedHours ?? 0) + active.Sum(e => e.EstimatedHours ?? 0);
            var hasWork = allForStage.Any();
            var isExpanded = _expandedStages.Contains(stageId);
            var barPercent = Math.Min(100, queuedHours / 40.0 * 100);
            var barColor = queuedHours > 40 ? "var(--danger)" : (queuedHours > 24 ? "var(--warning)" : (stage.StageColor ?? "var(--accent)"));

            <div class="stage-queue-card @(!hasWork ? "stage-queue-card--empty" : "")">
                <div class="stage-queue-header" @onclick="() => ToggleStageExpand(stageId)">
                    <div class="stage-queue-title">
                        <span class="stage-queue-swatch" style="background:@(stage.StageColor ?? "var(--accent)")"></span>
                        <span class="stage-queue-icon">@ResolveStageIcon(stage.StageIcon)</span>
                        <span class="stage-queue-name">@stage.Name</span>
                        @if (!string.IsNullOrEmpty(stage.Department))
                        {
                            <span class="badge badge-secondary stage-queue-dept">@stage.Department</span>
                        }
                    </div>
                    <span class="stage-queue-chevron @(isExpanded ? "stage-queue-chevron--open" : "")">▸</span>
                </div>

                <div class="stage-queue-metrics">
                    <div class="stage-metric stage-metric--waiting">
                        <span class="stage-metric-count">@waiting.Count</span>
                        <span class="stage-metric-label">Queued</span>
                    </div>
                    <div class="stage-metric stage-metric--active">
                        <span class="stage-metric-count">@active.Count</span>
                        <span class="stage-metric-label">Active</span>
                    </div>
                    <div class="stage-metric stage-metric--done">
                        <span class="stage-metric-count">@completed.Count</span>
                        <span class="stage-metric-label">Done</span>
                    </div>
                    @if (failed.Any())
                    {
                        <div class="stage-metric stage-metric--failed">
                            <span class="stage-metric-count">@failed.Count</span>
                            <span class="stage-metric-label">Failed</span>
                        </div>
                    }
                    <div class="stage-metric stage-metric--hours">
                        <span class="stage-metric-count">@queuedHours.ToString("F1")</span>
                        <span class="stage-metric-label">Hrs Queued</span>
                    </div>
                </div>

                @if (queuedHours > 0)
                {
                    <div class="stage-queue-workload">
                        <div class="stage-queue-workload-fill" style="width:@barPercent.ToString("F0")%;background:@barColor"></div>
                    </div>
                }

                @if (isExpanded && (waiting.Any() || active.Any()))
                {
                    <div class="stage-queue-items">
                        @foreach (var exec in active.Concat(waiting).OrderByDescending(e => e.Job?.Priority).ThenBy(e => e.ScheduledStartAt))
                        {
                            <div class="stage-queue-item @(exec.Status == StageExecutionStatus.InProgress ? "stage-queue-item--active" : "")">
                                <span class="stage-queue-item-dot @(exec.Status == StageExecutionStatus.InProgress ? "stage-queue-item-dot--active" : "")"></span>
                                <span class="stage-queue-item-part">
                                    @if (exec.BuildPackageId != null && exec.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        <text>📦 @(exec.BuildPackage?.Name ?? $"Build #{exec.BuildPackageId}")</text>
                                    }
                                    else
                                    {
                                        @(exec.Job?.Part?.PartNumber ?? "—")
                                    }
                                </span>
                                <span class="badge badge-@(exec.Job?.Priority.ToString().ToLower() ?? "normal")">@(exec.Job?.Priority ?? JobPriority.Normal)</span>
                                <span class="stage-queue-item-hours">@(exec.EstimatedHours?.ToString("F1") ?? "—")h</span>
                                @if (exec.Machine != null)
                                {
                                    <span class="stage-queue-item-machine">🖥️ @exec.Machine.Name</span>
                                }
                                @if (exec.ScheduledStartAt != null)
                                {
                                    <span class="stage-queue-item-time">@exec.ScheduledStartAt.Value.ToString("MM/dd HH:mm")</span>
                                }
                                @if (exec.Status == StageExecutionStatus.NotStarted)
                                {
                                    <button class="btn btn-sm btn-secondary stage-queue-item-action" @onclick="() => ShowReschedule(exec)" title="Reschedule">📅</button>
                                }
                            </div>
                        }
                    </div>
                }
                else if (isExpanded && !waiting.Any() && !active.Any())
                {
                    <div class="stage-queue-items">
                        <div class="stage-queue-empty">No items queued</div>
                    </div>
                }
            </div>
        }
    </div>
}
else if (_viewMode == "table")
{
    @* ── Table View ── *@
    <div class="card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
            <span>📋 Stage Executions — @_executions.Count scheduled · @(_executions.Sum(e => e.EstimatedHours ?? 0).ToString("F0"))h total</span>
            <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                <input type="text" class="form-control" placeholder="Search part, stage, machine…"
                       @bind="_tableSearch" @bind:event="oninput" style="width: 200px; height: 32px; font-size: 0.85rem;" />
                <select class="form-control" @bind="_tableFilterStatus" style="width: 150px; height: 32px; font-size: 0.85rem;">
                    <option value="">All statuses</option>
                    @foreach (var s in Enum.GetValues<StageExecutionStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                @if (_unscheduled.Any())
                {
                    <span class="badge badge-warning">⚠️ @_unscheduled.Count unscheduled</span>
                }
            </div>
        </div>
        @if (!_executions.Any() && !_unscheduled.Any())
        {
            <div class="empty-state"><div class="empty-state-icon">📅</div><div class="empty-state-text">No stage executions found</div></div>
        }
        else
        {
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Priority")'>Priority @TableSortIcon("Priority")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Part")'>Part @TableSortIcon("Part")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Stage")'>Stage @TableSortIcon("Stage")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Machine")'>Machine @TableSortIcon("Machine")</th>
                            <th>Operator</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Start")'>Start @TableSortIcon("Start")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("End")'>End @TableSortIcon("End")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Hours")'>Est. Hrs @TableSortIcon("Hours")</th>
                            <th style="cursor:pointer;user-select:none;" @onclick='() => ToggleTableSort("Status")'>Status @TableSortIcon("Status")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exec in SortedTableExecutions)
                        {
                            var isMissing = exec.MachineId == null || exec.ScheduledStartAt == null;
                            <tr class="@(isMissing ? "sched-row-warn" : "")">
                                <td>
                                    <span class="badge badge-@(exec.Job?.Priority.ToString().ToLower() ?? "normal")">@(exec.Job?.Priority ?? JobPriority.Normal)</span>
                                </td>
                                <td style="font-weight: 600;">
                                    @if (exec.BuildPackageId != null && exec.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        <span>📦 @(exec.BuildPackage?.Name ?? $"Build #{exec.BuildPackageId}")</span>
                                    }
                                    else
                                    {
                                        @(exec.Job?.Part?.PartNumber ?? "—")
                                    }
                                </td>
                                <td>
                                    @if (exec.ProductionStage != null)
                                    {
                                        <span style="display:inline-flex;align-items:center;gap:4px;">
                                            <span style="width:8px;height:8px;border-radius:50%;background:@(exec.ProductionStage.StageColor);display:inline-block;"></span>
                                            @ResolveStageIcon(exec.ProductionStage.StageIcon) @exec.ProductionStage.Name
                                        </span>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td>
                                    @if (exec.Machine != null)
                                    {
                                        @exec.Machine.Name
                                    }
                                    else
                                    {
                                        <span style="color:var(--warning)">Unassigned</span>
                                    }
                                </td>
                                <td>@(exec.OperatorName ?? "—")</td>
                                <td>@((exec.ScheduledStartAt ?? exec.Job?.ScheduledStart)?.ToString("MM/dd HH:mm") ?? "—")</td>
                                <td>@((exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd)?.ToString("MM/dd HH:mm") ?? "—")</td>
                                <td>@(exec.EstimatedHours?.ToString("F1") ?? "—")</td>
                                <td><span class="badge badge-@exec.Status.ToString().ToLower()">@exec.Status</span></td>
                                <td class="sched-table-actions">
                                    @if (exec.Status == StageExecutionStatus.NotStarted)
                                    {
                                        <button class="btn btn-sm btn-secondary" @onclick="() => ShowReschedule(exec)" title="Reschedule">📅</button>
                                        @if (exec.MachineId == null)
                                        {
                                            <button class="btn btn-sm btn-warning" @onclick="() => AutoScheduleSingle(exec.Id)" title="Auto-schedule">⚡</button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
</div>
</div>

@* ── Reschedule Modal ── *@
