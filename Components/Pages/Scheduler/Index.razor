    // ── Work Order Demand Helpers ──

    private int GetOutstanding(WorkOrderLine line)
    {
        var produced = line.ProducedQuantity;
        var inBuilds = GetInBuildQty(line);
        var ordered = line.Quantity;
        return Math.Max(0, ordered - produced - inBuilds);
    }

    private static int GetInBuildQty(WorkOrderLine line)
    {
        if (line.BuildPackageParts == null) return 0;
        return line.BuildPackageParts
            .Where(bp => bp.BuildPackage != null
                && bp.BuildPackage.Status != BuildPackageStatus.Cancelled
                && bp.BuildPackage.Status != BuildPackageStatus.Completed)
            .Sum(bp => bp.Quantity);
    }

    private bool IsAdditiveLine(WorkOrderLine line) =>
        line.Part?.ManufacturingApproach?.RequiresBuildPlate == true;

    private bool HasExistingJobs(WorkOrderLine line) =>
