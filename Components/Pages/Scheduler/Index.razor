    private async Task LoadMachineTimelinesAsync()
    {
        var timelines = new Dictionary<int, List<MachineTimelineEntry>>();
        var machines = SlsMachines;

        var tasks = machines.Select(async machine =>
        {
            try
            {
                var timeline = await BuildScheduling.GetMachineTimelineAsync(machine.Id, _dataRangeStart, _dataRangeEnd);
                return (machine.Id, Timeline: timeline);
            }
            catch
            {
                return (machine.Id, Timeline: new List<MachineTimelineEntry>());
            }
        });

        var results = await Task.WhenAll(tasks);
        foreach (var (machineId, timeline) in results)
        {
            timelines[machineId] = timeline;
        }

        _machineTimelines = timelines;
    }

