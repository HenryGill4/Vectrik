    // ── Viewport (Infinite Scroll + Fluid Zoom) ──

    [JSInvokable]
    public async Task OnViewportChanged(string startIso, string endIso, double pixelsPerHour)
    {
        _viewportStart = DateTime.Parse(startIso, null, System.Globalization.DateTimeStyles.RoundtripKind);
        _viewportEnd = DateTime.Parse(endIso, null, System.Globalization.DateTimeStyles.RoundtripKind);
        _pixelsPerHour = pixelsPerHour;

        // Check if we need more data
        var buffer = TimeSpan.FromDays(1);
        if (_viewportStart < _dataRangeStart + buffer || _viewportEnd > _dataRangeEnd - buffer)
        {
            await ExtendDataRangeAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ExtendDataRangeAsync()
    {
        var newStart = _viewportStart.AddDays(-7);
        var newEnd = _viewportEnd.AddDays(7);
        if (newStart >= _dataRangeStart && newEnd <= _dataRangeEnd) return;

        _dataRangeStart = newStart < _dataRangeStart ? newStart : _dataRangeStart;
        _dataRangeEnd = newEnd > _dataRangeEnd ? newEnd : _dataRangeEnd;

        // Re-fetch data for the extended range
        try
        {
            _executions = await StageService.GetScheduledExecutionsAsync(_dataRangeStart, _dataRangeEnd);
            await LoadMachineTimelinesAsync();

            // Update JS module with the new data range
            if (_ganttViewportModule != null)
            {
                await _ganttViewportModule.InvokeVoidAsync("updateDataRange",
                    _dataRangeStart.ToString("o"), _dataRangeEnd.ToString("o"), _pixelsPerHour);
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to extend data range: {ex.Message}");
        }
    }

    private double GetBarLeftPx(DateTime start) =>
        (start - _dataRangeStart).TotalHours * _pixelsPerHour;

    private double GetBarWidthPx(DateTime start, DateTime end) =>
        Math.Max(2, (end - start).TotalHours * _pixelsPerHour);

    private double GetTotalInnerWidthPx() =>
        (_dataRangeEnd - _dataRangeStart).TotalHours * _pixelsPerHour;

    private List<(DateTime Time, string Label, bool IsMajor)> GenerateTimeHeaders()
    {
        var headers = new List<(DateTime, string, bool)>();
        var rangeStart = _dataRangeStart;
        var rangeEnd = _dataRangeEnd;

        if (_pixelsPerHour > 60)
        {
            // High zoom: 15-min ticks
            var t = new DateTime(rangeStart.Year, rangeStart.Month, rangeStart.Day, rangeStart.Hour, rangeStart.Minute / 15 * 15, 0, DateTimeKind.Utc);
            while (t < rangeEnd)
            {
                var isMajor = t.Minute == 0;
                headers.Add((t, isMajor ? t.ToString("h tt").ToLower() : t.ToString(":mm"), isMajor));
                t = t.AddMinutes(15);
            }
        }
        else if (_pixelsPerHour >= 10)
        {
            // Medium zoom: hourly ticks with day headers
            var t = rangeStart.Date.AddHours(rangeStart.Hour);
            while (t < rangeEnd)
            {
                var isMajor = t.Hour == 0;
                headers.Add((t, isMajor ? t.ToString("ddd M/d") : t.ToString("h tt").ToLower(), isMajor));
                t = t.AddHours(1);
            }
        }
        else if (_pixelsPerHour >= 2)
        {
            // Low zoom: day ticks
            var t = rangeStart.Date;
            while (t < rangeEnd)
            {
                headers.Add((t, t.ToString("ddd M/d"), true));
                t = t.AddDays(1);
            }
        }
        else
        {
            // Very low zoom: week ticks with month headers
            var t = rangeStart.Date;
            // Snap to Monday
            t = t.AddDays(-(int)t.DayOfWeek + (int)DayOfWeek.Monday);
            if (t > rangeStart) t = t.AddDays(-7);
            while (t < rangeEnd)
            {
                headers.Add((t, t.ToString("M/d"), true));
                t = t.AddDays(7);
            }
        }

        return headers;
    }

