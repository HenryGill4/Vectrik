@page "/scheduler"
@inject IStageService StageService
@inject IJobService JobService
@inject IPartService PartService
@inject IMachineService MachineService
@inject ISchedulingService Scheduler
@inject ToastService Toast
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Production Scheduler - OpCentrix</PageTitle>

<div class="sched-page">
<div class="page-header">
    <h1 class="page-title">📅 Production Scheduler</h1>
    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="scheduler/capacity" class="btn btn-secondary">📊 Capacity</a>
        @if (_unscheduled.Any())
        {
            <button class="btn btn-warning" @onclick="AutoScheduleAll" disabled="@_scheduling">
                @if (_scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                ⚡ Auto-Schedule (@_unscheduled.Count)
            </button>
        }
        <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Job</button>
    </div>
</div>

@* ── Controls Bar ── *@
<div class="sched-controls">
    <div class="sched-controls-left">
        <div class="sched-date-inputs">
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">From</label>
                <input class="form-control" type="date" @bind="_dateFrom" @bind:event="onchange" />
            </div>
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label">To</label>
                <input class="form-control" type="date" @bind="_dateTo" @bind:event="onchange" />
            </div>
        </div>
        <div class="sched-zoom-group">
            <span class="sched-zoom-label">Zoom</span>
            <button class="btn btn-sm @ZoomBtnClass("30M")" @onclick='() => SetZoom("30M")'>30m</button>
            <button class="btn btn-sm @ZoomBtnClass("1H")" @onclick='() => SetZoom("1H")'>1h</button>
            <button class="btn btn-sm @ZoomBtnClass("2H")" @onclick='() => SetZoom("2H")'>2h</button>
            <button class="btn btn-sm @ZoomBtnClass("6H")" @onclick='() => SetZoom("6H")'>6h</button>
            <button class="btn btn-sm @ZoomBtnClass("12H")" @onclick='() => SetZoom("12H")'>12h</button>
            <span class="sched-zoom-sep"></span>
            <button class="btn btn-sm @ZoomBtnClass("1D")" @onclick='() => SetZoom("1D")'>1D</button>
            <button class="btn btn-sm @ZoomBtnClass("3D")" @onclick='() => SetZoom("3D")'>3D</button>
            <span class="sched-zoom-sep"></span>
            <button class="btn btn-sm @ZoomBtnClass("1W")" @onclick='() => SetZoom("1W")'>1W</button>
            <button class="btn btn-sm @ZoomBtnClass("2W")" @onclick='() => SetZoom("2W")'>2W</button>
            <button class="btn btn-sm @ZoomBtnClass("1M")" @onclick='() => SetZoom("1M")'>1M</button>
        </div>
        <div class="sched-nav-btns">
            <button class="btn btn-sm btn-secondary" @onclick="ShiftBack" title="Pan back">◀</button>
            <button class="btn btn-sm btn-secondary" @onclick="GoToNow" title="Jump to now">Now</button>
            <button class="btn btn-sm btn-secondary" @onclick="ShiftForward" title="Pan forward">▶</button>
        </div>
    </div>
    <div class="sched-controls-right">
        <div class="sched-view-toggle">
            <button class="btn btn-sm @(_viewMode == "gantt" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "gantt"'>📊 Machines</button>
            <button class="btn btn-sm @(_viewMode == "path" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "path"'>🔀 Part Path</button>
            <button class="btn btn-sm @(_viewMode == "stages" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "stages"'>🔧 Stages</button>
            <button class="btn btn-sm @(_viewMode == "table" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "table"'>📋 Table</button>
        </div>
        <button class="btn btn-secondary btn-sm" @onclick="LoadData">🔄</button>
    </div>
</div>

<div @ref="_schedulerRef">
@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading schedule...</div>
}
else if (_viewMode == "gantt")
{
    <div class="sched-layout">
        @* ── Gantt Chart ── *@
        <div class="sched-gantt-panel">
            <div class="card sched-gantt-card">
                @if (!_machines.Any())
                {
                    <div class="empty-state"><div class="empty-state-text">No machines configured for scheduling</div></div>
                }
                else
                {
                    <div class="gantt-container" style="@GetGanttContainerStyle()">
                        @* ── Header ── *@
                        @if (IsDayLevel)
                        {
                            <div class="gantt-header">
                                <div class="gantt-resource-label gantt-corner">Machine</div>
                                @foreach (var slot in _ganttSlots)
                                {
                                    var isToday = slot.Date == DateTime.UtcNow.Date;
                                    var isWeekend = slot.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                    <div class="gantt-day-header @(isWeekend ? "gantt-weekend" : "") @(isToday ? "gantt-today-header" : "")">
                                        <span class="gantt-day-name">@slot.ToString("ddd")</span>
                                        <span class="gantt-day-date">@slot.ToString("M/d")</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="gantt-header-group">
                                <div class="gantt-header gantt-header-dates">
                                    <div class="gantt-resource-label gantt-corner">Machine</div>
                                    @foreach (var dg in GetDateGroups())
                                    {
                                        var isToday = dg.Date == DateTime.UtcNow.Date;
                                        var isWeekend = dg.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                        <div class="gantt-date-group @(isWeekend ? "gantt-weekend" : "") @(isToday ? "gantt-today-header" : "")" style="grid-column: span @dg.Count;">
                                            <span class="gantt-day-name">@dg.Date.ToString("ddd")</span>
                                            <span class="gantt-day-date">@dg.Date.ToString("M/d")</span>
                                        </div>
                                    }
                                </div>
                                <div class="gantt-header gantt-header-times">
                                    <div class="gantt-resource-label"></div>
                                    @foreach (var slot in _ganttSlots)
                                    {
                                        <div class="gantt-slot-header">@FormatSlotTime(slot)</div>
                                    }
                                </div>
                            </div>
                        }

                        @* ── Machine rows ── *@
                        @foreach (var machine in _machines.Where(m => m.IsAvailableForScheduling))
                        {
                            var machineExecs = _executions.Where(e => e.MachineId == machine.Id).ToList();
                            <div class="gantt-row">
                                <div class="gantt-resource-label">
                                    <span class="gantt-machine-status gantt-status-@machine.Status.ToString().ToLower()"></span>
                                    <div class="gantt-machine-info">
                                        <span class="gantt-machine-name">@machine.Name</span>
                                        <span class="gantt-machine-type">@machine.MachineType</span>
                                    </div>
                                </div>
                                <div class="gantt-track" style="grid-column: 2 / span @_ganttSlots.Count;">
                                    @* Today marker *@
                                    @{ var todayPct = GetGanttPosition(DateTime.UtcNow); }
                                    @if (todayPct > 0 && todayPct < 100)
                                    {
                                        <div class="gantt-today-line" style="left: @(todayPct)%;"></div>
                                    }
                                    @* Execution bars *@
                                    @{
                                        // Group build-level executions into single bars by BuildPackageId
                                        var buildGroups = machineExecs
                                            .Where(e => e.BuildPackageId != null && e.ProductionStage?.IsBuildLevelStage == true)
                                            .GroupBy(e => new { e.BuildPackageId, e.ProductionStageId })
                                            .ToList();
                                        var buildGroupExecIds = buildGroups.SelectMany(g => g.Select(e => e.Id)).ToHashSet();
                                        var individualExecs = machineExecs.Where(e => !buildGroupExecIds.Contains(e.Id)).ToList();
                                    }
                                    @* Build-level bars (one per build+stage) *@
                                    @foreach (var group in buildGroups)
                                    {
                                        var first = group.OrderBy(e => e.ScheduledStartAt ?? DateTime.MaxValue).First();
                                        var last = group.OrderByDescending(e => e.ScheduledEndAt ?? DateTime.MinValue).First();
                                        var start = first.ScheduledStartAt ?? first.Job?.ScheduledStart ?? _dateFrom;
                                        var end = last.ScheduledEndAt ?? last.Job?.ScheduledEnd ?? start.AddHours(first.EstimatedHours ?? 4);
                                        var leftPct = GetGanttPosition(start);
                                        var widthPct = GetGanttWidth(start, end);
                                        var stageColor = first.ProductionStage?.StageColor ?? "";
                                        var partList = string.Join(", ", group.Select(e => e.Job?.Part?.PartNumber ?? "?").Distinct());
                                        var pkgName = first.BuildPackage?.Name ?? $"Build #{first.BuildPackageId}";
                                        <div class="gantt-bar gantt-bar-normal"
                                             style="left: @(leftPct)%; width: @(widthPct)%; @(string.IsNullOrEmpty(stageColor) ? "" : $"--bar-accent: {stageColor};") border: 2px solid var(--accent);"
                                             title="📦 @pkgName — @(first.ProductionStage?.Name ?? "Stage")&#10;Parts: @partList&#10;@start.ToString("MM/dd HH:mm") → @end.ToString("MM/dd HH:mm")&#10;Est: @(first.EstimatedHours?.ToString("F1") ?? "?")h"
                                             @onclick="() => ShowReschedule(first)">
                                            <span class="gantt-bar-text">📦 @pkgName · @(first.ProductionStage?.Name ?? "")</span>
                                        </div>
                                    }
                                    @* Individual bars (non-build-level) *@
                                    @foreach (var exec in individualExecs)
                                    {
                                        var start = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? _dateFrom;
                                        var end = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? start.AddHours(exec.EstimatedHours ?? 4);
                                        var leftPct = GetGanttPosition(start);
                                        var widthPct = GetGanttWidth(start, end);
                                        var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                                        var stageColor = exec.ProductionStage?.StageColor ?? "";
                                        var isConflict = HasOverlap(machine.Id, exec, machineExecs);
                                        <div class="gantt-bar gantt-bar-@priorityClass @(isConflict ? "gantt-bar-conflict" : "")"
                                             style="left: @(leftPct)%; width: @(widthPct)%; @(string.IsNullOrEmpty(stageColor) ? "" : $"--bar-accent: {stageColor};")"
                                             title="@(exec.Job?.Part?.PartNumber ?? "?") — @(exec.ProductionStage?.Name ?? "Stage")&#10;@start.ToString("MM/dd HH:mm") → @end.ToString("MM/dd HH:mm")&#10;Est: @(exec.EstimatedHours?.ToString("F1") ?? "?")h | Priority: @(exec.Job?.Priority)"
                                             @onclick="() => ShowReschedule(exec)">
                                            <span class="gantt-bar-text">@(exec.Job?.Part?.PartNumber ?? $"J{exec.JobId}") · @(exec.ProductionStage?.Name ?? "")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* ── Unassigned row ── *@
                        @{
                            var unassignedScheduled = _executions.Where(e => e.MachineId == null && e.ScheduledStartAt != null).ToList();
                        }
                        @if (unassignedScheduled.Any())
                        {
                            <div class="gantt-row gantt-row-unassigned">
                                <div class="gantt-resource-label">
                                    <span class="gantt-machine-status" style="background: var(--warning);"></span>
                                    <div class="gantt-machine-info">
                                        <span class="gantt-machine-name">Unassigned</span>
                                        <span class="gantt-machine-type">@unassignedScheduled.Count tasks</span>
                                    </div>
                                </div>
                                <div class="gantt-track" style="grid-column: 2 / span @_ganttSlots.Count;">
                                    @foreach (var exec in unassignedScheduled)
                                    {
                                        var start = exec.ScheduledStartAt ?? _dateFrom;
                                        var end = exec.ScheduledEndAt ?? start.AddHours(exec.EstimatedHours ?? 4);
                                        <div class="gantt-bar gantt-bar-unassigned" style="left: @(GetGanttPosition(start))%; width: @(GetGanttWidth(start, end))%;"
                                             title="UNASSIGNED — @(exec.Job?.Part?.PartNumber ?? "?") · @(exec.ProductionStage?.Name ?? "")"
                                             @onclick="() => ShowReschedule(exec)">
                                            <span class="gantt-bar-text">@(exec.Job?.Part?.PartNumber ?? $"J{exec.JobId}") · @(exec.ProductionStage?.Name ?? "")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @* Legend *@
                    <div class="gantt-legend">
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-emergency"></span> Emergency</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-rush"></span> Rush</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-high"></span> High</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-normal"></span> Normal</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-low"></span> Low</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-conflict"></span> Conflict</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-unassigned"></span> Unassigned</span>
                    </div>
                }
            </div>
        </div>

        @* ── Sidebar: Unscheduled Work ── *@
        @if (_unscheduled.Any())
        {
            <div class="sched-sidebar">
                <div class="card">
                    <div class="card-header sched-sidebar-header">
                        📋 Unscheduled (@_unscheduled.Count)
                    </div>
                    <div class="sched-sidebar-list">
                        @foreach (var exec in _unscheduled)
                        {
                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                            <div class="sched-sidebar-item" @onclick="() => AutoScheduleSingle(exec.Id)">
                                <div class="sched-sidebar-priority sched-priority-@priorityClass"></div>
                                <div class="sched-sidebar-info">
                                    <span class="sched-sidebar-part">@(exec.Job?.Part?.PartNumber ?? $"Job {exec.JobId}")</span>
                                    <span class="sched-sidebar-stage">@(exec.ProductionStage?.Name ?? "—")</span>
                                    <span class="sched-sidebar-est">@(exec.EstimatedHours?.ToString("F1") ?? "?")h est</span>
                                </div>
                                <span class="sched-sidebar-action" title="Auto-schedule this task">⚡</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_viewMode == "path")
{
    @* ── Part Path View: rows = jobs, bars = stage executions colored by stage ── *@
    <div class="sched-layout">
        <div class="sched-gantt-panel">
            @* Filter bar *@
            <div class="sched-path-filters">
                <select class="form-control" @bind="_pathFilterPartId" @bind:after="StateHasChanged">
                    <option value="0">All Parts</option>
                    @if (_parts != null) { @foreach (var p in _parts) { <option value="@p.Id">@p.PartNumber — @p.Name</option> } }
                </select>
                <select class="form-control" @bind="_pathFilterPriority" @bind:after="StateHasChanged">
                    <option value="">All Priorities</option>
                    @foreach (var p in Enum.GetValues<JobPriority>()) { <option value="@p">@p</option> }
                </select>
                <select class="form-control" @bind="_pathSortMode" @bind:after="StateHasChanged">
                    <option value="schedule">Sort: Schedule</option>
                    <option value="priority">Sort: Priority</option>
                    <option value="part">Sort: Part Number</option>
                </select>
            </div>

            <div class="card sched-gantt-card">
                @{
                    // Group executions by JobId for part-path rows
                    var jobGroups = _executions
                        .Where(e => e.JobId.HasValue)
                        .GroupBy(e => e.JobId!.Value)
                        .Select(g => new { JobId = g.Key, Job = g.First().Job, Execs = g.OrderBy(e => e.SortOrder).ToList() })
                        .Where(g => g.Job != null)
                        .ToList();

                    // Apply filters
                    if (_pathFilterPartId > 0)
                        jobGroups = jobGroups.Where(g => g.Job!.PartId == _pathFilterPartId).ToList();
                    if (!string.IsNullOrEmpty(_pathFilterPriority) && Enum.TryParse<JobPriority>(_pathFilterPriority, out var filterPri))
                        jobGroups = jobGroups.Where(g => g.Job!.Priority == filterPri).ToList();

                    // Apply sort
                    jobGroups = _pathSortMode switch
                    {
                        "priority" => jobGroups.OrderByDescending(g => g.Job!.Priority).ThenBy(g => g.Job!.ScheduledStart).ToList(),
                        "part" => jobGroups.OrderBy(g => g.Job!.PartNumber).ThenBy(g => g.Job!.ScheduledStart).ToList(),
                        _ => jobGroups.OrderBy(g => g.Execs.Min(e => e.ScheduledStartAt ?? DateTime.MaxValue)).ToList()
                    };
                }

                @if (!jobGroups.Any())
                {
                    <div class="empty-state"><div class="empty-state-icon">🔀</div><div class="empty-state-text">No scheduled jobs in this date range</div></div>
                }
                else
                {
                    <div class="gantt-container" style="@GetGanttContainerStyle()">
                        @* ── Header ── *@
                        @if (IsDayLevel)
                        {
                            <div class="gantt-header">
                                <div class="gantt-resource-label gantt-corner">Job / Part</div>
                                @foreach (var slot in _ganttSlots)
                                {
                                    var isToday = slot.Date == DateTime.UtcNow.Date;
                                    var isWeekend = slot.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                    <div class="gantt-day-header @(isWeekend ? "gantt-weekend" : "") @(isToday ? "gantt-today-header" : "")">
                                        <span class="gantt-day-name">@slot.ToString("ddd")</span>
                                        <span class="gantt-day-date">@slot.ToString("M/d")</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="gantt-header-group">
                                <div class="gantt-header gantt-header-dates">
                                    <div class="gantt-resource-label gantt-corner">Job / Part</div>
                                    @foreach (var dg in GetDateGroups())
                                    {
                                        var isToday = dg.Date == DateTime.UtcNow.Date;
                                        var isWeekend = dg.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                        <div class="gantt-date-group @(isWeekend ? "gantt-weekend" : "") @(isToday ? "gantt-today-header" : "")" style="grid-column: span @dg.Count;">
                                            <span class="gantt-day-name">@dg.Date.ToString("ddd")</span>
                                            <span class="gantt-day-date">@dg.Date.ToString("M/d")</span>
                                        </div>
                                    }
                                </div>
                                <div class="gantt-header gantt-header-times">
                                    <div class="gantt-resource-label"></div>
                                    @foreach (var slot in _ganttSlots)
                                    {
                                        <div class="gantt-slot-header">@FormatSlotTime(slot)</div>
                                    }
                                </div>
                            </div>
                        }

                        @* ── Job rows ── *@
                        @foreach (var group in jobGroups)
                        {
                            var job = group.Job!;
                            var isOverdue = job.IsOverdue;
                            var woId = job.WorkOrderLineId.HasValue ? job.WorkOrderLine?.WorkOrderId : (int?)null;
                            <div class="gantt-row @(isOverdue ? "gantt-row-overdue" : "")">
                                <div class="gantt-path-label">
                                    <span class="gantt-path-part">@(job.PartNumber ?? $"Part #{job.PartId}")</span>
                                    @if (woId.HasValue)
                                    {
                                        <a class="gantt-path-job" href="/workorders/@woId/jobs/@job.Id">@(job.JobNumber ?? $"J#{job.Id}")</a>
                                    }
                                    else
                                    {
                                        <span class="gantt-path-job" style="cursor:default;">@(job.JobNumber ?? $"J#{job.Id}")</span>
                                    }
                                    <span class="gantt-path-meta">
                                        <span class="badge badge-@job.Priority.ToString().ToLower()" style="font-size:0.6rem;padding:1px 6px;">@job.Priority</span>
                                        @(job.Quantity) qty
                                    </span>
                                </div>
                                <div class="gantt-track" style="grid-column: 2 / span @_ganttSlots.Count;">
                                    @* Today marker *@
                                    @{ var todayPct = GetGanttPosition(DateTime.UtcNow); }
                                    @if (todayPct > 0 && todayPct < 100)
                                    {
                                        <div class="gantt-today-line" style="left: @(todayPct)%;"></div>
                                    }
                                    @* Stage execution bars *@
                                    @foreach (var exec in group.Execs)
                                    {
                                        var start = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? _dateFrom;
                                        var end = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? start.AddHours(exec.EstimatedHours ?? 4);
                                        var leftPct = GetGanttPosition(start);
                                        var widthPct = GetGanttWidth(start, end);
                                        var stageColor = exec.ProductionStage?.StageColor ?? "#3B82F6";
                                        var statusClass = exec.Status switch
                                        {
                                            StageExecutionStatus.Completed => "gantt-bar-completed",
                                            StageExecutionStatus.InProgress => "gantt-bar-inprogress",
                                            StageExecutionStatus.Failed => "gantt-bar-failed",
                                            StageExecutionStatus.NotStarted => "gantt-bar-notstarted",
                                            _ => ""
                                        };
                                        var machineName = exec.Machine?.Name ?? "Unassigned";
                                        var stageName = exec.ProductionStage?.Name ?? "Stage";
                                        var tooltip = $"{stageName}\nMachine: {machineName}\n{start:MM/dd HH:mm} \u2192 {end:MM/dd HH:mm}\nEst: {exec.EstimatedHours?.ToString("F1") ?? "?"}h\nStatus: {exec.Status}";
                                        if (exec.OperatorName != null) tooltip += $"\nOperator: {exec.OperatorName}";
                                        <div class="gantt-bar gantt-bar-stage @statusClass"
                                             style="left: @(leftPct)%; width: @(widthPct)%; --bar-accent: @stageColor;"
                                             title="@tooltip"
                                             @onclick="() => ShowReschedule(exec)">
                                            <span class="gantt-bar-text">@stageName<span class="gantt-bar-machine">@machineName</span></span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @* Stage color legend *@
                    <div class="gantt-path-legend">
                        @foreach (var stage in _executions
                            .Where(e => e.ProductionStage != null)
                            .Select(e => e.ProductionStage!)
                            .DistinctBy(s => s.Id)
                            .OrderBy(s => s.DisplayOrder))
                        {
                            <span class="gantt-legend-item"><span class="gantt-path-legend-swatch" style="background:@stage.StageColor;"></span> @stage.Name</span>
                        }
                    </div>
                }
            </div>
        </div>

        @* ── Sidebar: Unscheduled Work ── *@
        @if (_unscheduled.Any())
        {
            <div class="sched-sidebar">
                <div class="card">
                    <div class="card-header sched-sidebar-header">
                        📋 Unscheduled (@_unscheduled.Count)
                    </div>
                    <div class="sched-sidebar-list">
                        @foreach (var exec in _unscheduled)
                        {
                            var priorityClass = exec.Job?.Priority.ToString().ToLower() ?? "normal";
                            <div class="sched-sidebar-item" @onclick="() => AutoScheduleSingle(exec.Id)">
                                <div class="sched-sidebar-priority sched-priority-@priorityClass"></div>
                                <div class="sched-sidebar-info">
                                    <span class="sched-sidebar-part">@(exec.Job?.Part?.PartNumber ?? $"Job {exec.JobId}")</span>
                                    <span class="sched-sidebar-stage">@(exec.ProductionStage?.Name ?? "—")</span>
                                    <span class="sched-sidebar-est">@(exec.EstimatedHours?.ToString("F1") ?? "?")h est</span>
                                </div>
                                <span class="sched-sidebar-action" title="Auto-schedule this task">⚡</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (_viewMode == "stages")
{
    @* ── Stage Queue View ── *@
    <div class="stage-queue-grid">
        @foreach (var stage in _stages.OrderBy(s => s.DisplayOrder))
        {
            var stageId = stage.Id;
            var allForStage = _executions.Concat(_unscheduled)
                .Where(e => e.ProductionStageId == stageId)
                .ToList();
            var waiting = allForStage.Where(e => e.Status == StageExecutionStatus.NotStarted).ToList();
            var active = allForStage.Where(e => e.Status == StageExecutionStatus.InProgress).ToList();
            var completed = allForStage.Where(e => e.Status == StageExecutionStatus.Completed).ToList();
            var failed = allForStage.Where(e => e.Status == StageExecutionStatus.Failed).ToList();
            var queuedHours = waiting.Sum(e => e.EstimatedHours ?? 0) + active.Sum(e => e.EstimatedHours ?? 0);
            var hasWork = allForStage.Any();
            var isExpanded = _expandedStages.Contains(stageId);
            var barPercent = Math.Min(100, queuedHours / 40.0 * 100);
            var barColor = queuedHours > 40 ? "var(--danger)" : (queuedHours > 24 ? "var(--warning)" : (stage.StageColor ?? "var(--accent)"));

            <div class="stage-queue-card @(!hasWork ? "stage-queue-card--empty" : "")">
                <div class="stage-queue-header" @onclick="() => ToggleStageExpand(stageId)">
                    <div class="stage-queue-title">
                        <span class="stage-queue-swatch" style="background:@(stage.StageColor ?? "var(--accent)")"></span>
                        <span class="stage-queue-icon">@ResolveStageIcon(stage.StageIcon)</span>
                        <span class="stage-queue-name">@stage.Name</span>
                        @if (!string.IsNullOrEmpty(stage.Department))
                        {
                            <span class="badge badge-secondary stage-queue-dept">@stage.Department</span>
                        }
                    </div>
                    <span class="stage-queue-chevron @(isExpanded ? "stage-queue-chevron--open" : "")">▸</span>
                </div>

                <div class="stage-queue-metrics">
                    <div class="stage-metric stage-metric--waiting">
                        <span class="stage-metric-count">@waiting.Count</span>
                        <span class="stage-metric-label">Queued</span>
                    </div>
                    <div class="stage-metric stage-metric--active">
                        <span class="stage-metric-count">@active.Count</span>
                        <span class="stage-metric-label">Active</span>
                    </div>
                    <div class="stage-metric stage-metric--done">
                        <span class="stage-metric-count">@completed.Count</span>
                        <span class="stage-metric-label">Done</span>
                    </div>
                    @if (failed.Any())
                    {
                        <div class="stage-metric stage-metric--failed">
                            <span class="stage-metric-count">@failed.Count</span>
                            <span class="stage-metric-label">Failed</span>
                        </div>
                    }
                    <div class="stage-metric stage-metric--hours">
                        <span class="stage-metric-count">@queuedHours.ToString("F1")</span>
                        <span class="stage-metric-label">Hrs Queued</span>
                    </div>
                </div>

                @if (queuedHours > 0)
                {
                    <div class="stage-queue-workload">
                        <div class="stage-queue-workload-fill" style="width:@barPercent.ToString("F0")%;background:@barColor"></div>
                    </div>
                }

                @if (isExpanded && (waiting.Any() || active.Any()))
                {
                    <div class="stage-queue-items">
                        @foreach (var exec in active.Concat(waiting).OrderByDescending(e => e.Job?.Priority).ThenBy(e => e.ScheduledStartAt))
                        {
                            <div class="stage-queue-item @(exec.Status == StageExecutionStatus.InProgress ? "stage-queue-item--active" : "")">
                                <span class="stage-queue-item-dot @(exec.Status == StageExecutionStatus.InProgress ? "stage-queue-item-dot--active" : "")"></span>
                                <span class="stage-queue-item-part">
                                    @if (exec.BuildPackageId != null && exec.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        <text>📦 @(exec.BuildPackage?.Name ?? $"Build #{exec.BuildPackageId}")</text>
                                    }
                                    else
                                    {
                                        @(exec.Job?.Part?.PartNumber ?? "—")
                                    }
                                </span>
                                <span class="badge badge-@(exec.Job?.Priority.ToString().ToLower() ?? "normal")">@(exec.Job?.Priority ?? JobPriority.Normal)</span>
                                <span class="stage-queue-item-hours">@(exec.EstimatedHours?.ToString("F1") ?? "—")h</span>
                                @if (exec.Machine != null)
                                {
                                    <span class="stage-queue-item-machine">🖥️ @exec.Machine.Name</span>
                                }
                                @if (exec.ScheduledStartAt != null)
                                {
                                    <span class="stage-queue-item-time">@exec.ScheduledStartAt.Value.ToString("MM/dd HH:mm")</span>
                                }
                                @if (exec.Status == StageExecutionStatus.NotStarted)
                                {
                                    <button class="btn btn-sm btn-secondary stage-queue-item-action" @onclick="() => ShowReschedule(exec)" title="Reschedule">📅</button>
                                }
                            </div>
                        }
                    </div>
                }
                else if (isExpanded && !waiting.Any() && !active.Any())
                {
                    <div class="stage-queue-items">
                        <div class="stage-queue-empty">No items queued</div>
                    </div>
                }
            </div>
        }
    </div>
}
else if (_viewMode == "table")
{
    @* ── Table View ── *@
    <div class="card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
            <span>📋 Stage Executions — @_executions.Count scheduled · @(_executions.Sum(e => e.EstimatedHours ?? 0).ToString("F0"))h total</span>
            @if (_unscheduled.Any())
            {
                <span class="badge badge-warning">⚠️ @_unscheduled.Count unscheduled</span>
            }
        </div>
        @if (!_executions.Any() && !_unscheduled.Any())
        {
            <div class="empty-state"><div class="empty-state-icon">📅</div><div class="empty-state-text">No stage executions found</div></div>
        }
        else
        {
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Priority</th>
                            <th>Part</th>
                            <th>Stage</th>
                            <th>Machine</th>
                            <th>Operator</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Est. Hrs</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exec in _executions.Concat(_unscheduled))
                        {
                            var isMissing = exec.MachineId == null || exec.ScheduledStartAt == null;
                            <tr class="@(isMissing ? "sched-row-warn" : "")">
                                <td>
                                    <span class="badge badge-@(exec.Job?.Priority.ToString().ToLower() ?? "normal")">@(exec.Job?.Priority ?? JobPriority.Normal)</span>
                                </td>
                                <td style="font-weight: 600;">
                                    @if (exec.BuildPackageId != null && exec.ProductionStage?.IsBuildLevelStage == true)
                                    {
                                        <span>📦 @(exec.BuildPackage?.Name ?? $"Build #{exec.BuildPackageId}")</span>
                                    }
                                    else
                                    {
                                        @(exec.Job?.Part?.PartNumber ?? "—")
                                    }
                                </td>
                                <td>
                                    @if (exec.ProductionStage != null)
                                    {
                                        <span style="display:inline-flex;align-items:center;gap:4px;">
                                            <span style="width:8px;height:8px;border-radius:50%;background:@(exec.ProductionStage.StageColor);display:inline-block;"></span>
                                            @ResolveStageIcon(exec.ProductionStage.StageIcon) @exec.ProductionStage.Name
                                        </span>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td>
                                    @if (exec.Machine != null)
                                    {
                                        @exec.Machine.Name
                                    }
                                    else
                                    {
                                        <span style="color:var(--warning)">Unassigned</span>
                                    }
                                </td>
                                <td>@(exec.OperatorName ?? "—")</td>
                                <td>@((exec.ScheduledStartAt ?? exec.Job?.ScheduledStart)?.ToString("MM/dd HH:mm") ?? "—")</td>
                                <td>@((exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd)?.ToString("MM/dd HH:mm") ?? "—")</td>
                                <td>@(exec.EstimatedHours?.ToString("F1") ?? "—")</td>
                                <td><span class="badge badge-@exec.Status.ToString().ToLower()">@exec.Status</span></td>
                                <td class="sched-table-actions">
                                    @if (exec.Status == StageExecutionStatus.NotStarted)
                                    {
                                        <button class="btn btn-sm btn-secondary" @onclick="() => ShowReschedule(exec)" title="Reschedule">📅</button>
                                        @if (exec.MachineId == null)
                                        {
                                            <button class="btn btn-sm btn-warning" @onclick="() => AutoScheduleSingle(exec.Id)" title="Auto-schedule">⚡</button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
</div>
</div>

@* ── Reschedule Modal ── *@
@if (_showReschedule && _rescheduleExec != null)
{
    <div class="modal-overlay" @onclick="() => _showReschedule = false">
        <div class="modal-content" @onclick:stopPropagation style="max-width: 500px;">
            <div class="modal-header">
                <span class="modal-title">📅 Reschedule Execution</span>
                <button class="modal-close" @onclick="() => _showReschedule = false">&times;</button>
            </div>
            <div style="padding: 4px 0 12px; color: var(--text-muted); font-size: 0.85rem;">
                @(_rescheduleExec.Job?.Part?.PartNumber ?? "—") · @(_rescheduleExec.ProductionStage?.Name ?? "Stage")
                · Est: @(_rescheduleExec.EstimatedHours?.ToString("F1") ?? "?")h
            </div>
            <div class="form-group">
                <label class="form-label">Machine</label>
                <select class="form-control" @bind="_rescheduleMachineId">
                    <option value="">Unassigned</option>
                    @foreach (var m in _machines.Where(m => m.IsAvailableForScheduling))
                    {
                        <option value="@m.Id">@m.Name (@m.MachineType)</option>
                    }
                </select>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group"><label class="form-label">Start</label><input class="form-control" type="datetime-local" @bind="_rescheduleStart" /></div>
                <div class="form-group"><label class="form-label">End</label><input class="form-control" type="datetime-local" @bind="_rescheduleEnd" /></div>
            </div>
            <div style="display: flex; gap: 8px; margin-top: 8px;">
                <button class="btn btn-primary" @onclick="ConfirmReschedule">💾 Save</button>
                <button class="btn btn-warning" @onclick="AutoScheduleFromModal">⚡ Auto-Schedule</button>
            </div>
        </div>
    </div>
}

@* ── Create Job Modal ── *@
@if (_showCreate)
{
    <div class="modal-overlay" @onclick="() => _showCreate = false">
        <div class="modal-content" @onclick:stopPropagation style="max-width: 520px;">
            <div class="modal-header">
                <span class="modal-title">New Job</span>
                <button class="modal-close" @onclick="() => _showCreate = false">&times;</button>
            </div>
            @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger">@_error</div> }
            <div class="form-group">
                <label class="form-label">Part <span style="color:var(--danger);">*</span></label>
                <select class="form-control" @bind="_newJob.PartId" @bind:after="OnPartSelected">
                    <option value="0">Select part...</option>
                    @if (_parts != null) { @foreach (var p in _parts) { <option value="@p.Id">@p.PartNumber — @p.Name</option> } }
                </select>
            </div>
            @if (_selectedPartRouting.Any())
            {
                <div style="background: var(--bg-tertiary); border-radius: 6px; padding: 10px; margin-bottom: 12px; font-size: 0.82rem;">
                    <div style="font-weight: 600; margin-bottom: 4px; color: var(--text-secondary);">📋 Routing Preview</div>
                    @foreach (var r in _selectedPartRouting)
                    {
                        <div style="display: flex; gap: 8px; padding: 2px 0; align-items: center;">
                            <span style="width:8px;height:8px;border-radius:50%;background:@(r.ProductionStage?.StageColor ?? "var(--accent)");display:inline-block;flex-shrink:0;"></span>
                            <span style="flex:1;">@(r.ProductionStage?.Name ?? "Stage")</span>
                            <span style="color:var(--text-muted);">@((r.EstimatedHours ?? r.ProductionStage?.DefaultDurationHours ?? 1).ToString("F1"))h</span>
                            <span style="color:var(--text-muted);">@(r.AssignedMachineId ?? r.ProductionStage?.DefaultMachineId ?? "Auto")</span>
                        </div>
                    }
                    <div style="margin-top: 6px; color: var(--text-muted); border-top: 1px solid var(--border); padding-top: 6px;">
                        Total est: @_selectedPartRouting.Sum(r => r.EstimatedHours ?? r.ProductionStage?.DefaultDurationHours ?? 1).ToString("F1")h
                        · Machines will be auto-assigned for optimal scheduling
                    </div>
                </div>
            }
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-group">
                    <label class="form-label">Quantity <span style="color:var(--danger);">*</span></label>
                    <input class="form-control" type="number" @bind="_newJob.Quantity" min="1" />
                </div>
                <div class="form-group">
                    <label class="form-label">Priority</label>
                    <select class="form-control" @bind="_newJob.Priority">
                        @foreach (var p in Enum.GetValues<JobPriority>()) { <option value="@p">@p</option> }
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Earliest Start</label>
                <input class="form-control" type="datetime-local" @bind="_newJob.ScheduledStart" />
            </div>
            <div class="form-group">
                <label class="form-label">Notes</label>
                <textarea class="form-control" @bind="_newJob.Notes" rows="2" placeholder="Optional notes..."></textarea>
            </div>
            <button class="btn btn-primary" @onclick="CreateJob" disabled="@(_creatingJob)">
                @if (_creatingJob) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                Create & Auto-Schedule
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _scheduling;
    private bool _creatingJob;
    private List<StageExecution> _executions = new();
    private List<StageExecution> _unscheduled = new();
    private List<Machine> _machines = new();
    private List<Part>? _parts;
    private List<DateTime> _ganttSlots = new();
    private List<ProductionStage> _stages = new();
    private HashSet<int> _expandedStages = new();
    private DateTime _dateFrom = DateTime.UtcNow.Date;
    private DateTime _dateTo = DateTime.UtcNow.Date.AddDays(14);
    private string _viewMode = "gantt";
    private string _zoomLevel = "2W";
    private string _userName = "System";

    // Zoom interop
    private ElementReference _schedulerRef;
    private DotNetObjectReference<Index>? _dotNetRef;
    private static readonly string[] ZoomLevels = { "30M", "1H", "2H", "6H", "12H", "1D", "3D", "1W", "2W", "1M" };

    // Part Path filters
    private int _pathFilterPartId;
    private string? _pathFilterPriority;
    private string _pathSortMode = "schedule";

    // Create job
    private bool _showCreate;
    private Job _newJob = new() { ScheduledStart = DateTime.UtcNow, EstimatedHours = 8, Quantity = 1, Priority = JobPriority.Normal };
    private List<PartStageRequirement> _selectedPartRouting = new();
    private string? _error;

    // Reschedule
    private bool _showReschedule;
    private StageExecution? _rescheduleExec;
    private string _rescheduleMachineId = "";
    private DateTime _rescheduleStart;
    private DateTime _rescheduleEnd;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _userName = state.User?.Identity?.Name ?? "System";
        }
        _parts = await PartService.GetAllPartsAsync();
        _machines = await MachineService.GetAllMachinesAsync(activeOnly: true);
        _stages = await StageService.GetAllStagesAsync(activeOnly: true);
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("opcentrix.initSchedulerZoom", _dotNetRef, _schedulerRef);
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        _executions = await StageService.GetScheduledExecutionsAsync(_dateFrom, _dateTo);
        _unscheduled = await StageService.GetUnscheduledExecutionsAsync();
        BuildGanttSlots();
        _loading = false;
    }

    // ── Zoom Configuration ──

    private bool IsDayLevel => _zoomLevel is "1W" or "2W" or "1M";

    private (TimeSpan Range, TimeSpan Slot) GetZoomConfig() => _zoomLevel switch
    {
        "30M" => (TimeSpan.FromMinutes(30), TimeSpan.FromMinutes(1)),
        "1H"  => (TimeSpan.FromHours(1), TimeSpan.FromMinutes(5)),
        "2H"  => (TimeSpan.FromHours(2), TimeSpan.FromMinutes(5)),
        "6H"  => (TimeSpan.FromHours(6), TimeSpan.FromMinutes(15)),
        "12H" => (TimeSpan.FromHours(12), TimeSpan.FromMinutes(30)),
        "1D"  => (TimeSpan.FromDays(1), TimeSpan.FromHours(1)),
        "3D"  => (TimeSpan.FromDays(3), TimeSpan.FromHours(4)),
        "1W"  => (TimeSpan.FromDays(7), TimeSpan.FromDays(1)),
        "2W"  => (TimeSpan.FromDays(14), TimeSpan.FromDays(1)),
        "1M"  => (TimeSpan.FromDays(30), TimeSpan.FromDays(1)),
        _     => (TimeSpan.FromDays(14), TimeSpan.FromDays(1))
    };

    private void SetZoom(string level)
    {
        _zoomLevel = level;
        var (range, slot) = GetZoomConfig();
        if (IsDayLevel)
        {
            _dateFrom = _dateFrom.Date;
        }
        else
        {
            var now = DateTime.UtcNow;
            _dateFrom = now - TimeSpan.FromTicks(range.Ticks / 2);
            if (slot.Ticks > 0)
            {
                var dayStart = _dateFrom.Date.Ticks;
                var offset = _dateFrom.Ticks - dayStart;
                _dateFrom = new DateTime(dayStart + (offset / slot.Ticks) * slot.Ticks, _dateFrom.Kind);
            }
        }
        _dateTo = _dateFrom.Add(range);
        _ = LoadData();
    }

    private void ShiftBack()
    {
        var (range, _) = GetZoomConfig();
        var shift = TimeSpan.FromTicks(range.Ticks / 2);
        _dateFrom -= shift;
        if (IsDayLevel) _dateFrom = _dateFrom.Date;
        _dateTo = _dateFrom.Add(range);
        _ = LoadData();
    }

    private void ShiftForward()
    {
        var (range, _) = GetZoomConfig();
        var shift = TimeSpan.FromTicks(range.Ticks / 2);
        _dateFrom += shift;
        if (IsDayLevel) _dateFrom = _dateFrom.Date;
        _dateTo = _dateFrom.Add(range);
        _ = LoadData();
    }

    private void GoToNow()
    {
        var (range, _) = GetZoomConfig();
        if (IsDayLevel)
        {
            _dateFrom = DateTime.UtcNow.Date;
        }
        else
        {
            _dateFrom = DateTime.UtcNow - TimeSpan.FromTicks(range.Ticks / 2);
        }
        _dateTo = _dateFrom.Add(range);
        _ = LoadData();
    }

    private string ZoomBtnClass(string level) => _zoomLevel == level ? "btn-primary" : "btn-secondary";

    private void BuildGanttSlots()
    {
        var (_, slotSize) = GetZoomConfig();
        _ganttSlots = new List<DateTime>();
        for (var t = _dateFrom; t < _dateTo; t = t.Add(slotSize))
        {
            _ganttSlots.Add(t);
            if (_ganttSlots.Count >= 200) break;
        }
    }

    private string FormatSlotTime(DateTime slot)
    {
        var (_, slotSize) = GetZoomConfig();
        if (slotSize >= TimeSpan.FromHours(1))
            return slot.ToString("h tt").ToLower().Replace(" ", "");
        if (slot.Minute == 0)
            return slot.ToString("h tt").ToLower().Replace(" ", "");
        return ":" + slot.ToString("mm");
    }

    private List<(DateTime Date, int Count)> GetDateGroups()
    {
        var groups = new List<(DateTime Date, int Count)>();
        if (!_ganttSlots.Any()) return groups;
        var currentDate = _ganttSlots[0].Date;
        var count = 0;
        foreach (var slot in _ganttSlots)
        {
            if (slot.Date != currentDate)
            {
                groups.Add((currentDate, count));
                currentDate = slot.Date;
                count = 0;
            }
            count++;
        }
        groups.Add((currentDate, count));
        return groups;
    }

    private int GetColumnMinWidth() => _zoomLevel switch
    {
        "30M" => 32,
        "1H"  => 48,
        "2H"  => 36,
        "6H"  => 40,
        "12H" => 44,
        "1D"  => 80,
        "3D"  => 60,
        "1W"  => 120,
        "2W"  => 100,
        "1M"  => 56,
        _     => 80
    };

    private string GetGanttContainerStyle()
    {
        var colMin = GetColumnMinWidth();
        var style = $"--gantt-cols: {_ganttSlots.Count};";
        if (colMin > 0)
            style += $" --gantt-col-min: {colMin}px; min-width: calc(var(--gantt-label-w) + {_ganttSlots.Count * colMin}px);";
        return style;
    }

    private double GetGanttPosition(DateTime dt)
    {
        var totalSpan = (_dateTo - _dateFrom).TotalHours;
        if (totalSpan <= 0) return 0;
        var offset = (dt - _dateFrom).TotalHours;
        return Math.Clamp(offset / totalSpan * 100, 0, 100);
    }

    private double GetGanttWidth(DateTime start, DateTime end)
    {
        var totalSpan = (_dateTo - _dateFrom).TotalHours;
        if (totalSpan <= 0) return 1;
        var width = (end - start).TotalHours / totalSpan * 100;
        var minWidth = IsDayLevel ? 0.3 : 1.5;
        return Math.Clamp(width, minWidth, 100);
    }

    // ── JS Interop Zoom (mouse wheel + touch pinch) ──

    [JSInvokable]
    public async Task JsZoomIn(double cursorPct)
    {
        if (StepZoom(-1, cursorPct))
        {
            await LoadData();
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task JsZoomOut(double cursorPct)
    {
        if (StepZoom(1, cursorPct))
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private bool StepZoom(int direction, double cursorPct)
    {
        var currentIdx = Array.IndexOf(ZoomLevels, _zoomLevel);
        var newIdx = currentIdx + direction;
        if (newIdx < 0 || newIdx >= ZoomLevels.Length) return false;

        // Time at cursor position (anchor point)
        var totalSpan = _dateTo - _dateFrom;
        var cursorTime = _dateFrom + TimeSpan.FromTicks((long)(totalSpan.Ticks * Math.Clamp(cursorPct, 0, 1)));

        // Change zoom level
        _zoomLevel = ZoomLevels[newIdx];
        var (newRange, slot) = GetZoomConfig();

        // Reposition so cursor stays over the same time
        _dateFrom = cursorTime - TimeSpan.FromTicks((long)(newRange.Ticks * cursorPct));
        if (IsDayLevel)
        {
            _dateFrom = _dateFrom.Date;
        }
        else if (slot.Ticks > 0)
        {
            var dayStart = _dateFrom.Date.Ticks;
            var offset = _dateFrom.Ticks - dayStart;
            _dateFrom = new DateTime(dayStart + (offset / slot.Ticks) * slot.Ticks, _dateFrom.Kind);
        }
        _dateTo = _dateFrom.Add(newRange);
        return true;
    }

    private bool HasOverlap(int machineId, StageExecution current, List<StageExecution> machineExecs)
    {
        var cStart = current.ScheduledStartAt;
        var cEnd = current.ScheduledEndAt;
        if (cStart == null || cEnd == null) return false;

        return machineExecs.Any(e =>
            e.Id != current.Id &&
            e.ScheduledStartAt < cEnd &&
            e.ScheduledEndAt > cStart);
    }

    // ── Stage Queue ──

    private void ToggleStageExpand(int stageId)
    {
        if (!_expandedStages.Remove(stageId))
            _expandedStages.Add(stageId);
    }

    private static string ResolveStageIcon(string? icon)
    {
        if (string.IsNullOrEmpty(icon)) return "⚙️";
        if (!icon.StartsWith("fas ") && !icon.StartsWith("far ") && !icon.StartsWith("fa-")) return icon;
        return icon switch
        {
            "fas fa-print"           => "🖨️",
            "fas fa-wind"            => "💨",
            "fas fa-fire"            => "🔥",
            "fas fa-bolt"            => "⚡",
            "fas fa-cog"             => "⚙️",
            "fas fa-pen-nib"         => "✒️",
            "fas fa-spray-can"       => "🎨",
            "fas fa-clipboard-check" => "✅",
            "fas fa-truck"           => "🚚",
            _                        => "⚙️"
        };
    }

    // ── Reschedule ──

    private void ShowReschedule(StageExecution exec)
    {
        _rescheduleExec = exec;
        _rescheduleMachineId = exec.MachineId?.ToString() ?? "";
        _rescheduleStart = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? DateTime.UtcNow;
        _rescheduleEnd = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? DateTime.UtcNow.AddHours(4);
        _showReschedule = true;
    }

    private async Task ConfirmReschedule()
    {
        if (_rescheduleExec == null) return;
        try
        {
            int? machineId = int.TryParse(_rescheduleMachineId, out var mid) ? mid : null;
            await StageService.UpdateScheduleAsync(_rescheduleExec.Id, _rescheduleStart, _rescheduleEnd, machineId);
            Toast.ShowSuccess("Schedule updated");
            _showReschedule = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task AutoScheduleFromModal()
    {
        if (_rescheduleExec == null) return;
        try
        {
            await Scheduler.AutoScheduleExecutionAsync(_rescheduleExec.Id);
            Toast.ShowSuccess("Auto-scheduled successfully");
            _showReschedule = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // ── Auto-schedule ──

    private async Task AutoScheduleSingle(int executionId)
    {
        try
        {
            await Scheduler.AutoScheduleExecutionAsync(executionId);
            Toast.ShowSuccess("Task auto-scheduled");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task AutoScheduleAll()
    {
        _scheduling = true;
        StateHasChanged();
        try
        {
            var count = await Scheduler.AutoScheduleAllAsync();
            Toast.ShowSuccess($"Auto-scheduled {count} job(s)");
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _scheduling = false; }
    }

    // ── Create Job ──

    private async Task OnPartSelected()
    {
        _selectedPartRouting = new();
        if (_newJob.PartId > 0)
        {
            var part = _parts?.FirstOrDefault(p => p.Id == _newJob.PartId);
            if (part != null)
            {
                _selectedPartRouting = await PartService.GetStageRequirementsAsync(part.Id);
                _newJob.EstimatedHours = _selectedPartRouting.Sum(r => r.EstimatedHours ?? r.ProductionStage?.DefaultDurationHours ?? 1);
            }
        }
    }

    private async Task CreateJob()
    {
        _error = null;
        if (_newJob.PartId <= 0) { _error = "Please select a part."; return; }

        _creatingJob = true;
        StateHasChanged();
        try
        {
            _newJob.ScheduledEnd = _newJob.ScheduledStart.AddHours(_newJob.EstimatedHours);
            _newJob.CreatedBy = _userName;
            _newJob.LastModifiedBy = _userName;
            await JobService.CreateJobAsync(_newJob);
            Toast.ShowSuccess("Job created and auto-scheduled");
            _showCreate = false;
            _newJob = new() { ScheduledStart = DateTime.UtcNow, EstimatedHours = 8, Quantity = 1, Priority = JobPriority.Normal };
            _selectedPartRouting = new();
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _creatingJob = false; }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
