    private async Task ShiftViewportAsync(int direction)
    {
        if (_ganttViewportModule == null) return;
        // Shift by half viewport width worth of time
        var viewportHours = (_viewportEnd - _viewportStart).TotalHours;
        var shiftHours = viewportHours * 0.5 * direction;
        var targetTime = _viewportStart.AddHours(viewportHours / 2 + shiftHours);
        await _ganttViewportModule.InvokeVoidAsync("scrollToTime", targetTime.ToString("o"));
    }

