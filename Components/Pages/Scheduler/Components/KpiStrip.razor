@* ── KPI Strip: at-a-glance production metrics ── *@

<div class="sched-kpi-strip">
    <div class="sched-kpi" title="Stage executions currently in progress">
        <span class="sched-kpi-value">@_inProgress</span>
        <span class="sched-kpi-label">In Progress</span>
    </div>
    <div class="sched-kpi @(_dueToday > 0 ? "sched-kpi--warning" : "")" title="Work orders due today">
        <span class="sched-kpi-value">@_dueToday</span>
        <span class="sched-kpi-label">Due Today</span>
    </div>
    <div class="sched-kpi @(_overdue > 0 ? "sched-kpi--danger" : "")" title="Work orders past due date with outstanding parts">
        <span class="sched-kpi-value">@_overdue</span>
        <span class="sched-kpi-label">Overdue</span>
    </div>
    <div class="sched-kpi" title="Percentage of machines currently occupied">
        <span class="sched-kpi-value">@_utilization.ToString("F0")%</span>
        <span class="sched-kpi-label">Utilization</span>
    </div>
    <div class="sched-kpi @(Unscheduled.Count > 0 ? "sched-kpi--warning" : "")" title="Scheduled executions with no machine assigned">
        <span class="sched-kpi-value">@Unscheduled.Count</span>
        <span class="sched-kpi-label">Unassigned</span>
    </div>
    @if (_conflicts > 0)
    {
        <div class="sched-kpi sched-kpi--danger" title="Overlapping executions on the same machine">
            <span class="sched-kpi-value">@_conflicts</span>
            <span class="sched-kpi-label">Conflicts</span>
        </div>
    }
    <div class="sched-kpi sched-kpi--muted" title="Total scheduled hours in date range">
        <span class="sched-kpi-value">@_totalHours.ToString("F0")h</span>
        <span class="sched-kpi-label">Scheduled</span>
    </div>
    @if (BottleneckReport != null && BottleneckReport.Items.Any(b => b.Severity != "ok"))
    {
        var worstSeverity = BottleneckReport.Items.Any(b => b.Severity == "critical") ? "danger" : "warning";
        var count = BottleneckReport.Items.Count(b => b.Severity != "ok");
        <div class="sched-kpi sched-kpi--@worstSeverity" title="@string.Join(" | ", BottleneckReport.Recommendations)">
            <span class="sched-kpi-value">@count</span>
            <span class="sched-kpi-label">Bottleneck@(count != 1 ? "s" : "")</span>
        </div>
    }
</div>

@code {
    [Parameter] public List<StageExecution> Executions { get; set; } = [];
    [Parameter] public List<StageExecution> Unscheduled { get; set; } = [];
    [Parameter] public List<Machine> Machines { get; set; } = [];
    [Parameter] public List<WorkOrder> WorkOrders { get; set; } = [];
    [Parameter] public BottleneckReport? BottleneckReport { get; set; }

    // Cached KPI values — only recalculated when parameters change
    private int _inProgress;
    private int _dueToday;
    private int _overdue;
    private double _utilization;
    private int _conflicts;
    private double _totalHours;

    protected override void OnParametersSet()
    {
        var today = DateTime.UtcNow.Date;

        _inProgress = Executions.Count(e => e.Status == StageExecutionStatus.InProgress);
        _totalHours = Executions.Sum(e => e.EstimatedHours ?? 0);
        _dueToday = WorkOrders.Count(w => w.DueDate.Date == today);
        _overdue = WorkOrders.Count(w => w.DueDate.Date < today
            && w.Lines.Any(l => l.Quantity > l.ProducedQuantity));

        // Utilization
        var schedulable = Machines.Count(m => m.IsAvailableForScheduling);
        if (schedulable > 0)
        {
            var occupied = Machines.Count(m => m.IsAvailableForScheduling
                && Executions.Any(e => e.MachineId == m.Id && e.Status == StageExecutionStatus.InProgress));
            _utilization = occupied * 100.0 / schedulable;
        }
        else
        {
            _utilization = 0;
        }

        // Conflict detection — all-pairs overlap check, cached
        var conflictingIds = new HashSet<int>();
        var byMachine = Executions
            .Where(e => e.MachineId.HasValue && e.ScheduledStartAt.HasValue && e.ScheduledEndAt.HasValue)
            .GroupBy(e => e.MachineId!.Value);
        foreach (var group in byMachine)
        {
            var items = group.ToList();
            for (int i = 0; i < items.Count; i++)
            {
                for (int j = i + 1; j < items.Count; j++)
                {
                    if (items[i].ScheduledStartAt < items[j].ScheduledEndAt &&
                        items[j].ScheduledStartAt < items[i].ScheduledEndAt)
                    {
                        conflictingIds.Add(items[i].Id);
                        conflictingIds.Add(items[j].Id);
                    }
                }
            }
        }
        _conflicts = conflictingIds.Count;
    }
}
