@using System.Globalization

@{
    var barClass = IsUnassigned ? "unassigned" : (Exec.Job?.Priority.ToString().ToLower() ?? "normal");
    var stageColor = Exec.ProductionStage?.StageColor ?? "";
    var isBatchScope = Exec.Job?.Scope == JobScope.Batch || Exec.ProductionBatchId != null;
    var batchBorder = isBatchScope ? "border-bottom: 3px solid var(--warning);" : "";
    var jobHue = GetJobHue();
    var jobColorStyle = jobHue >= 0 && !IsUnassigned
        ? $"--job-hue: {jobHue}; border-left: 4px solid hsl({jobHue}, 70%, 55%);"
        : "";
    var scopeIcon = Exec.Job?.Scope switch
    {
        JobScope.Build => "🏗️ ",
        JobScope.Batch => "📦 ",
        _ => ""
    };
}
<div class="gantt-bar gantt-bar-@barClass @(IsConflict ? "gantt-bar-conflict" : "") @(IsSelected ? "gantt-bar-selected" : "") gantt-bar-has-tooltip"
     style="left: @(FormatPx(BarLeftPx))px; width: @(FormatPx(BarWidthPx))px; @batchBorder @jobColorStyle @(string.IsNullOrEmpty(stageColor) || IsUnassigned ? "" : $"--bar-accent: {stageColor};")"
     data-exec-id="@Exec.Id"
     data-bar-type="exec"
     data-job-id="@Exec.JobId"
     @onclick="HandleClick"
     @onclick:stopPropagation="true">
    @if (IsSelected) { <span class="gantt-bar-check">✓</span> }
    <span class="gantt-bar-text">@scopeIcon@(Exec.Job?.Part?.PartNumber ?? $"J{Exec.JobId}") · @(Exec.ProductionStage?.Name ?? "")</span>
    <div class="gantt-bar-tooltip">
        @{
            var ttPart = Exec.Job?.Part?.PartNumber ?? $"Job {Exec.JobId}";
            var ttStage = Exec.ProductionStage?.Name ?? "Stage";
            var ttWo = Exec.Job?.WorkOrderLine?.WorkOrder;
            var ttScope = Exec.Job?.Scope switch { JobScope.Build => "Build", JobScope.Batch => "Batch", JobScope.Part => "Part", _ => "" };
        }
        <div class="gantt-bar-tooltip-title">
            @if (IsUnassigned) { <span class="gantt-bar-tooltip-badge gantt-bar-tooltip-badge--warn">UNASSIGNED</span> }
            @ttPart — @ttStage
        </div>
        <div class="gantt-bar-tooltip-row">
            <span class="gantt-bar-tooltip-label">Time</span>
            <span>@Start.ToLocalTime().ToString("ddd MMM d, h:mm tt") → @End.ToLocalTime().ToString("h:mm tt")</span>
        </div>
        <div class="gantt-bar-tooltip-row">
            <span class="gantt-bar-tooltip-label">Est.</span>
            <span>@(Exec.EstimatedHours?.ToString("F1") ?? "?")h</span>
            <span class="gantt-bar-tooltip-label" style="margin-left: 8px;">Priority</span>
            <span class="gantt-bar-tooltip-badge gantt-bar-tooltip-badge--@(Exec.Job?.Priority.ToString().ToLower() ?? "normal")">@Exec.Job?.Priority</span>
        </div>
        @if (!string.IsNullOrEmpty(ttScope))
        {
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Scope</span>
                <span>@ttScope</span>
                <span class="gantt-bar-tooltip-label" style="margin-left: 8px;">Qty</span>
                <span>@Exec.Job?.Quantity</span>
            </div>
        }
        @if (Exec.Machine != null)
        {
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Machine</span>
                <span>@Exec.Machine.Name</span>
            </div>
        }
        @if (ttWo != null)
        {
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">WO</span>
                <span>@ttWo.OrderNumber — @ttWo.CustomerName</span>
            </div>
        }
        @if (Exec.MachineProgram != null)
        {
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Program</span>
                <span>@Exec.MachineProgram.Name</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public StageExecution Exec { get; set; } = default!;
    [Parameter, EditorRequired] public double BarLeftPx { get; set; }
    [Parameter, EditorRequired] public double BarWidthPx { get; set; }
    [Parameter, EditorRequired] public DateTime Start { get; set; }
    [Parameter, EditorRequired] public DateTime End { get; set; }
    [Parameter] public bool IsConflict { get; set; }
    [Parameter] public bool IsUnassigned { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<StageExecution> OnClick { get; set; }

    private static string FormatPx(double value) => value.ToString("F1", CultureInfo.InvariantCulture);

    private Task HandleClick() => OnClick.InvokeAsync(Exec);

    /// <summary>
    /// Generates a consistent hue (0-359) for a job based on its PartId.
    /// All stages of the same part get the same hue, making it easy to
    /// visually track a part's journey across machines on the Gantt.
    /// </summary>
    private int GetJobHue()
    {
        var key = Exec.Job?.PartId ?? Exec.JobId ?? -1;
        if (key <= 0) return -1;
        // Golden-angle distribution gives visually distinct hues for sequential IDs
        return (int)((key * 137.508) % 360);
    }

    private string ComputeTooltip()
    {
        var part = Exec.Job?.Part?.PartNumber ?? "?";
        var stage = Exec.ProductionStage?.Name ?? "";
        var scope = Exec.Job?.Scope switch
        {
            JobScope.Build => "Build",
            JobScope.Batch => "Batch",
            JobScope.Part => "Part",
            _ => ""
        };

        if (IsUnassigned)
            return $"UNASSIGNED — {part} · {stage}";

        var lines = new List<string>
        {
            $"{part} — {(string.IsNullOrEmpty(stage) ? "Stage" : stage)}",
            $"{Start:MM/dd HH:mm} → {End:MM/dd HH:mm}",
            $"Est: {Exec.EstimatedHours?.ToString("F1") ?? "?"}h | Priority: {Exec.Job?.Priority}"
        };

        if (!string.IsNullOrEmpty(scope))
            lines.Add($"Scope: {scope} | Qty: {Exec.Job?.Quantity}");

        if (Exec.Machine != null)
            lines.Add($"Machine: {Exec.Machine.Name}");

        var wo = Exec.Job?.WorkOrderLine?.WorkOrder;
        if (wo != null)
            lines.Add($"WO: {wo.OrderNumber} — {wo.CustomerName}");

        if (Exec.MachineProgram != null)
            lines.Add($"Program: {Exec.MachineProgram.Name}");

        return string.Join("\n", lines);
    }
}
