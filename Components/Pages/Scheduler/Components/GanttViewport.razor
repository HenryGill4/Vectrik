@implements IAsyncDisposable
@inject IJSRuntime JS
@using System.Globalization

@if (DataRangeStart != default && DataRangeEnd != default)
{
    <div class="gantt-container gantt-viewport" @ref="_containerRef">
        <div class="gantt-inner" data-data-end="@DataRangeEnd.ToString("o")"
             style="width: @(FormatPx(GetTotalInnerWidthPx()))px; position: relative;">
            @* ── Time Header ── *@
            <div class="gantt-time-header">
                @foreach (var tick in GenerateTimeHeaders())
                {
                    var tickLeft = GetBarLeftPx(tick.Time);
                    <div class="gantt-tick @(tick.IsMajor ? "gantt-tick-major" : "")" style="left: @(FormatPx(tickLeft))px;">
                        <span class="gantt-tick-label">@tick.Label</span>
                    </div>
                }
            </div>

            @* ── Non-shift shading (nights/weekends dimmed) ── *@
            @foreach (var gap in GetNonShiftPeriods())
            {
                var gapLeft = GetBarLeftPx(gap.Start);
                var gapWidth = (gap.End - gap.Start).TotalHours * PixelsPerHour;
                <div class="gantt-offshift" style="left: @(FormatPx(gapLeft))px; width: @(FormatPx(gapWidth))px;" title="Off-shift"></div>
            }

            @* ── Today line ── *@
            <div class="gantt-today-line" style="left: @(FormatPx(GetBarLeftPx(DateTime.UtcNow)))px;"></div>

            @* ── Child content: machine rows, job rows, build rows, etc. ── *@
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public DateTime DataRangeStart { get; set; }
    [Parameter, EditorRequired] public DateTime DataRangeEnd { get; set; }
    [Parameter, EditorRequired] public double PixelsPerHour { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public List<OperatingShift> Shifts { get; set; } = [];

    /// <summary>Raised when zoom changes _pixelsPerHour. Parent must update its own copy and re-render.</summary>
    [Parameter] public EventCallback<double> OnPixelsPerHourChanged { get; set; }

    /// <summary>Raised when scroll/zoom changes the visible time window.</summary>
    [Parameter] public EventCallback<ViewportBoundsChangedArgs> OnViewportBoundsChanged { get; set; }

    /// <summary>Raised when the viewport scrolls near the data range edge and more data is needed.</summary>
    [Parameter] public EventCallback OnDataRangeExtensionNeeded { get; set; }

    /// <summary>Raised when a bar is drag-dropped to a new time position.</summary>
    [Parameter] public EventCallback<BarDragResult> OnBarDragCompleted { get; set; }

    // JS interop
    private ElementReference _containerRef;
    private DotNetObjectReference<GanttViewport>? _dotNetRef;
    private IJSObjectReference? _jsModule;
    private bool _jsInitialized;
    private bool _disposed;

    // Zoom sync state (for Ctrl+wheel zoom flow)
    private bool _needsZoomSync;
    private double _pendingAnchorTimeHours;
    private double _pendingAnchorViewportX;

    // Reinit state (for post-refresh JS rebind)
    private bool _needsReinit;

    // Viewport bounds (from JS callbacks)
    private DateTime _viewportStart;
    private DateTime _viewportEnd;

    private const double ZoomFactor = 1.15;
    private const double MinPxPerHour = 0.5;
    private const double MaxPxPerHour = 120;

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;

        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/gantt-viewport.js");
                await InitJsAsync();
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
            return;
        }

        // After Ctrl+wheel zoom: C# re-rendered with new PixelsPerHour.
        // Tell JS to sync its zoom and restore scroll to the cursor anchor.
        if (_needsZoomSync && _jsModule != null && !_disposed)
        {
            _needsZoomSync = false;
            _needsReinit = false; // Zoom sync supersedes reinit — don't fight over scroll position
            try
            {
                await _jsModule.InvokeVoidAsync("syncScrollToAnchor",
                    _pendingAnchorTimeHours, _pendingAnchorViewportX);
            }
            catch (JSException ex)
            {
                // JS interop recovery — self-heals on next render
            }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
            return; // Don't run reinit in the same render as zoom sync
        }

        // After background refresh: Blazor may have recreated DOM content.
        // Rebind JS to the current container while preserving scroll/zoom.
        if (_needsReinit && _jsModule != null && !_disposed)
        {
            _needsReinit = false;
            try
            {
                await _jsModule.InvokeVoidAsync("reinit",
                    _containerRef,
                    DataRangeStart.ToString("o"), DataRangeEnd.ToString("o"),
                    PixelsPerHour);
            }
            catch (JSException ex)
            {
                // JS interop recovery — self-heals on next render
            }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
        }
    }

    private async Task InitJsAsync()
    {
        if (_jsModule == null || _dotNetRef == null || _disposed) return;
        try
        {
            await _jsModule.InvokeVoidAsync("initGanttViewport",
                _dotNetRef, _containerRef,
                DataRangeStart.ToString("o"), DataRangeEnd.ToString("o"),
                PixelsPerHour);
            _jsInitialized = true;
        }
        catch (JSException ex)
        {
            // JS interop recovery — self-heals on next render
        }
        catch (TaskCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("dispose"); }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
            try { await _jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            catch (JSException) { }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
        }
        _dotNetRef?.Dispose();
    }

    // ── JS Callbacks (invoked from gantt-viewport.js) ───────────────────────

    [JSInvokable]
    public async Task OnViewportChanged(string startIso, string endIso, double pixelsPerHour)
    {
        if (_disposed) return;
        _viewportStart = DateTime.Parse(startIso, null, System.Globalization.DateTimeStyles.RoundtripKind);
        _viewportEnd = DateTime.Parse(endIso, null, System.Globalization.DateTimeStyles.RoundtripKind);

        // Notify parent of new viewport bounds
        await OnViewportBoundsChanged.InvokeAsync(new ViewportBoundsChangedArgs(
            _viewportStart, _viewportEnd, pixelsPerHour));

        // Check if we need more data
        var buffer = TimeSpan.FromDays(1);
        if (_viewportStart < DataRangeStart + buffer || _viewportEnd > DataRangeEnd - buffer)
        {
            await OnDataRangeExtensionNeeded.InvokeAsync();
        }
    }

    /// <summary>
    /// Called by JS after Ctrl+wheel or pinch zoom. JS has already applied the zoom
    /// (updated inner width and scroll position) so the viewport doesn't jump.
    /// JS sends the actual accumulated pixelsPerHour (not direction) so rapid wheel
    /// events during the debounce window are correctly reflected.
    /// </summary>
    [JSInvokable]
    public async Task OnZoomApplied(double pixelsPerHour, double anchorTimeHours, double anchorViewportX)
    {
        if (_disposed) return;
        var newPph = Math.Clamp(pixelsPerHour, MinPxPerHour, MaxPxPerHour);

        if (Math.Abs(newPph - PixelsPerHour) < 0.001) return;

        // JS already updated scroll position and inner width before calling us.
        // Store anchor as fallback in case the Blazor DOM diff disrupts scroll.
        _pendingAnchorTimeHours = anchorTimeHours;
        _pendingAnchorViewportX = anchorViewportX;
        _needsZoomSync = true;

        // Notify parent to update PixelsPerHour — triggers re-render
        await OnPixelsPerHourChanged.InvokeAsync(newPph);
    }

    /// <summary>
    /// Called by JS when a bar is drag-dropped to a new position.
    /// </summary>
    [JSInvokable("OnBarDragCompleted")]
    public async Task HandleBarDragFromJs(string barType, string entityId, string newStartIso, string targetMachineId = "0")
    {
        if (_disposed) return;
        var newStart = DateTime.Parse(newStartIso, null, System.Globalization.DateTimeStyles.RoundtripKind);
        int.TryParse(targetMachineId, out var machineId);
        if (int.TryParse(entityId, out var id))
        {
            await OnBarDragCompleted.InvokeAsync(new BarDragResult(barType, id, newStart, machineId > 0 ? machineId : null));
        }
    }

    // ── Public Methods (called by parent via @ref) ──────────────────────────

    /// <summary>Zoom in from button click. Calls JS immediately, then notifies parent.</summary>
    public async Task ZoomInAsync()
    {
        if (_disposed) return;
        var newPph = Math.Clamp(PixelsPerHour * ZoomFactor, MinPxPerHour, MaxPxPerHour);
        if (Math.Abs(newPph - PixelsPerHour) < 0.001) return;

        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("applyZoom", newPph); }
            catch (JSDisconnectedException) { return; }
            catch (ObjectDisposedException) { return; }
            catch (TaskCanceledException) { return; }
        }

        await OnPixelsPerHourChanged.InvokeAsync(newPph);
    }

    /// <summary>Zoom out from button click. Calls JS immediately, then notifies parent.</summary>
    public async Task ZoomOutAsync()
    {
        if (_disposed) return;
        var newPph = Math.Clamp(PixelsPerHour / ZoomFactor, MinPxPerHour, MaxPxPerHour);
        if (Math.Abs(newPph - PixelsPerHour) < 0.001) return;

        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("applyZoom", newPph); }
            catch (JSDisconnectedException) { return; }
            catch (ObjectDisposedException) { return; }
            catch (TaskCanceledException) { return; }
        }

        await OnPixelsPerHourChanged.InvokeAsync(newPph);
    }

    /// <summary>Scroll the viewport to center on the given time.</summary>
    public async Task ScrollToTimeAsync(DateTime time)
    {
        if (_jsModule == null || _disposed) return;
        try { await _jsModule.InvokeVoidAsync("scrollToTime", time.ToString("o")); }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (TaskCanceledException) { }
    }

    /// <summary>Pan the viewport by half its width in the given direction (-1 = back, 1 = forward).</summary>
    public async Task ShiftViewportAsync(int direction)
    {
        if (_jsModule == null || _disposed) return;
        var viewportHours = (_viewportEnd - _viewportStart).TotalHours;
        if (viewportHours <= 0) viewportHours = 24;
        var shiftHours = viewportHours * 0.5 * direction;
        var targetTime = _viewportStart.AddHours(viewportHours / 2 + shiftHours);
        try { await _jsModule.InvokeVoidAsync("scrollToTime", targetTime.ToString("o")); }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (TaskCanceledException) { }
    }

    /// <summary>Save JS scroll/zoom state before a data refresh.</summary>
    public async Task SaveStateAsync()
    {
        if (_jsModule == null || _disposed) return;
        try { await _jsModule.InvokeVoidAsync("saveState"); }
        catch (JSException) { }
        catch (ObjectDisposedException) { }
        catch (TaskCanceledException) { }
        catch (OperationCanceledException) { }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Request a JS reinit on the next render cycle (after data reload changes DOM).</summary>
    public void RequestReinit()
    {
        _needsReinit = true;
    }

    /// <summary>Update the JS module's data range (after extending data boundaries).</summary>
    public async Task UpdateDataRangeInJsAsync()
    {
        if (_jsModule == null || _disposed) return;
        try
        {
            await _jsModule.InvokeVoidAsync("updateDataRange",
                DataRangeStart.ToString("o"), DataRangeEnd.ToString("o"), PixelsPerHour);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (TaskCanceledException) { }
    }

    // ── Position Helpers (for time header + inner width) ────────────────────

    private double GetBarLeftPx(DateTime start) =>
        (start - DataRangeStart).TotalHours * PixelsPerHour;

    private double GetTotalInnerWidthPx() =>
        (DataRangeEnd - DataRangeStart).TotalHours * PixelsPerHour;

    /// <summary>Formats a pixel value for CSS using invariant culture (always uses . as decimal separator).</summary>
    private static string FormatPx(double value) =>
        value.ToString("F1", CultureInfo.InvariantCulture);

    /// <summary>
    /// Computes gaps between shift windows across the visible data range.
    /// These periods are rendered as dimmed overlays on the Gantt background.
    /// </summary>
    private List<(DateTime Start, DateTime End)> GetNonShiftPeriods()
    {
        if (!Shifts.Any()) return []; // 24/7 — no off-shift periods

        var gaps = new List<(DateTime, DateTime)>();
        var cursor = DataRangeStart;
        var limit = DataRangeEnd;

        var maxDays = (int)(DataRangeEnd - DataRangeStart).TotalDays + 2;
        for (int dayOffset = 0; cursor < limit && dayOffset < maxDays; dayOffset++)
        {
            var checkDate = DataRangeStart.Date.AddDays(dayOffset);
            if (checkDate > limit) break;

            var dayName = checkDate.DayOfWeek.ToString()[..3];
            var dayShifts = Shifts
                .Where(s => s.DaysOfWeek.Contains(dayName, StringComparison.OrdinalIgnoreCase))
                .OrderBy(s => s.StartTime)
                .ToList();

            if (!dayShifts.Any())
            {
                // Entire day is off-shift
                var dayStart = checkDate;
                var dayEnd = checkDate.AddDays(1);
                if (dayStart < cursor) dayStart = cursor;
                if (dayEnd > limit) dayEnd = limit;
                if (dayStart < dayEnd)
                    gaps.Add((dayStart, dayEnd));
                cursor = dayEnd;
                continue;
            }

            foreach (var shift in dayShifts)
            {
                var shiftStart = checkDate + shift.StartTime;
                var shiftEnd = checkDate + shift.EndTime;
                if (shift.EndTime <= shift.StartTime)
                    shiftEnd = shiftEnd.AddDays(1);

                // Gap before this shift
                if (cursor < shiftStart)
                {
                    var gapStart = cursor < DataRangeStart ? DataRangeStart : cursor;
                    var gapEnd = shiftStart > limit ? limit : shiftStart;
                    if (gapStart < gapEnd)
                        gaps.Add((gapStart, gapEnd));
                }

                cursor = shiftEnd > cursor ? shiftEnd : cursor;
            }
        }

        // Gap after last shift to end of range
        if (cursor < limit)
            gaps.Add((cursor, limit));

        return gaps;
    }

    private List<(DateTime Time, string Label, bool IsMajor)> GenerateTimeHeaders()
    {
        var headers = new List<(DateTime, string, bool)>();
        var rangeStart = DataRangeStart;
        var rangeEnd = DataRangeEnd;

        if (PixelsPerHour > 60)
        {
            // High zoom: 15-min ticks
            var t = new DateTime(rangeStart.Year, rangeStart.Month, rangeStart.Day, rangeStart.Hour, rangeStart.Minute / 15 * 15, 0, DateTimeKind.Utc);
            while (t < rangeEnd)
            {
                var isMajor = t.Minute == 0;
                headers.Add((t, isMajor ? t.ToString("h tt").ToLower() : t.ToString(":mm"), isMajor));
                t = t.AddMinutes(15);
            }
        }
        else if (PixelsPerHour >= 10)
        {
            // Medium zoom: hourly ticks with day headers
            var t = rangeStart.Date.AddHours(rangeStart.Hour);
            while (t < rangeEnd)
            {
                var isMajor = t.Hour == 0;
                headers.Add((t, isMajor ? t.ToString("ddd M/d") : t.ToString("h tt").ToLower(), isMajor));
                t = t.AddHours(1);
            }
        }
        else if (PixelsPerHour >= 2)
        {
            // Low zoom: day ticks
            var t = rangeStart.Date;
            while (t < rangeEnd)
            {
                headers.Add((t, t.ToString("ddd M/d"), true));
                t = t.AddDays(1);
            }
        }
        else
        {
            // Very low zoom: week ticks with month headers
            var t = rangeStart.Date;
            t = t.AddDays(-(int)t.DayOfWeek + (int)DayOfWeek.Monday);
            if (t > rangeStart) t = t.AddDays(-7);
            while (t < rangeEnd)
            {
                headers.Add((t, t.ToString("M/d"), true));
                t = t.AddDays(7);
            }
        }

        return headers;
    }

    /// <summary>Event args for viewport bounds changes.</summary>
    public record ViewportBoundsChangedArgs(DateTime Start, DateTime End, double PixelsPerHour);

    /// <summary>Result of a bar drag-and-drop reschedule operation.</summary>
    public record BarDragResult(string BarType, int EntityId, DateTime NewStart, int? TargetMachineId = null);
}
