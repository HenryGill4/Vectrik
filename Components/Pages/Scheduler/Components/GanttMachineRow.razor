<div class="gantt-row" data-machine-id="@Machine.Id">
    <div class="gantt-resource-label">
        <span class="gantt-machine-status gantt-status-@Machine.Status.ToString().ToLower()"></span>
        <div class="gantt-machine-info">
            <span class="gantt-machine-name" title="@Machine.Name">
                @Machine.Name
                @if (Executions.Count > 0)
                {
                    <span class="gantt-queue-badge" title="@Executions.Count scheduled task(s)">@Executions.Count</span>
                }
            </span>
            <span class="gantt-machine-type">@Machine.MachineType</span>
        </div>
    </div>
    <div class="gantt-track">
        @* ── Build program bars (full build duration, behind stage bars) ── *@
        @foreach (var entry in BuildTimeline)
        {
            var build = BuildPrograms.FirstOrDefault(b => b.Id == entry.MachineProgramId);
            if (build == null) continue;
            var barLeft = GetBarLeftPx(entry.PrintStart);
            var barWidth = GetBarWidthPx(entry.PrintStart, entry.PrintEnd);
            <GanttBuildBar Build="build"
                BarLeftPx="barLeft"
                BarWidthPx="barWidth"
                Start="entry.PrintStart"
                End="entry.PrintEnd"
                HasChangeoverConflict="entry.HasChangeoverConflict"
                ChangeoverMinutes="@(Machine.AutoChangeoverEnabled ? Machine.ChangeoverMinutes : 0)"
                PixelsPerHour="PixelsPerHour"
                IsSelected="SelectedBuildIds.Contains(build.Id)"
                DowntimeStart="entry.DowntimeStart"
                DowntimeEnd="entry.DowntimeEnd"
                OnBuildAction="OnBuildAction" />
        }
        @* ── Build-level stage execution groups (skip stages already shown by build bars) ── *@
        @{
            // Only exclude executions whose build bars were actually rendered.
            // Timeline entries for non-BuildPlate programs won't have a match in
            // BuildPrograms, so their build bar is skipped — they must remain in
            // remainingExecs to be rendered as individual or group bars.
            var renderedProgramIds = BuildPrograms.Select(b => b.Id).ToHashSet();
            var timelineExecIds = BuildTimeline
                .Where(t => t.StageExecutionId.HasValue && renderedProgramIds.Contains(t.MachineProgramId))
                .Select(t => t.StageExecutionId!.Value)
                .ToHashSet();
            var remainingExecs = Executions.Where(e => !timelineExecIds.Contains(e.Id)).ToList();
            var buildGroups = remainingExecs
                .Where(e => e.MachineProgramId != null)
                .GroupBy(e => new { e.MachineProgramId, e.ProductionStageId, e.JobId })
                .ToList();
            var buildGroupExecIds = buildGroups.SelectMany(g => g.Select(e => e.Id)).ToHashSet();
            var individualExecs = remainingExecs.Where(e => !buildGroupExecIds.Contains(e.Id)).ToList();
        }
        @foreach (var group in buildGroups)
        {
            var first = group.OrderBy(e => e.ScheduledStartAt ?? DateTime.MaxValue).First();
            var last = group.OrderByDescending(e => e.ScheduledEndAt ?? DateTime.MinValue).First();
            var start = first.ScheduledStartAt ?? first.Job?.ScheduledStart ?? DataRangeStart;
            var end = last.ScheduledEndAt ?? last.Job?.ScheduledEnd ?? start.AddHours(first.EstimatedHours ?? 4);
            var partList = string.Join(", ", group.Select(e => e.Job?.Part?.PartNumber ?? "?").Distinct());
            <GanttBuildGroupBar FirstExec="first"
                BarLeftPx="GetBarLeftPx(start)"
                BarWidthPx="GetBarWidthPx(start, end)"
                Start="start" End="end"
                PartList="@partList"
                IsSelected="SelectedExecIds.Contains(first.Id)"
                OnClick="OnBarClick" />
        }
        @foreach (var exec in individualExecs)
        {
            var start = exec.ScheduledStartAt ?? exec.Job?.ScheduledStart ?? DataRangeStart;
            var end = exec.ScheduledEndAt ?? exec.Job?.ScheduledEnd ?? start.AddHours(exec.EstimatedHours ?? 4);
            var isConflict = HasOverlap(exec);
            <GanttBar Exec="exec"
                BarLeftPx="GetBarLeftPx(start)"
                BarWidthPx="GetBarWidthPx(start, end)"
                Start="start" End="end"
                IsConflict="isConflict"
                IsSelected="SelectedExecIds.Contains(exec.Id)"
                OnClick="OnBarClick" />
        }
        @* ── "+" zone for SLS machines ── *@
        @if (Machine.IsAdditiveMachine && OnNextBuildRequested.HasDelegate)
        {
            var lastEnd = GetLastScheduledEnd();
            var zoneLeft = GetBarLeftPx(lastEnd);
            <div class="gantt-next-build-zone" style="left: @(zoneLeft.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;"
                 @onclick="() => OnNextBuildRequested.InvokeAsync(Machine.Id)"
                 @onclick:stopPropagation
                 title="Schedule next build on @Machine.Name">
                <span>+</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Machine Machine { get; set; } = default!;
    [Parameter, EditorRequired] public List<StageExecution> Executions { get; set; } = [];
    [Parameter, EditorRequired] public DateTime DataRangeStart { get; set; }
    [Parameter, EditorRequired] public double PixelsPerHour { get; set; }
    [Parameter] public EventCallback<StageExecution> OnBarClick { get; set; }
    [Parameter] public EventCallback<(MachineProgram Build, string Action)> OnBuildAction { get; set; }
    [Parameter] public List<MachineProgram> BuildPrograms { get; set; } = [];
    [Parameter] public List<ProgramTimelineEntry> BuildTimeline { get; set; } = [];
    [Parameter] public HashSet<int> SelectedExecIds { get; set; } = [];
    [Parameter] public HashSet<int> SelectedBuildIds { get; set; } = [];
    [Parameter] public EventCallback<int> OnNextBuildRequested { get; set; }

    private double GetBarLeftPx(DateTime start) =>
        (start - DataRangeStart).TotalHours * PixelsPerHour;

    private double GetBarWidthPx(DateTime start, DateTime end) =>
        Math.Max(2, (end - start).TotalHours * PixelsPerHour);

    private DateTime GetLastScheduledEnd()
    {
        var lastExec = Executions
            .Where(e => e.ScheduledEndAt.HasValue)
            .OrderByDescending(e => e.ScheduledEndAt)
            .FirstOrDefault();
        var lastTimeline = BuildTimeline
            .OrderByDescending(t => t.PrintEnd)
            .FirstOrDefault();

        var candidates = new List<DateTime> { DateTime.UtcNow };
        if (lastExec?.ScheduledEndAt != null) candidates.Add(lastExec.ScheduledEndAt.Value);
        if (lastTimeline != null) candidates.Add(lastTimeline.ChangeoverEnd ?? lastTimeline.PrintEnd);

        return candidates.Max();
    }

    private bool HasOverlap(StageExecution current)
    {
        var cStart = current.ScheduledStartAt;
        var cEnd = current.ScheduledEndAt;
        if (cStart == null || cEnd == null) return false;

        return Executions.Any(e =>
            e.Id != current.Id &&
            e.ScheduledStartAt < cEnd &&
            e.ScheduledEndAt > cStart);
    }
}
