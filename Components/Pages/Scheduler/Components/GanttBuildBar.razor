@using System.Globalization

@{
    var statusClass = Build.ScheduleStatus switch
    {
        ProgramScheduleStatus.Scheduled => "gantt-build-scheduled",
        ProgramScheduleStatus.Printing => "gantt-build-printing",
        ProgramScheduleStatus.PostPrint => "gantt-build-postprint",
        ProgramScheduleStatus.Completed => "gantt-build-completed",
        _ => "gantt-build-scheduled"
    };
    var statusIcon = Build.ScheduleStatus switch
    {
        ProgramScheduleStatus.Printing => "🖨️",
        ProgramScheduleStatus.PostPrint => "⏳",
        ProgramScheduleStatus.Completed => "✅",
        ProgramScheduleStatus.Scheduled => "📅",
        _ => "📦"
    };
    var durationStr = Build.EstimatedPrintHours.HasValue ? $"{Build.EstimatedPrintHours.Value:F1}h" : "";
    var partLabel = Build.TotalPartCount == 1 ? "part" : "parts";
    var isNarrow = BarWidthPx < 120;
    var isMedium = BarWidthPx >= 120 && BarWidthPx < 200;
    var parts = Build.ProgramParts?.OrderByDescending(p => p.Quantity * p.StackLevel).ToList() ?? [];
    var primaryHue = parts.FirstOrDefault()?.PartId is int pid ? GetPartHue(pid) : -1;
    var hueStyle = primaryHue >= 0 && Build.ScheduleStatus == ProgramScheduleStatus.Scheduled
        ? $"--build-hue: {primaryHue};"
        : "";
}
<div class="gantt-build-bar-wrapper" style="left: @(FormatPx(BarLeftPx))px; width: @(FormatPx(BarWidthPx))px;"
     data-program-id="@Build.Id"
     data-bar-type="build"
     data-machine-id="@Build.MachineId">
    <div class="gantt-bar gantt-build-bar @statusClass @(HasChangeoverConflict ? "gantt-changeover-conflict" : "") @(IsSelected ? "gantt-bar-selected" : "") gantt-bar-has-tooltip"
         style="@hueStyle"
         @onclick="OpenDetail"
         @onclick:stopPropagation="true">
        @if (HasChangeoverConflict)
        {
            <span class="gantt-conflict-icon" title="Changeover conflict: cooldown chamber may not be emptied in time">⚠️</span>
        }
        @if (IsSelected)
        {
            <span class="gantt-bar-check">✓</span>
        }
        @if (isNarrow)
        {
            <span class="gantt-bar-text">@statusIcon @(Build.TotalPartCount)p</span>
        }
        else
        {
            <div class="gantt-build-bar-content">
                <span class="gantt-build-bar-title">@statusIcon @Build.Name</span>
                <span class="gantt-build-bar-detail">
                    @Build.TotalPartCount @partLabel · @durationStr
                    @if (!isMedium && parts.Count > 0)
                    {
                        <span class="gantt-build-parts-inline">
                            @foreach (var pp in parts.Take(3))
                            {
                                <span class="gantt-build-part-tag" style="--part-hue: @GetPartHue(pp.PartId);" title="@(pp.Part?.PartNumber ?? "?") ×@(pp.Quantity * pp.StackLevel)">@(pp.Part?.PartNumber ?? "?")<span class="gantt-build-part-qty">×@(pp.Quantity * pp.StackLevel)</span></span>
                            }
                            @if (parts.Count > 3)
                            {
                                <span class="gantt-build-part-more">+@(parts.Count - 3)</span>
                            }
                        </span>
                    }
                </span>
            </div>
        }
        @* ── Part composition stripe at bottom of bar ── *@
        @if (parts.Count > 0)
        {
            var totalQty = parts.Sum(p => p.Quantity * p.StackLevel);
            <div class="gantt-build-stripe">
                @foreach (var pp in parts)
                {
                    var pct = totalQty > 0 ? (pp.Quantity * pp.StackLevel * 100.0 / totalQty) : 0;
                    <div class="gantt-build-stripe-seg" style="width: @(pct.ToString("F1", CultureInfo.InvariantCulture))%; background: hsl(@GetPartHue(pp.PartId), 65%, 50%);" title="@(pp.Part?.PartNumber ?? "?") — @(pp.Quantity * pp.StackLevel) parts (@(pct.ToString("F0"))%)"></div>
                }
            </div>
        }
        @* ── Rich hover tooltip ── *@
        <div class="gantt-bar-tooltip gantt-bar-tooltip--build">
            <div class="gantt-bar-tooltip-title">
                @statusIcon @Build.Name
                @if (HasChangeoverConflict) { <span class="gantt-bar-tooltip-badge gantt-bar-tooltip-badge--warn">⚠ Conflict</span> }
            </div>
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Status</span>
                <span>@Build.ScheduleStatus</span>
            </div>
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Parts</span>
                <span>@Build.TotalPartCount @(Build.TotalPartCount == 1 ? "part" : "parts") (@Build.UniquePartCount @(Build.UniquePartCount == 1 ? "type" : "types"))</span>
            </div>
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Duration</span>
                <span>@(Build.EstimatedPrintHours?.ToString("F1") ?? "?")h</span>
            </div>
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">Start</span>
                <span>@Start.ToLocalTime().ToString("ddd MMM d, h:mm tt")</span>
            </div>
            <div class="gantt-bar-tooltip-row">
                <span class="gantt-bar-tooltip-label">End</span>
                <span>@End.ToLocalTime().ToString("ddd MMM d, h:mm tt")</span>
            </div>
            @if (ChangeoverMinutes > 0)
            {
                <div class="gantt-bar-tooltip-row gantt-bar-tooltip-row--@(HasChangeoverConflict ? "warn" : "ok")">
                    <span class="gantt-bar-tooltip-label">Changeover</span>
                    <span>
                        @((int)ChangeoverMinutes)m —
                        @if (HasChangeoverConflict)
                        {
                            <span>⚠ No operator available — machine will stop</span>
                        }
                        else
                        {
                            <span>✓ Operator available</span>
                        }
                    </span>
                </div>
            }
            @if (parts.Count > 0)
            {
                <div class="gantt-bar-tooltip-parts">
                    @foreach (var pp in parts)
                    {
                        <span class="gantt-bar-tooltip-part-tag" style="--part-hue: @GetPartHue(pp.PartId);">
                            @(pp.Part?.PartNumber ?? $"#{pp.PartId}") ×@(pp.Quantity * pp.StackLevel)
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* ── Changeover time segment (shown after build end) ── *@
    @if (ChangeoverMinutes > 0 && Build.ScheduleStatus != ProgramScheduleStatus.Completed)
    {
        var changeoverWidthPx = ChangeoverMinutes / 60.0 * PixelsPerHour;
        <div class="gantt-changeover-segment @(HasChangeoverConflict ? "gantt-changeover-segment--conflict" : "")"
             style="left: @(FormatPx(BarWidthPx))px; width: @(FormatPx(changeoverWidthPx))px;"
             title="Auto-changeover: @ChangeoverMinutes min @(HasChangeoverConflict ? "⚠️ No operator available" : "✓ Safe")">
            @if (changeoverWidthPx > 20)
            {
                <span class="gantt-changeover-label">@((int)ChangeoverMinutes)m</span>
            }
        </div>
    }

    @* ── Machine DOWN block (shown when changeover lands outside operator hours) ── *@
    @if (DowntimeStart.HasValue && DowntimeEnd.HasValue && Build.ScheduleStatus != ProgramScheduleStatus.Completed)
    {
        var dtOffsetHours = (DowntimeStart.Value - Start).TotalHours;
        var dtDurationHours = (DowntimeEnd.Value - DowntimeStart.Value).TotalHours;
        var dtLeftPx = dtOffsetHours * PixelsPerHour;
        var dtWidthPx = dtDurationHours * PixelsPerHour;
        <div class="gantt-downtime-block"
             style="left: @(FormatPx(dtLeftPx))px; width: @(FormatPx(Math.Max(dtWidthPx, 8)))px;"
             title="Machine DOWN: @(dtDurationHours.ToString("F1"))h until operator arrives and unloads printer">
            @if (dtWidthPx > 30)
            {
                <span class="gantt-downtime-label">DOWN @(dtDurationHours.ToString("F0"))h</span>
            }
            else if (dtWidthPx > 12)
            {
                <span class="gantt-downtime-label">⬇</span>
            }
        </div>
    }


</div>

@code {
    [Parameter, EditorRequired] public MachineProgram Build { get; set; } = default!;
    [Parameter, EditorRequired] public double BarLeftPx { get; set; }
    [Parameter, EditorRequired] public double BarWidthPx { get; set; }
    [Parameter, EditorRequired] public DateTime Start { get; set; }
    [Parameter, EditorRequired] public DateTime End { get; set; }
    [Parameter] public bool HasChangeoverConflict { get; set; }
    [Parameter] public double ChangeoverMinutes { get; set; }
    [Parameter] public double PixelsPerHour { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public DateTime? DowntimeStart { get; set; }
    [Parameter] public DateTime? DowntimeEnd { get; set; }

    /// <summary>Raised when the user clicks a status action. Value is (MachineProgram, actionKey).</summary>
    [Parameter] public EventCallback<(MachineProgram Build, string Action)> OnBuildAction { get; set; }

    private static string FormatPx(double value) => value.ToString("F1", CultureInfo.InvariantCulture);

    /// <summary>Same golden-angle hue as GanttBar.GetJobHue — ensures build bars match their downstream stage bars.</summary>
    private static int GetPartHue(int partId) => partId > 0 ? (int)((partId * 137.508) % 360) : -1;

    private Task OpenDetail() => OnBuildAction.InvokeAsync((Build, "detail"));

    private string ComputeTooltip()
    {
        var parts = Build.TotalPartCount;
        var unique = Build.UniquePartCount;
        var duration = Build.EstimatedPrintHours?.ToString("F1") ?? "?";
        var tip = $"{Build.Name}\n{Build.ScheduleStatus} · {parts} parts ({unique} types) · {duration}h\n{Start.ToLocalTime():ddd MMM d, h:mm tt} → {End.ToLocalTime():ddd MMM d, h:mm tt}";
        if (ChangeoverMinutes > 0)
            tip += $"\nChangeover: {(int)ChangeoverMinutes} min {(HasChangeoverConflict ? "⚠️ No operator available" : "✓ Safe")}";
        if (HasChangeoverConflict)
            tip += "\n⚠️ Machine will STOP until an operator removes the cooled build.";
        return tip;
    }
}
