@using Vectrik.Models

@* ── Top bar: title + primary actions ── *@
<div class="sched-topbar">
    <div class="sched-topbar-left">
        <h1 class="sched-title">Production Scheduler</h1>
        @if (AutoRefreshEnabled)
        {
            <span class="sched-live-dot" title="Auto-refresh active"></span>
        }
        <span class="sched-last-refresh" title="Last refreshed">@LastRefresh.ToLocalTime().ToString("HH:mm:ss")</span>
    </div>
    <div class="sched-topbar-actions">
        @if (ShowSmartReschedule && ViewMode == "gantt")
        {
            <button class="btn btn-accent btn-sm" @onclick="OnSmartReschedule" disabled="@Scheduling"
                    title="Optimize SLS build schedule: fix overlaps, align changeovers, balance machines">
                @if (Scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                Smart Reschedule
            </button>
        }
        @if (ShowAutoSchedule)
        {
            <button class="btn btn-warning btn-sm" @onclick="OnAutoScheduleAll" disabled="@Scheduling">
                @if (Scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                ⚡ Auto-Schedule (@AutoScheduleCount)
            </button>
        }
        <div class="sched-new-dropdown" @onfocusout="HandleDropdownFocusOut">
            <button class="btn btn-primary btn-sm" @onclick="() => _newDropdownOpen = !_newDropdownOpen">+ New ▾</button>
            @if (_newDropdownOpen)
            {
                <div class="sched-new-dropdown-menu">
                    <button class="sched-new-dropdown-item" @onclick="() => { _newDropdownOpen = false; OnNewBuild.InvokeAsync(); }">
                        SLS Build
                    </button>
                    <button class="sched-new-dropdown-item" @onclick="() => { _newDropdownOpen = false; OnNewCncJob.InvokeAsync(); }">
                        CNC Job
                    </button>
                </div>
            }
        </div>
        <button class="btn btn-secondary btn-sm" @onclick="OnManualRefresh" title="Refresh now">🔄</button>
    </div>
</div>

@* ── Tab bar: view switcher ── *@
<div class="sched-tabbar">
    <div class="sched-tabs">
        <button class="sched-tab @(ViewMode == "gantt" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("gantt"); })'>
            <span class="sched-tab-icon">📅</span>
            <span class="sched-tab-label">Production</span>
        </button>
        <button class="sched-tab @(ViewMode == "demand" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("demand"); })'>
            <span class="sched-tab-icon">📋</span>
            <span class="sched-tab-label">Demand</span>
        </button>
        <button class="sched-tab @(ViewMode == "programs" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("programs"); })'>
            <span class="sched-tab-icon">🖨️</span>
            <span class="sched-tab-label">Programs</span>
        </button>
        <button class="sched-tab @(ViewMode == "floor" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("floor"); })'>
            <span class="sched-tab-icon">🔧</span>
            <span class="sched-tab-label">Floor</span>
        </button>
        <button class="sched-tab @(ViewMode == "dispatch" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("dispatch"); })'>
            <span class="sched-tab-icon">🚀</span>
            <span class="sched-tab-label">Dispatch</span>
        </button>
        <button class="sched-tab @(ViewMode == "setup" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("setup"); })'>
            <span class="sched-tab-icon">⚙️</span>
            <span class="sched-tab-label">Setup</span>
        </button>
        <button class="sched-tab @(ViewMode == "data" ? "sched-tab--active" : "")" @onclick='@(() => { _newDropdownOpen = false; OnViewModeChanged.InvokeAsync("data"); })'>
            <span class="sched-tab-icon">📊</span>
            <span class="sched-tab-label">Data</span>
        </button>
    </div>

    @* ── Contextual controls: only shown for views that need them ── *@
    <div class="sched-tab-controls">
        @if (HasGanttViewport)
        {
            <div class="sched-viewport-info">
                <span class="sched-viewport-date">
                    @ViewportStart.ToString("MMM d") &mdash; @ViewportEnd.ToString("MMM d, yyyy")
                </span>
                <span class="sched-viewport-zoom">@(PixelsPerHour.ToString("F1")) px/hr</span>
            </div>
            <div class="sched-nav-btns">
                <button class="btn btn-sm btn-secondary" @onclick="@(() => OnShiftViewport.InvokeAsync(-1))" title="Pan back">◀</button>
                <button class="btn btn-sm btn-accent" @onclick="OnScrollToNow" title="Jump to now">Now</button>
                <button class="btn btn-sm btn-secondary" @onclick="@(() => OnShiftViewport.InvokeAsync(1))" title="Pan forward">▶</button>
            </div>
            <div class="sched-nav-btns">
                <button class="btn btn-sm btn-secondary" @onclick="OnZoomOut" title="Zoom out">−</button>
                <button class="btn btn-sm btn-secondary" @onclick="OnZoomIn" title="Zoom in">+</button>
            </div>
        }

        @* ── Per-view filters ── *@
        @if (ViewMode == "gantt")
        {
            <div class="sched-filter-group">
                <button class="sched-filter-btn @(ShowConflictsOnly ? "sched-filter-btn--active sched-filter-btn--danger" : "")"
                        @onclick="ToggleConflictsOnly"
                        title="Show only overlapping/conflicting executions">
                    ⚠️ Conflicts
                </button>
            </div>
        }
        else if (ViewMode == "programs")
        {
            <div class="sched-filter-group">
                <button class="sched-filter-btn @(ProgramStatusFilter == null ? "sched-filter-btn--active" : "")"
                        @onclick="() => SetProgramStatusFilter(null)">All</button>
                <button class="sched-filter-btn @(ProgramStatusFilter == ProgramScheduleStatus.Ready ? "sched-filter-btn--active" : "")"
                        @onclick="() => SetProgramStatusFilter(ProgramScheduleStatus.Ready)">Ready</button>
                <button class="sched-filter-btn @(ProgramStatusFilter == ProgramScheduleStatus.Scheduled ? "sched-filter-btn--active" : "")"
                        @onclick="() => SetProgramStatusFilter(ProgramScheduleStatus.Scheduled)">Scheduled</button>
                <button class="sched-filter-btn @(ProgramStatusFilter == ProgramScheduleStatus.Printing ? "sched-filter-btn--active" : "")"
                        @onclick="() => SetProgramStatusFilter(ProgramScheduleStatus.Printing)">Printing</button>
                <button class="sched-filter-btn @(ProgramStatusFilter == ProgramScheduleStatus.PostPrint ? "sched-filter-btn--active" : "")"
                        @onclick="() => SetProgramStatusFilter(ProgramScheduleStatus.PostPrint)">Post-Print</button>
            </div>
        }
        else if (ViewMode == "demand")
        {
            <div class="sched-filter-group">
                <button class="sched-filter-btn @(ShowOverdueOnly ? "sched-filter-btn--active sched-filter-btn--danger" : "")"
                        @onclick="ToggleOverdueOnly"
                        title="Show only overdue work orders">
                    🔴 Overdue
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string ViewMode { get; set; } = "gantt";
    [Parameter] public DateTime ViewportStart { get; set; }
    [Parameter] public DateTime ViewportEnd { get; set; }
    [Parameter] public double PixelsPerHour { get; set; }
    [Parameter] public bool Scheduling { get; set; }
    [Parameter] public bool AutoRefreshEnabled { get; set; }
    [Parameter] public DateTime LastRefresh { get; set; }
    [Parameter] public bool ShowAutoSchedule { get; set; }
    [Parameter] public int AutoScheduleCount { get; set; }

    [Parameter] public bool ShowConflictsOnly { get; set; }
    [Parameter] public ProgramScheduleStatus? ProgramStatusFilter { get; set; }
    [Parameter] public bool ShowOverdueOnly { get; set; }

    private bool HasGanttViewport => ViewMode is "gantt" or "programs" or "data";

    [Parameter] public EventCallback<string> OnViewModeChanged { get; set; }
    [Parameter] public EventCallback<int> OnShiftViewport { get; set; }
    [Parameter] public EventCallback OnScrollToNow { get; set; }
    [Parameter] public EventCallback OnZoomIn { get; set; }
    [Parameter] public EventCallback OnZoomOut { get; set; }
    [Parameter] public EventCallback OnManualRefresh { get; set; }
    [Parameter] public EventCallback OnToggleAutoRefresh { get; set; }
    [Parameter] public EventCallback OnAutoScheduleAll { get; set; }
    [Parameter] public bool ShowSmartReschedule { get; set; }
    [Parameter] public EventCallback OnSmartReschedule { get; set; }
    [Parameter] public EventCallback OnNewBuild { get; set; }
    [Parameter] public EventCallback OnNewCncJob { get; set; }

    private bool _newDropdownOpen;
    private CancellationTokenSource? _focusOutCts;

    [Parameter] public EventCallback<bool> OnShowConflictsOnlyChanged { get; set; }
    [Parameter] public EventCallback<ProgramScheduleStatus?> OnProgramStatusFilterChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowOverdueOnlyChanged { get; set; }

    private async Task HandleDropdownFocusOut()
    {
        _focusOutCts?.Cancel();
        _focusOutCts = new CancellationTokenSource();
        var token = _focusOutCts.Token;
        try
        {
            await Task.Delay(150, token);
            _newDropdownOpen = false;
        }
        catch (TaskCanceledException) { /* click arrived before delay — keep open */ }
    }

    private async Task ToggleConflictsOnly()
    {
        await OnShowConflictsOnlyChanged.InvokeAsync(!ShowConflictsOnly);
    }

    private async Task SetProgramStatusFilter(ProgramScheduleStatus? status)
    {
        await OnProgramStatusFilterChanged.InvokeAsync(status);
    }

    private async Task ToggleOverdueOnly()
    {
        await OnShowOverdueOnlyChanged.InvokeAsync(!ShowOverdueOnly);
    }
}
