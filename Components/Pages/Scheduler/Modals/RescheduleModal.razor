@inject IStageService StageService
@inject ISchedulingService Scheduler
@inject IProgramSchedulingService ProgramScheduling
@inject ISchedulingRuleService SchedulingRuleService
@inject ToastService Toast

@if (IsVisible && Execution != null)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content" @onclick:stopPropagation style="max-width: 600px;">
            <div class="modal-header">
                <span class="modal-title">📅 @(Execution.ScheduledStartAt == null ? "Schedule" : "Reschedule")</span>
                <button class="modal-close" @onclick="Close">&times;</button>
            </div>

            <div class="modal-body">
                @* ── Context ── *@
                <div style="padding: 4px 0 12px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
                    <strong>@(Execution.Job?.Part?.PartNumber ?? Execution.MachineProgram?.Name ?? "—")</strong>
                    <span style="color: var(--text-muted);">@(Execution.ProductionStage?.Name ?? "Stage")</span>
                    <span class="badge badge-@(Execution.Job?.Priority.ToString().ToLower() ?? "normal")">@(Execution.Job?.Priority ?? JobPriority.Normal)</span>
                    <span style="color: var(--text-muted); font-size: 0.82rem;">Est: @(Execution.EstimatedHours?.ToString("F1") ?? "?")h</span>
                    @if (Execution.Job?.WorkOrderLine?.WorkOrder != null)
                    {
                        <span class="badge badge-info" style="font-size: 0.7rem;">WO: @Execution.Job.WorkOrderLine.WorkOrder.OrderNumber</span>
                    }
                </div>

                @* ── Manual Controls ── *@
                <div class="form-group">
                    <label class="form-label">Machine</label>
                    <select class="form-control" @bind="_machineId">
                        <option value="">Unassigned</option>
                        @foreach (var m in Machines.Where(m => m.IsAvailableForScheduling))
                        {
                            <option value="@m.Id">@m.Name (@m.MachineType)</option>
                        }
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group"><label class="form-label">Start</label><input class="form-control" type="datetime-local" @bind="_start" /></div>
                    <div class="form-group"><label class="form-label">End</label><input class="form-control" type="datetime-local" @bind="_end" /></div>
                </div>

                @* ── Scheduling Rules Info ── *@
                @if (_ruleSummary != null && _ruleSummary.TotalEnabledRules > 0)
                {
                    <div style="padding: 8px 10px; margin-top: 8px; border-radius: 6px; background: rgba(var(--primary-rgb), 0.08); border: 1px solid rgba(var(--primary-rgb), 0.2); font-size: 0.82rem; display: flex; align-items: center; gap: 8px;">
                        <span>🛡</span>
                        <div>
                            <strong>@_ruleSummary.TotalEnabledRules scheduling rule(s) active</strong>
                            <span style="color: var(--text-muted); margin-left: 4px;">
                                @if (_ruleSummary.RequiresOperatorForChangeover) { <text>· Operator required</text> }
                                @if (_ruleSummary.MaxConsecutiveBuilds.HasValue) { <text>· Max @_ruleSummary.MaxConsecutiveBuilds builds</text> }
                                @if (_ruleSummary.ActiveBlackoutCount > 0) { <text>· @_ruleSummary.ActiveBlackoutCount blackout(s)</text> }
                            </span>
                        </div>
                    </div>
                }

                @* ── Changeover Warning ── *@
                @if (_changeoverInfo != null && !_changeoverInfo.OperatorAvailable)
                {
                    <div style="padding: 10px; margin-top: 8px; border-radius: 6px; background: rgba(var(--danger-rgb), 0.1); border: 1px solid rgba(var(--danger-rgb), 0.3); font-size: 0.82rem;">
                        <strong style="color: var(--danger);">Changeover Conflict</strong>
                        <div style="margin-top: 4px;">
                            No operator available from @_changeoverInfo.ChangeoverStart.ToString("MMM d HH:mm") to @_changeoverInfo.ChangeoverEnd.ToString("MMM d HH:mm").
                        </div>
                        @if (_changeoverInfo.SuggestedAction != null)
                        {
                            <div style="margin-top: 4px; color: var(--text-secondary);">
                                @_changeoverInfo.SuggestedAction
                            </div>
                        }
                    </div>
                }

                @* ── Downstream Impact ── *@
                @if (_downstreamCount > 0)
                {
                    <div style="padding: 8px; margin-top: 8px; border-radius: 6px; background: rgba(var(--warning-rgb), 0.08); border: 1px solid rgba(var(--warning-rgb), 0.2); font-size: 0.82rem;">
                        Moving this will cascade to <strong>@_downstreamCount downstream stage(s)</strong> in the same job.
                    </div>
                }
            </div>

            <div class="modal-footer" style="display: flex; gap: 8px;">
                <button class="btn btn-primary" @onclick="ConfirmRescheduleAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                    Save
                </button>
                <button class="btn btn-warning" @onclick="AutoScheduleAsync" disabled="@_saving">⚡ Auto-Schedule</button>
                <div style="flex:1;"></div>
                <button class="btn btn-secondary" @onclick="Close">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public bool IsVisible { get; set; }
    [Parameter, EditorRequired] public StageExecution? Execution { get; set; }
    [Parameter, EditorRequired] public List<Machine> Machines { get; set; } = [];
    [Parameter] public string InitialMachineId { get; set; } = "";
    [Parameter] public DateTime InitialStart { get; set; }
    [Parameter] public DateTime InitialEnd { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private string _machineId = "";
    private DateTime _start;
    private DateTime _end;
    private bool _saving;
    private ChangeoverAnalysis? _changeoverInfo;
    private MachineRuleSummary? _ruleSummary;
    private int _downstreamCount;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && Execution != null)
        {
            _machineId = InitialMachineId;
            _start = InitialStart;
            _end = InitialEnd;
            _changeoverInfo = null;
            _ruleSummary = null;
            _downstreamCount = 0;

            // Load changeover analysis and scheduling rules if on an SLS machine
            if (Execution.MachineId.HasValue)
            {
                try
                {
                    var machine = Machines.FirstOrDefault(m => m.Id == Execution.MachineId.Value);
                    if (machine?.AutoChangeoverEnabled == true && _end != default)
                    {
                        _changeoverInfo = await ProgramScheduling.AnalyzeChangeoverAsync(machine.Id, _end);
                    }
                    _ruleSummary = await SchedulingRuleService.GetRuleSummaryAsync(Execution.MachineId.Value);
                }
                catch { }
            }

            // Count downstream stages
            if (Execution.JobId.HasValue)
            {
                _downstreamCount = Math.Max(0, (Execution.Job?.Stages?.Count(s => s.SortOrder > Execution.SortOrder) ?? 0));
            }
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task ConfirmRescheduleAsync()
    {
        if (Execution == null) return;
        if (_end <= _start)
        {
            Toast.ShowError("End time must be after start time.");
            return;
        }
        _saving = true;
        try
        {
            int? machineId = int.TryParse(_machineId, out var mid) ? mid : null;
            await StageService.UpdateScheduleAsync(Execution.Id, _start, _end, machineId);
            Toast.ShowSuccess("Schedule updated");
            await OnConfirm.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task AutoScheduleAsync()
    {
        if (Execution == null) return;
        _saving = true;
        try
        {
            await Scheduler.AutoScheduleExecutionAsync(Execution.Id);
            Toast.ShowSuccess("Auto-scheduled successfully");
            await OnConfirm.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }
}
