@* ═══════════════════════════════════════════════════════════════════════════
   UnifiedScheduleWizard — CNC job scheduling wizard.
   Creates jobs from work order lines for CNC/non-additive parts.
   SLS build scheduling is handled by NextBuildAdvisor.
   ═══════════════════════════════════════════════════════════════════════════ *@
@inject IProgramSchedulingService ProgramScheduling
@inject IWorkOrderService WorkOrderService
@inject ISchedulingService SchedulingService
@inject ToastService Toast

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content modal-lg" @onclick:stopPropagation>
            @if (_scheduling)
            {
                <div class="wizard-scheduling-overlay">
                    <div class="wizard-scheduling-pulse"></div>
                    <div class="wizard-scheduling-icon">
                        <svg class="wizard-scheduling-gear" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/>
                        </svg>
                    </div>
                    <div class="wizard-scheduling-title">Scheduling Jobs</div>
                    <div class="wizard-scheduling-progress-ring">
                        <div class="wizard-scheduling-progress-bar" style="width: @(_cncConfigs.Count > 0 ? (_schedulingProgress * 100 / _cncConfigs.Count) : 0)%"></div>
                    </div>
                    <div class="wizard-scheduling-status">
                        @_schedulingProgress of @_cncConfigs.Count job@(_cncConfigs.Count != 1 ? "s" : "")
                    </div>
                    <div class="wizard-scheduling-hint">Creating jobs, calculating durations, assigning machines...</div>
                </div>
            }

            <div class="modal-header">
                <h3 class="modal-title">@StepTitle</h3>
                <button class="btn-icon" @onclick="Close" disabled="@_scheduling">&#x2715;</button>
            </div>

            <div class="modal-body">
                @* ── Step Indicator ── *@
                <div class="wizard-steps">
                    @for (var i = 0; i < _steps.Length; i++)
                    {
                        var idx = i;
                        var isActive = _stepIndex >= idx;
                        var isDone = _stepIndex > idx;
                        <div class="wizard-step @(isActive ? "wizard-step--active" : "") @(isDone ? "wizard-step--done" : "")">
                            <span class="wizard-step-num">@(idx + 1)</span>
                            <span class="wizard-step-label">@_steps[idx]</span>
                        </div>
                        @if (idx < _steps.Length - 1)
                        {
                            <div class="wizard-step-connector @(isDone ? "wizard-step-connector--done" : "")"></div>
                        }
                    }
                </div>

                @* ── Loading/Error ── *@
                @if (_isLoading)
                {
                    <div class="wizard-loading">
                        <span class="spinner"></span>
                        <span>Loading parts...</span>
                    </div>
                }
                else if (_errorMessage != null)
                {
                    <div class="wizard-error">
                        <strong>Error:</strong>
                        <p style="margin: 8px 0 0;">@_errorMessage</p>
                    </div>
                }

                @* ══════════════════════════════════════════════════════════
                   Step 1: Select CNC Parts
                   ══════════════════════════════════════════════════════════ *@
                @if (!_isLoading && _errorMessage == null && _stepIndex == 0)
                {
                    <div class="wizard-content">
                        <p class="wizard-hint">Select CNC parts to create jobs for. Each part will create a job with auto-scheduled stages.</p>

                        @if (!_partSelections.Any())
                        {
                            <div class="empty-state">No CNC parts require scheduling.</div>
                        }
                        else
                        {
                            <div class="program-wizard-parts">
                                @foreach (var ps in _partSelections)
                                {
                                    <div class="program-wizard-part @(ps.IsSelected ? "program-wizard-part--selected" : "")" @onclick="() => ps.IsSelected = !ps.IsSelected">
                                        <label class="program-wizard-part-check" @onclick:stopPropagation>
                                            <input type="checkbox" @bind="ps.IsSelected" />
                                        </label>
                                        <div class="program-wizard-part-info">
                                            <div class="program-wizard-part-header">
                                                <span class="wo-line-type-badge wo-line-type--cnc">CNC</span>
                                                <span class="program-wizard-part-number">@(ps.Line.Part?.PartNumber ?? "?")</span>
                                                <span class="program-wizard-part-name">@(ps.Line.Part?.Name ?? "")</span>
                                            </div>
                                            <div class="program-wizard-part-detail">
                                                <span class="badge badge-info">@ps.OutstandingQty outstanding</span>
                                            </div>
                                        </div>
                                        <div class="program-wizard-part-wo">
                                            <span class="text-muted">@ps.WoNumber</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @* ══════════════════════════════════════════════════════════
                   Step 2: Configure Jobs
                   ══════════════════════════════════════════════════════════ *@
                @if (!_isLoading && _errorMessage == null && _stepIndex == 1)
                {
                    <div class="wizard-content">
                        <p class="wizard-hint">Configure CNC jobs. Each part will create a job with auto-scheduled stages.</p>
                        @foreach (var cnc in _cncConfigs)
                        {
                            <div class="program-wizard-run-config">
                                <div class="program-wizard-run-header">
                                    <span class="wo-line-type-badge wo-line-type--cnc">CNC</span>
                                    <span class="program-wizard-run-part">@(cnc.Line.Part?.PartNumber ?? "?")</span>
                                    <span class="text-muted">@(cnc.Line.Part?.Name ?? "")</span>
                                </div>
                                <div class="program-wizard-run-detail">
                                    <div class="program-wizard-run-input">
                                        <label>Qty:</label>
                                        <input type="number" min="1" class="form-control" style="width:80px;" @bind="cnc.Quantity" />
                                    </div>
                                    <div class="program-wizard-run-input">
                                        <label>Priority:</label>
                                        <select class="form-control" style="width:120px;" @bind="cnc.Priority">
                                            @foreach (var p in Enum.GetValues<JobPriority>())
                                            {
                                                <option value="@p">@p</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @* ══════════════════════════════════════════════════════════
                   Step 3: Review & Schedule
                   ══════════════════════════════════════════════════════════ *@
                @if (!_isLoading && _errorMessage == null && _stepIndex == 2)
                {
                    <div class="wizard-content">
                        <p class="wizard-hint">Review and schedule CNC jobs.</p>

                        <div class="program-wizard-summary">
                            <h4>Schedule Summary</h4>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Part</th>
                                        <th>Quantity</th>
                                        <th>Priority</th>
                                        <th>Work Order</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cnc in _cncConfigs)
                                    {
                                        <tr>
                                            <td>
                                                <span class="wo-line-type-badge wo-line-type--cnc">CNC</span>
                                                @(cnc.Line.Part?.PartNumber ?? "?")
                                            </td>
                                            <td><strong>@cnc.Quantity</strong></td>
                                            <td><span class="badge badge-@cnc.Priority.ToString().ToLower()">@cnc.Priority</span></td>
                                            <td class="text-muted">@cnc.WoNumber</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <div class="modal-footer">
                @if (_stepIndex > 0)
                {
                    <button class="btn btn-secondary" @onclick="PreviousStep" disabled="@_scheduling">Back</button>
                }
                <div style="flex:1;"></div>

                @if (_stepIndex < _steps.Length - 1)
                {
                    <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanProceed)">
                        Next
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="ExecuteScheduleAsync" disabled="@(_scheduling || !CanProceed)">
                        @if (_scheduling)
                        {
                            <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span>
                            <span>Scheduling...</span>
                        }
                        else
                        {
                            <span>Schedule @_cncConfigs.Count Job(s)</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public WorkOrder? WorkOrder { get; set; }
    [Parameter] public List<WorkOrderLine>? Lines { get; set; }
    [Parameter] public List<Machine> Machines { get; set; } = [];
    [Parameter] public string UserName { get; set; } = "System";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnScheduled { get; set; }

    private static readonly string[] _steps = ["Select Parts", "Configure Jobs", "Review & Schedule"];

    private int _stepIndex;
    private bool _scheduling;
    private int _schedulingProgress;
    private bool _isLoading;
    private string? _errorMessage;

    private List<PartSelection> _partSelections = [];
    private List<CncJobConfig> _cncConfigs = [];

    private string StepTitle => _stepIndex switch
    {
        0 => "Schedule CNC Jobs — Select Parts",
        1 => "Schedule CNC Jobs — Configure",
        2 => "Schedule CNC Jobs — Review & Schedule",
        _ => "Schedule CNC Jobs"
    };

    private bool CanProceed => _stepIndex switch
    {
        0 => _partSelections.Any(p => p.IsSelected),
        1 => _cncConfigs.All(c => c.Quantity > 0),
        2 => _cncConfigs.Any(),
        _ => true
    };

    // ── Data Models ──

    private class PartSelection
    {
        public WorkOrderLine Line { get; set; } = null!;
        public string WoNumber { get; set; } = "";
        public int OutstandingQty { get; set; }
        public bool IsSelected { get; set; } = true;
    }

    private class CncJobConfig
    {
        public WorkOrderLine Line { get; set; } = null!;
        public string WoNumber { get; set; } = "";
        public int Quantity { get; set; }
        public JobPriority Priority { get; set; } = JobPriority.Normal;
    }

    // ══════════════════════════════════════════════════════════
    // Initialization
    // ══════════════════════════════════════════════════════════

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_partSelections.Any())
        {
            if (WorkOrder == null || Lines == null)
                await InitializeFromAllOrdersAsync();
            else
                InitializeFromLines();
        }
    }

    private async Task InitializeFromAllOrdersAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _partSelections.Clear();
        _cncConfigs.Clear();
        _stepIndex = 0;
        StateHasChanged();

        try
        {
            var orders = await WorkOrderService.GetWorkOrdersByStatusesAsync(
                WorkOrderStatus.InProgress, WorkOrderStatus.Released);
            var allLines = orders.SelectMany(wo => wo.Lines ?? []).ToList();

            foreach (var line in allLines)
            {
                if (line.Part == null) continue;
                var isAdditive = line.Part.ManufacturingApproach?.RequiresBuildPlate == true;
                if (isAdditive) continue; // SLS parts use NextBuildAdvisor

                var outstanding = CalculateOutstanding(line);
                if (outstanding <= 0) continue;

                var woNumber = orders.FirstOrDefault(o => o.Id == line.WorkOrderId)?.OrderNumber ?? "";
                _partSelections.Add(new PartSelection
                {
                    Line = line,
                    WoNumber = woNumber,
                    OutstandingQty = outstanding
                });
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to initialize: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void InitializeFromLines()
    {
        _partSelections.Clear();
        _cncConfigs.Clear();
        _stepIndex = 0;

        foreach (var line in Lines ?? [])
        {
            if (line.Part == null) continue;
            var isAdditive = line.Part.ManufacturingApproach?.RequiresBuildPlate == true;
            if (isAdditive) continue; // SLS parts use NextBuildAdvisor

            var outstanding = CalculateOutstanding(line);
            if (outstanding <= 0) continue;

            _partSelections.Add(new PartSelection
            {
                Line = line,
                WoNumber = WorkOrder?.OrderNumber ?? "",
                OutstandingQty = outstanding
            });
        }
    }

    // ══════════════════════════════════════════════════════════
    // Navigation
    // ══════════════════════════════════════════════════════════

    private void NextStep()
    {
        if (_stepIndex >= _steps.Length - 1) return;

        // Initialize CNC configs when leaving part selection
        if (_stepIndex == 0)
            InitializeCncConfigs();

        _stepIndex++;
    }

    private void PreviousStep()
    {
        if (_stepIndex > 0) _stepIndex--;
    }

    private void InitializeCncConfigs()
    {
        _cncConfigs = _partSelections
            .Where(p => p.IsSelected)
            .Select(ps => new CncJobConfig
            {
                Line = ps.Line,
                WoNumber = ps.WoNumber,
                Quantity = ps.OutstandingQty,
                Priority = JobPriority.Normal
            }).ToList();
    }

    // ══════════════════════════════════════════════════════════
    // Execution
    // ══════════════════════════════════════════════════════════

    private async Task ExecuteScheduleAsync()
    {
        if (_scheduling) return; // Guard against double-invocation
        _scheduling = true;
        _schedulingProgress = 0;

        try
        {
            StateHasChanged();
            await Task.Yield(); // Flush render so overlay appears before heavy DB work
            var scheduled = 0;
            var errors = new List<string>();

            foreach (var cnc in _cncConfigs)
            {
                _schedulingProgress++;
                StateHasChanged();
                await Task.Yield(); // Allow UI to repaint with progress

                try
                {
                    await ProgramScheduling.ScheduleFromWorkOrderLineAsync(cnc.Line.Id);
                    scheduled++;
                }
                catch (Exception ex)
                {
                    errors.Add($"CNC {cnc.Line.Part?.PartNumber}: {ex.Message}");
                }
            }

            if (errors.Any())
            {
                Toast.ShowWarning($"Scheduled {scheduled} with {errors.Count} error(s)");
                foreach (var err in errors.Take(3))
                    Toast.ShowError(err);
            }
            else
            {
                Toast.ShowSuccess($"Successfully scheduled {scheduled} CNC job(s)");
            }

            await OnScheduled.InvokeAsync();
        }
        catch (TaskCanceledException) { }
        catch (ObjectDisposedException) { }
        catch (Exception ex)
        {
            Toast.ShowError($"Scheduling failed: {ex.Message}");
        }
        finally
        {
            _scheduling = false;
        }
    }

    // ══════════════════════════════════════════════════════════
    // Helpers
    // ══════════════════════════════════════════════════════════

    private static int CalculateOutstanding(WorkOrderLine line)
    {
        var produced = line.ProducedQuantity;
        var inPrograms = line.ProgramParts?
            .Where(pp => pp.MachineProgram?.ScheduleStatus is ProgramScheduleStatus.Scheduled
                or ProgramScheduleStatus.Printing or ProgramScheduleStatus.PostPrint)
            .Sum(pp => pp.Quantity * pp.StackLevel) ?? 0;
        var inProduction = line.Jobs?
            .Where(j => j.Status is not (JobStatus.Completed or JobStatus.Cancelled))
            .Sum(j => j.Quantity) ?? 0;
        var scheduled = Math.Max(inPrograms, inProduction);
        return Math.Max(0, line.Quantity - produced - scheduled);
    }

    private async Task Close()
    {
        if (_scheduling) return; // Don't close while scheduling is in progress
        _partSelections.Clear();
        _cncConfigs.Clear();
        _stepIndex = 0;
        _isLoading = false;
        _errorMessage = null;
        await OnClose.InvokeAsync();
    }
}
