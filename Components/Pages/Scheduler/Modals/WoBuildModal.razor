@inject IBuildPlanningService BuildPlanning
@inject IBuildSchedulingService BuildScheduling
@inject ToastService Toast

@if (IsVisible && WorkOrderLine != null)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content" @onclick:stopPropagation style="max-width: 550px;">
            <div class="modal-header">
                <span class="modal-title">🖨️ @(_step == Step.Create ? "Create Build from Work Order" : "Slicer Data & Schedule")</span>
                <button class="modal-close" @onclick="Close">&times;</button>
            </div>
            <div style="padding: 4px 0 12px; color: var(--text-muted); font-size: 0.85rem;">
                WO: @(WorkOrder?.OrderNumber ?? "?") · @(WorkOrder?.CustomerName ?? "")
            </div>
            <div style="background: var(--bg-tertiary); border-radius: 6px; padding: 10px; margin-bottom: 12px; font-size: 0.85rem;">
                <div style="display:flex;gap:8px;align-items:center;">
                    <span class="wo-line-type-badge wo-line-type--sls">🖨️ SLS</span>
                    <strong>@(WorkOrderLine.Part?.PartNumber ?? "?")</strong>
                    <span style="color:var(--text-muted);">@(WorkOrderLine.Part?.Name ?? "")</span>
                </div>
                <div style="margin-top:6px;color:var(--text-secondary);">
                    Ordered: @WorkOrderLine.Quantity · Produced: @WorkOrderLine.ProducedQuantity · Outstanding: @Outstanding
                </div>
            </div>

            @if (_step == Step.Create)
            {
                @* ── Step 1: Create Build Package ── *@
                <div class="form-group">
                    <label class="form-label">Build Name <span style="color:var(--danger);">*</span></label>
                    <input class="form-control" @bind="_buildName" placeholder="e.g. Build-SUP-001-0615" />
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group">
                        <label class="form-label">SLS Machine <span style="color:var(--danger);">*</span></label>
                        <select class="form-control" @bind="_machineId">
                            <option value="">Select machine...</option>
                            @foreach (var m in SlsMachines)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Quantity</label>
                        <input class="form-control" type="number" @bind="_quantity" min="1" max="@Outstanding" />
                    </div>
                </div>
                <div style="display: flex; gap: 8px;">
                    <button class="btn btn-primary" @onclick="CreateBuildAsync" disabled="@_processing">
                        @if (_processing) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                        📦 Create Build
                    </button>
                    <button class="btn btn-secondary" @onclick="Close">Cancel</button>
                </div>
            }
            else if (_step == Step.SlicerAndSchedule)
            {
                @* ── Step 2: Slicer Data Entry + Schedule ── *@
                <div style="background: var(--bg-secondary); border-radius: 6px; padding: 10px; margin-bottom: 12px; font-size: 0.85rem;">
                    ✅ Build <strong>@_createdPackage?.Name</strong> created with @_quantity parts.
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div class="form-group">
                        <label class="form-label">Print Duration (hours) <span style="color:var(--danger);">*</span></label>
                        <input class="form-control" type="number" step="0.1" min="0.1" @bind="_slicerDuration" />
                        <small style="color:var(--text-secondary)">From slicer software</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stack Level</label>
                        <select class="form-control" @bind="_stackLevel">
                            @foreach (var level in _availableStackLevels)
                            {
                                <option value="@level">@level× stack</option>
                            }
                        </select>
                    </div>
                </div>
                @if (_prefillNote != null)
                {
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;">@_prefillNote</div>
                }

                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <button class="btn btn-primary" @onclick="SaveSlicerAndReadyAsync" disabled="@(_processing || _slicerDuration is null or <= 0)">
                        @if (_processing) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                        ✅ Mark Ready
                    </button>
                    <button class="btn btn-success" @onclick="SaveSlicerAndScheduleAsync" disabled="@(_processing || _slicerDuration is null or <= 0)">
                        @if (_processing) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                        📅 Mark Ready & Schedule Now
                    </button>
                    <button class="btn btn-secondary" @onclick="FinishWithoutSchedule">Done (schedule later)</button>
                </div>
            }
        </div>
    </div>
}

@code {
    private enum Step { Create, SlicerAndSchedule }

    [Parameter, EditorRequired] public bool IsVisible { get; set; }
    [Parameter] public WorkOrder? WorkOrder { get; set; }
    [Parameter] public WorkOrderLine? WorkOrderLine { get; set; }
    [Parameter, EditorRequired] public List<Machine> SlsMachines { get; set; } = [];
    [Parameter, EditorRequired] public List<Machine> AllMachines { get; set; } = [];
    [Parameter, EditorRequired] public string UserName { get; set; } = "System";
    [Parameter] public string InitialBuildName { get; set; } = "";
    [Parameter] public string InitialMachineId { get; set; } = "";
    [Parameter] public int InitialQuantity { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnCreated { get; set; }

    private Step _step = Step.Create;
    private string _buildName = "";
    private string _machineId = "";
    private int _quantity;
    private bool _processing;

    // Step 2 — Slicer data
    private BuildPackage? _createdPackage;
    private int _createdMachineIntId;
    private double? _slicerDuration;
    private int _stackLevel = 1;
    private List<int> _availableStackLevels = [1];
    private string? _prefillNote;

    private int Outstanding => WorkOrderLine != null ? GetOutstanding(WorkOrderLine) : 0;

    protected override void OnParametersSet()
    {
        if (IsVisible && WorkOrderLine != null)
        {
            _buildName = InitialBuildName;
            _machineId = InitialMachineId;
            _quantity = InitialQuantity;
            _step = Step.Create;
            _createdPackage = null;
            _slicerDuration = null;
            _stackLevel = 1;
            _prefillNote = null;
        }
    }

    private async Task Close()
    {
        _step = Step.Create;
        _createdPackage = null;
        await OnClose.InvokeAsync();
    }

    private async Task CreateBuildAsync()
    {
        if (WorkOrderLine == null || string.IsNullOrWhiteSpace(_buildName)) return;
        if (!int.TryParse(_machineId, out var machineIntId)) return;

        _processing = true;
        StateHasChanged();
        try
        {
            var machine = AllMachines.FirstOrDefault(m => m.Id == machineIntId);
            if (machine == null) { Toast.ShowError("Select a valid SLS machine."); return; }

            var pkg = new BuildPackage
            {
                Name = _buildName,
                MachineId = machine.Id,
                Status = BuildPackageStatus.Draft,
                Material = WorkOrderLine.Part?.Material,
                CreatedBy = UserName,
                LastModifiedBy = UserName
            };
            var created = await BuildPlanning.CreatePackageAsync(pkg);
            await BuildPlanning.AddPartToPackageAsync(created.Id, WorkOrderLine.PartId, _quantity, WorkOrderLine.Id);

            _createdPackage = created;
            _createdMachineIntId = machineIntId;

            // Pre-fill slicer data from AdditiveBuildConfig if available
            var config = WorkOrderLine.Part?.AdditiveBuildConfig;
            if (config != null)
            {
                _stackLevel = config.GetRecommendedStackLevel(_quantity);
                _slicerDuration = config.GetStackDuration(_stackLevel);
                _availableStackLevels = config.AvailableStackLevels;
                if (_slicerDuration.HasValue)
                    _prefillNote = $"Pre-filled from part config: {_slicerDuration:F1}h at {_stackLevel}× stack. Adjust if slicer output differs.";
                else
                    _prefillNote = "Enter the print duration from slicer software.";
            }
            else
            {
                _availableStackLevels = [1];
                _stackLevel = 1;
                _slicerDuration = null;
                _prefillNote = "No additive config on this part. Enter duration from slicer software.";
            }

            _step = Step.SlicerAndSchedule;
            Toast.ShowSuccess($"Build '{_buildName}' created — enter slicer data below.");
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _processing = false; }
    }

    private async Task SaveSlicerDataAsync()
    {
        if (_createdPackage == null || _slicerDuration is null or <= 0) return;

        // Update build with slicer data
        _createdPackage.EstimatedDurationHours = _slicerDuration;
        _createdPackage.IsSlicerDataEntered = true;
        _createdPackage.Status = BuildPackageStatus.Sliced;
        _createdPackage.LastModifiedBy = UserName;
        _createdPackage.LastModifiedDate = DateTime.UtcNow;
        await BuildPlanning.UpdatePackageAsync(_createdPackage);

        // Update stack level on the part entry
        var refreshed = await BuildPlanning.GetPackageByIdAsync(_createdPackage.Id);
        var pp = refreshed?.Parts.FirstOrDefault();
        if (pp != null)
            await BuildPlanning.UpdatePartInPackageAsync(pp.Id, pp.Quantity, _stackLevel, pp.SlicerNotes);

        // Mark as Ready
        _createdPackage.Status = BuildPackageStatus.Ready;
        _createdPackage.LastModifiedBy = UserName;
        _createdPackage.LastModifiedDate = DateTime.UtcNow;
        await BuildPlanning.UpdatePackageAsync(_createdPackage);
    }

    private async Task SaveSlicerAndReadyAsync()
    {
        _processing = true;
        StateHasChanged();
        try
        {
            await SaveSlicerDataAsync();
            Toast.ShowSuccess($"Build '{_createdPackage?.Name}' → Ready. Schedule it from the Builds tab.");
            await OnCreated.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    private async Task SaveSlicerAndScheduleAsync()
    {
        _processing = true;
        StateHasChanged();
        try
        {
            await SaveSlicerDataAsync();

            // Schedule on the selected machine
            var result = await BuildScheduling.ScheduleBuildAsync(_createdPackage!.Id, _createdMachineIntId);
            var msg = $"Build '{_createdPackage.Name}' scheduled: {result.Slot.PrintStart:g} → {result.Slot.PrintEnd:g}";
            if (result.ChangeoverInfo is { OperatorAvailable: false, SuggestedAction: not null })
                msg += $"\n⚠️ {result.ChangeoverInfo.SuggestedAction}";

            Toast.ShowSuccess(msg);
            await OnCreated.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed to schedule: {ex.Message}"); }
        finally { _processing = false; }
    }

    private async Task FinishWithoutSchedule()
    {
        await OnCreated.InvokeAsync();
    }

    private static int GetOutstanding(WorkOrderLine line)
    {
        var produced = line.ProducedQuantity;
        var inBuilds = GetInBuildQty(line);
        var ordered = line.Quantity;
        return Math.Max(0, ordered - produced - inBuilds);
    }

    private static int GetInBuildQty(WorkOrderLine line)
    {
        if (line.BuildPackageParts == null) return 0;
        return line.BuildPackageParts
            .Where(bp => bp.BuildPackage != null
                && bp.BuildPackage.Status != BuildPackageStatus.Cancelled
                && bp.BuildPackage.Status != BuildPackageStatus.Completed)
            .Sum(bp => bp.Quantity);
    }
}
