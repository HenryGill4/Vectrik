@* ═══════════════════════════════════════════════════════════════════════════
   NextBuildAdvisor — Machine-centric build scheduling assistant.
   "What should I print next on this machine?"
   Program-first flow: Select existing program OR create new → Timing → Schedule.
   Changeover-aware: suggests start times that land changeover during operator hours.
   ═══════════════════════════════════════════════════════════════════════════ *@
@using Microsoft.AspNetCore.Components.Forms
@using Vectrik.Components.Pages.Scheduler.Models
@using Vectrik.Components.Pages.Scheduler.Components
@inject IJSRuntime JS
@inject IBuildAdvisorService Advisor
@inject IProgramSchedulingService ProgramScheduling
@inject IProgramPlanningService ProgramPlanning
@inject IMachineProgramService ProgramService
@inject IStageCostService StageCostService
@inject IStageService StageService
@inject ICertifiedLayoutService CertifiedLayoutService
@inject ToastService Toast

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content modal-lg advisor-modal" @onclick:stopPropagation>
            @if (_scheduling)
            {
                <div class="wizard-scheduling-overlay">
                    <div class="wizard-scheduling-pulse"></div>
                    <div class="wizard-scheduling-icon">
                        <svg class="wizard-scheduling-gear" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/>
                        </svg>
                    </div>
                    <div class="wizard-scheduling-title">Scheduling Build</div>
                    <div class="wizard-scheduling-progress-ring">
                        <div class="wizard-scheduling-progress-bar" style="width: 100%; animation: wizard-progress-indeterminate 1.5s ease-in-out infinite;"></div>
                    </div>
                    <div class="wizard-scheduling-status">Calculating slot, creating jobs...</div>
                    <div class="wizard-scheduling-hint">Finding optimal timing, analyzing changeover windows...</div>
                </div>
            }
            <div class="advisor-modal-fixed">
                <div class="modal-header">
                    <h3 class="modal-title">@StepTitle</h3>
                    @if (_sessionBuilds > 0)
                    {
                        <span class="badge badge-success" style="margin-left: 8px;">@_sessionBuilds scheduled this session</span>
                    }
                    <button class="btn-icon" @onclick="Close" disabled="@_scheduling">&#x2715;</button>
                </div>

                @* ── Step Indicator ── *@
                <div class="wizard-steps">
                    @for (var i = 0; i < ActiveSteps.Length; i++)
                    {
                        var idx = i;
                        var isActive = VisualStep >= idx;
                        var isDone = VisualStep > idx;
                        <div class="wizard-step @(isActive ? "wizard-step--active" : "") @(isDone ? "wizard-step--done" : "")">
                            <span class="wizard-step-num">@(idx + 1)</span>
                            <span class="wizard-step-label">@ActiveSteps[idx]</span>
                        </div>
                        @if (idx < ActiveSteps.Length - 1)
                        {
                            <div class="wizard-step-connector @(isDone ? "wizard-step-connector--done" : "")"></div>
                        }
                    }
                </div>

            </div>@* end advisor-modal-fixed *@

            <div class="advisor-modal-scroll">
                @if (_loading)
                {
                    <div class="wizard-loading"><span class="spinner"></span> Analyzing demand and available programs...</div>
                }

                @* ══════════ Step 0: Machine & Demand Overview ══════════ *@
                @if (!_loading && _step == 0)
                {
                    <AdvisorStepMachine State="@BuildWizardState()" OnMachineChanged="OnMachineChangedById" />
                }

                @* ══════════ Step 1: Select Program ══════════ *@
                @if (!_loading && _step == 1)
                {
                    <AdvisorStepProgram @key="_selectedMachineId"
                                        State="@BuildWizardState()"
                                        OnProgramSelected="OnExistingProgramSelected"
                                        OnCreateNewProgram="OnCreateNewProgram" />
                }

                @* ══════════ Steps 2+3: Plate / Slicer / Review ══════════ *@
                @if (!_loading && (_step == 2 || _step == 3))
                {
                    <AdvisorStepSchedule State="@BuildWizardState()"
                                         InternalStep="_step"
                                         ExistingNeedsSlicerData="_existingNeedsSlicerData"
                                         SlicerPrintHours="_slicerPrintHours"
                                         SlicerPrintHoursChanged="v => _slicerPrintHours = v"
                                         SlicerLayerCount="_slicerLayerCount"
                                         SlicerLayerCountChanged="v => _slicerLayerCount = v"
                                         SlicerBuildHeightMm="_slicerBuildHeightMm"
                                         SlicerBuildHeightMmChanged="v => _slicerBuildHeightMm = v"
                                         SlicerPowderKg="_slicerPowderKg"
                                         SlicerPowderKgChanged="v => _slicerPowderKg = v"
                                         SlicerSoftware="_slicerSoftware"
                                         SlicerSoftwareChanged="v => _slicerSoftware = v"
                                         SlicerVersion="_slicerVersion"
                                         SlicerVersionChanged="v => _slicerVersion = v"
                                         SlicerFileName="_slicerFileName"
                                         SlicerFileNameChanged="v => _slicerFileName = v"
                                         ProgramName="@_programName"
                                         ProgramNameChanged="v => _programName = v ?? string.Empty"
                                         EstimatedPrintHours="EstimatedPrintHours"
                                         EffectivePrintHours="EffectivePrintHours"
                                         EstimatedBuildCost="_estimatedBuildCost"
                                         UseCertifiedLayouts="_useCertifiedLayouts"
                                         CertifiedLayouts="_certifiedLayouts"
                                         PlateLayoutAssignments="_plateLayoutAssignments"
                                         OnPlateAssignmentsChanged="OnPlateLayoutAssignmentsChanged"
                                         OnComposerModeChanged="OnComposerModeChanged"
                                         OnStackLevelChanged="args => OnStackLevelChanged(args.Index, args.NewLevel)"
                                         OnPositionsChanged="args => OnPositionsChanged(args.Index, args.NewPositions)"
                                         OnRemovePart="RemoveFromPlate"
                                         OnAddPart="OnAddPartById"
                                         OnResetToRecommendation="ResetToRecommendation"
                                         OnOptionSelected="OnOptionSelected"
                                         StartAfterOverride="_startAfterOverride"
                                         StartAfterOverrideChanged="async v => { _startAfterOverride = v; await RefreshTimingOptions(); }"
                                         OnRefreshTimingOptions="EventCallback.Empty"
                                         Uploading="_uploading"
                                         UploadedFiles="_uploadedFiles"
                                         OnSliceFileUpload="HandleSliceFileUpload" />
                }
            </div>

            @* ── Footer ── *@
            <div class="modal-footer">
                @if (_step > 0)
                {
                    <button class="btn btn-secondary" @onclick="GoBack" disabled="@_scheduling">Back</button>
                }
                <div style="flex:1;"></div>

                @if (_step < 3)
                {
                    <button class="btn btn-primary" @onclick="AdvanceStep" disabled="@DisableNext">Next</button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="ScheduleAndCloseAsync" disabled="@(_scheduling || !_plateAllocations.Any())">
                        @if (_scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                        Schedule This Build
                    </button>
                    <button class="btn btn-accent" @onclick="ScheduleAndQueueNextAsync" disabled="@(_scheduling || !_plateAllocations.Any())">
                        @if (_scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                        Schedule & Queue Next
                    </button>
                    @if (OtherMachine != null)
                    {
                        <button class="btn btn-secondary" @onclick="ScheduleAndSwitchMachineAsync" disabled="@(_scheduling || !_plateAllocations.Any())"
                                title="Schedule this build, then switch to @OtherMachine.Name">
                            @if (_scheduling) { <span class="spinner" style="width:14px;height:14px;margin-right:4px;"></span> }
                            Schedule & Switch to @OtherMachine.Name
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public List<Machine> Machines { get; set; } = [];
    [Parameter] public int? InitialMachineId { get; set; }
    [Parameter] public int? InitialPartId { get; set; }
    [Parameter] public string UserName { get; set; } = "System";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnScheduled { get; set; }

    private int _step;
    private bool _loading;
    private bool _scheduling;
    private bool _initialized;
    private int _sessionBuilds;
    private int _selectedMachineId;
    private DateTime? _startAfterOverride;
    private bool _showPartPicker;
    private BuildRecommendation? _recommendation;
    private List<DemandSummary> _demand = [];

    // Program selection (Step 0)
    private List<MachineProgram> _availablePrograms = [];
    private MachineProgram? _selectedExistingProgram;
    private bool _creatingNewProgram;
    private bool _existingNeedsSlicerData;

    // Schedule options (Step 0 — shown after program selected)
    private List<ScheduleOption> _scheduleOptions = [];
    private ScheduleOption? _selectedOption;
    private List<ProgramTimelineEntry> _machineBuilds = [];
    private List<(string MachineName, ProgramTimelineEntry Build)> _otherMachineBuilds = [];
    private ProgramTimelineEntry? _currentBuild;
    private int _scheduledBuildCount;

    // Mutable plate state (editable copy of the recommendation — used for new programs)
    private List<EditablePlateAllocation> _plateAllocations = [];
    private bool _plateEdited;
    private List<string> _activeWarnings = [];

    // Certified layout mode
    private bool _useCertifiedLayouts = true;
    private List<CertifiedLayout> _certifiedLayouts = [];
    private List<PlateSlotAssignment> _plateLayoutAssignments = [];

    // Program details (Step 1 — new programs only)
    private string _programName = "";
    private double? _slicerPrintHours;
    private int? _slicerLayerCount;
    private double? _slicerBuildHeightMm;
    private double? _slicerPowderKg;
    private string? _slicerSoftware;
    private string? _slicerVersion;
    private string? _slicerFileName;

    private bool _uploading;
    private int? _createdProgramId;
    private List<MachineProgramFile> _uploadedFiles = [];

    // ── Computed ──

    private List<Machine> SlsMachines => Machines.Where(m => m.IsAdditiveMachine && m.IsAvailableForScheduling).ToList();

    /// Builds the shared wizard state snapshot for sub-components.
    private AdvisorWizardState BuildWizardState() => new()
    {
        SlsMachines = SlsMachines,
        SelectedMachineId = _selectedMachineId,
        SelectedMachine = _selectedMachine,
        Demand = _demand,
        Recommendation = _recommendation,
        CurrentBuild = _currentBuild,
        AvailablePrograms = _availablePrograms,
        SelectedExistingProgram = _selectedExistingProgram,
        CreatingNewProgram = _creatingNewProgram,
        ExistingNeedsSlicerData = _existingNeedsSlicerData,
        PlateAllocations = _plateAllocations,
        PlateEdited = _plateEdited,
        ActiveWarnings = _activeWarnings,
        ScheduleOptions = _scheduleOptions,
        SelectedOption = _selectedOption,
    };
    private Machine? _selectedMachine => Machines.FirstOrDefault(m => m.Id == _selectedMachineId);
    private Machine? OtherMachine => SlsMachines.FirstOrDefault(m => m.Id != _selectedMachineId);

    /// Dynamic step labels based on flow
    private string[] ActiveSteps => _creatingNewProgram
        ? ["Machine", "Program", "Build Plate", "Schedule"]
        : _existingNeedsSlicerData
            ? ["Machine", "Program", "Slicer", "Schedule"]
            : ["Machine", "Program", "Schedule"];

    /// Maps internal _step (0,1,2,3) to the visual step index for the step indicator
    private int VisualStep => _step switch
    {
        0 => 0,
        1 => 1,
        2 => 2,
        3 => (_selectedExistingProgram != null && !_existingNeedsSlicerData) ? 2 : 3,
        _ => 0
    };

    private string StepTitle => _step switch
    {
        0 => "Next Build Advisor — Select Machine",
        1 => "Next Build Advisor — Select Program",
        2 => _existingNeedsSlicerData
            ? "Next Build Advisor — Slicer Data"
            : "Next Build Advisor — Build Plate",
        3 => "Next Build Advisor — Review & Schedule",
        _ => "Next Build Advisor"
    };

    private List<DemandSummary> AvailablePartsForPlate => _demand
        .Where(d => d.IsAdditive && d.NetRemaining > 0 && d.BuildConfig != null
            && !_plateAllocations.Any(a => a.PartId == d.PartId))
        .ToList();

    private double EstimatedPrintHours
    {
        get
        {
            // For existing programs, use the program's actual print hours
            if (_selectedExistingProgram != null)
                return _selectedExistingProgram.EstimatedPrintHours ?? 24;

            if (!_plateAllocations.Any()) return 0;
            var maxHours = 0.0;
            foreach (var alloc in _plateAllocations)
            {
                var config = _demand.FirstOrDefault(d => d.PartId == alloc.PartId)?.BuildConfig;
                var duration = config?.GetStackDuration(alloc.StackLevel) ?? config?.SingleStackDurationHours ?? 24;
                maxHours = Math.Max(maxHours, duration);
            }
            return maxHours;
        }
    }

    /// Print hours: for existing programs use their data (or user-entered slicer data if missing),
    /// for new programs use only user-entered slicer data
    private double EffectivePrintHours =>
        (_selectedExistingProgram != null)
            ? (_existingNeedsSlicerData && _slicerPrintHours.HasValue && _slicerPrintHours > 0)
                ? _slicerPrintHours.Value
                : _selectedExistingProgram.EstimatedPrintHours ?? 24
            : (_slicerPrintHours.HasValue && _slicerPrintHours > 0)
                ? _slicerPrintHours.Value : 0;

    private decimal _estimatedBuildCost;

    private async Task CalculateBuildCostAsync()
    {
        if (!_plateAllocations.Any())
        {
            _estimatedBuildCost = 0;
            return;
        }

        try
        {
            var totalParts = _plateAllocations.Sum(a => a.TotalParts);
            var printHours = EffectivePrintHours;

            // Get the SLS printing stage for cost estimation
            var allStages = await StageService.GetAllStagesAsync(activeOnly: true);
            var slsStage = allStages.FirstOrDefault(s => s.StageSlug == "sls-printing");

            if (slsStage != null)
            {
                // Use the stage cost service which respects cost profiles and fallback rates
                var estimate = await StageCostService.EstimateCostAsync(slsStage.Id, printHours, totalParts, 1);
                _estimatedBuildCost = estimate.TotalCost;
            }
            else
            {
                // Fallback: machine rate × print hours
                _estimatedBuildCost = (decimal)printHours * (_selectedMachine?.HourlyRate ?? 0);
            }
        }
        catch
        {
            // Fallback on error
            _estimatedBuildCost = (decimal)EffectivePrintHours * (_selectedMachine?.HourlyRate ?? 0);
        }
    }

    private ProgramScheduleSlot? ActiveSlot => _selectedOption?.Slot ?? _recommendation?.Slot;
    private bool ActiveChangeoverAligned => _selectedOption?.ChangeoverAligned ?? _recommendation?.Plate.OperatorAvailable ?? true;

    private bool DisableNext => _step switch
    {
        0 => false, // Machine is always pre-selected
        1 => (_selectedExistingProgram == null && !_creatingNewProgram),
        2 => _existingNeedsSlicerData
            ? !(_slicerPrintHours.HasValue && _slicerPrintHours > 0)
            : !_plateAllocations.Any(),
        _ => true
    };

    // ── Lifecycle ──

    protected override async Task OnParametersSetAsync()
    {
        if (!IsVisible)
        {
            _initialized = false;
            return;
        }

        if (_initialized) return;
        _initialized = true;

        _step = 0;
        _scheduling = false;
        _startAfterOverride = null;
        _showPartPicker = false;
        _plateEdited = false;
        _plateAllocations.Clear();
        _scheduleOptions.Clear();
        _selectedOption = null;
        _availablePrograms.Clear();
        _selectedExistingProgram = null;
        _existingNeedsSlicerData = false;
        _creatingNewProgram = false;
        ResetProgramState();

        _selectedMachineId = InitialMachineId
            ?? SlsMachines.FirstOrDefault()?.Id ?? 0;

        if (_selectedMachineId > 0)
            await LoadRecommendationAsync();
    }

    private void ResetProgramState()
    {
        _programName = "";
        _slicerPrintHours = null;
        _slicerLayerCount = null;
        _slicerBuildHeightMm = null;
        _slicerPowderKg = null;
        _slicerSoftware = null;
        _slicerVersion = null;
        _slicerFileName = null;

        _uploading = false;
        _createdProgramId = null;
        _uploadedFiles.Clear();
    }

    // ── Step 0: Loading ──

    private async Task OnMachineChangedById(int id)
    {
        _selectedMachineId = id;
        await OnMachineChanged();
    }

    private async Task OnMachineChanged()
    {
        _selectedExistingProgram = null;
        _existingNeedsSlicerData = false;
        _creatingNewProgram = false;
        _scheduleOptions.Clear();
        _selectedOption = null;
        if (_selectedMachineId > 0)
            await LoadRecommendationAsync();
    }

    private async Task LoadRecommendationAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _demand = await Advisor.GetAggregateDemandAsync();

            // Load certified layouts for plate composition
            _certifiedLayouts = await CertifiedLayoutService.GetCertifiedAsync();
            _plateLayoutAssignments = [];

            // Load build queue for selected machine
            var timeline = await ProgramScheduling.GetMachineTimelineAsync(
                _selectedMachineId, DateTime.UtcNow.AddDays(-1), DateTime.UtcNow.AddDays(14));
            _machineBuilds = timeline
                .Where(t => t.ScheduleStatus == ProgramScheduleStatus.Printing
                    || (t.ScheduleStatus == ProgramScheduleStatus.Scheduled && t.PrintEnd > DateTime.UtcNow))
                .OrderBy(t => t.PrintStart)
                .ToList();
            _currentBuild = _machineBuilds.FirstOrDefault();
            _scheduledBuildCount = _machineBuilds.Count(t =>
                t.ScheduleStatus == ProgramScheduleStatus.Scheduled);

            // Load builds from other machines for full context
            _otherMachineBuilds.Clear();
            foreach (var other in SlsMachines.Where(m => m.Id != _selectedMachineId))
            {
                var otherTimeline = await ProgramScheduling.GetMachineTimelineAsync(
                    other.Id, DateTime.UtcNow.AddDays(-1), DateTime.UtcNow.AddDays(14));
                foreach (var b in otherTimeline.Where(t =>
                    t.ScheduleStatus == ProgramScheduleStatus.Printing
                    || (t.ScheduleStatus == ProgramScheduleStatus.Scheduled && t.PrintEnd > DateTime.UtcNow))
                    .OrderBy(t => t.PrintStart))
                {
                    _otherMachineBuilds.Add((other.Name, b));
                }
            }

            // Load available programs
            _availablePrograms = await ProgramScheduling.GetAvailableBuildPlateProgramsAsync();

            // Build recommendation for the "create new" flow
            var slot = await ProgramScheduling.FindEarliestSlotAsync(
                _selectedMachineId, 1, _startAfterOverride ?? DateTime.UtcNow);

            var plate = await Advisor.OptimizePlateAsync(
                _selectedMachineId, slot.PrintStart, _demand,
                forcePrimaryPartId: InitialPartId);

            if (plate.EstimatedPrintHours > 0)
            {
                slot = await ProgramScheduling.FindEarliestSlotAsync(
                    _selectedMachineId, plate.EstimatedPrintHours,
                    _startAfterOverride ?? DateTime.UtcNow);
            }

            var machine = _selectedMachine;
            var warnings = new List<string>();
            var rationale = BuildRationale(plate, machine);

            if (!plate.OperatorAvailable && machine?.AutoChangeoverEnabled == true)
                warnings.Add($"Changeover at {plate.ChangeoverTime.ToLocalTime():MMM d h:mm tt} — no operator available. Machine may be down until next shift.");
            foreach (var part in plate.Parts.Where(p => p.Surplus > 0))
                warnings.Add($"{part.PartNumber}: {part.Surplus} surplus {(part.Surplus == 1 ? "part" : "parts")} beyond current demand (will go to stock).");

            _recommendation = new BuildRecommendation(
                _selectedMachineId, machine?.Name ?? "Machine", slot, plate, rationale, warnings);

            InitializePlateFromRecommendation();

            // Auto-select the best matching program for the recommended build's primary part
            var primaryPartId = plate.Parts.FirstOrDefault()?.PartId;
            if (primaryPartId.HasValue && _availablePrograms.Any())
            {
                var bestProgram = _availablePrograms
                    .Where(p => p.ProgramParts.Any(pp => pp.PartId == primaryPartId.Value))
                    .OrderByDescending(p => p.EstimatedPrintHours.HasValue && p.EstimatedPrintHours > 0)
                    .ThenByDescending(p => p.TotalPartCount)
                    .FirstOrDefault();

                if (bestProgram != null)
                    await OnExistingProgramSelected(bestProgram);
            }
        }
        catch (TaskCanceledException) { /* Circuit disconnected during load */ }
        catch (ObjectDisposedException) { /* Component disposed during load */ }
        catch (Exception ex)
        {
            Toast.ShowError($"Advisor error: {ex.Message}");
            _recommendation = null;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Program selection ──

    private async Task OnExistingProgramSelected(MachineProgram program)
    {
        _selectedExistingProgram = program;
        _creatingNewProgram = false;
        _existingNeedsSlicerData = !program.HasSlicerData;

        // Pre-populate slicer fields from existing program data (if any)
        if (_existingNeedsSlicerData)
        {
            _slicerPrintHours = program.EstimatedPrintHours;
            _slicerLayerCount = program.LayerCount;
            _slicerBuildHeightMm = program.BuildHeightMm;
            _slicerPowderKg = program.EstimatedPowderKg;
            _slicerSoftware = program.SlicerSoftware;
            _slicerVersion = program.SlicerVersion;
            _slicerFileName = program.SlicerFileName;
        }

        // Populate plate allocations from the existing program's parts,
        // linking to current demand WO lines for fulfillment
        _plateAllocations = program.ProgramParts.Select(pp =>
        {
            var demandInfo = _demand.FirstOrDefault(d => d.PartId == pp.PartId);
            // Use existing WO line if set, otherwise link from current demand
            var woLineId = pp.WorkOrderLineId ?? demandInfo?.SourceLines.FirstOrDefault()?.WorkOrderLineId;
            return new EditablePlateAllocation
            {
                PartId = pp.PartId,
                PartNumber = pp.Part?.PartNumber ?? demandInfo?.PartNumber ?? $"Part #{pp.PartId}",
                Positions = pp.Quantity,
                StackLevel = pp.StackLevel,
                DemandRemaining = demandInfo?.NetRemaining ?? 0,
                WorkOrderLineId = woLineId,
                WoDueDate = demandInfo?.EarliestDueDate,
                SourceLines = demandInfo?.SourceLines ?? []
            };
        }).ToList();

        // Generate timing options based on actual program duration
        await GenerateTimingOptionsForDuration(program.EstimatedPrintHours ?? 24);
    }

    private async Task OnCreateNewProgram()
    {
        _selectedExistingProgram = null;
        _creatingNewProgram = true;

        // Generate timing options based on recommendation
        var machine = _selectedMachine;
        if (machine?.AutoChangeoverEnabled == true && _recommendation != null)
        {
            var primary = _demand.FirstOrDefault(d => d.IsAdditive && d.NetRemaining > 0 && d.BuildConfig != null);
            if (primary?.BuildConfig != null)
            {
                var baseDuration = primary.BuildConfig.SingleStackDurationHours ?? 24;
                _scheduleOptions = await ProgramScheduling.GenerateScheduleOptionsAsync(
                    _selectedMachineId, baseDuration,
                    _startAfterOverride ?? DateTime.UtcNow,
                    primary.BuildConfig, primary.NetRemaining);
                _selectedOption = _scheduleOptions.FirstOrDefault();
            }
        }
    }

    private async Task GenerateTimingOptionsForDuration(double durationHours)
    {
        _scheduleOptions.Clear();
        _selectedOption = null;

        var machine = _selectedMachine;
        if (machine?.AutoChangeoverEnabled != true) return;

        // Generate options for the fixed duration (no stack level variants — program is already defined)
        var notBefore = _startAfterOverride ?? DateTime.UtcNow;
        var slot = await ProgramScheduling.FindEarliestSlotAsync(_selectedMachineId, durationHours, notBefore);

        var totalParts = _selectedExistingProgram?.TotalPartCount ?? 0;
        _scheduleOptions.Add(new ScheduleOption(
            Label: "Earliest",
            Description: $"{slot.PrintStart.ToLocalTime():MMM d h:mm tt} — {slot.PrintEnd.ToLocalTime():MMM d h:mm tt} ({durationHours:F1}h)",
            Slot: slot,
            StackLevel: 1,
            PartsPerBuild: totalParts,
            DurationHours: durationHours,
            ChangeoverAligned: slot.OperatorAvailableForChangeover,
            IsWeekendOptimal: false,
            RecommendationScore: slot.OperatorAvailableForChangeover ? 90 : 50));

        // If changeover isn't aligned, try to generate a shift-aligned option
        if (!slot.OperatorAvailableForChangeover)
        {
            var alignedOptions = await ProgramScheduling.GenerateScheduleOptionsAsync(
                _selectedMachineId, durationHours, notBefore);
            var aligned = alignedOptions.FirstOrDefault(o => o.ChangeoverAligned);
            if (aligned != null)
            {
                _scheduleOptions.Add(aligned with { Label = "Shift-Aligned" });
            }
        }

        _selectedOption = _scheduleOptions.OrderByDescending(o => o.RecommendationScore).FirstOrDefault();
    }

    private async Task RefreshTimingOptions()
    {
        if (_selectedExistingProgram != null)
            await GenerateTimingOptionsForDuration(_selectedExistingProgram.EstimatedPrintHours ?? 24);
        else if (_creatingNewProgram)
            await OnCreateNewProgram();
    }

    private void OnOptionSelected(ScheduleOption option)
    {
        _selectedOption = option;
    }

    // ── Plate management (for new programs) ──

    private void InitializePlateFromRecommendation()
    {
        _plateAllocations = _recommendation?.Plate.Parts.Select(p =>
        {
            var demandInfo = _demand.FirstOrDefault(d => d.PartId == p.PartId);
            return new EditablePlateAllocation
            {
                PartId = p.PartId,
                PartNumber = p.PartNumber,
                Positions = p.Positions,
                StackLevel = p.StackLevel,
                DemandRemaining = p.DemandRemaining,
                WorkOrderLineId = p.WorkOrderLineId,
                WoDueDate = p.WoDueDate,
                SourceLines = demandInfo?.SourceLines ?? []
            };
        }).ToList() ?? [];

        _plateEdited = false;
        _activeWarnings = _recommendation?.Warnings.ToList() ?? [];
        _showPartPicker = false;
        RecalculateWarnings();
    }

    private void ApplySelectedOptionToPlate()
    {
        if (_selectedOption == null) return;
        foreach (var alloc in _plateAllocations)
        {
            var config = _demand.FirstOrDefault(d => d.PartId == alloc.PartId)?.BuildConfig;
            if (config == null) continue;
            var levels = config.AvailableStackLevels;
            alloc.StackLevel = levels.Contains(_selectedOption.StackLevel)
                ? _selectedOption.StackLevel : levels.First();
            var maxPos = config.GetPositionsPerBuild(alloc.StackLevel);
            var needed = (int)Math.Ceiling((double)alloc.DemandRemaining / alloc.StackLevel);
            alloc.Positions = Math.Min(maxPos, Math.Max(1, needed));
        }
        _plateEdited = false;
        RecalculateWarnings();
    }

    private void ResetToRecommendation()
    {
        InitializePlateFromRecommendation();
        if (_selectedOption != null) ApplySelectedOptionToPlate();
    }

    // ── Certified Layout Mode Handlers ──

    private void OnComposerModeChanged(bool certified)
    {
        _useCertifiedLayouts = certified;
        if (certified)
        {
            // Switching to certified mode — clear free-form allocations
            // User will place certified layouts via the WYSIWYG editor
        }
    }

    private void OnPlateLayoutAssignmentsChanged(List<PlateSlotAssignment> assignments)
    {
        _plateLayoutAssignments = assignments;
        _plateEdited = true;

        // Sync certified layout assignments to the legacy _plateAllocations
        // so the rest of the wizard flow (timing, scheduling) still works
        _plateAllocations.Clear();
        foreach (var a in assignments)
        {
            var cl = _certifiedLayouts.FirstOrDefault(l => l.Id == a.CertifiedLayoutId);
            if (cl == null) continue;

            var demandMatch = _demand.FirstOrDefault(d => d.PartId == cl.PartId);
            _plateAllocations.Add(new EditablePlateAllocation
            {
                PartId = cl.PartId,
                PartNumber = cl.Part?.PartNumber ?? $"#{cl.PartId}",
                Positions = cl.Positions,
                StackLevel = cl.StackLevel,
                DemandRemaining = demandMatch?.NetRemaining ?? 0,
                SourceLines = demandMatch?.SourceLines ?? [],
                WoDueDate = demandMatch?.EarliestDueDate,
                WorkOrderLineId = demandMatch?.SourceLines?.FirstOrDefault()?.WorkOrderLineId
            });
        }

        RecalculateWarnings();
        StateHasChanged();
    }

    private void OnStackLevelChanged(int index, int newLevel)
    {
        if (index < 0 || index >= _plateAllocations.Count) return;
        var alloc = _plateAllocations[index];
        alloc.StackLevel = newLevel;

        var config = _demand.FirstOrDefault(d => d.PartId == alloc.PartId)?.BuildConfig;
        if (config != null)
        {
            var maxPos = config.GetPositionsPerBuild(newLevel);
            var needed = (int)Math.Ceiling((double)alloc.DemandRemaining / newLevel);
            alloc.Positions = Math.Min(maxPos, Math.Max(1, needed));
        }

        _plateEdited = true;
        RecalculateWarnings();
    }

    private void OnPositionsChanged(int index, int newPositions)
    {
        if (index < 0 || index >= _plateAllocations.Count) return;
        _plateAllocations[index].Positions = Math.Max(1, newPositions);
        _plateEdited = true;
        RecalculateWarnings();
    }

    private void RemoveFromPlate(int index)
    {
        if (index < 0 || index >= _plateAllocations.Count) return;
        _plateAllocations.RemoveAt(index);
        _plateEdited = true;
        RecalculateWarnings();
    }

    private void AddPartToPlate(DemandSummary d)
    {
        if (_plateAllocations.Any(a => a.PartId == d.PartId)) return;
        if (d.BuildConfig == null) return;

        var primaryLevel = _selectedOption?.StackLevel ?? _plateAllocations.FirstOrDefault()?.StackLevel ?? 1;
        var levels = d.BuildConfig.AvailableStackLevels;
        var level = levels.Contains(primaryLevel) ? primaryLevel : levels.First();

        var perBuild = d.BuildConfig.GetPositionsPerBuild(level);
        var needed = (int)Math.Ceiling((double)d.NetRemaining / level);
        var positions = Math.Min(perBuild, Math.Max(1, needed));

        _plateAllocations.Add(new EditablePlateAllocation
        {
            PartId = d.PartId,
            PartNumber = d.PartNumber,
            Positions = positions,
            StackLevel = level,
            DemandRemaining = d.NetRemaining,
            WorkOrderLineId = d.SourceLines.FirstOrDefault()?.WorkOrderLineId,
            WoDueDate = d.EarliestDueDate,
            SourceLines = d.SourceLines
        });

        _plateEdited = true;
        _showPartPicker = false;
        RecalculateWarnings();
    }

    private void OnAddPartSelected(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        if (!int.TryParse(val, out var partId)) return;
        var d = _demand.FirstOrDefault(x => x.PartId == partId);
        if (d != null) AddPartToPlate(d);
    }

    private void OnAddPartById(int partId)
    {
        var d = _demand.FirstOrDefault(x => x.PartId == partId);
        if (d != null) AddPartToPlate(d);
    }

    private void RecalculateWarnings()
    {
        _activeWarnings.Clear();
        foreach (var alloc in _plateAllocations)
        {
            if (alloc.Surplus > 0)
                _activeWarnings.Add($"{alloc.PartNumber}: {alloc.Surplus} surplus {(alloc.Surplus == 1 ? "part" : "parts")} beyond current demand (will go to stock).");
        }

        if (_selectedOption != null && !_selectedOption.ChangeoverAligned)
        {
            _activeWarnings.Add($"Changeover at {_selectedOption.Slot.ChangeoverStart.ToLocalTime():MMM d h:mm tt} — no operator available.");
        }
        else if (_recommendation != null && !_recommendation.Plate.OperatorAvailable && _selectedOption == null)
        {
            var machine = _selectedMachine;
            if (machine?.AutoChangeoverEnabled == true)
                _activeWarnings.Add($"Changeover at {_recommendation.Plate.ChangeoverTime.ToLocalTime():MMM d h:mm tt} — no operator available.");
        }
    }

    // ── Step navigation ──

    private async Task AdvanceStep()
    {
        if (_step == 0)
        {
            // Machine & Demand → Program Selection
            _step = 1;
            await ScrollToSelectedProgramAsync();
            return;
        }

        if (_step == 1)
        {
            if (_selectedExistingProgram != null)
            {
                if (_existingNeedsSlicerData)
                {
                    // Existing program missing slicer data — go to slicer entry step
                    _step = 2;
                    return;
                }
                // Existing program with slicer data — skip to review
                _step = 3;
                await CalculateBuildCostAsync();
                return;
            }
            else
            {
                // Creating new — go to plate composition form
                ApplySelectedOptionToPlate();
                // Generate default program name from plate parts
                if (string.IsNullOrWhiteSpace(_programName))
                {
                    _programName = string.Join("+", _plateAllocations.Select(a => a.PartNumber))
                        + $"-{DateTime.UtcNow:yyMMdd}";
                }
                // Create draft program immediately so file uploads work on Step 2
                await CreateDraftProgramAsync();
                _step = 2;
                return;
            }
        }
        _step++;
        // Calculate build cost when entering the review step
        if (_step == 3)
            await CalculateBuildCostAsync();
    }

    private async Task GoBack()
    {
        if (_step == 3 && _selectedExistingProgram != null && !_existingNeedsSlicerData)
        {
            _step = 1;
            await ScrollToSelectedProgramAsync();
        }
        else if (_step > 0)
        {
            _step--;
            if (_step == 1) await ScrollToSelectedProgramAsync();
        }
    }

    /// <summary>After render, scroll the program list to show the selected program card.</summary>
    private async Task ScrollToSelectedProgramAsync()
    {
        if (_selectedExistingProgram == null) return;
        // Wait for Blazor render, then scroll
        await Task.Yield();
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            await JS.InvokeVoidAsync("eval",
                $"document.getElementById('advisor-prog-{_selectedExistingProgram.Id}')?.scrollIntoView({{behavior:'smooth',block:'center'}})");
        }
        catch { /* JS interop may fail if component not rendered yet */ }
    }

    // ── Program creation (new programs only) ──

    private async Task CreateDraftProgramAsync()
    {
        if (_createdProgramId.HasValue) return; // already created

        List<ProgramPart> programParts;

        if (_useCertifiedLayouts && _plateLayoutAssignments.Any())
        {
            // Build ProgramParts from certified layout assignments
            programParts = _plateLayoutAssignments.Select(a =>
            {
                var cl = _certifiedLayouts.FirstOrDefault(l => l.Id == a.CertifiedLayoutId);
                var demandMatch = _demand.FirstOrDefault(d => d.PartId == cl?.PartId);
                return new ProgramPart
                {
                    PartId = cl?.PartId ?? 0,
                    Quantity = cl?.Positions ?? 0,
                    StackLevel = cl?.StackLevel ?? 1,
                    CertifiedLayoutId = a.CertifiedLayoutId,
                    PlateSlots = string.Join(",", a.Slots),
                    WorkOrderLineId = demandMatch?.SourceLines?.FirstOrDefault()?.WorkOrderLineId
                };
            }).Where(pp => pp.PartId > 0).ToList();
        }
        else
        {
            // Free-form mode — existing behavior
            programParts = _plateAllocations.Select(a => new ProgramPart
            {
                PartId = a.PartId,
                Quantity = a.Positions,
                StackLevel = a.StackLevel,
                WorkOrderLineId = a.WorkOrderLineId
            }).ToList();
        }

        var newProgram = new MachineProgram
        {
            Name = _programName,
            ProgramType = ProgramType.BuildPlate,
            MachineId = _selectedMachineId,
            UsesCertifiedLayouts = _useCertifiedLayouts && _plateLayoutAssignments.Any(),
            CreatedBy = UserName,
            LastModifiedBy = UserName,
            ProgramParts = programParts
        };

        var program = await ProgramPlanning.CreateBuildPlateAsync(newProgram, UserName);
        _createdProgramId = program.Id;

        // Increment use counts on certified layouts
        if (_useCertifiedLayouts)
        {
            foreach (var a in _plateLayoutAssignments)
            {
                var cl = _certifiedLayouts.FirstOrDefault(l => l.Id == a.CertifiedLayoutId);
                if (cl != null)
                {
                    cl.UseCount++;
                    cl.LastUsedDate = DateTime.UtcNow;
                }
            }
        }
    }

    private async Task HandleSliceFileUpload(InputFileChangeEventArgs e)
    {
        if (!_createdProgramId.HasValue) return;
        _uploading = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            var uploaded = await ProgramService.UploadFileAsync(
                _createdProgramId.Value, file.Name, stream, file.Size, UserName);
            _uploadedFiles.Add(uploaded);
            Toast.ShowSuccess($"File {file.Name} uploaded.");
        }
        catch (Exception ex) { Toast.ShowError($"Upload failed: {ex.Message}"); }
        finally { _uploading = false; }
    }

    // ── Scheduling ──

    private async Task ScheduleAndCloseAsync()
    {
        if (await ExecuteScheduleAsync())
        {
            await OnScheduled.InvokeAsync();
            await OnClose.InvokeAsync();
        }
    }

    private async Task ScheduleAndQueueNextAsync()
    {
        if (await ExecuteScheduleAsync())
        {
            _step = 0;
            _startAfterOverride = ActiveSlot?.PrintEnd;
            _plateEdited = false;
            _scheduleOptions.Clear();
            _selectedOption = null;
            _selectedExistingProgram = null;
            _existingNeedsSlicerData = false;
            _creatingNewProgram = false;
            ResetProgramState();
            await LoadRecommendationAsync();
        }
    }

    private async Task ScheduleAndSwitchMachineAsync()
    {
        if (OtherMachine == null) return;
        if (await ExecuteScheduleAsync())
        {
            _step = 0;
            _selectedMachineId = OtherMachine.Id;
            _startAfterOverride = null;
            _plateEdited = false;
            _scheduleOptions.Clear();
            _selectedOption = null;
            _selectedExistingProgram = null;
            _existingNeedsSlicerData = false;
            _creatingNewProgram = false;
            ResetProgramState();
            await LoadRecommendationAsync();
        }
    }

    private async Task<bool> ExecuteScheduleAsync()
    {
        if (!_plateAllocations.Any()) return false;
        _scheduling = true;

        try
        {
            StateHasChanged();
            await Task.Yield(); // Flush render so overlay appears before heavy DB work
            int programId;

            if (_selectedExistingProgram != null)
            {
                programId = _selectedExistingProgram.Id;

                // Save slicer data if it was entered for an existing program that was missing it
                if (_existingNeedsSlicerData && _slicerPrintHours.HasValue && _slicerPrintHours > 0)
                {
                    await ProgramPlanning.UpdateSlicerDataAsync(
                        programId, _slicerPrintHours,
                        _slicerLayerCount, _slicerBuildHeightMm, _slicerPowderKg,
                        _slicerFileName, _slicerSoftware, _slicerVersion);
                    _existingNeedsSlicerData = false;
                }

                // Use ScheduleBuildPlateRunAsync to create a copy and schedule it,
                // leaving the original program available for future scheduling
                var scheduleStart = ActiveSlot?.PrintStart ?? DateTime.UtcNow;
                var result = await ProgramScheduling.ScheduleBuildPlateRunAsync(programId, _selectedMachineId, scheduleStart);

                // Link the COPY's ProgramParts to WO lines (not the source's)
                // Use GroupBy to handle multiple allocations for the same PartId
                // (e.g. same part at different positions or for different WO lines)
                var woLinks = _plateAllocations
                    .Where(a => a.WorkOrderLineId.HasValue)
                    .GroupBy(a => a.PartId)
                    .ToDictionary(g => g.Key, g => g.First().WorkOrderLineId);
                if (woLinks.Any())
                    await ProgramPlanning.LinkProgramPartsToWorkOrdersAsync(result.MachineProgramId, woLinks);
            }
            else
            {
                // Create new program
                if (!_createdProgramId.HasValue)
                    await CreateDraftProgramAsync();

                programId = _createdProgramId!.Value;

                // Update program name if user changed it
                // Apply slicer data → transitions Draft to Ready
                if (_slicerPrintHours.HasValue && _slicerPrintHours > 0)
                {
                    await ProgramPlanning.UpdateSlicerDataAsync(
                        programId, _slicerPrintHours,
                        _slicerLayerCount, _slicerBuildHeightMm, _slicerPowderKg,
                        _slicerFileName, _slicerSoftware, _slicerVersion);
                }
                else
                {
                    // No slicer data entered — use a minimal duration so scheduling can proceed
                    await ProgramPlanning.UpdateSlicerDataAsync(programId, EstimatedPrintHours);
                }

                // New programs are scheduled directly (they are single-use)
                var scheduleStart = ActiveSlot?.PrintStart ?? DateTime.UtcNow;
                await ProgramScheduling.ScheduleBuildPlateAsync(programId, _selectedMachineId, scheduleStart);
            }

            _sessionBuilds++;
            var machine = _selectedMachine;
            var scheduledParts = _plateAllocations.Sum(a => a.TotalParts);
            Toast.ShowSuccess($"Build scheduled: {scheduledParts} {(scheduledParts == 1 ? "part" : "parts")} on {machine?.Name ?? "machine"}");
            _createdProgramId = null; // prevent cleanup on close
            return true;
        }
        catch (TaskCanceledException) { return false; /* Circuit disconnected */ }
        catch (ObjectDisposedException) { return false; /* Component disposed */ }
        catch (Exception ex)
        {
            Toast.ShowError($"Schedule failed: {ex.Message}");
            return false;
        }
        finally
        {
            _scheduling = false;
        }
    }

    private async Task Close()
    {
        // Clean up orphan Draft if we created one but didn't schedule
        if (_createdProgramId.HasValue)
        {
            try { await ProgramPlanning.DeleteBuildPlateAsync(_createdProgramId.Value); }
            catch { /* best effort cleanup */ }
        }

        if (_sessionBuilds > 0)
            await OnScheduled.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    // ── Helpers ──

    private static string BuildRationale(PlateComposition plate, Machine? machine)
    {
        var parts = plate.Parts;
        if (!parts.Any()) return "No demand found.";

        var primary = parts[0];
        var rationale = $"{primary.TotalParts}x {primary.PartNumber}";
        if (parts.Count > 1)
            rationale += $" + {parts.Skip(1).Sum(p => p.TotalParts)} fill parts ({parts.Count} types)";

        rationale += $", {(plate.RecommendedStackLevel > 1 ? $"{plate.RecommendedStackLevel}x stack" : "single stack")}";
        return rationale;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

