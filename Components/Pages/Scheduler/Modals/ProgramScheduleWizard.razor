@* ═══════════════════════════════════════════════════════════════════════════
   ProgramScheduleWizard — Multi-step wizard for scheduling work order lines
   via existing MachinePrograms (BuildPlate type) or creating new programs.
   ═══════════════════════════════════════════════════════════════════════════ *@
@inject IMachineProgramService ProgramService
@inject IProgramSchedulingService ProgramScheduling
@inject IProgramPlanningService ProgramPlanning
@inject IDownstreamProgramService DownstreamService
@inject IMachineService MachineService
@inject ToastService Toast

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content modal-lg" @onclick:stopPropagation>
            <div class="modal-header">
            <h3 class="modal-title">
                @if (_step == WizardStep.SelectParts)
                {
                    <span>📋 Select Parts to Schedule</span>
                }
                else if (_step == WizardStep.MatchPrograms)
                {
                    <span>🔗 Match Programs</span>
                }
                else if (_step == WizardStep.ConfigureRuns)
                {
                    <span>⚙️ Configure Print Runs</span>
                }
                else if (_step == WizardStep.DownstreamSetup)
                {
                    <span>🔧 Downstream Programs</span>
                }
                else
                {
                    <span>📅 Schedule Programs</span>
                }
            </h3>
            <button class="btn-icon" @onclick="Close">✕</button>
        </div>

        <div class="modal-body">
            @* ── Step Indicator ── *@
            <div class="wizard-steps">
                <div class="wizard-step @(_step >= WizardStep.SelectParts ? "wizard-step--active" : "") @(_step > WizardStep.SelectParts ? "wizard-step--done" : "")">
                    <span class="wizard-step-num">1</span>
                    <span class="wizard-step-label">Parts</span>
                </div>
                <div class="wizard-step-connector @(_step > WizardStep.SelectParts ? "wizard-step-connector--done" : "")"></div>
                <div class="wizard-step @(_step >= WizardStep.MatchPrograms ? "wizard-step--active" : "") @(_step > WizardStep.MatchPrograms ? "wizard-step--done" : "")">
                    <span class="wizard-step-num">2</span>
                    <span class="wizard-step-label">Programs</span>
                </div>
                <div class="wizard-step-connector @(_step > WizardStep.MatchPrograms ? "wizard-step-connector--done" : "")"></div>
                <div class="wizard-step @(_step >= WizardStep.ConfigureRuns ? "wizard-step--active" : "") @(_step > WizardStep.ConfigureRuns ? "wizard-step--done" : "")">
                    <span class="wizard-step-num">3</span>
                    <span class="wizard-step-label">Runs</span>
                </div>
                <div class="wizard-step-connector @(_step > WizardStep.ConfigureRuns ? "wizard-step-connector--done" : "")"></div>
                <div class="wizard-step @(_step >= WizardStep.DownstreamSetup ? "wizard-step--active" : "") @(_step > WizardStep.DownstreamSetup ? "wizard-step--done" : "")">
                    <span class="wizard-step-num">4</span>
                    <span class="wizard-step-label">Downstream</span>
                </div>
                <div class="wizard-step-connector @(_step > WizardStep.DownstreamSetup ? "wizard-step-connector--done" : "")"></div>
                <div class="wizard-step @(_step >= WizardStep.Schedule ? "wizard-step--active" : "")">
                    <span class="wizard-step-num">5</span>
                    <span class="wizard-step-label">Schedule</span>
                </div>
            </div>

            @* ── Loading/Error States ── *@
            @if (_isLoading)
            {
                <div class="wizard-loading">
                    <span class="spinner"></span>
                    <span>Loading parts and programs...</span>
                </div>
            }
            else if (_errorMessage != null)
            {
                <div class="wizard-error">
                    <strong>⚠️ Error</strong>
                    <p style="margin: 8px 0 0;">@_errorMessage</p>
                </div>
            }

            @* ── Step 1: Select Parts ── *@
            @if (!_isLoading && _errorMessage == null && _step == WizardStep.SelectParts)
            {
                <div class="wizard-content">
                    <p class="wizard-hint">Select the SLS parts you want to schedule. Parts with existing programs will be shown with their match status.</p>

                    @if (!_partSelections.Any())
                    {
                        <div class="empty-state">No additive parts require scheduling.</div>
                    }
                    else
                    {
                        <div class="program-wizard-parts">
                            @foreach (var ps in _partSelections)
                            {
                                <div class="program-wizard-part @(ps.IsSelected ? "program-wizard-part--selected" : "")">
                                    <label class="program-wizard-part-check">
                                        <input type="checkbox" @bind="ps.IsSelected" />
                                    </label>
                                    <div class="program-wizard-part-info">
                                        <div class="program-wizard-part-header">
                                            <span class="program-wizard-part-number">@ps.Line.Part?.PartNumber</span>
                                            <span class="program-wizard-part-name">@ps.Line.Part?.Name</span>
                                        </div>
                                        <div class="program-wizard-part-detail">
                                            <span class="badge badge-info">@ps.OutstandingQty outstanding</span>
                                            @if (ps.MatchingPrograms.Any())
                                            {
                                                <span class="badge badge-success">@ps.MatchingPrograms.Count program(s) available</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-warning">No program — will create new</span>
                                            }
                                            @if (ps.Line.Part?.AdditiveBuildConfig?.PlannedPartsPerBuildSingle > 0)
                                            {
                                                <span class="badge badge-secondary">@ps.Line.Part.AdditiveBuildConfig.PlannedPartsPerBuildSingle per build</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="program-wizard-part-wo">
                                        <span class="text-muted">@WorkOrder?.OrderNumber</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @* ── Step 2: Match Programs ── *@
            @if (!_isLoading && _errorMessage == null && _step == WizardStep.MatchPrograms)
            {
                <div class="wizard-content">
                    <p class="wizard-hint">Select which program to use for each part, or create a new program.</p>

                    @foreach (var ps in _partSelections.Where(p => p.IsSelected))
                    {
                        <div class="program-wizard-match">
                            <div class="program-wizard-match-header">
                                <span class="program-wizard-match-part">@ps.Line.Part?.PartNumber — @ps.OutstandingQty parts needed</span>
                            </div>

                            @if (ps.MatchingPrograms.Any())
                            {
                                <div class="program-wizard-match-options">
                                    @foreach (var prog in ps.MatchingPrograms)
                                    {
                                        var isSelected = ps.SelectedProgramId == prog.Id;
                                        <div class="program-wizard-match-option @(isSelected ? "program-wizard-match-option--selected" : "")"
                                             @onclick="() => SelectProgram(ps, prog.Id)">
                                            <div class="program-wizard-match-option-radio">
                                                <input type="radio" name="prog-@ps.Line.Id" checked="@isSelected" />
                                            </div>
                                            <div class="program-wizard-match-option-info">
                                                <div class="program-wizard-match-option-name">
                                                    @prog.Name
                                                    @if (prog.Status == ProgramStatus.Active)
                                                    {
                                                        <span class="badge badge-success badge-sm">Active</span>
                                                    }
                                                </div>
                                                <div class="program-wizard-match-option-detail">
                                                    @if (prog.EstimatedPrintHours.HasValue)
                                                    {
                                                        <span>@prog.EstimatedPrintHours.Value.ToString("F1")h print</span>
                                                    }
                                                    @if (prog.ProgramParts?.Any() == true)
                                                    {
                                                        var partQty = prog.ProgramParts.Where(pp => pp.PartId == ps.Line.PartId).Sum(pp => pp.Quantity);
                                                        <span>· @partQty per run</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    <div class="program-wizard-match-option @(ps.SelectedProgramId == -1 ? "program-wizard-match-option--selected" : "")"
                                         @onclick="() => SelectProgram(ps, -1)">
                                        <div class="program-wizard-match-option-radio">
                                            <input type="radio" name="prog-@ps.Line.Id" checked="@(ps.SelectedProgramId == -1)" />
                                        </div>
                                        <div class="program-wizard-match-option-info">
                                            <span class="program-wizard-match-option-name">+ Create New Program</span>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="program-wizard-no-match">
                                    <span class="text-warning">⚠️ No existing program contains this part.</span>
                                    <span>A new BuildPlate program will be created.</span>
                                    <input type="text" class="form-control" style="max-width:300px;margin-top:8px;"
                                           placeholder="New program name…"
                                           @bind="ps.NewProgramName" />
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @* ── Step 3: Configure Runs ── *@
            @if (!_isLoading && _errorMessage == null && _step == WizardStep.ConfigureRuns)
            {
                <div class="wizard-content">
                    <p class="wizard-hint">Configure how many print runs of each program are needed to fulfill the demand.</p>

                    @foreach (var ps in _partSelections.Where(p => p.IsSelected))
                    {
                        var partsPerRun = ps.GetPartsPerRun();
                        var recommendedRuns = ps.OutstandingQty > 0 && partsPerRun > 0
                            ? (int)Math.Ceiling((double)ps.OutstandingQty / partsPerRun)
                            : 1;
                        var totalParts = ps.RunCount * partsPerRun;

                        <div class="program-wizard-run-config">
                            <div class="program-wizard-run-header">
                                <span class="program-wizard-run-part">@ps.Line.Part?.PartNumber</span>
                                <span class="text-muted">via @(ps.SelectedProgramId > 0 ? ps.MatchingPrograms.FirstOrDefault(p => p.Id == ps.SelectedProgramId)?.Name : ps.NewProgramName)</span>
                            </div>
                            <div class="program-wizard-run-detail">
                                <div class="program-wizard-run-input">
                                    <label>Runs:</label>
                                    <input type="number" min="1" max="50" class="form-control" style="width:80px;"
                                           @bind="ps.RunCount" />
                                    <span class="text-muted">× @partsPerRun parts = @totalParts total</span>
                                </div>
                                @if (totalParts < ps.OutstandingQty)
                                {
                                    <span class="text-warning">⚠️ @(ps.OutstandingQty - totalParts) parts short — increase runs</span>
                                }
                                else if (totalParts > ps.OutstandingQty)
                                {
                                    <span class="text-success">✓ @(totalParts - ps.OutstandingQty) extra (stock build)</span>
                                }
                                else
                                {
                                    <span class="text-success">✓ Exact match</span>
                                }
                            </div>
                            @if (recommendedRuns != ps.RunCount)
                            {
                                <button class="btn btn-sm btn-ghost" @onclick="() => ps.RunCount = recommendedRuns">
                                    Set to recommended (@recommendedRuns)
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            @* ── Step 4: Downstream Setup ── *@
            @if (!_isLoading && _errorMessage == null && _step == WizardStep.DownstreamSetup)
            {
                <div class="wizard-content">
                    <p class="wizard-hint">Review downstream processing stages. Required stages need programs assigned before scheduling.</p>

                    @if (_downstreamLoading)
                    {
                        <div class="wizard-loading">
                            <span class="spinner"></span>
                            <span>Loading downstream requirements...</span>
                        </div>
                    }
                    else if (!_downstreamRequirements.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">✅</div>
                            <div class="empty-state-text">No downstream stages required — ready to schedule.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var ps in _partSelections.Where(p => p.IsSelected && p.SelectedProgramId > 0))
                        {
                            var reqs = _downstreamRequirements.GetValueOrDefault(ps.SelectedProgramId) ?? [];
                            if (!reqs.Any()) continue;

                            <div class="program-wizard-match" style="margin-bottom: 12px;">
                                <div class="program-wizard-match-header">
                                    <span class="program-wizard-match-part">📋 @(ps.MatchingPrograms.FirstOrDefault(p => p.Id == ps.SelectedProgramId)?.Name ?? "Program")</span>
                                </div>
                                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                                    @foreach (var req in reqs.OrderBy(r => r.ExecutionOrder))
                                    {
                                        var statusClass = req.AssignedProgramId.HasValue
                                            ? "downstream-stage--ready"
                                            : req.HasDefaultParameters
                                                ? "downstream-stage--default"
                                                : "downstream-stage--missing";
                                        var statusIcon = req.AssignedProgramId.HasValue ? "🟢" : req.HasDefaultParameters ? "🟡" : "🔴";

                                        <div class="downstream-stage @statusClass">
                                            <div style="display: flex; align-items: center; gap: 12px;">
                                                <span style="font-size: 1.1rem;">@statusIcon</span>
                                                <div style="flex: 1;">
                                                    <div style="font-weight: 600;">@req.StageName</div>
                                                    <div style="font-size: 0.8rem; color: var(--text-muted);">@req.MachineType · @(req.IsRequired ? "Required" : "Optional")</div>
                                                </div>
                                                @if (req.AssignedProgramId.HasValue)
                                                {
                                                    <span class="badge badge-success">@req.AssignedProgramName</span>
                                                }
                                                else if (req.HasDefaultParameters)
                                                {
                                                    <button class="btn btn-sm btn-warning"
                                                            @onclick="() => CreateDownstreamPlaceholderAsync(ps.SelectedProgramId, req)"
                                                            disabled="@_downstreamProcessing">
                                                        ⚡ Create with Defaults
                                                    </button>
                                                }
                                                else if (req.IsRequired)
                                                {
                                                    <span class="badge badge-danger">⚠️ Program needed</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (HasUnassignedDefaults)
                        {
                            <div style="margin-top: 12px;">
                                <button class="btn btn-warning" @onclick="CreateAllDownstreamPlaceholdersAsync" disabled="@_downstreamProcessing">
                                    ⚡ Create All with Defaults
                                </button>
                            </div>
                        }
                    }
                </div>
            }

            @* ── Step 5: Schedule ── *@
            @if (!_isLoading && _errorMessage == null && _step == WizardStep.Schedule)
            {
                <div class="wizard-content">
                    <p class="wizard-hint">Select machines and confirm scheduling. Programs will be scheduled in sequence.</p>

                    <div class="program-wizard-schedule-options">
                        <div class="form-group">
                            <label>Machine Selection:</label>
                            <select class="form-control" @bind="_machineSelectionMode">
                                <option value="auto">🤖 Auto-select (earliest available slot)</option>
                                <option value="manual">🔧 Manual selection per program</option>
                            </select>
                        </div>

                        @if (_machineSelectionMode == "manual")
                        {
                            @foreach (var ps in _partSelections.Where(p => p.IsSelected))
                            {
                                <div class="program-wizard-machine-select">
                                    <label>@ps.Line.Part?.PartNumber:</label>
                                    <select class="form-control" @bind="ps.SelectedMachineId">
                                        <option value="0">Auto-select</option>
                                        @foreach (var m in SlsMachines)
                                        {
                                            <option value="@m.Id">@m.Name</option>
                                        }
                                    </select>
                                </div>
                            }
                        }

                        <div class="form-group" style="margin-top:16px;">
                            <label>Start After:</label>
                            <input type="datetime-local" class="form-control" style="max-width:250px;"
                                   @bind="_startAfter" />
                        </div>
                    </div>

                    @* ── Summary ── *@
                    <div class="program-wizard-summary">
                        <h4>Schedule Summary</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Part</th>
                                    <th>Program</th>
                                    <th>Runs</th>
                                    <th>Parts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ps in _partSelections.Where(p => p.IsSelected))
                                {
                                    var progName = ps.SelectedProgramId > 0
                                        ? ps.MatchingPrograms.FirstOrDefault(p => p.Id == ps.SelectedProgramId)?.Name ?? "?"
                                        : ps.NewProgramName ?? "New Program";
                                    <tr>
                                        <td>@ps.Line.Part?.PartNumber</td>
                                        <td>@progName</td>
                                        <td>@ps.RunCount</td>
                                        <td>@(ps.RunCount * ps.GetPartsPerRun())</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (_step > WizardStep.SelectParts)
            {
                <button class="btn btn-secondary" @onclick="PreviousStep" disabled="@_scheduling">← Back</button>
            }
            <div style="flex:1;"></div>
            
            @if (_step < WizardStep.Schedule)
            {
                <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanProceed())">
                    Next →
                </button>
            }
            else
            {
                <button class="btn btn-primary" @onclick="ExecuteScheduleAsync" disabled="@(_scheduling || !CanProceed())">
                    @if (_scheduling)
                    {
                        <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span>
                        <span>Scheduling...</span>
                    }
                    else
                    {
                        <span>📅 Schedule @_partSelections.Count(p => p.IsSelected) Program(s)</span>
                    }
                </button>
            }
        </div>
    </div>
</div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public WorkOrder? WorkOrder { get; set; }
    [Parameter] public List<WorkOrderLine>? Lines { get; set; }
    [Parameter] public List<Machine> SlsMachines { get; set; } = [];
    [Parameter] public string UserName { get; set; } = "System";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnScheduled { get; set; }

    private enum WizardStep { SelectParts, MatchPrograms, ConfigureRuns, DownstreamSetup, Schedule }
    private WizardStep _step = WizardStep.SelectParts;

    private List<PartSelection> _partSelections = [];
    private string _machineSelectionMode = "auto";
    private DateTime _startAfter = DateTime.UtcNow;
    private bool _scheduling;
    private bool _isLoading;
    private string? _errorMessage;

    // Downstream state
    private Dictionary<int, List<DownstreamProgramRequirement>> _downstreamRequirements = [];
    private bool _downstreamLoading;
    private bool _downstreamProcessing;

    private class PartSelection
    {
        public WorkOrderLine Line { get; set; } = null!;
        public int OutstandingQty { get; set; }
        public bool IsSelected { get; set; } = true;
        public List<MachineProgram> MatchingPrograms { get; set; } = [];
        public int SelectedProgramId { get; set; } // -1 = create new
        public string NewProgramName { get; set; } = "";
        public int RunCount { get; set; } = 1;
        public int SelectedMachineId { get; set; }

        public int GetPartsPerRun()
        {
            if (SelectedProgramId > 0)
            {
                var prog = MatchingPrograms.FirstOrDefault(p => p.Id == SelectedProgramId);
                if (prog?.ProgramParts != null)
                    return prog.ProgramParts.Where(pp => pp.PartId == Line.PartId).Sum(pp => pp.Quantity);
            }
            // Fallback to build config
            return Line.Part?.AdditiveBuildConfig?.PlannedPartsPerBuildSingle ?? 1;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && WorkOrder != null && Lines != null && !_partSelections.Any())
        {
            await InitializeSelectionsAsync();
        }
    }

    private async Task InitializeSelectionsAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _partSelections.Clear();
        _step = WizardStep.SelectParts;
        StateHasChanged();

        try
        {
            foreach (var line in Lines ?? [])
            {
                // Only additive parts - with null safety
                if (line.Part?.ManufacturingApproach?.RequiresBuildPlate != true) continue;

                var outstanding = CalculateOutstanding(line);
                if (outstanding <= 0) continue;

                // Find existing programs containing this part
                var programs = await ProgramService.GetBuildPlateProgramsAsync(ProgramStatus.Active);
                var matching = programs
                    .Where(p => p.ProgramParts?.Any(pp => pp.PartId == line.PartId) == true
                             && p.EstimatedPrintHours.HasValue)
                    .ToList();

            var ps = new PartSelection
            {
                Line = line,
                OutstandingQty = outstanding,
                MatchingPrograms = matching,
                SelectedProgramId = matching.FirstOrDefault()?.Id ?? -1,
                NewProgramName = $"Build-{line.Part.PartNumber}-{DateTime.UtcNow:yyMMdd}"
            };

            // Calculate recommended runs
            var partsPerRun = ps.GetPartsPerRun();
            if (partsPerRun > 0 && outstanding > 0)
                ps.RunCount = (int)Math.Ceiling((double)outstanding / partsPerRun);

            _partSelections.Add(ps);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to initialize wizard: {ex.Message}";
            Console.WriteLine($"[ProgramScheduleWizard] Error: {ex}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private int CalculateOutstanding(WorkOrderLine line)
    {
        var produced = line.ProducedQuantity;
        var inPrograms = line.ProgramParts?
            .Where(pp => pp.MachineProgram?.ScheduleStatus is not (ProgramScheduleStatus.Completed or ProgramScheduleStatus.Cancelled))
            .Sum(pp => pp.Quantity) ?? 0;
        return Math.Max(0, line.Quantity - produced - inPrograms);
    }

    private void SelectProgram(PartSelection ps, int programId)
    {
        ps.SelectedProgramId = programId;
        // Recalculate runs when program changes
        var partsPerRun = ps.GetPartsPerRun();
        if (partsPerRun > 0 && ps.OutstandingQty > 0)
            ps.RunCount = (int)Math.Ceiling((double)ps.OutstandingQty / partsPerRun);
    }

    private bool CanProceed() => _step switch
    {
        WizardStep.SelectParts => _partSelections.Any(p => p.IsSelected),
        WizardStep.MatchPrograms => _partSelections.Where(p => p.IsSelected).All(p =>
            p.SelectedProgramId > 0 || !string.IsNullOrWhiteSpace(p.NewProgramName)),
        WizardStep.ConfigureRuns => _partSelections.Where(p => p.IsSelected).All(p => p.RunCount > 0),
        WizardStep.DownstreamSetup => DownstreamReady,
        WizardStep.Schedule => true,
        _ => true
    };

    private async Task NextStep()
    {
        if (_step < WizardStep.Schedule)
        {
            _step++;
            if (_step == WizardStep.DownstreamSetup)
                await LoadDownstreamRequirementsAsync();
        }
    }

    private void PreviousStep()
    {
        if (_step > WizardStep.SelectParts)
            _step--;
    }

    // ── Downstream helpers ──────────────────────────────

    /// <summary>All required downstream stages have programs assigned.</summary>
    private bool DownstreamReady => _downstreamRequirements.Values
        .SelectMany(r => r)
        .Where(r => r.IsRequired)
        .All(r => r.AssignedProgramId.HasValue);

    /// <summary>At least one unassigned stage has default parameters available.</summary>
    private bool HasUnassignedDefaults => _downstreamRequirements.Values
        .SelectMany(r => r)
        .Any(r => !r.AssignedProgramId.HasValue && r.HasDefaultParameters);

    private async Task LoadDownstreamRequirementsAsync()
    {
        _downstreamLoading = true;
        _downstreamRequirements.Clear();
        StateHasChanged();

        try
        {
            foreach (var ps in _partSelections.Where(p => p.IsSelected && p.SelectedProgramId > 0))
            {
                var reqs = await DownstreamService.GetRequiredProgramsAsync(ps.SelectedProgramId);
                if (reqs.Any())
                    _downstreamRequirements[ps.SelectedProgramId] = reqs;
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load downstream requirements: {ex.Message}");
        }
        finally
        {
            _downstreamLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateDownstreamPlaceholderAsync(int programId, DownstreamProgramRequirement req)
    {
        _downstreamProcessing = true;
        StateHasChanged();
        try
        {
            await DownstreamService.CreatePlaceholderProgramsAsync(programId, [req.ProcessStageId], UserName);
            Toast.ShowSuccess($"Created placeholder program for {req.StageName}");
            await LoadDownstreamRequirementsAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed: {ex.Message}");
        }
        finally
        {
            _downstreamProcessing = false;
        }
    }

    private async Task CreateAllDownstreamPlaceholdersAsync()
    {
        _downstreamProcessing = true;
        StateHasChanged();
        try
        {
            var totalCreated = 0;
            foreach (var (programId, reqs) in _downstreamRequirements)
            {
                var stageIds = reqs
                    .Where(r => !r.AssignedProgramId.HasValue && r.HasDefaultParameters)
                    .Select(r => r.ProcessStageId)
                    .ToList();
                if (stageIds.Any())
                {
                    await DownstreamService.CreatePlaceholderProgramsAsync(programId, stageIds, UserName);
                    totalCreated += stageIds.Count;
                }
            }
            Toast.ShowSuccess($"Created {totalCreated} placeholder program(s)");
            await LoadDownstreamRequirementsAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed: {ex.Message}");
        }
        finally
        {
            _downstreamProcessing = false;
        }
    }

    private async Task ExecuteScheduleAsync()
    {
        _scheduling = true;
        StateHasChanged();

        try
        {
            var scheduled = 0;
            var errors = new List<string>();

            foreach (var ps in _partSelections.Where(p => p.IsSelected))
            {
                try
                {
                    int programId = ps.SelectedProgramId;

                    // Create new program if needed
                    if (programId <= 0)
                    {
                        var newProgram = new MachineProgram
                        {
                            Name = ps.NewProgramName,
                            ProgramType = ProgramType.BuildPlate,
                            Status = ProgramStatus.Active,
                            ScheduleStatus = ProgramScheduleStatus.Ready,
                            CreatedBy = UserName,
                            LastModifiedBy = UserName
                        };
                        var created = await ProgramPlanning.CreateBuildPlateAsync(newProgram, UserName);

                        // Add the part
                        await ProgramPlanning.AddPartToProgramAsync(
                            created.Id,
                            ps.Line.PartId,
                            ps.Line.Part?.AdditiveBuildConfig?.PlannedPartsPerBuildSingle ?? ps.OutstandingQty,
                            ps.Line.Id);

                        programId = created.Id;
                        Toast.ShowSuccess($"Created program: {created.Name}");
                    }

                    // Schedule the runs
                    for (int run = 0; run < ps.RunCount; run++)
                    {
                        var machineId = _machineSelectionMode == "manual" && ps.SelectedMachineId > 0
                            ? ps.SelectedMachineId
                            : (int?)null;

                        if (run == 0)
                        {
                            // First run uses the original program
                            if (machineId.HasValue)
                                await ProgramScheduling.ScheduleBuildPlateAsync(programId, machineId.Value, _startAfter);
                            else
                                await ProgramScheduling.ScheduleBuildPlateAutoMachineAsync(programId, _startAfter);
                        }
                        else
                        {
                            // Additional runs create copies
                            if (machineId.HasValue)
                                await ProgramScheduling.ScheduleBuildPlateRunAsync(programId, machineId.Value, _startAfter);
                            else
                                await ProgramScheduling.ScheduleBuildPlateRunAutoMachineAsync(programId, _startAfter);
                        }
                        scheduled++;
                    }
                }
                catch (Exception ex)
                {
                    errors.Add($"{ps.Line.Part?.PartNumber}: {ex.Message}");
                }
            }

            if (errors.Any())
            {
                Toast.ShowWarning($"Scheduled {scheduled} run(s) with {errors.Count} error(s)");
                foreach (var err in errors.Take(3))
                    Toast.ShowError(err);
            }
            else
            {
                Toast.ShowSuccess($"Successfully scheduled {scheduled} program run(s)");
            }

            await OnScheduled.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Scheduling failed: {ex.Message}");
        }
        finally
        {
            _scheduling = false;
        }
    }

    private void Close()
    {
        _partSelections.Clear();
        _downstreamRequirements.Clear();
        _step = WizardStep.SelectParts;
        _isLoading = false;
        _errorMessage = null;
        OnClose.InvokeAsync();
    }
}
