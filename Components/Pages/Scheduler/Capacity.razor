@page "/scheduler/capacity"
@inject IStageService StageService
@inject IOeeService OeeService
@inject ICapacityPlanningService CapacityService
@inject IBuildAdvisorService BuildAdvisor
@inject ISetupDispatchService DispatchService
@inject ToastService Toast
@using Vectrik.Models.Enums
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Manager,Supervisor")]

<PageTitle>Capacity Management - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Machine Capacity Management</h1>
    <div style="display: flex; gap: 8px;">
        <button class="btn btn-accent" @onclick="OpenWizard">Smart Assign</button>
        <a href="scheduler" class="btn btn-secondary">Scheduler</a>
    </div>
</div>

@* ── Date Range ── *@
<div class="sched-controls">
    <div class="sched-date-range">
        <label>From</label>
        <input type="date" @bind="_from" @bind:event="oninput" />
        <label>To</label>
        <input type="date" @bind="_to" @bind:event="oninput" />
        <button class="btn btn-xs btn-secondary" @onclick="LoadDataAsync">Refresh</button>
    </div>
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading capacity data...</div>
}
else
{
    @* ── Section A: Machine Cards Grid ── *@
    <div class="capacity-section">
        <h2>Machine Overview</h2>
        <div class="capacity-cards">
            @foreach (var card in _machineCards)
            {
                <div class="capacity-card @(card.UtilizationPct > 100 ? "capacity-card--overloaded" : card.UtilizationPct > 85 ? "capacity-card--high" : "")">
                    <div class="capacity-card-header">
                        <span class="capacity-card-name">@card.MachineName</span>
                        <span class="capacity-card-type">@card.MachineType</span>
                        <span class="capacity-card-status capacity-card-status--@card.Status.ToString().ToLower()">@card.Status</span>
                    </div>

                    @if (card.CurrentProgramName != null)
                    {
                        <div class="capacity-card-program">Loaded: @card.CurrentProgramName</div>
                    }

                    <div class="capacity-card-util">
                        <div class="capacity-util-bar">
                            <div class="capacity-util-fill" style="width: @Math.Min(100, card.UtilizationPct)%; background: @GetUtilColor(card.UtilizationPct)"></div>
                        </div>
                        <span class="capacity-util-pct">@($"{card.UtilizationPct:F0}")%</span>
                        <span class="capacity-util-hours">@($"{card.LoadedHours:F1}")h / @($"{card.AvailableHours:F1}")h</span>
                    </div>

                    <div class="capacity-card-queue">
                        <span>@card.QueueCount queued</span>
                        @if (card.NextDuePart != null)
                        {
                            <span class="@(card.NextDueDate < DateTime.UtcNow ? "capacity-overdue" : "")">
                                Next: @card.NextDuePart @(card.NextDueDate.HasValue ? $"(due {card.NextDueDate.Value:MMM d})" : "")
                            </span>
                        }
                    </div>

                    @if (!card.IsAdditive)
                    {
                        <button class="btn btn-xs btn-primary capacity-card-action" @onclick="() => OpenWizardForMachine(card.MachineId)">Assign Work</button>
                    }
                </div>
            }
        </div>
    </div>

    @* ── Section B: Demand Gap Panel ── *@
    <div class="capacity-section">
        <h2>Demand Gaps (@_demandGaps.Count parts with unmet demand)</h2>
        @if (_demandGaps.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Part</th>
                        <th>Demand</th>
                        <th>Scheduled</th>
                        <th>Gap</th>
                        <th>Machines</th>
                        <th>Due Date</th>
                        <th>Priority</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gap in _demandGaps)
                    {
                        <tr class="@(gap.IsOverdue ? "capacity-row-overdue" : "")">
                            <td class="font-mono">@gap.PartNumber</td>
                            <td>@gap.DemandQty</td>
                            <td>@gap.ScheduledQty</td>
                            <td><strong>@gap.GapQty</strong></td>
                            <td>@gap.CapableMachineCount</td>
                            <td class="@(gap.IsOverdue ? "capacity-overdue" : "")">@gap.EarliestDueDate.ToString("MMM d")</td>
                            <td><span class="capacity-priority capacity-priority--@gap.HighestPriority.ToString().ToLower()">@gap.HighestPriority</span></td>
                            <td><button class="btn btn-xs btn-accent" @onclick="() => AssignPart(gap.PartId)">Assign</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state"><div class="empty-state-text">All demand is covered.</div></div>
        }
    </div>

    @* ── Section C: Bottleneck Alerts ── *@
    @if (_bottlenecks != null && _bottlenecks.Items.Any())
    {
        <div class="capacity-section">
            <h2>Bottleneck Alerts</h2>
            <div class="capacity-bottlenecks">
                @foreach (var item in _bottlenecks.Items)
                {
                    <div class="capacity-bottleneck capacity-bottleneck--@item.Severity.ToLower()">
                        <span class="capacity-bottleneck-dept">@item.Department @(item.MachineName != null ? $"({item.MachineName})" : "")</span>
                        <span>Utilization: @($"{item.UtilizationPct:F0}")% | Queue: @($"{item.QueueHours:F1}")h</span>
                    </div>
                }
                @foreach (var rec in _bottlenecks.Recommendations)
                {
                    <div class="capacity-recommendation">@rec</div>
                }
            </div>
        </div>
    }
}

@* ── Setup Assignment Wizard Modal ── *@
@if (_showWizard)
{
    <div class="modal-overlay" @onclick="CloseWizard">
        <div class="modal-content modal-lg" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Smart Setup Assignment</h3>
                <div class="setup-wizard-steps">
                    <span class="setup-wizard-step @(_wizardStep == 0 ? "active" : _wizardStep > 0 ? "done" : "")">1. Select Demand</span>
                    <span class="setup-wizard-step @(_wizardStep == 1 ? "active" : _wizardStep > 1 ? "done" : "")">2. Machine Assignment</span>
                    <span class="setup-wizard-step @(_wizardStep == 2 ? "active" : "")">3. Confirm</span>
                </div>
                <button class="modal-close" @onclick="CloseWizard">&times;</button>
            </div>
            <div class="modal-body">

                @if (_wizardStep == 0)
                {
                    @* Step 1: Select demand *@
                    <p style="color: var(--text-secondary); margin-bottom: 12px;">Select parts with unmet demand to assign to machines.</p>
                    @foreach (var gap in _demandGaps)
                    {
                        <label class="setup-wizard-demand-item @(gap.IsOverdue ? "setup-wizard-demand-overdue" : "")">
                            <input type="checkbox" checked="@_selectedPartIds.Contains(gap.PartId)"
                                   @onchange="(e) => TogglePartSelection(gap.PartId, (bool)(e.Value ?? false))" />
                            <span class="font-mono">@gap.PartNumber</span>
                            <span>x@(gap.GapQty) needed</span>
                            <span class="@(gap.IsOverdue ? "capacity-overdue" : "")">Due: @gap.EarliestDueDate.ToString("MMM d")</span>
                            <span class="capacity-priority capacity-priority--@gap.HighestPriority.ToString().ToLower()">@gap.HighestPriority</span>
                        </label>
                    }
                }
                else if (_wizardStep == 1)
                {
                    @* Step 2: Machine assignment *@
                    <p style="color: var(--text-secondary); margin-bottom: 12px;">Review recommended machine assignments. The system selected the best option based on changeover, due dates, and throughput.</p>
                    @foreach (var partId in _selectedPartIds)
                    {
                        var partSuggestions = _suggestions.Where(s => s.PartId == partId).ToList();
                        if (!partSuggestions.Any()) continue;
                        <div class="setup-wizard-part-group">
                            <h4 class="font-mono">@partSuggestions.First().PartNumber — x@(partSuggestions.First().Quantity)</h4>
                            @foreach (var sug in partSuggestions)
                            {
                                <label class="setup-wizard-suggestion @(sug.IsRecommended ? "setup-wizard-suggestion--recommended" : "")">
                                    <input type="radio" name="assign-@partId" checked="@sug.IsRecommended"
                                           @onchange="() => SelectSuggestion(partId, sug.MachineId, sug.MachineProgramId)" />
                                    <span class="setup-wizard-machine">@sug.MachineName</span>
                                    <span class="setup-wizard-program">@sug.ProgramName</span>
                                    <span>Setup: @($"{sug.EstimatedSetupMinutes:F0}")m | Run: @($"{sug.EstimatedRunMinutes:F0}")m</span>
                                    <span class="setup-wizard-score" title="@sug.ScoreReason">Score: @sug.Score</span>
                                    @if (sug.IsRecommended)
                                    {
                                        <span class="setup-wizard-badge">Recommended</span>
                                    }
                                </label>
                            }
                        </div>
                    }
                }
                else if (_wizardStep == 2)
                {
                    @* Step 3: Review & confirm *@
                    <p style="color: var(--text-secondary); margin-bottom: 12px;">Review assignments before scheduling.</p>
                    <table class="data-table">
                        <thead><tr><th>Part</th><th>Machine</th><th>Program</th><th>Setup</th><th>Run</th><th>Total</th></tr></thead>
                        <tbody>
                            @foreach (var sug in _suggestions.Where(s => s.IsRecommended))
                            {
                                <tr>
                                    <td class="font-mono">@sug.PartNumber x@(sug.Quantity)</td>
                                    <td>@sug.MachineName</td>
                                    <td>@sug.ProgramName</td>
                                    <td>@($"{sug.EstimatedSetupMinutes:F0}")m</td>
                                    <td>@($"{sug.EstimatedRunMinutes:F0}")m</td>
                                    <td><strong>@($"{(sug.EstimatedSetupMinutes + sug.EstimatedRunMinutes) / 60:F1}")h</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer">
                @if (_wizardStep > 0)
                {
                    <button class="btn btn-secondary" @onclick="WizardBack">Back</button>
                }
                @if (_wizardStep < 2)
                {
                    <button class="btn btn-accent" @onclick="WizardNext"
                            disabled="@(_wizardStep == 0 && _selectedPartIds.Count == 0)">Next</button>
                }
                else
                {
                    <button class="btn btn-accent" @onclick="ExecuteAssignments"
                            disabled="@(!_suggestions.Any(s => s.IsRecommended))">
                        Schedule @_suggestions.Count(s => s.IsRecommended) Assignment(s)
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CloseWizard">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private DateTime _from = DateTime.UtcNow.Date;
    private DateTime _to = DateTime.UtcNow.Date.AddDays(7);
    private List<MachineCapacityCard> _machineCards = new();
    private List<DemandGapItem> _demandGaps = new();
    private BottleneckReport? _bottlenecks;

    // Wizard state
    private bool _showWizard;
    private int _wizardStep;
    private List<int> _selectedPartIds = new();
    private List<MachineAssignmentSuggestion> _suggestions = new();
    private int? _wizardMachineFilter;

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }
    private int _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var claim = state.User.FindFirst("UserId")?.Value;
            if (int.TryParse(claim, out var uid)) _currentUserId = uid;
        }
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        _machineCards = await CapacityService.GetMachineCapacityCardsAsync(_from, _to);
        _demandGaps = await CapacityService.GetDemandGapsAsync();
        _bottlenecks = await BuildAdvisor.AnalyzeBottlenecksAsync(_from, _to);

        _loading = false;
        StateHasChanged();
    }

    private static string GetUtilColor(double pct) => pct switch
    {
        > 100 => "var(--danger)",
        > 85 => "#f59e0b",
        > 40 => "var(--accent)",
        _ => "#22c55e"
    };

    // ── Wizard ────────────────────────────────────────────────

    private void OpenWizard()
    {
        _showWizard = true;
        _wizardStep = 0;
        _selectedPartIds = new();
        _suggestions = new();
        _wizardMachineFilter = null;
    }

    private void OpenWizardForMachine(int machineId)
    {
        OpenWizard();
        _wizardMachineFilter = machineId;
    }

    private void CloseWizard()
    {
        _showWizard = false;
    }

    private void TogglePartSelection(int partId, bool selected)
    {
        if (selected && !_selectedPartIds.Contains(partId))
            _selectedPartIds.Add(partId);
        else if (!selected)
            _selectedPartIds.Remove(partId);
    }

    private void AssignPart(int partId)
    {
        OpenWizard();
        _selectedPartIds = new List<int> { partId };
    }

    private async Task WizardNext()
    {
        if (_wizardStep == 0 && _selectedPartIds.Count > 0)
        {
            // Generate suggestions
            _suggestions = await CapacityService.SuggestAssignmentsAsync(_selectedPartIds);

            // Filter to specific machine if opened from machine card
            if (_wizardMachineFilter.HasValue)
            {
                foreach (var s in _suggestions)
                    s.IsRecommended = s.MachineId == _wizardMachineFilter.Value && s.IsRecommended;
            }
        }
        _wizardStep++;
    }

    private void WizardBack()
    {
        if (_wizardStep > 0) _wizardStep--;
    }

    private void SelectSuggestion(int partId, int machineId, int programId)
    {
        foreach (var s in _suggestions.Where(s => s.PartId == partId))
            s.IsRecommended = s.MachineId == machineId && s.MachineProgramId == programId;
    }

    private async Task ExecuteAssignments()
    {
        try
        {
            var created = await CapacityService.ExecuteAssignmentsAsync(_suggestions, _currentUserId);
            Toast.ShowSuccess($"Scheduled {created.Count} assignment(s) with setup dispatches.");
            _showWizard = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }
}
