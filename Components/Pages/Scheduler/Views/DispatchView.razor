@using Vectrik.Services
@using Vectrik.Models
@using Vectrik.Models.Enums
@using Vectrik.Components.Pages.Scheduler.Components

<div class="dispatch-view">
    @* ── Machine Availability Strip ── *@
    <section class="dispatch-section">
        <h2 class="dispatch-section-title">Machine Availability</h2>
        <div class="dispatch-machine-strip">
            @foreach (var machine in MachineAvailability)
            {
                <MachineSlotSummary Summary="machine" OnComposeBuild="HandleMachineComposeBuild" />
            }
            @if (!MachineAvailability.Any())
            {
                <div class="dispatch-empty">No SLS machines configured. <a href="/machines" style="color: var(--primary);">Add machines</a> to start scheduling builds.</div>
            }
        </div>
    </section>

    @* ── Drafts Awaiting Schedule (Engineer → Scheduler Handoff) ── *@
    @if (DraftPrograms.Any())
    {
        <section class="dispatch-section">
            <h2 class="dispatch-section-title">Awaiting Schedule — @DraftPrograms.Count plate@(DraftPrograms.Count != 1 ? "s" : "") composed</h2>
            <div class="dispatch-drafts-grid">
                @foreach (var prog in DraftPrograms)
                {
                    <div class="dispatch-draft-card">
                        <div class="dispatch-draft-header">
                            <strong>@(prog.Name ?? $"Program #{prog.Id}")</strong>
                            <span class="handoff-badge handoff-badge--awaiting">Awaiting Schedule</span>
                        </div>
                        <div class="dispatch-draft-meta">
                            <span>@prog.TotalPartCount parts</span>
                            @if (prog.EstimatedPrintHours.HasValue)
                            {
                                <span>~@prog.EstimatedPrintHours.Value.ToString("F1")h</span>
                            }
                            <span>by @prog.CreatedBy</span>
                            <span>@prog.CreatedDate.ToLocalTime().ToString("MMM d, HH:mm")</span>
                        </div>
                        @if (prog.ProgramParts?.Any() == true)
                        {
                            <div class="dispatch-draft-parts">
                                @foreach (var pp in prog.ProgramParts)
                                {
                                    <span class="dispatch-recommendation-part">
                                        @(pp.Part?.PartNumber ?? $"#{pp.PartId}") ×@(pp.Quantity * pp.StackLevel)
                                        @if (pp.StackLevel > 1) { <span class="dispatch-stack-indicator">@(pp.StackLevel)x</span> }
                                    </span>
                                }
                            </div>
                        }
                        <div class="dispatch-draft-actions">
                            <button class="btn btn-sm btn-accent" @onclick="() => OnOpenAdvisorForMachine.InvokeAsync(prog.MachineId ?? 0)">
                                Schedule
                            </button>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ── Recommended Builds ── *@
    @if (Recommendations.Any())
    {
        <section class="dispatch-section">
            <h2 class="dispatch-section-title">Recommended Next Builds</h2>
            <div class="dispatch-recommendations">
                @foreach (var rec in Recommendations)
                {
                    <div class="dispatch-recommendation-card">
                        <div class="dispatch-recommendation-header">
                            <strong>@rec.MachineName</strong>
                            <span class="dispatch-recommendation-time">
                                Start @rec.Slot.PrintStart.ToLocalTime().ToString("MMM d, HH:mm")
                            </span>
                        </div>
                        <div class="dispatch-recommendation-rationale">@rec.Rationale</div>
                        @if (rec.Warnings.Any())
                        {
                            <div class="dispatch-recommendation-warnings">
                                @foreach (var w in rec.Warnings)
                                {
                                    <span class="dispatch-recommendation-warning">⚠️ @w</span>
                                }
                            </div>
                        }
                        @if (rec.Plate.Parts.Any())
                        {
                            <div class="dispatch-recommendation-parts">
                                @foreach (var p in rec.Plate.Parts)
                                {
                                    <span class="dispatch-recommendation-part">
                                        @p.PartNumber ×@p.TotalParts
                                        @if (p.StackLevel > 1) { <span class="dispatch-stack-indicator">@(p.StackLevel)x</span> }
                                    </span>
                                }
                                <span class="dispatch-recommendation-duration">~@rec.Plate.EstimatedPrintHours.ToString("F1")h</span>
                            </div>
                        }
                        <div class="dispatch-recommendation-actions">
                            <button class="btn btn-sm btn-accent" @onclick="() => OnOpenAdvisorForMachine.InvokeAsync(rec.MachineId)">
                                Schedule This Build
                            </button>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ── Saved Plates (Template Library) ── *@
    @if (Templates.Any())
    {
        <section class="dispatch-section">
            <details class="dispatch-templates-details">
                <summary class="dispatch-section-title dispatch-section-title--clickable">
                    Saved Plates — @Templates.Count template@(Templates.Count != 1 ? "s" : "")
                </summary>
                <TemplateLibrary Templates="Templates"
                                 OnInstantiate="OnInstantiateTemplate"
                                 OnTemplateSelected="t => { }" />
            </details>
        </section>
    }

    @* ── Demand Cards ── *@
    <section class="dispatch-section">
        <div class="dispatch-section-header">
            <h2 class="dispatch-section-title">Outstanding Demand — @DemandSummaries.Count(d => d.IsAdditive && d.NetRemaining > 0) SLS parts</h2>
            <div class="dispatch-filter-group">
                <button class="sched-filter-btn @(_showOnlyAdditive ? "sched-filter-btn--active" : "")" @onclick="() => _showOnlyAdditive = !_showOnlyAdditive">
                    SLS Only
                </button>
            </div>
        </div>
        <div class="dispatch-demand-grid">
            @foreach (var demand in FilteredDemand)
            {
                <DemandPartCard Demand="demand" OnComposeBuild="HandlePartComposeBuild" />
            }
            @if (!FilteredDemand.Any())
            {
                <div class="dispatch-empty">No outstanding demand</div>
            }
        </div>
    </section>
</div>

@code {
    [Parameter] public List<MachineAvailabilitySummary> MachineAvailability { get; set; } = [];
    [Parameter] public List<BuildRecommendation> Recommendations { get; set; } = [];
    [Parameter] public List<DemandSummary> DemandSummaries { get; set; } = [];
    [Parameter] public List<BuildTemplate> Templates { get; set; } = [];
    [Parameter] public List<MachineProgram> DraftPrograms { get; set; } = [];

    [Parameter] public EventCallback<int> OnOpenAdvisorForMachine { get; set; }
    [Parameter] public EventCallback<int> OnOpenAdvisorForPart { get; set; }
    [Parameter] public EventCallback<int> OnInstantiateTemplate { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }

    private bool _showOnlyAdditive = true;

    private IEnumerable<DemandSummary> FilteredDemand => DemandSummaries
        .Where(d => d.NetRemaining > 0)
        .Where(d => !_showOnlyAdditive || d.IsAdditive);

    private Task HandleMachineComposeBuild(int machineId) =>
        OnOpenAdvisorForMachine.InvokeAsync(machineId);

    private Task HandlePartComposeBuild(int partId) =>
        OnOpenAdvisorForPart.InvokeAsync(partId);
}
