@* ── Gantt View: machines gantt chart with work order sidebar ── *@
@using Vectrik.Components.Pages.Scheduler.Components
@using Vectrik.Models.Enums

<div class="sched-layout">
    @* ── Gantt Chart ── *@
    <div class="sched-gantt-panel">
        @* ── SLS Program Pipeline Strip (collapsible) ── *@
        @if (BuildPrograms.Any())
        {
            var pipelinePrograms = BuildPrograms
                .Where(p => p.ScheduleStatus is not (ProgramScheduleStatus.Cancelled or ProgramScheduleStatus.Completed))
                .ToList();
            var filteredPrograms = ProgramStatusFilter == null ? BuildPrograms : BuildPrograms.Where(p => p.ScheduleStatus == ProgramStatusFilter.Value).ToList();
            var none = filteredPrograms.Where(p => p.ScheduleStatus == ProgramScheduleStatus.None).ToList();
            var ready = filteredPrograms.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Ready).ToList();
            var scheduled = filteredPrograms.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Scheduled).ToList();
            var printing = filteredPrograms.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Printing).ToList();
            var postPrint = filteredPrograms.Where(p => p.ScheduleStatus == ProgramScheduleStatus.PostPrint).ToList();

            <details class="gantt-pipeline-details">
                <summary class="gantt-pipeline-toggle">
                    SLS Pipeline — @pipelinePrograms.Count active program@(pipelinePrograms.Count != 1 ? "s" : "")
                </summary>
                <div class="builds-workflow-indicator">
                    <div class="workflow-step @(none.Any() ? "workflow-step--active" : "")">
                        <span class="workflow-step-icon">📝</span>
                        <span class="workflow-step-label">Draft</span>
                        <span class="workflow-step-count">@none.Count</span>
                    </div>
                    <div class="workflow-arrow">→</div>
                    <div class="workflow-step @(ready.Any() ? "workflow-step--active" : "")">
                        <span class="workflow-step-icon">✅</span>
                        <span class="workflow-step-label">Ready</span>
                        <span class="workflow-step-count">@ready.Count</span>
                    </div>
                    <div class="workflow-arrow">→</div>
                    <div class="workflow-step @(scheduled.Any() ? "workflow-step--active" : "")">
                        <span class="workflow-step-icon">📅</span>
                        <span class="workflow-step-label">Scheduled</span>
                        <span class="workflow-step-count">@scheduled.Count</span>
                    </div>
                    <div class="workflow-arrow">→</div>
                    <div class="workflow-step @(printing.Any() ? "workflow-step--active" : "")">
                        <span class="workflow-step-icon">🖨️</span>
                        <span class="workflow-step-label">Printing</span>
                        <span class="workflow-step-count">@printing.Count</span>
                    </div>
                    <div class="workflow-arrow">→</div>
                    <div class="workflow-step @(postPrint.Any() ? "workflow-step--active" : "")">
                        <span class="workflow-step-icon">🔥</span>
                        <span class="workflow-step-label">Post-Print</span>
                        <span class="workflow-step-count">@postPrint.Count</span>
                    </div>
                </div>
                <div class="builds-pipeline-summary">
                    <div class="builds-pipeline-stat">
                        <span class="builds-pipeline-count">@pipelinePrograms.Count</span>
                        <span class="builds-pipeline-label">Active Programs</span>
                    </div>
                    <div class="builds-pipeline-stat builds-pipeline-stat--ready">
                        <span class="builds-pipeline-count">@(ready.Count + scheduled.Count)</span>
                        <span class="builds-pipeline-label">Ready / Scheduled</span>
                    </div>
                    <div class="builds-pipeline-stat builds-pipeline-stat--printing">
                        <span class="builds-pipeline-count">@printing.Count</span>
                        <span class="builds-pipeline-label">Printing</span>
                    </div>
                    <div class="builds-pipeline-stat builds-pipeline-stat--post">
                        <span class="builds-pipeline-count">@postPrint.Count</span>
                        <span class="builds-pipeline-label">Post-Print</span>
                    </div>
                </div>
            </details>
        }

        @if (HasSelection)
        {
            <div class="gantt-batch-bar">
                <span class="gantt-batch-count">@SelectionCount selected</span>
                <button class="btn btn-sm btn-danger" @onclick="OnBatchDelete">@(_confirmBatchDelete ? $"Confirm Delete {_selectedBuildIds.Count}?" : "Delete Selected")</button>
                <button class="btn btn-sm btn-secondary" @onclick="OnBatchReschedule">Reschedule Selected</button>
                <button class="btn btn-sm btn-secondary" @onclick="ClearSelection">Clear</button>
            </div>
        }
        <div class="card sched-gantt-card">
            @if (!Machines.Any())
            {
                <div class="empty-state"><div class="empty-state-text">No machines configured for scheduling</div></div>
            }
            else
            {
                <GanttViewport @ref="Viewport"
                    DataRangeStart="DataRangeStart"
                    DataRangeEnd="DataRangeEnd"
                    PixelsPerHour="PixelsPerHour"
                    Shifts="Shifts"
                    OnPixelsPerHourChanged="OnPixelsPerHourChanged"
                    OnViewportBoundsChanged="OnViewportBoundsChanged"
                    OnDataRangeExtensionNeeded="OnDataRangeExtensionNeeded"
                    OnBarDragCompleted="OnBarDragCompleted">
                        @* ── Machine rows (grouped by department, ordered by production flow) ── *@
                        @{
                            var orderedMachines = GetOrderedMachines();
                                string? lastGroup = null;
                            }
                            @foreach (var machine in orderedMachines)
                            {
                                var groupLabel = machine.Department ?? machine.MachineType ?? "Other";
                            if (groupLabel != lastGroup)
                            {
                                lastGroup = groupLabel;
                                <div class="gantt-group-header">
                                    <span class="gantt-group-label">@groupLabel</span>
                                </div>
                            }
                            <GanttMachineRow Machine="machine"
                                    Executions="GetExecutionsForMachine(machine)"
                                    DataRangeStart="DataRangeStart"
                                    PixelsPerHour="PixelsPerHour"
                                    OnBarClick="HandleBarClick"
                                OnBuildAction="HandleBuildBarClick"
                                OnNextBuildRequested="OnNextBuildRequested"
                                BuildPrograms="BuildPrograms"
                                BuildTimeline="GetTimelineForMachine(machine)"
                                SelectedExecIds="_selectedExecIds"
                                SelectedBuildIds="_selectedBuildIds" />
                        }

                        @* ── Unassigned row ── *@
                        @{
                            var unassignedScheduled = Executions.Where(e => e.MachineId == null && e.ScheduledStartAt != null).ToList();
                        }
                        @if (unassignedScheduled.Any())
                        {
                            <div class="gantt-row gantt-row-unassigned">
                                <div class="gantt-resource-label">
                                    <span class="gantt-machine-status" style="background: var(--warning);"></span>
                                    <div class="gantt-machine-info">
                                        <span class="gantt-machine-name">Unassigned</span>
                                        <span class="gantt-machine-type">@unassignedScheduled.Count tasks</span>
                                    </div>
                                </div>
                                <div class="gantt-track">
                                    @foreach (var exec in unassignedScheduled)
                                    {
                                        var start = exec.ScheduledStartAt ?? DataRangeStart;
                                        var end = exec.ScheduledEndAt ?? start.AddHours(exec.EstimatedHours ?? 4);
                                        <GanttBar Exec="exec"
                                            BarLeftPx="GetBarLeftPx(start)"
                                            BarWidthPx="GetBarWidthPx(start, end)"
                                            Start="start" End="end"
                                            IsUnassigned="true"
                                            IsSelected="_selectedExecIds.Contains(exec.Id)"
                                            OnClick="HandleBarClick" />
                                    }
                                </div>
                            </div>
                        }
                </GanttViewport>

                @* Part Key + Status Indicators *@
                <details open class="gantt-legend-details">
                    <summary class="gantt-legend-toggle">Part Key</summary>
                    <div class="gantt-legend gantt-part-key">
                        @{
                            var partEntries = GetPartKeyEntries();
                        }
                        @foreach (var entry in partEntries)
                        {
                            var isSelected = SelectedPartIds.Contains(entry.PartId);
                            var anySelected = SelectedPartIds.Count > 0;
                            <button class="gantt-part-swatch @(isSelected ? "gantt-part-swatch--active" : "") @(anySelected && !isSelected ? "gantt-part-swatch--dimmed" : "")"
                                    style="--part-hue: @entry.Hue;"
                                    @onclick="() => TogglePartFilter(entry.PartId)"
                                    title="@entry.PartNumber — @entry.Count execution(s). Click to filter.">
                                <span class="gantt-part-color"></span>
                                <span class="gantt-part-label">@entry.PartNumber</span>
                                <span class="gantt-part-count">@entry.Count</span>
                            </button>
                        }
                        @if (SelectedPartIds.Count > 0)
                        {
                            <button class="gantt-part-swatch gantt-part-clear" @onclick="ClearPartFilter" title="Clear part filter">
                                Clear
                            </button>
                        }
                        @* Status indicators *@
                        <span class="gantt-legend-sep"></span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-build-scheduled"></span> Build</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-conflict"></span> Conflict</span>
                        <span class="gantt-legend-item"><span class="gantt-legend-swatch gantt-bar-unassigned"></span> Unassigned</span>
                    </div>
                </details>
            }
        </div>
    </div>

    @* ── Work Orders Sidebar (right) ── *@
    <WorkOrderPanel WorkOrders="WorkOrders"
                    Unscheduled="Unscheduled"
                    Machines="Machines"
                    UserName="UserName"
                    OnScheduleRequested="OnScheduleRequested"
                    OnAutoSchedule="OnAutoSchedule" />
</div>

@code {
    [Parameter, EditorRequired] public List<StageExecution> Executions { get; set; } = [];
    [Parameter, EditorRequired] public List<StageExecution> Unscheduled { get; set; } = [];
    [Parameter, EditorRequired] public List<Machine> Machines { get; set; } = [];
    [Parameter] public List<ProductionStage> Stages { get; set; } = [];
    [Parameter] public List<MachineProgram> BuildPrograms { get; set; } = [];
    [Parameter] public Dictionary<int, List<ProgramTimelineEntry>> MachineTimelines { get; set; } = new();
    [Parameter] public List<OperatingShift> Shifts { get; set; } = [];
    [Parameter] public List<WorkOrder> WorkOrders { get; set; } = [];
    [Parameter] public string UserName { get; set; } = "System";
    [Parameter] public DateTime DataRangeStart { get; set; }
    [Parameter] public DateTime DataRangeEnd { get; set; }
    [Parameter] public double PixelsPerHour { get; set; }
    [Parameter] public bool ShowConflictsOnly { get; set; }
    [Parameter] public ProgramScheduleStatus? ProgramStatusFilter { get; set; }
    [Parameter] public HashSet<int> SelectedPartIds { get; set; } = new();
    [Parameter] public EventCallback<HashSet<int>> OnSelectedPartIdsChanged { get; set; }
    [Parameter] public string StatusFilter { get; set; } = "active";
    [Parameter] public HashSet<string> PriorityFilter { get; set; } = new();
    [Parameter] public string SortBy { get; set; } = "schedule";
    [Parameter] public EventCallback<StageExecution> OnShowReschedule { get; set; }
    [Parameter] public EventCallback<(MachineProgram Build, string Action)> OnBuildAction { get; set; }
    [Parameter] public EventCallback<List<int>> OnBatchDeleteBuilds { get; set; }
    [Parameter] public EventCallback<List<int>> OnBatchRescheduleBuilds { get; set; }
    [Parameter] public EventCallback OnScheduleRequested { get; set; }
    [Parameter] public EventCallback<int> OnAutoSchedule { get; set; }
    [Parameter] public EventCallback<int> OnNextBuildRequested { get; set; }
    [Parameter] public EventCallback<double> OnPixelsPerHourChanged { get; set; }
    [Parameter] public EventCallback<GanttViewport.ViewportBoundsChangedArgs> OnViewportBoundsChanged { get; set; }
    [Parameter] public EventCallback OnDataRangeExtensionNeeded { get; set; }
    [Parameter] public EventCallback<GanttViewport.BarDragResult> OnBarDragCompleted { get; set; }

    public GanttViewport? Viewport { get; private set; }

    private List<Machine> GetOrderedMachines()
    {
        var available = Machines.Where(m => m.IsAvailableForScheduling).ToList();

        if (SortBy == "priority")
        {
            // Machines with highest-priority jobs float to top
            return available
                .OrderBy(m => GetTopPriorityForMachine(m.Id))
                .ThenBy(m => m.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        if (SortBy == "part")
        {
            // Machines sorted by earliest part name
            return available
                .OrderBy(m => GetFirstPartNameForMachine(m.Id))
                .ThenBy(m => m.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        if (SortBy == "duedate")
        {
            // Machines with earliest due dates first
            return available
                .OrderBy(m => GetEarliestDueDateForMachine(m.Id))
                .ThenBy(m => m.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        // Default: schedule date — use stage-based ordering
        var machineStageOrder = new Dictionary<int, int>();
        foreach (var stage in Stages.OrderBy(s => s.DisplayOrder))
        {
            foreach (var mid in stage.GetAssignedMachineIntIds())
                machineStageOrder.TryAdd(mid, stage.DisplayOrder);

            if (!string.IsNullOrEmpty(stage.DefaultMachineId))
            {
                var match = Machines.FirstOrDefault(m =>
                    m.MachineId.Equals(stage.DefaultMachineId, StringComparison.OrdinalIgnoreCase));
                if (match != null)
                    machineStageOrder.TryAdd(match.Id, stage.DisplayOrder);
            }
        }

        foreach (var stage in Stages.OrderBy(s => s.DisplayOrder))
        {
            if (string.IsNullOrEmpty(stage.Department)) continue;
            foreach (var machine in Machines)
            {
                if (machineStageOrder.ContainsKey(machine.Id)) continue;
                if (machine.Department?.Equals(stage.Department, StringComparison.OrdinalIgnoreCase) == true)
                    machineStageOrder.TryAdd(machine.Id, stage.DisplayOrder);
            }
        }

        return available
            .OrderBy(m => machineStageOrder.GetValueOrDefault(m.Id, int.MaxValue))
            .ThenBy(m => m.Priority)
            .ThenBy(m => m.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private int GetTopPriorityForMachine(int machineId)
    {
        var execs = Executions.Where(e => e.MachineId == machineId && e.Job != null);
        if (!execs.Any()) return int.MaxValue;
        // Lower enum value = higher priority (Emergency=0, Rush=1, ...)
        return execs.Min(e => (int)(e.Job!.Priority));
    }

    private string GetFirstPartNameForMachine(int machineId)
    {
        var part = Executions
            .Where(e => e.MachineId == machineId && e.Job?.Part != null)
            .Select(e => e.Job!.Part!.PartNumber)
            .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
        return part ?? "\uffff"; // Sort empty to end
    }

    private DateTime GetEarliestDueDateForMachine(int machineId)
    {
        var earliest = Executions
            .Where(e => e.MachineId == machineId && e.ScheduledStartAt != null)
            .Min(e => e.ScheduledStartAt);
        return earliest ?? DateTime.MaxValue;
    }

    private List<StageExecution> GetExecutionsForMachine(Machine machine)
    {
        var execs = Executions.Where(e => e.MachineId == machine.Id).ToList();

        // Apply status filter
        execs = StatusFilter switch
        {
            "active" => execs.Where(e => e.Status is not (StageExecutionStatus.Completed or StageExecutionStatus.Skipped) && e.Job?.Status is not (JobStatus.Completed or JobStatus.Cancelled)).ToList(),
            "scheduled" => execs.Where(e => e.Status == StageExecutionStatus.NotStarted).ToList(),
            "inprogress" => execs.Where(e => e.Status == StageExecutionStatus.InProgress).ToList(),
            "completed" => execs.Where(e => e.Status == StageExecutionStatus.Completed).ToList(),
            "paused" => execs.Where(e => e.Status == StageExecutionStatus.Paused).ToList(),
            "cancelled" => execs.Where(e => e.Job?.Status == JobStatus.Cancelled).ToList(),
            _ => execs // "all"
        };

        // Apply priority filter
        if (PriorityFilter.Count > 0)
        {
            execs = execs.Where(e => e.Job != null && PriorityFilter.Contains(e.Job.Priority.ToString())).ToList();
        }

        // Apply part filter
        if (SelectedPartIds.Count > 0)
        {
            execs = execs.Where(e => e.Job != null && SelectedPartIds.Contains(e.Job.PartId)).ToList();
        }

        // Apply conflicts filter
        if (ShowConflictsOnly)
        {
            execs = execs.Where(e => HasOverlap(e, execs)).ToList();
        }

        return execs;
    }

    private bool HasOverlap(StageExecution exec, List<StageExecution> allExecs)
    {
        var start = exec.ScheduledStartAt;
        var end = exec.ScheduledEndAt;
        if (start == null || end == null) return false;
        return allExecs.Any(other =>
            other.Id != exec.Id &&
            other.ScheduledStartAt != null && other.ScheduledEndAt != null &&
            other.ScheduledStartAt < end && other.ScheduledEndAt > start);
    }

    private double GetBarLeftPx(DateTime start) =>
        (start - DataRangeStart).TotalHours * PixelsPerHour;

    private double GetBarWidthPx(DateTime start, DateTime end) =>
        Math.Max(8, (end - start).TotalHours * PixelsPerHour);

    private List<ProgramTimelineEntry> GetTimelineForMachine(Machine machine)
    {
        if (MachineTimelines.TryGetValue(machine.Id, out var entries))
            return entries;
        return [];
    }

    // ── Batch Selection ──
    private HashSet<int> _selectedExecIds = [];
    private HashSet<int> _selectedBuildIds = [];

    private bool HasSelection => _selectedExecIds.Count > 0 || _selectedBuildIds.Count > 0;
    private int SelectionCount => _selectedExecIds.Count + _selectedBuildIds.Count;

    private async Task HandleBarClick(StageExecution exec)
    {
        // Forward to parent for reschedule dialog
        await OnShowReschedule.InvokeAsync(exec);
    }

    // ── Part Key ──
    private record PartKeyEntry(int PartId, string PartNumber, int Hue, int Count);

    private List<PartKeyEntry> GetPartKeyEntries()
    {
        return Executions
            .Where(e => e.Job != null && e.Job.Part != null && e.Job.PartId > 0)
            .GroupBy(e => e.Job!.PartId)
            .Select(g =>
            {
                var first = g.First();
                var hue = (int)((first.Job!.PartId * 137.508) % 360);
                return new PartKeyEntry(
                    first.Job.PartId,
                    first.Job.Part!.PartNumber,
                    hue,
                    g.Count());
            })
            .OrderByDescending(e => e.Count) // Most frequent first
            .ToList();
    }

    private async Task TogglePartFilter(int partId)
    {
        var updated = new HashSet<int>(SelectedPartIds);
        if (!updated.Remove(partId))
            updated.Add(partId);
        await OnSelectedPartIdsChanged.InvokeAsync(updated);
    }

    private async Task ClearPartFilter()
    {
        await OnSelectedPartIdsChanged.InvokeAsync(new HashSet<int>());
    }

    private async Task HandleBuildBarClick((MachineProgram Build, string Action) args)
    {
        if (args.Action == "select")
        {
            // Toggle build selection — reset confirm state since selection changed
            if (_selectedBuildIds.Contains(args.Build.Id))
                _selectedBuildIds.Remove(args.Build.Id);
            else
                _selectedBuildIds.Add(args.Build.Id);
            _confirmBatchDelete = false;
        }
        else if (args.Action == "detail")
        {
            // Open full-screen detail modal
            await OnBuildAction.InvokeAsync((args.Build, "detail"));
        }
        else
        {
            // Forward real actions to parent
            await OnBuildAction.InvokeAsync(args);
        }
    }

    private void ClearSelection()
    {
        _selectedExecIds.Clear();
        _selectedBuildIds.Clear();
        _confirmBatchDelete = false;
    }

    private bool _confirmBatchDelete;

    private async Task OnBatchDelete()
    {
        if (_selectedBuildIds.Count == 0) return;
        if (!_confirmBatchDelete)
        {
            _confirmBatchDelete = true;
            return;
        }
        _confirmBatchDelete = false;
        await OnBatchDeleteBuilds.InvokeAsync(_selectedBuildIds.ToList());
        ClearSelection();
    }

    private async Task OnBatchReschedule()
    {
        if (_selectedBuildIds.Count > 0)
            await OnBatchRescheduleBuilds.InvokeAsync(_selectedBuildIds.ToList());
        ClearSelection();
    }
}
