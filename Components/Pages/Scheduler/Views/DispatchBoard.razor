@using Vectrik.Services
@using Vectrik.Models
@using Vectrik.Models.Enums

<div class="dispatch-board">
    <div class="dispatch-board-header">
        <h2>Setup Dispatch Board</h2>
        <div class="dispatch-board-stats">
            <span class="dispatch-stat"><strong>@_data.TotalActive</strong> Active</span>
            <span class="dispatch-stat dispatch-stat--queued"><strong>@_data.TotalQueued</strong> Queued</span>
            <span class="dispatch-stat dispatch-stat--progress"><strong>@_data.TotalInProgress</strong> In Progress</span>
        </div>
        <button class="btn btn-sm btn-accent" @onclick="OpenCreateModal">+ New Dispatch</button>
    </div>

    @if (_loading)
    {
        <div class="loading"><span class="spinner"></span> Loading dispatches...</div>
    }
    else
    {
        @* ── Machine Swim Lanes ── *@
        <div class="dispatch-board-lanes">
            @foreach (var lane in _data.MachineLanes)
            {
                <div class="dispatch-lane">
                    <div class="dispatch-lane-header">
                        <div class="dispatch-lane-machine">
                            <span class="dispatch-lane-name">@lane.Machine.Name</span>
                            <span class="dispatch-lane-status dispatch-lane-status--@lane.Machine.SetupState.ToString().ToLower()">
                                @lane.Machine.SetupState
                            </span>
                        </div>
                        @if (lane.Machine.CurrentProgramId.HasValue)
                        {
                            <span class="dispatch-lane-program" title="Current program loaded">
                                @(lane.Machine.CurrentProgram?.Name ?? $"Program #{lane.Machine.CurrentProgramId}")
                            </span>
                        }
                    </div>

                    @* Current dispatch (in progress) *@
                    @if (lane.CurrentDispatch != null)
                    {
                        <div class="dispatch-card dispatch-card--active">
                            <div class="dispatch-card-header">
                                <span class="dispatch-card-number">@lane.CurrentDispatch.DispatchNumber</span>
                                <span class="dispatch-card-badge dispatch-card-badge--@lane.CurrentDispatch.Status.ToString().ToLower()">
                                    @lane.CurrentDispatch.StatusDisplay
                                </span>
                            </div>
                            <div class="dispatch-card-body">
                                <div class="dispatch-card-type">@lane.CurrentDispatch.TypeDisplay</div>
                                @if (lane.CurrentDispatch.MachineProgram != null)
                                {
                                    <div class="dispatch-card-program">@lane.CurrentDispatch.MachineProgram.Name</div>
                                }
                                @if (lane.CurrentDispatch.Part != null)
                                {
                                    <div class="dispatch-card-part">@lane.CurrentDispatch.Part.PartNumber — @lane.CurrentDispatch.Part.Name</div>
                                }
                                @if (lane.CurrentDispatch.AssignedOperator != null)
                                {
                                    <div class="dispatch-card-operator">@lane.CurrentDispatch.AssignedOperator.FullName</div>
                                }
                                @if (lane.CurrentDispatch.StartedAt.HasValue)
                                {
                                    var elapsed = (DateTime.UtcNow - lane.CurrentDispatch.StartedAt.Value).TotalMinutes;
                                    <div class="dispatch-card-timer">
                                        @($"{elapsed:F0}") min elapsed
                                        @if (lane.CurrentDispatch.EstimatedSetupMinutes.HasValue)
                                        {
                                            <span> / @($"{lane.CurrentDispatch.EstimatedSetupMinutes:F0}") min est.</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="dispatch-card-actions">
                                @if (lane.CurrentDispatch.Status == DispatchStatus.InProgress)
                                {
                                    <button class="btn btn-xs btn-accent" @onclick="() => CompleteDispatch(lane.CurrentDispatch.Id)">Complete</button>
                                    <button class="btn btn-xs btn-secondary" @onclick="() => RequestVerification(lane.CurrentDispatch.Id)">Verify</button>
                                }
                                else if (lane.CurrentDispatch.Status == DispatchStatus.PendingVerification)
                                {
                                    <button class="btn btn-xs btn-accent" @onclick="() => VerifyAndComplete(lane.CurrentDispatch.Id)">Verify & Complete</button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="dispatch-card dispatch-card--empty">
                            <span>No active setup</span>
                        </div>
                    }

                    @* Queued dispatches *@
                    @foreach (var dispatch in lane.QueuedDispatches)
                    {
                        <div class="dispatch-card dispatch-card--queued">
                            <div class="dispatch-card-header">
                                <span class="dispatch-card-number">@dispatch.DispatchNumber</span>
                                <span class="dispatch-card-priority" title="Priority @dispatch.Priority">P@dispatch.Priority</span>
                                <span class="dispatch-card-badge dispatch-card-badge--@dispatch.Status.ToString().ToLower()">
                                    @dispatch.StatusDisplay
                                </span>
                            </div>
                            <div class="dispatch-card-body">
                                <div class="dispatch-card-type">@dispatch.TypeDisplay</div>
                                @if (dispatch.MachineProgram != null)
                                {
                                    <div class="dispatch-card-program">@dispatch.MachineProgram.Name</div>
                                }
                                @if (dispatch.Part != null)
                                {
                                    <div class="dispatch-card-part">@dispatch.Part.PartNumber</div>
                                }
                                @if (dispatch.EstimatedSetupMinutes.HasValue)
                                {
                                    <div class="dispatch-card-est">~@($"{dispatch.EstimatedSetupMinutes:F0}") min</div>
                                }
                            </div>
                            <div class="dispatch-card-actions">
                                @if (dispatch.Status == DispatchStatus.Queued)
                                {
                                    <button class="btn btn-xs btn-primary" @onclick="() => StartDispatch(dispatch.Id)">Start</button>
                                    <button class="btn btn-xs btn-secondary" @onclick="() => DeferDispatch(dispatch.Id)">Defer</button>
                                    <button class="btn btn-xs btn-danger" @onclick="() => CancelDispatch(dispatch.Id)">Cancel</button>
                                }
                                else if (dispatch.Status == DispatchStatus.Assigned)
                                {
                                    <button class="btn btn-xs btn-primary" @onclick="() => StartDispatch(dispatch.Id)">Start</button>
                                }
                            </div>
                        </div>
                    }

                    @if (!lane.QueuedDispatches.Any() && lane.CurrentDispatch == null)
                    {
                        <div class="dispatch-lane-empty">Queue empty</div>
                    }
                </div>
            }
        </div>

        @* ── Unassigned Pool ── *@
        @if (_data.UnassignedDispatches.Any())
        {
            <div class="dispatch-unassigned">
                <h3>Unassigned Dispatches (@_data.UnassignedDispatches.Count)</h3>
                <div class="dispatch-unassigned-list">
                    @foreach (var dispatch in _data.UnassignedDispatches)
                    {
                        <div class="dispatch-card dispatch-card--unassigned">
                            <span class="dispatch-card-number">@dispatch.DispatchNumber</span>
                            <span>@dispatch.Machine?.Name</span>
                            <span>@dispatch.TypeDisplay</span>
                            @if (dispatch.MachineProgram != null)
                            {
                                <span>@dispatch.MachineProgram.Name</span>
                            }
                            <span class="dispatch-card-priority">P@dispatch.Priority</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@* ── Create Dispatch Modal ── *@
@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content modal-md" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Create Setup Dispatch</h3>
                <button class="modal-close" @onclick="CloseCreateModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Machine</label>
                    <select class="form-select" @bind="_createMachineId">
                        <option value="0">Select machine...</option>
                        @foreach (var lane in _data.MachineLanes)
                        {
                            <option value="@lane.Machine.Id">@lane.Machine.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Dispatch Type</label>
                    <select class="form-select" @bind="_createType">
                        @foreach (var t in Enum.GetValues<DispatchType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Program (optional)</label>
                    <select class="form-select" @bind="_createProgramId">
                        <option value="">None</option>
                        @foreach (var p in _availablePrograms)
                        {
                            <option value="@p.Id">@p.Name (@p.ProgramNumber)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Estimated Setup Time (minutes)</label>
                    <input type="number" class="form-control" @bind="_createEstMinutes" />
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" @bind="_createNotes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                <button class="btn btn-accent" @onclick="CreateDispatch" disabled="@(_createMachineId == 0)">Create Dispatch</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnRefreshRequested { get; set; }

    private DispatchDashboardData _data = new();
    private bool _loading = true;
    private bool _showCreateModal;

    // Create modal fields
    private int _createMachineId;
    private DispatchType _createType = DispatchType.Setup;
    private int? _createProgramId;
    private double? _createEstMinutes;
    private string? _createNotes;
    private List<MachineProgram> _availablePrograms = new();

    [Inject] private ISetupDispatchService DispatchService { get; set; } = null!;
    [Inject] private IMachineProgramService ProgramService { get; set; } = null!;
    [Inject] private ToastService Toast { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        _data = await DispatchService.GetDashboardDataAsync();
        _loading = false;
        StateHasChanged();
    }

    // ── Actions ──────────────────────────────────────────────

    private async Task StartDispatch(int dispatchId)
    {
        try
        {
            await DispatchService.StartDispatchAsync(dispatchId);
            Toast.ShowSuccess("Dispatch started.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task CompleteDispatch(int dispatchId)
    {
        try
        {
            await DispatchService.CompleteDispatchAsync(dispatchId);
            Toast.ShowSuccess("Setup completed.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task RequestVerification(int dispatchId)
    {
        try
        {
            await DispatchService.RequestVerificationAsync(dispatchId);
            Toast.ShowSuccess("Verification requested.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task VerifyAndComplete(int dispatchId)
    {
        try
        {
            await DispatchService.VerifyDispatchAsync(dispatchId, 0); // TODO: get current user ID
            await DispatchService.CompleteDispatchAsync(dispatchId);
            Toast.ShowSuccess("Setup verified and completed.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task CancelDispatch(int dispatchId)
    {
        try
        {
            await DispatchService.CancelDispatchAsync(dispatchId, "Cancelled from dispatch board");
            Toast.ShowSuccess("Dispatch cancelled.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task DeferDispatch(int dispatchId)
    {
        try
        {
            await DispatchService.DeferDispatchAsync(dispatchId, "Deferred from dispatch board");
            Toast.ShowSuccess("Dispatch deferred.");
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    // ── Create Modal ─────────────────────────────────────────

    private async Task OpenCreateModal()
    {
        _showCreateModal = true;
        _createMachineId = 0;
        _createType = DispatchType.Setup;
        _createProgramId = null;
        _createEstMinutes = null;
        _createNotes = null;

        // Load available programs
        _availablePrograms = await ProgramService.GetActiveProgramsAsync();
    }

    private void CloseCreateModal() => _showCreateModal = false;

    private async Task CreateDispatch()
    {
        if (_createMachineId == 0) return;

        try
        {
            await DispatchService.CreateManualDispatchAsync(
                machineId: _createMachineId,
                type: _createType,
                machineProgramId: _createProgramId,
                estimatedSetupMinutes: _createEstMinutes,
                notes: _createNotes);

            Toast.ShowSuccess("Dispatch created.");
            _showCreateModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }
}
