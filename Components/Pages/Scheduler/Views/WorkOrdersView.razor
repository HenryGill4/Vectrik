@* ── Work Orders Command Center: demand dashboard + suggestions + WO cards ── *@
@using Opcentrix_V3.Components.Pages.Scheduler.Modals
@inject IBuildPlanningService BuildPlanning
@inject IBuildSchedulingService BuildScheduling
@inject IBuildTemplateService BuildTemplateService
@inject ISchedulingService SchedulingService
@inject IWorkOrderService WoService
@inject IJSRuntime JS
@inject ToastService Toast

<div class="wo-demand-view">
    @{
        var woAllLines = WorkOrders.SelectMany(w => w.Lines).ToList();
        var woTotalOutstanding = woAllLines.Sum(l => GetOutstanding(l));
        var woTotalInBuilds = woAllLines.Sum(l => GetInBuildQty(l));
        var woTotalInProduction = woAllLines.Sum(l => GetInProductionQty(l));
        var woAddLines = woAllLines.Where(l => IsAdditiveLine(l) && GetOutstanding(l) > 0).ToList();
        var woCncLines = woAllLines.Where(l => !IsAdditiveLine(l) && GetOutstanding(l) > 0).ToList();
        var woUnscheduledLines = woAllLines.Where(l => GetOutstanding(l) > 0 && GetInBuildQty(l) == 0 && !HasExistingJobs(l)).ToList();
        var templatesAvailable = BuildTemplates.Count(t => t.IsCertified);
        var templatesNeedingRecert = BuildTemplates.Count(t => t.NeedsRecertification);
        var today = DateTime.UtcNow.Date;
        var endOfWeek = today.AddDays(7 - (int)today.DayOfWeek);
        var endOfNextWeek = endOfWeek.AddDays(7);
        var overdueWos = WorkOrders.Where(w => w.DueDate.Date < today && w.Lines.Any(l => GetOutstanding(l) > 0)).ToList();
        var thisWeekWos = WorkOrders.Where(w => w.DueDate.Date >= today && w.DueDate.Date < endOfWeek).ToList();
        var nextWeekWos = WorkOrders.Where(w => w.DueDate.Date >= endOfWeek && w.DueDate.Date < endOfNextWeek).ToList();
    }

    @if (!WorkOrders.Any())
    {
        <div class="empty-state"><div class="empty-state-icon">📋</div><div class="empty-state-text">No released work orders. Release a work order to see demand here.</div></div>
    }
    else
    {
        <div class="wo-demand-stats">
            <div class="wo-demand-stat">
                <span class="wo-demand-stat-count">@WorkOrders.Count</span>
                <span class="wo-demand-stat-label">Active Orders</span>
            </div>
            <div class="wo-demand-stat wo-demand-stat--outstanding">
                <span class="wo-demand-stat-count">@woTotalOutstanding</span>
                <span class="wo-demand-stat-label">Parts Outstanding</span>
            </div>
            <div class="wo-demand-stat wo-demand-stat--additive">
                <span class="wo-demand-stat-count">@woAddLines.Count</span>
                <span class="wo-demand-stat-label">Need Builds (SLS)</span>
            </div>
            <div class="wo-demand-stat wo-demand-stat--cnc">
                <span class="wo-demand-stat-count">@woCncLines.Count</span>
                <span class="wo-demand-stat-label">Need Machining</span>
            </div>
            @if (woTotalInBuilds > 0)
            {
                <div class="wo-demand-stat wo-demand-stat--inbuilds">
                    <span class="wo-demand-stat-count">@woTotalInBuilds</span>
                    <span class="wo-demand-stat-label">In Builds</span>
                </div>
            }
            @if (woTotalInProduction > 0)
            {
                <div class="wo-demand-stat wo-demand-stat--inprod">
                    <span class="wo-demand-stat-count">@woTotalInProduction</span>
                    <span class="wo-demand-stat-label">In Production</span>
                </div>
            }
            <div class="wo-demand-stat wo-demand-stat--unscheduled">
                <span class="wo-demand-stat-count">@woUnscheduledLines.Count</span>
                <span class="wo-demand-stat-label">Not Yet Scheduled</span>
            </div>
            @if (overdueWos.Count > 0)
            {
                <div class="wo-demand-stat wo-demand-stat--overdue @(_statFilter == "overdue" ? "wo-demand-stat--active" : "")" @onclick='() => ToggleStatFilter("overdue")'>
                    <span class="wo-demand-stat-count">@overdueWos.Count</span>
                    <span class="wo-demand-stat-label">🔴 Overdue</span>
                </div>
            }
            <div class="wo-demand-stat wo-demand-stat--thisweek @(_statFilter == "thisweek" ? "wo-demand-stat--active" : "")" @onclick='() => ToggleStatFilter("thisweek")'>
                <span class="wo-demand-stat-count">@thisWeekWos.Count</span>
                <span class="wo-demand-stat-label">Due This Week</span>
            </div>
            <div class="wo-demand-stat wo-demand-stat--nextweek @(_statFilter == "nextweek" ? "wo-demand-stat--active" : "")" @onclick='() => ToggleStatFilter("nextweek")'>
                <span class="wo-demand-stat-count">@nextWeekWos.Count</span>
                <span class="wo-demand-stat-label">Due Next Week</span>
            </div>
            <div class="wo-demand-stat">
                <span class="wo-demand-stat-count">@templatesAvailable</span>
                <span class="wo-demand-stat-label">Templates Available</span>
            </div>
            @if (templatesNeedingRecert > 0)
            {
                <div class="wo-demand-stat wo-demand-stat--outstanding">
                    <span class="wo-demand-stat-count">@templatesNeedingRecert</span>
                    <span class="wo-demand-stat-label">⚠️ Needing Re-cert</span>
                </div>
            }
        </div>

        @* ── Build Suggestions (Phase C) ── *@
        @if (Suggestions != null && (Suggestions.TemplateSuggestions.Any(s => !_dismissedSuggestions.Contains($"t-{s.BuildTemplateId}-{s.PartId}")) || Suggestions.MixedBuildSuggestions.Any(s => !_dismissedSuggestions.Contains($"m-{string.Join(",", s.Parts.Select(p => p.PartId))}"))))
        {
            <div class="wo-suggestions-section">
                <h3 class="wo-suggestions-title">💡 Build Suggestions</h3>

                @foreach (var suggestion in Suggestions.TemplateSuggestions)
                {
                    var key = $"t-{suggestion.BuildTemplateId}-{suggestion.PartId}";
                    if (_dismissedSuggestions.Contains(key)) continue;

                    <div class="wo-suggestion-card">
                        <div class="wo-suggestion-card-info">
                            <div class="wo-suggestion-card-header">
                                <span class="badge badge-success">✅ Template</span>
                                <strong>@suggestion.TemplateName</strong>
                            </div>
                            <div class="wo-suggestion-card-detail">
                                @suggestion.PartNumber — @suggestion.SuggestedQuantity pc · @suggestion.EstimatedDurationHours.ToString("F1")h · Used @suggestion.UseCount×
                            </div>
                            <div class="wo-suggestion-card-rationale">@suggestion.Rationale</div>
                            @if (suggestion.FulfillsWorkOrders.Any())
                            {
                                <div class="wo-suggestion-card-wos">
                                    Fulfills: @string.Join(", ", suggestion.FulfillsWorkOrders.Select(w => $"{w.OrderNumber} ({w.QuantityFulfilled}pc)"))
                                </div>
                            }
                        </div>
                        <div class="wo-suggestion-card-actions">
                            <button class="btn btn-sm btn-primary" @onclick="() => ScheduleFromSuggestion(suggestion)" title="Schedule using this certified template">
                                📅 Schedule from Template
                            </button>
                            <button class="btn btn-sm btn-secondary" @onclick='() => _dismissedSuggestions.Add(key)' title="Dismiss this suggestion">
                                ✕
                            </button>
                        </div>
                    </div>
                }

                @foreach (var suggestion in Suggestions.MixedBuildSuggestions)
                {
                    var key = $"m-{string.Join(",", suggestion.Parts.Select(p => p.PartId))}";
                    if (_dismissedSuggestions.Contains(key)) continue;

                    <div class="wo-suggestion-card wo-suggestion-card--mixed">
                        <div class="wo-suggestion-card-info">
                            <div class="wo-suggestion-card-header">
                                <span class="badge badge-info">🔀 Mixed Build</span>
                                @if (suggestion.MatchingTemplateName != null)
                                {
                                    <strong>@suggestion.MatchingTemplateName</strong>
                                }
                            </div>
                            <div class="wo-suggestion-card-detail">
                                @string.Join(" + ", suggestion.Parts.Select(p => $"{p.PartNumber} ({p.SuggestedQuantity})")) · @suggestion.EstimatedDurationHours.ToString("F1")h
                            </div>
                            <div class="wo-suggestion-card-rationale">@suggestion.Rationale</div>
                            @if (suggestion.FulfillsWorkOrders.Any())
                            {
                                <div class="wo-suggestion-card-wos">
                                    Fulfills: @string.Join(", ", suggestion.FulfillsWorkOrders.Select(w => $"{w.OrderNumber} ({w.QuantityFulfilled}pc)"))
                                </div>
                            }
                        </div>
                        <div class="wo-suggestion-card-actions">
                            @if (suggestion.MatchingTemplateId.HasValue)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="() => ScheduleFromMixedSuggestion(suggestion)" title="Schedule using the matching template">
                                    📅 Schedule from Template
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-accent" @onclick="() => CreateMixedBuild(suggestion)" title="Create a new mixed build plate">
                                    🆕 Create Mixed Build
                                </button>
                            }
                            <button class="btn btn-sm btn-secondary" @onclick='() => _dismissedSuggestions.Add(key)' title="Dismiss this suggestion">
                                ✕
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        @* ── Work Order Cards ── *@
        @if (_statFilter != null)
        {
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 0.82rem; color: var(--text-secondary);">
                <span>Showing: <strong>@_statFilter</strong></span>
                <button class="btn btn-sm btn-ghost" @onclick="() => _statFilter = null">✕ Clear filter</button>
            </div>
        }
        <div class="wo-demand-list">
            @foreach (var wo in GetFilteredWorkOrders().OrderBy(w => w.DueDate))
            {
                var daysUntilDue = (wo.DueDate.Date - DateTime.UtcNow.Date).Days;
                var dueClass = daysUntilDue < 0 ? "wo-card--overdue" : (daysUntilDue <= 3 ? "wo-card--urgent" : "");
                var woOutstanding = wo.Lines.Sum(l => GetOutstanding(l));

                <div class="wo-demand-card @dueClass">
                    <div class="wo-card-header">
                        <div class="wo-card-title">
                            <a href="/workorders/@wo.Id" class="wo-card-number">@wo.OrderNumber</a>
                            <span class="wo-card-customer">@wo.CustomerName</span>
                        </div>
                        <div class="wo-card-meta">
                            <span class="badge badge-@wo.Priority.ToString().ToLower()">@wo.Priority</span>
                            <span class="badge badge-@(wo.Status == WorkOrderStatus.Released ? "primary" : "info")">@wo.Status</span>
                            @if (daysUntilDue < 0)
                            {
                                <span class="badge badge-danger">@Math.Abs(daysUntilDue)d OVERDUE</span>
                            }
                            else if (daysUntilDue <= 3)
                            {
                                <span class="badge badge-warning">Due in @(daysUntilDue)d</span>
                            }
                            else
                            {
                                <span class="wo-card-due">Due @wo.DueDate.ToString("MM/dd")</span>
                            }
                        </div>
                    </div>

                    @if (woOutstanding <= 0)
                    {
                        <div class="wo-card-fulfilled">
                            <span>✅ All parts produced or scheduled</span>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                            <button class="btn btn-sm btn-primary" @onclick="() => ScheduleAllForWoAsync(wo)" disabled="@_schedulingWoId.HasValue" title="SLS lines: schedule existing builds + create from templates. CNC lines: generate and schedule jobs.">
                                @if (_schedulingWoId == wo.Id) { <span>Scheduling...</span> } else { <span>⚡ Schedule All Lines</span> }
                            </button>
                        </div>
                        <div class="wo-card-lines">
                            @foreach (var line in wo.Lines.OrderByDescending(l => GetOutstanding(l)))
                            {
                                var outstanding = GetOutstanding(line);
                                var isAdditive = IsAdditiveLine(line);
                                var hasJobs = HasExistingJobs(line);
                                var inBuilds = GetInBuildQty(line);
                                var inProduction = GetInProductionQty(line);
                                var progressPct = line.Quantity > 0 ? Math.Min(100, line.ProducedQuantity * 100.0 / line.Quantity) : 0;
                                var prodPct = line.Quantity > 0 ? Math.Min(100 - progressPct, inProduction * 100.0 / line.Quantity) : 0;
                                var buildPct = line.Quantity > 0 ? Math.Min(100 - progressPct - prodPct, inBuilds * 100.0 / line.Quantity) : 0;

                                <div class="wo-line-row @(outstanding <= 0 ? "wo-line-row--done" : "")">
                                    <div class="wo-line-info">
                                        <div class="wo-line-part">
                                            <span class="wo-line-type-badge @(isAdditive ? "wo-line-type--sls" : "wo-line-type--cnc")">
                                                @(isAdditive ? "🖨️ SLS" : "⚙️ CNC")
                                            </span>
                                            <span class="wo-line-partnum">@(line.Part?.PartNumber ?? "?")</span>
                                            <span class="wo-line-partname">@(line.Part?.Name ?? "")</span>
                                        </div>
                                         <div class="wo-line-qty">
                                            <span class="wo-line-qty-detail">@line.ProducedQuantity / @line.Quantity</span>
                                            @if (inProduction > 0)
                                            {
                                                <span style="color: var(--warning); font-size: 0.75rem;">⚙️ @inProduction in jobs</span>
                                            }
                                            @if (inBuilds > 0)
                                            {
                                                <span style="color: var(--accent); font-size: 0.75rem;">🖨️ @inBuilds in builds</span>
                                            }
                                            @if (outstanding > 0)
                                            {
                                                <span class="wo-line-outstanding">@outstanding remaining</span>
                                            }
                                            else
                                            {
                                                <span class="wo-line-complete">✅ Covered</span>
                                            }
                                        </div>
                                    </div>

                                    @* Progress bar: produced (green) + in-production (yellow) + in-builds (blue) *@
                                    <div class="wo-line-progress">
                                        <div style="display: flex; height: 100%;">
                                            @if (progressPct > 0)
                                            {
                                                <div class="wo-line-progress-fill" style="width: @progressPct.ToString("F0")%;"></div>
                                            }
                                            @if (prodPct > 0)
                                            {
                                                <div class="wo-line-progress-prod" style="width: @prodPct.ToString("F0")%;"></div>
                                            }
                                            @if (buildPct > 0)
                                            {
                                                <div class="wo-line-progress-build" style="width: @buildPct.ToString("F0")%;"></div>
                                            }
                                        </div>
                                    </div>

                                    @* Actions *@
                                    @if (outstanding > 0)
                                    {
                                        <div class="wo-line-actions">
                                            @if (hasJobs)
                                            {
                                                <span class="badge badge-info" style="font-size:0.7rem;">Jobs exist</span>
                                            }
                                            @if (isAdditive)
                                            {
                                                @* ── Certified Template Cards for SLS Lines ── *@
                                                var matchingTemplates = GetMatchingTemplates(line.PartId);
                                                var recertTemplates = GetRecertTemplates(line.PartId);
                                                @if (matchingTemplates.Any())
                                                {
                                                    @foreach (var template in matchingTemplates)
                                                    {
                                                        <div class="wo-template-card">
                                                            <div class="wo-template-card-info">
                                                                <span class="wo-template-card-name" title="@template.Name">✅ @template.Name</span>
                                                                <span class="wo-template-card-detail">@template.TotalPartCount parts · @template.EstimatedDurationHours.ToString("F1")h · Used @template.UseCount×</span>
                                                            </div>
                                                            <button class="btn btn-sm btn-primary" @onclick="() => ShowQuickScheduleModal(wo, line, template)" title="Schedule using this certified template">
                                                                📅 Schedule This Build
                                                            </button>
                                                        </div>
                                                    }
                                                }
                                                @if (recertTemplates.Any())
                                                {
                                                    @foreach (var template in recertTemplates)
                                                    {
                                                        <div class="wo-template-card wo-template-card--recert">
                                                            <div class="wo-template-card-info">
                                                                <span class="wo-template-card-name">⚠️ @template.Name</span>
                                                                <span class="wo-template-card-detail">Needs re-certification (part updated)</span>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                @if (!matchingTemplates.Any())
                                                {
                                                    <button class="btn btn-sm btn-accent" @onclick='() => NavigateToNewBuild(line)' title="Create a new build for this part on the Builds page">
                                                        🆕 New Build
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-secondary" @onclick="() => OpenWoBuildModal(wo, line)" title="Create a build plate for this part">
                                                    🖨️ Create Build
                                                </button>

                                                @* ── Split Build Suggestion or Configuration Warning ── *@
                                                var config = line.Part?.AdditiveBuildConfig;
                                                var isConfigured = IsBuildConfigured(config);
                                                var partsPerBuild = GetPartsPerBuild(config, outstanding);
                                                var needsSplit = partsPerBuild > 0 && outstanding > partsPerBuild;

                                                @if (!isConfigured && outstanding > 1)
                                                {
                                                    var existingBuilds = GetBuildsForPart(line.PartId);
                                                    @if (existingBuilds.Any())
                                                    {
                                                        <div class="wo-config-warning" style="flex-direction: column; align-items: flex-start; gap: 6px;">
                                                            <span style="font-size: 0.8rem; color: var(--text-muted);">📦 Existing builds with this part:</span>
                                                            @foreach (var eb in existingBuilds)
                                                            {
                                                                var ebStatusIcon = eb.Status switch
                                                                {
                                                                    BuildPackageStatus.Completed => "✅",
                                                                    BuildPackageStatus.PostPrint => "📦",
                                                                    BuildPackageStatus.Printing => "🖨️",
                                                                    BuildPackageStatus.Scheduled => "📅",
                                                                    BuildPackageStatus.Ready => "🟢",
                                                                    _ => "📝"
                                                                };
                                                                var ebPartQty = eb.Parts?.FirstOrDefault(p => p.PartId == line.PartId)?.Quantity ?? 0;
                                                                <div style="display: flex; align-items: center; gap: 6px; font-size: 0.8rem;">
                                                                    <span>@ebStatusIcon @eb.Name — @ebPartQty pcs — @eb.Status</span>
                                                                    @if (eb.Status == BuildPackageStatus.Ready)
                                                                    {
                                                                        <button class="btn btn-sm btn-primary" style="padding: 2px 8px; font-size: 0.75rem;" @onclick="() => ScheduleExistingBuildAsync(eb)">
                                                                            📅 Schedule
                                                                        </button>
                                                                    }
                                                                    @if (eb.Status == BuildPackageStatus.Draft)
                                                                    {
                                                                        <button class="btn btn-sm btn-secondary" style="padding: 2px 8px; font-size: 0.75rem;" @onclick="() => OpenWoBuildModal(wo, line)">
                                                                            ✏️ Setup
                                                                        </button>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="wo-config-warning">
                                                            <span>⚠️ Build capacity not configured — </span>
                                                            <a href="/parts/@line.PartId/edit" target="_blank" title="Configure how many parts fit on a build plate">
                                                                Edit Part → Stacking tab
                                                            </a>
                                                        </div>
                                                    }
                                                }
                                                else if (needsSplit)
                                                {
                                                    var splitSuggestion = SuggestBuildSplit(outstanding, partsPerBuild);
                                                    <div class="wo-split-suggestion">
                                                        <div class="wo-split-info">
                                                            <span>📊 @outstanding parts → @splitSuggestion.Count builds (@partsPerBuild per build): @string.Join(" + ", splitSuggestion)</span>
                                                        </div>
                                                        @if (_splitLineId == line.Id)
                                                        {
                                                            <div class="wo-split-editor">
                                                                @for (var i = 0; i < _splitQuantities.Count; i++)
                                                                {
                                                                    var idx = i;
                                                                    <div class="wo-split-editor-row">
                                                                        <label>Build @(idx + 1):</label>
                                                                        <input type="number" min="1" max="@outstanding" value="@_splitQuantities[idx]"
                                                                               @onchange="e => UpdateSplitQuantity(idx, e)" class="form-control form-control-sm" style="width:80px;" />
                                                                        @if (_splitQuantities.Count > 1)
                                                                        {
                                                                            <button class="btn btn-sm btn-ghost" @onclick="() => RemoveSplitRow(idx)" title="Remove">✕</button>
                                                                        }
                                                                    </div>
                                                                }
                                                                <div class="wo-split-editor-actions">
                                                                    <button class="btn btn-sm btn-ghost" @onclick="AddSplitRow" title="Add another build">+ Add Build</button>
                                                                    <span class="wo-split-total @(SplitTotal != outstanding ? "wo-split-total--mismatch" : "")">Total: @SplitTotal / @outstanding</span>
                                                                </div>
                                                                <div class="wo-split-editor-submit">
                                                                    <button class="btn btn-sm btn-primary" @onclick="() => CreateAllSplitBuildsAsync(wo, line)" disabled="@(_creatingSplitBuilds || SplitTotal != outstanding)">
                                                                        @if (_creatingSplitBuilds) { <span>Creating...</span> } else { <span>🖨️ Create @_splitQuantities.Count Builds</span> }
                                                                    </button>
                                                                    <button class="btn btn-sm btn-ghost" @onclick="() => _splitLineId = null">Cancel</button>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-sm btn-accent" @onclick="() => OpenSplitEditor(line.Id, outstanding, partsPerBuild)" title="Split into multiple builds">
                                                                🔀 Split & Create @splitSuggestion.Count Builds
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                @if (!hasJobs)
                                                {
                                                    <button class="btn btn-sm btn-accent" @onclick="() => OpenWoJobModal(wo, line)" title="Generate and auto-schedule a job for this part">
                                                        ⚙️ Schedule Job
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-secondary" @onclick="() => OpenWoJobModal(wo, line)" title="Create another job for remaining quantity">
                                                        ⚙️ Add Job
                                                    </button>
                                                    @if (HasUnscheduledJobs(line))
                                                    {
                                                        <button class="btn btn-sm btn-primary" @onclick="() => AutoScheduleLineJobsAsync(line)" title="Auto-schedule all Draft jobs on this line">
                                                            📅 Auto-Schedule
                                                        </button>
                                                    }
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* ── WO-specific Modals ── *@
<WoBuildModal
    IsVisible="_showWoBuildModal"
    WorkOrder="_selectedWo"
    WorkOrderLine="_selectedWoLine"
    SlsMachines="SlsMachines"
    AllMachines="AllMachines"
    UserName="@UserName"
    InitialBuildName="@_woBuildName"
    InitialMachineId="@_woBuildMachineId"
    InitialQuantity="_woBuildQuantity"
    OnClose="() => { _showWoBuildModal = false; }"
    OnCreated="OnModalConfirmedAsync" />

<WoJobModal
    IsVisible="_showWoJobModal"
    WorkOrder="_selectedWo"
    WorkOrderLine="_selectedWoLine"
    UserName="@UserName"
    OnClose="() => { _showWoJobModal = false; }"
    OnScheduled="OnModalConfirmedAsync" />

<QuickScheduleModal
    IsVisible="_showQuickScheduleModal"
    Template="_selectedTemplate"
    WorkOrder="_quickScheduleWo"
    WorkOrderLine="_quickScheduleWoLine"
    SlsMachines="SlsMachines"
    AllMachines="AllMachines"
    UserName="@UserName"
    InitialMachineId="@_quickScheduleMachineId"
    OnClose="() => { _showQuickScheduleModal = false; }"
    OnScheduled="OnModalConfirmedAsync" />

@code {
    [Parameter, EditorRequired] public List<WorkOrder> WorkOrders { get; set; } = [];
    [Parameter, EditorRequired] public List<BuildTemplate> BuildTemplates { get; set; } = [];
    [Parameter] public List<BuildPackage> BuildPackages { get; set; } = [];
    [Parameter] public BuildSuggestionResult? Suggestions { get; set; }
    [Parameter, EditorRequired] public List<Machine> SlsMachines { get; set; } = [];
    [Parameter, EditorRequired] public List<Machine> AllMachines { get; set; } = [];
    [Parameter, EditorRequired] public string UserName { get; set; } = "System";
    [Parameter] public bool ShowOverdueOnly { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }

    // WO Build modal state
    private bool _showWoBuildModal;
    private WorkOrder? _selectedWo;
    private WorkOrderLine? _selectedWoLine;
    private string _woBuildName = "";
    private string _woBuildMachineId = "";
