    // ── Build Split Helpers ──

    /// <summary>
    /// Returns the planned parts-per-build for the optimal stack level, or 0 if not meaningfully configured.
    /// A value of 1 is treated as "unconfigured" since it's the default and creates unusable 1-part-per-build splits.
    /// </summary>
    private static int GetPartsPerBuild(PartAdditiveBuildConfig? config, int quantity)
    {
        if (config == null) return 0;
        var level = config.GetRecommendedStackLevel(quantity);
        var partsPerBuild = config.GetPartsPerBuild(level) ?? 0;

        // Treat 1 as "unconfigured" — avoids showing "100 builds for 100 parts" nonsense
        return partsPerBuild > 1 ? partsPerBuild : 0;
    }

    /// <summary>
    /// Returns true if the part's additive build config is meaningfully configured for build planning.
    /// </summary>
    private static bool IsBuildConfigured(PartAdditiveBuildConfig? config)
    {
        if (config == null) return false;
        // Must have PlannedPartsPerBuildSingle > 1 (not the default)
        return config.PlannedPartsPerBuildSingle > 1;
    }

    /// <summary>
    /// Splits an outstanding quantity into build-sized batches.
    /// </summary>
    private static List<int> SuggestBuildSplit(int outstandingQty, int partsPerBuild)
    {
        if (partsPerBuild <= 0) return [outstandingQty];
        var splits = new List<int>();
        var remaining = outstandingQty;
        while (remaining > 0)
        {
            var batch = Math.Min(remaining, partsPerBuild);
            splits.Add(batch);
            remaining -= batch;
        }
        return splits;
    }

    private void OpenSplitEditor(int lineId, int outstanding, int partsPerBuild)
    {
        _splitLineId = lineId;
        _splitQuantities = SuggestBuildSplit(outstanding, partsPerBuild);
    }

    private void UpdateSplitQuantity(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val > 0)
            _splitQuantities[index] = val;
    }

    private void AddSplitRow() => _splitQuantities.Add(1);

    private void RemoveSplitRow(int index)
    {
        if (_splitQuantities.Count > 1)
            _splitQuantities.RemoveAt(index);
    }

    private async Task CreateAllSplitBuildsAsync(WorkOrder wo, WorkOrderLine line)
    {
        if (SplitTotal != line.Quantity - line.ProducedQuantity - GetInBuildQty(line)) return;
        _creatingSplitBuilds = true;
        StateHasChanged();
        try
        {
            var machineId = SlsMachines.FirstOrDefault()?.Id;
            var created = 0;
            for (var i = 0; i < _splitQuantities.Count; i++)
            {
                var qty = _splitQuantities[i];
                var buildName = $"Build-{line.Part?.PartNumber ?? "?"}-{DateTime.UtcNow:MMdd}-{(char)('A' + i)}";
                var package = await BuildPlanning.CreatePackageAsync(new BuildPackage
                {
                    Name = buildName,
                    MachineId = machineId,
                    Status = BuildPackageStatus.Draft,
                    CreatedBy = UserName,
                    LastModifiedBy = UserName
                });
                await BuildPlanning.AddPartToPackageAsync(package.Id, line.PartId, qty, line.Id);
                created++;
            }
            Toast.ShowSuccess($"Created {created} builds for {line.Part?.PartNumber ?? "?"}. Enter slicer data, then schedule.");
            _splitLineId = null;
            _splitQuantities.Clear();
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed to create split builds: {ex.Message}"); }
        finally { _creatingSplitBuilds = false; }
    }

    // ── Build Suggestion Actions (Phase C) ──

    private void ScheduleFromSuggestion(TemplateSuggestion suggestion)
    {
        var woRef = suggestion.FulfillsWorkOrders.FirstOrDefault();
        if (woRef == null) return;

        var wo = WorkOrders.FirstOrDefault(w => w.Id == woRef.WorkOrderId);
        var line = wo?.Lines.FirstOrDefault(l => l.Id == woRef.WorkOrderLineId);
        var template = BuildTemplates.FirstOrDefault(t => t.Id == suggestion.BuildTemplateId);
        if (wo == null || line == null || template == null) return;

        ShowQuickScheduleModal(wo, line, template);
    }

    private void ScheduleFromMixedSuggestion(MixedBuildSuggestion suggestion)
    {
        if (!suggestion.MatchingTemplateId.HasValue) return;

        var woRef = suggestion.FulfillsWorkOrders.FirstOrDefault();
        if (woRef == null) return;

        var wo = WorkOrders.FirstOrDefault(w => w.Id == woRef.WorkOrderId);
        var line = wo?.Lines.FirstOrDefault(l => l.Id == woRef.WorkOrderLineId);
        var template = BuildTemplates.FirstOrDefault(t => t.Id == suggestion.MatchingTemplateId.Value);
        if (wo == null || line == null || template == null) return;

        ShowQuickScheduleModal(wo, line, template);
    }

    private async Task CreateMixedBuild(MixedBuildSuggestion suggestion)
    {
        _creatingFromWo = true;
        StateHasChanged();
        try
        {
            var partNames = string.Join("+", suggestion.Parts.Select(p => p.PartNumber));
            var package = await BuildPlanning.CreatePackageAsync(new BuildPackage
            {
                Name = $"Mixed-{partNames}-{DateTime.UtcNow:MMdd}",
                Status = BuildPackageStatus.Draft,
                EstimatedDurationHours = suggestion.EstimatedDurationHours,
                CreatedBy = UserName,
                LastModifiedBy = UserName
            });

            foreach (var part in suggestion.Parts)
            {
                var woRef = suggestion.FulfillsWorkOrders.FirstOrDefault(w =>
                {
                    var wo = WorkOrders.FirstOrDefault(o => o.Id == w.WorkOrderId);
                    return wo?.Lines.Any(l => l.Id == w.WorkOrderLineId && l.PartId == part.PartId) == true;
                });

                await BuildPlanning.AddPartToPackageAsync(
                    package.Id,
                    part.PartId,
                    part.SuggestedQuantity,
                    woRef?.WorkOrderLineId);
            }

            Toast.ShowSuccess($"Mixed build '{package.Name}' created with {suggestion.Parts.Count} parts. Enter slicer data on the Builds page.");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _creatingFromWo = false; }
    }
