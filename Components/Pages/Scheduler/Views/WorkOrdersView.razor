        _selectedWo = wo;
        _selectedWoLine = line;
        _showWoJobModal = true;
    }

    private async Task AutoScheduleLineJobsAsync(WorkOrderLine line)
    {
        var draftJobs = line.Jobs?.Where(j => j.Status == JobStatus.Draft).ToList() ?? [];
        if (draftJobs.Count == 0) return;
        var scheduled = 0;
        foreach (var job in draftJobs)
        {
            try
            {
                await SchedulingService.AutoScheduleJobAsync(job.Id);
                scheduled++;
            }
            catch { /* skip jobs that can't be scheduled */ }
        }
        if (scheduled > 0)
        {
            Toast.ShowSuccess($"Auto-scheduled {scheduled} job(s) for {line.Part?.PartNumber ?? "?"}");
            await OnRefreshRequested.InvokeAsync();
        }
        else
        {
            Toast.ShowWarning("No jobs could be scheduled (no capable machines found)");
        }
    }

    /// <summary>
    /// Schedule all unfulfilled lines on a WO: for SLS lines, schedule existing Ready/Sliced
    /// builds and create new builds from certified templates; for CNC lines, generate and
    /// auto-schedule jobs.
    /// </summary>
    private async Task ScheduleAllForWoAsync(WorkOrder wo)
    {
        _schedulingWoId = wo.Id;
        StateHasChanged();
        try
        {
            var jobsCreated = 0;
            var jobsScheduled = 0;
            var buildsScheduled = 0;
            var buildsCreated = 0;
            var slsNoTemplate = 0;
            var slsNoMachine = 0;

            foreach (var line in wo.Lines)
            {
                if (GetOutstanding(line) <= 0) continue;

                if (IsAdditiveLine(line))
                {
                    // Schedule existing Ready/Sliced builds for this part
                    var existingBuilds = GetBuildsForPart(line.PartId)
                        .Where(b => b.Status is BuildPackageStatus.Ready or BuildPackageStatus.Sliced)
                        .ToList();
                    foreach (var build in existingBuilds)
                    {
                        try
                        {
                            var machineId = build.MachineId ?? SlsMachines.FirstOrDefault()?.Id;
                            if (machineId.HasValue)
                            {
                                await BuildScheduling.ScheduleBuildAsync(build.Id, machineId.Value);
                                buildsScheduled++;
                            }
                        }
                        catch { /* skip builds that fail to schedule */ }
                    }

                    // Create and schedule new builds from certified template for remaining demand
                    var outstanding = GetOutstanding(line);
                    if (outstanding > 0)
                    {
                        var defaultMachineId = SlsMachines.FirstOrDefault()?.Id;
                        if (!defaultMachineId.HasValue)
                        {
                            slsNoMachine++;
                            continue;
                        }

                        var templates = GetMatchingTemplates(line.PartId);
                        if (templates.Count > 0)
                        {
                            var template = templates.First();
                            var templateQty = template.Parts
                                .Where(p => p.PartId == line.PartId)
                                .Sum(p => p.Quantity);

                            if (templateQty > 0)
                            {
                                var buildsNeeded = (int)Math.Ceiling((double)outstanding / templateQty);
                                for (var i = 0; i < buildsNeeded; i++)
                                {
                                    try
                                    {
                                        var package = await BuildTemplateService.InstantiateAsync(
                                            template.Id, defaultMachineId.Value, UserName, line.Id);
                                        buildsCreated++;
                                        await BuildScheduling.ScheduleBuildAsync(package.Id, defaultMachineId.Value);
                                        buildsScheduled++;
                                    }
                                    catch { /* skip failed instantiation/scheduling */ }
                                }
                            }
                        }
                        else
                        {
                            slsNoTemplate++;
                        }
                    }

                    continue;
                }

                // CNC: generate a job if none exist
                if (!HasExistingJobs(line))
                {
                    try
                    {
                        var job = await WoService.GenerateJobForLineAsync(line.Id, UserName);
                        jobsCreated++;
                        try
                        {
                            await SchedulingService.AutoScheduleJobAsync(job.Id);
                            jobsScheduled++;
                        }
                        catch { /* job created but couldn't schedule */ }
                    }
                    catch { /* skip lines that fail */ }
                }
                else if (HasUnscheduledJobs(line))
                {
                    // Auto-schedule existing Draft jobs
                    foreach (var job in line.Jobs!.Where(j => j.Status == JobStatus.Draft))
                    {
                        try
                        {
                            await SchedulingService.AutoScheduleJobAsync(job.Id);
                            jobsScheduled++;
                        }
                        catch { /* skip */ }
                    }
                }
            }

            var parts = new List<string>();
            if (buildsCreated > 0) parts.Add($"{buildsCreated} build(s) created");
            if (buildsScheduled > 0) parts.Add($"{buildsScheduled} build(s) scheduled");
            if (jobsCreated > 0) parts.Add($"{jobsCreated} job(s) created");
            if (jobsScheduled > 0) parts.Add($"{jobsScheduled} job(s) scheduled");
            if (slsNoTemplate > 0) parts.Add($"{slsNoTemplate} SLS line(s) need certified templates");
            if (slsNoMachine > 0) parts.Add($"{slsNoMachine} SLS line(s) skipped — no SLS machines");
            Toast.ShowSuccess(parts.Count > 0 ? string.Join(", ", parts) : "Nothing to schedule");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Schedule All failed: {ex.Message}"); }
        finally { _schedulingWoId = null; }
    }

    // ── Build Lookup Helpers ──

    /// <summary>
    /// Returns active (non-completed, non-cancelled) builds that contain the specified part.
    /// </summary>
    private List<BuildPackage> GetBuildsForPart(int partId) =>
        BuildPackages
            .Where(bp => bp.Parts != null && bp.Parts.Any(p => p.PartId == partId)
                && bp.Status != BuildPackageStatus.Completed
                && bp.Status != BuildPackageStatus.Cancelled)
            .OrderByDescending(bp => bp.CreatedDate)
            .ToList();

    /// <summary>
    /// Schedule an existing Ready build on the first available SLS machine.
    /// </summary>
    private async Task ScheduleExistingBuildAsync(BuildPackage build)
    {
        try
        {
            var machineId = build.MachineId ?? SlsMachines.FirstOrDefault()?.Id;
            if (machineId is null)
            {
                Toast.ShowError("No SLS machine available to schedule this build.");
                return;
            }

            await BuildScheduling.ScheduleBuildAsync(build.Id, machineId.Value);
            Toast.ShowSuccess($"Build '{build.Name}' scheduled successfully.");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to schedule build: {ex.Message}");
        }
    }

    // ── Template Matching Helpers ──

    private List<BuildTemplate> GetMatchingTemplates(int partId) =>
        BuildTemplates
            .Where(t => t.IsCertified && t.Parts.Any(p => p.PartId == partId))
            .ToList();

    private List<BuildTemplate> GetRecertTemplates(int partId) =>
        BuildTemplates
            .Where(t => t.NeedsRecertification && t.Parts.Any(p => p.PartId == partId))
            .ToList();

