@* ── BuildPlate Programs View: pipeline + per-machine timelines ── *@
@using Opcentrix_V3.Components.Pages.Scheduler.Components
@inject IProgramPlanningService ProgramPlanning
@inject IMachineProgramService ProgramService
@inject ToastService Toast

<ConfirmDialog @ref="_confirmDialog" />

<div class="sched-layout">
    <div class="sched-gantt-panel">
        @* ── Program Pipeline Summary ── *@
        @{
            var filtered = FilteredPrograms;
            var active = filtered
                .Where(p => p.ScheduleStatus != ProgramScheduleStatus.Cancelled && p.ScheduleStatus != ProgramScheduleStatus.Completed)
                .OrderBy(p => p.ScheduleStatus).ThenByDescending(p => p.ScheduledDate ?? p.CreatedDate)
                .ToList();
            var ready = filtered.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Ready).ToList();
            var scheduled = filtered.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Scheduled).ToList();
            var printing = filtered.Where(p => p.ScheduleStatus == ProgramScheduleStatus.Printing).ToList();
            var postPrint = filtered.Where(p => p.ScheduleStatus == ProgramScheduleStatus.PostPrint).ToList();
        }

        @* ── Visual Workflow Indicator ── *@
        <div class="builds-workflow-indicator">
            <div class="workflow-step @(ready.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">✅</span>
                <span class="workflow-step-label">Ready</span>
                <span class="workflow-step-count">@ready.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(scheduled.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">📅</span>
                <span class="workflow-step-label">Scheduled</span>
                <span class="workflow-step-count">@scheduled.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(printing.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">🖨️</span>
                <span class="workflow-step-label">Printing</span>
                <span class="workflow-step-count">@printing.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(postPrint.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">🔥</span>
                <span class="workflow-step-label">Post-Print</span>
                <span class="workflow-step-count">@postPrint.Count</span>
            </div>
        </div>

        <div class="builds-pipeline-summary">
            <div class="builds-pipeline-stat">
                <span class="builds-pipeline-count">@active.Count</span>
                <span class="builds-pipeline-label">Active Programs</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--ready">
                <span class="builds-pipeline-count">@(ready.Count + scheduled.Count)</span>
                <span class="builds-pipeline-label">Ready / Scheduled</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--printing">
                <span class="builds-pipeline-count">@printing.Count</span>
                <span class="builds-pipeline-label">Printing</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--post">
                <span class="builds-pipeline-count">@postPrint.Count</span>
                <span class="builds-pipeline-label">Post-Print</span>
            </div>
            <div class="builds-pipeline-stat">
                <span class="builds-pipeline-count">@SlsMachines.Count</span>
                <span class="builds-pipeline-label">SLS Machines</span>
            </div>
        </div>

        @* ── Per-Machine Build Timelines ── *@
        <div class="card sched-gantt-card">
            @if (!SlsMachines.Any())
            {
                <div class="empty-state"><div class="empty-state-icon">🖨️</div><div class="empty-state-text">No SLS machines configured for scheduling</div></div>
            }
            else
            {
                <GanttViewport @ref="Viewport"
                    DataRangeStart="DataRangeStart"
                    DataRangeEnd="DataRangeEnd"
                    PixelsPerHour="PixelsPerHour"
                    OnPixelsPerHourChanged="OnPixelsPerHourChanged"
                    OnViewportBoundsChanged="OnViewportBoundsChanged"
                    OnDataRangeExtensionNeeded="OnDataRangeExtensionNeeded">

                        @* ── SLS machine rows with build bars ── *@
                        @foreach (var machine in SlsMachines)
                        {
                            var timeline = MachineTimelines.GetValueOrDefault(machine.Id) ?? [];
                            <div class="gantt-row">
                                <div class="gantt-resource-label">
                                    <span class="gantt-machine-status gantt-status-@machine.Status.ToString().ToLower()"></span>
                                    <div class="gantt-machine-info">
                                        <span class="gantt-machine-name">@machine.Name</span>
                                        <span class="gantt-machine-type">@(machine.LaserCount != null ? $"{machine.LaserCount} laser" : machine.MachineType) · @(machine.BuildPlateCapacity) plate</span>
                                    </div>
                                </div>
                                <div class="gantt-track">
                                    @foreach (var entry in timeline)
                                    {
                                        var barLeft = GetBarLeftPx(entry.PrintStart);
                                        var barWidth = GetBarWidthPx(entry.PrintStart, entry.PrintEnd);
                                        var statusClass = entry.ScheduleStatus switch
                                        {
                                            ProgramScheduleStatus.Printing => "builds-bar--printing",
                                            ProgramScheduleStatus.PostPrint => "builds-bar--postprint",
                                            ProgramScheduleStatus.Completed => "builds-bar--completed",
                                            ProgramScheduleStatus.Scheduled => "builds-bar--scheduled",
                                            _ => "builds-bar--ready"
                                        };
                                        var tooltip = $"{entry.ProgramName}\nStatus: {entry.ScheduleStatus}\n{entry.PrintStart:MM/dd HH:mm} \u2192 {entry.PrintEnd:MM/dd HH:mm}";
                                        if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                            tooltip += $"\nChangeover: {entry.ChangeoverStart:HH:mm} \u2192 {entry.ChangeoverEnd:HH:mm}";
                                        <div class="gantt-bar @statusClass"
                                             style="left: @(FormatPx(barLeft))px; width: @(FormatPx(barWidth))px;"
                                             title="@tooltip">
                                            <span class="gantt-bar-text">📦 @entry.ProgramName · @entry.ScheduleStatus</span>
                                        </div>
                                        @if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                        {
                                            var coLeft = GetBarLeftPx(entry.ChangeoverStart.Value);
                                            var coWidth = GetBarWidthPx(entry.ChangeoverStart.Value, entry.ChangeoverEnd.Value);
                                            <div class="builds-changeover-bar"
                                                 style="left: @(FormatPx(coLeft))px; width: @(FormatPx(coWidth))px;"
                                                 title="Changeover: @entry.ChangeoverStart.Value.ToString("HH:mm") → @entry.ChangeoverEnd.Value.ToString("HH:mm")">
                                                <span class="gantt-bar-text">🔄 Changeover</span>
                                            </div>
                                        }
                                                         }
                                                    </div>
                                                </div>
                                            }
                                    </GanttViewport>

                                    @* Build status legend *@
                <div class="gantt-legend">
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--scheduled"></span> Scheduled</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--printing"></span> Printing</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--postprint"></span> Post-Print</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--completed"></span> Completed</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-changeover-bar"></span> Changeover</span>
                </div>
            }
        </div>

        @* ── Ready Programs Cards ── *@
        @if (ready.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">✅ Ready to Schedule (@ready.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var prog in ready)
                    {
                        <div class="builds-ready-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(prog.Name ?? $"Program #{prog.Id}")</span>
                                <span class="badge badge-@ProgramStatusBadgeClass(prog.ScheduleStatus)">@ProgramStatusIcon(prog.ScheduleStatus) @prog.ScheduleStatus</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(prog.TotalPartCount) parts</span>
                                <span>🖨️ @(prog.EstimatedPrintHours?.ToString("F1") ?? "?")h print</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Printing Programs — with Post-Print action ── *@
        @if (printing.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">🖨️ Printing (@printing.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var prog in printing)
                    {
                        <div class="builds-ready-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(prog.Name ?? $"Program #{prog.Id}")</span>
                                <span class="badge badge-accent">🖨️ Printing</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(prog.TotalPartCount) parts</span>
                                <span>@(prog.EstimatedPrintHours?.ToString("F1") ?? "?")h est</span>
                            </div>
                            <div style="margin-top:6px;">
                                <button class="btn btn-sm btn-info" @onclick="() => TransitionToPostPrintAsync(prog)" disabled="@_processing"
                                        title="Print complete — move to Post-Print stages">
                                    🔄 → Post-Print
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Post-Print Programs — with Release Plate action ── *@
        @if (postPrint.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">🔥 Post-Print (@postPrint.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var prog in postPrint)
                    {
                        <div class="builds-ready-card builds-postprint-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(prog.Name ?? $"Program #{prog.Id}")</span>
                                <span class="badge badge-info">🔥 Post-Print</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(prog.TotalPartCount) parts</span>
                            </div>
                            <div style="margin-top:8px;">
                                <button class="btn btn-sm btn-success" @onclick="() => ReleasePlateAsync(prog)" disabled="@_processing"
                                        title="Release plate — create part instances and per-part jobs">
                                    📦 Release Plate
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @{
        var buildUnscheduled = Unscheduled.Where(e => e.MachineProgramId.HasValue).ToList();
    }
    <UnscheduledSidebar Executions="buildUnscheduled"
                        Title="📋 Unscheduled Build Stages"
                        OnAutoSchedule="OnAutoSchedule" />
</div>

@code {
    [Parameter, EditorRequired] public List<MachineProgram> BuildPrograms { get; set; } = [];
    [Parameter, EditorRequired] public List<Machine> SlsMachines { get; set; } = [];
    [Parameter, EditorRequired] public Dictionary<int, List<ProgramTimelineEntry>> MachineTimelines { get; set; } = [];
    [Parameter, EditorRequired] public List<StageExecution> Unscheduled { get; set; } = [];
    [Parameter] public DateTime DataRangeStart { get; set; }
    [Parameter] public DateTime DataRangeEnd { get; set; }
    [Parameter] public double PixelsPerHour { get; set; }
    [Parameter] public ProgramScheduleStatus? ProgramStatusFilter { get; set; }
    [Parameter] public EventCallback<int> OnAutoSchedule { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }
    [Parameter] public string UserName { get; set; } = "System";

    [Parameter] public EventCallback<double> OnPixelsPerHourChanged { get; set; }
    [Parameter] public EventCallback<GanttViewport.ViewportBoundsChangedArgs> OnViewportBoundsChanged { get; set; }
    [Parameter] public EventCallback OnDataRangeExtensionNeeded { get; set; }

    /// <summary>Exposes the inner GanttViewport for direct method calls (zoom, scroll, save state).</summary>
    public GanttViewport? Viewport { get; private set; }

    private bool _processing;
    private ConfirmDialog _confirmDialog = null!;

    /// <summary>Filters programs based on the toolbar filter.</summary>
    private List<MachineProgram> FilteredPrograms => ProgramStatusFilter == null
        ? BuildPrograms
        : BuildPrograms.Where(p => p.ScheduleStatus == ProgramStatusFilter.Value).ToList();

    private double GetBarLeftPx(DateTime start) =>
        (start - DataRangeStart).TotalHours * PixelsPerHour;

    private double GetBarWidthPx(DateTime start, DateTime end) =>
        Math.Max(2, (end - start).TotalHours * PixelsPerHour);

    private string FormatPx(double value) => value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private async Task TransitionToPostPrintAsync(MachineProgram prog)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            $"Mark \"{prog.Name}\" print as complete and move to Post-Print?",
            "Confirm Post-Print Transition");
        if (!confirmed) return;
        _processing = true;
        try
        {
            prog.ScheduleStatus = ProgramScheduleStatus.PostPrint;
            prog.LastModifiedBy = UserName;
            prog.LastModifiedDate = DateTime.UtcNow;
            await ProgramPlanning.UpdateBuildPlateAsync(prog, UserName);
            Toast.ShowSuccess($"{prog.Name} → Post-Print");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    private async Task ReleasePlateAsync(MachineProgram prog)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            $"Release plate for \"{prog.Name}\"? This will create part instances and per-part jobs.",
            "Confirm Plate Release");
        if (!confirmed) return;
        _processing = true;
        try
        {
            prog.ScheduleStatus = ProgramScheduleStatus.Completed;
            prog.LastModifiedBy = UserName;
            prog.LastModifiedDate = DateTime.UtcNow;
            await ProgramPlanning.UpdateBuildPlateAsync(prog, UserName);
            Toast.ShowSuccess($"Plate released for {prog.Name}.");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    private static string ProgramStatusBadgeClass(ProgramScheduleStatus status) => status switch
    {
        ProgramScheduleStatus.Ready => "warning",
        ProgramScheduleStatus.Scheduled => "primary",
        ProgramScheduleStatus.Printing => "accent",
        ProgramScheduleStatus.PostPrint => "info",
        ProgramScheduleStatus.Completed => "success",
        ProgramScheduleStatus.Cancelled => "secondary",
        _ => "secondary"
    };

    private static string ProgramStatusIcon(ProgramScheduleStatus status) => status switch
    {
        ProgramScheduleStatus.Ready => "✅",
        ProgramScheduleStatus.Scheduled => "📅",
        ProgramScheduleStatus.Printing => "🖨️",
        ProgramScheduleStatus.PostPrint => "🔥",
        ProgramScheduleStatus.Completed => "✔️",
        ProgramScheduleStatus.Cancelled => "❌",
        _ => "📦"
    };
}
