@* ── SLS Builds View: build pipeline + per-machine timelines ── *@
@using Opcentrix_V3.Components.Pages.Scheduler.Components
@inject IBuildPlanningService BuildPlanning
@inject IBuildSchedulingService BuildScheduling
@inject ToastService Toast

<ConfirmDialog @ref="_confirmDialog" />

<div class="sched-layout">
    <div class="sched-gantt-panel">
        @* ── Build Pipeline Summary ── *@
        @{
            var filtered = FilteredBuilds;
            var active = filtered
                .Where(b => b.Status != BuildPackageStatus.Cancelled && b.Status != BuildPackageStatus.Completed)
                .OrderBy(b => b.Status).ThenByDescending(b => b.ScheduledDate ?? b.CreatedDate)
                .ToList();
            var draft = filtered.Where(b => b.Status == BuildPackageStatus.Draft).ToList();
            var sliced = filtered.Where(b => b.Status == BuildPackageStatus.Sliced && b.IsSlicerDataEntered).ToList();
            var ready = filtered.Where(b => b.Status == BuildPackageStatus.Ready).ToList();
            var scheduled = filtered.Where(b => b.Status == BuildPackageStatus.Scheduled).ToList();
            var printing = filtered.Where(b => b.Status == BuildPackageStatus.Printing).ToList();
            var postPrint = filtered.Where(b => b.Status == BuildPackageStatus.PostPrint).ToList();
        }

        @* ── Visual Workflow Indicator ── *@
        <div class="builds-workflow-indicator">
            <div class="workflow-step @(draft.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">📝</span>
                <span class="workflow-step-label">Draft</span>
                <span class="workflow-step-count">@draft.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(sliced.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">🔪</span>
                <span class="workflow-step-label">Sliced</span>
                <span class="workflow-step-count">@sliced.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(ready.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">✅</span>
                <span class="workflow-step-label">Ready</span>
                <span class="workflow-step-count">@ready.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(scheduled.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">📅</span>
                <span class="workflow-step-label">Scheduled</span>
                <span class="workflow-step-count">@scheduled.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(printing.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">🖨️</span>
                <span class="workflow-step-label">Printing</span>
                <span class="workflow-step-count">@printing.Count</span>
            </div>
            <div class="workflow-arrow">→</div>
            <div class="workflow-step @(postPrint.Any() ? "workflow-step--active" : "")">
                <span class="workflow-step-icon">🔥</span>
                <span class="workflow-step-label">Post-Print</span>
                <span class="workflow-step-count">@postPrint.Count</span>
            </div>
        </div>

        <div class="builds-pipeline-summary">
            <div class="builds-pipeline-stat">
                <span class="builds-pipeline-count">@active.Count</span>
                <span class="builds-pipeline-label">Active Builds</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--ready">
                <span class="builds-pipeline-count">@(ready.Count + scheduled.Count)</span>
                <span class="builds-pipeline-label">Ready / Scheduled</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--printing">
                <span class="builds-pipeline-count">@printing.Count</span>
                <span class="builds-pipeline-label">Printing</span>
            </div>
            <div class="builds-pipeline-stat builds-pipeline-stat--post">
                <span class="builds-pipeline-count">@postPrint.Count</span>
                <span class="builds-pipeline-label">Post-Print</span>
            </div>
            <div class="builds-pipeline-stat">
                <span class="builds-pipeline-count">@SlsMachines.Count</span>
                <span class="builds-pipeline-label">SLS Machines</span>
            </div>
        </div>

        @* ── Per-Machine Build Timelines ── *@
        <div class="card sched-gantt-card">
            @if (!SlsMachines.Any())
            {
                <div class="empty-state"><div class="empty-state-icon">🖨️</div><div class="empty-state-text">No SLS machines configured for scheduling</div></div>
            }
            else
            {
                <GanttViewport @ref="Viewport"
                    DataRangeStart="DataRangeStart"
                    DataRangeEnd="DataRangeEnd"
                    PixelsPerHour="PixelsPerHour"
                    OnPixelsPerHourChanged="OnPixelsPerHourChanged"
                    OnViewportBoundsChanged="OnViewportBoundsChanged"
                    OnDataRangeExtensionNeeded="OnDataRangeExtensionNeeded">

                        @* ── SLS machine rows with build bars ── *@
                        @foreach (var machine in SlsMachines)
                        {
                            var timeline = MachineTimelines.GetValueOrDefault(machine.Id) ?? [];
                            <div class="gantt-row">
                                <div class="gantt-resource-label">
                                    <span class="gantt-machine-status gantt-status-@machine.Status.ToString().ToLower()"></span>
                                    <div class="gantt-machine-info">
                                        <span class="gantt-machine-name">@machine.Name</span>
                                        <span class="gantt-machine-type">@(machine.LaserCount != null ? $"{machine.LaserCount} laser" : "SLS") · @(machine.BuildPlateCapacity) plate</span>
                                    </div>
                                </div>
                                <div class="gantt-track">
                                    @foreach (var entry in timeline)
                                    {
                                        var barLeft = GetBarLeftPx(entry.PrintStart);
                                        var barWidth = GetBarWidthPx(entry.PrintStart, entry.PrintEnd);
                                        var statusClass = entry.Status switch
                                        {
                                            BuildPackageStatus.Printing => "builds-bar--printing",
                                            BuildPackageStatus.PostPrint => "builds-bar--postprint",
                                            BuildPackageStatus.Completed => "builds-bar--completed",
                                            BuildPackageStatus.Scheduled => "builds-bar--scheduled",
                                            _ => "builds-bar--ready"
                                        };
                                        var tooltip = $"{entry.BuildName}\nStatus: {entry.Status}\n{entry.PrintStart:MM/dd HH:mm} \u2192 {entry.PrintEnd:MM/dd HH:mm}";
                                        if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                            tooltip += $"\nChangeover: {entry.ChangeoverStart:HH:mm} \u2192 {entry.ChangeoverEnd:HH:mm}";
                                        <div class="gantt-bar @statusClass"
                                             style="left: @(FormatPx(barLeft))px; width: @(FormatPx(barWidth))px;"
                                             title="@tooltip">
                                            <span class="gantt-bar-text">📦 @entry.BuildName · @entry.Status</span>
                                        </div>
                                        @if (entry.ChangeoverStart != null && entry.ChangeoverEnd != null)
                                        {
                                            var coLeft = GetBarLeftPx(entry.ChangeoverStart.Value);
                                            var coWidth = GetBarWidthPx(entry.ChangeoverStart.Value, entry.ChangeoverEnd.Value);
                                            <div class="builds-changeover-bar"
                                                 style="left: @(FormatPx(coLeft))px; width: @(FormatPx(coWidth))px;"
                                                 title="Changeover: @entry.ChangeoverStart.Value.ToString("HH:mm") → @entry.ChangeoverEnd.Value.ToString("HH:mm")">
                                                <span class="gantt-bar-text">🔄 Changeover</span>
                                            </div>
                                        }
                                                         }
                                                    </div>
                                                </div>
                                            }
                                    </GanttViewport>

                                    @* Build status legend *@
                <div class="gantt-legend">
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--scheduled"></span> Scheduled</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--printing"></span> Printing</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--postprint"></span> Post-Print</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-bar--completed"></span> Completed</span>
                    <span class="gantt-legend-item"><span class="gantt-legend-swatch builds-changeover-bar"></span> Changeover</span>
                </div>
            }
        </div>

        @* ── Sliced Builds — Set Stage Durations before marking Ready ── *@
        @if (sliced.Any())
        {
            <div class="builds-ready-section builds-sliced-section">
                <h3 class="builds-ready-title">🔪 Sliced — Set Stage Durations (@sliced.Count)</h3>
                <p class="builds-section-hint">Set the expected durations for post-print stages, then mark ready for scheduling.</p>
                <div class="builds-ready-grid">
                    @foreach (var build in sliced)
                    {
                        <div class="builds-ready-card builds-sliced-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(build.Name ?? $"Build #{build.Id}")</span>
                                <span class="badge badge-info">🔪 Sliced</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(build.TotalPartCount) parts</span>
                                <span>🖨️ @(build.EstimatedDurationHours?.ToString("F1") ?? "?")h print</span>
                            </div>

                            @* ── Post-Print Stage Durations ── *@
                            <div class="builds-stage-durations">
                                <div class="stage-duration-row">
                                    <label>💨 Depowdering</label>
                                    <input type="number" step="0.25" min="0" max="24"
                                           value="@(build.DepowderingHours ?? 1.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageDepowdering, e))" />
                                    <span>hrs</span>
                                </div>
                                <div class="stage-duration-row">
                                    <label>🔥 Heat Treat</label>
                                    <input type="number" step="0.5" min="0" max="48"
                                           value="@(build.HeatTreatmentHours ?? 4.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageHeatTreatment, e))" />
                                    <span>hrs</span>
                                </div>
                                <div class="stage-duration-row">
                                    <label>⚡ Wire EDM</label>
                                    <input type="number" step="0.25" min="0" max="24"
                                           value="@(build.WireEdmHours ?? 2.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageWireEdm, e))" />
                                    <span>hrs</span>
                                </div>
                            </div>

                            <div class="builds-total-duration">
                                <span>Total estimated: @GetTotalBuildDuration(build).ToString("F1")h</span>
                            </div>

                            <div style="margin-top:8px;">
                                <button class="btn btn-sm btn-success" @onclick="() => MarkReadyAsync(build)" disabled="@_processing"
                                        title="Mark this build as ready for scheduling">
                                    ✅ Mark Ready
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Ready Builds Cards ── *@
        @if (ready.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">✅ Ready to Schedule (@ready.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var build in ready)
                    {
                        <div class="builds-ready-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(build.Name ?? $"Build #{build.Id}")</span>
                                <span class="badge badge-@BuildStatusBadgeClass(build.Status)">@BuildStatusIcon(build.Status) @build.Status</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(build.TotalPartCount) parts</span>
                                <span>@GetTotalBuildDuration(build).ToString("F1")h total</span>
                            </div>
                            <div class="builds-stage-summary">
                                <span>🖨️ @(build.EstimatedDurationHours?.ToString("F1") ?? "?")h</span>
                                <span>💨 @(build.DepowderingHours?.ToString("F1") ?? "1.0")h</span>
                                <span>🔥 @(build.HeatTreatmentHours?.ToString("F1") ?? "4.0")h</span>
                                <span>⚡ @(build.WireEdmHours?.ToString("F1") ?? "2.0")h</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Printing Builds — with Post-Print action ── *@
        @if (printing.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">🖨️ Printing (@printing.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var build in printing)
                    {
                        <div class="builds-ready-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(build.Name ?? $"Build #{build.Id}")</span>
                                <span class="badge badge-accent">🖨️ Printing</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(build.TotalPartCount) parts</span>
                                <span>@(build.EstimatedDurationHours?.ToString("F1") ?? "?")h est</span>
                                @if (build.PrintStartedAt != null)
                                {
                                    <span>▶ @build.PrintStartedAt.Value.ToString("MM/dd HH:mm")</span>
                                }
                            </div>
                            <div style="margin-top:6px;">
                                <button class="btn btn-sm btn-info" @onclick="() => TransitionToPostPrintAsync(build)" disabled="@_processing"
                                        title="Print complete — move to Post-Print stages">
                                    🔄 → Post-Print
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Post-Print Builds — with stage durations + Release Plate action ── *@
        @if (postPrint.Any())
        {
            <div class="builds-ready-section">
                <h3 class="builds-ready-title">🔥 Post-Print (@postPrint.Count)</h3>
                <div class="builds-ready-grid">
                    @foreach (var build in postPrint)
                    {
                        <div class="builds-ready-card builds-postprint-card">
                            <div class="builds-ready-card-header">
                                <span class="builds-ready-card-name">📦 @(build.Name ?? $"Build #{build.Id}")</span>
                                <span class="badge badge-info">🔥 Post-Print</span>
                            </div>
                            <div class="builds-ready-card-meta">
                                <span>@(build.TotalPartCount) parts</span>
                                @if (build.PrintCompletedAt != null)
                                {
                                    <span>✔ Printed @build.PrintCompletedAt.Value.ToString("MM/dd HH:mm")</span>
                                }
                            </div>

                            @* ── Build Stage Durations ── *@
                            <div class="builds-stage-durations">
                                <div class="stage-duration-row">
                                    <label>💨 Depowdering</label>
                                    <input type="number" step="0.25" min="0" max="24"
                                           value="@(build.DepowderingHours ?? 1.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageDepowdering, e))" />
                                    <span>hrs</span>
                                </div>
                                <div class="stage-duration-row">
                                    <label>🔥 Heat Treat</label>
                                    <input type="number" step="0.5" min="0" max="48"
                                           value="@(build.HeatTreatmentHours ?? 4.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageHeatTreatment, e))" />
                                    <span>hrs</span>
                                </div>
                                <div class="stage-duration-row">
                                    <label>⚡ Wire EDM</label>
                                    <input type="number" step="0.25" min="0" max="24"
                                           value="@(build.WireEdmHours ?? 2.0)"
                                           @onchange="@(e => UpdateStageDuration(build, StageWireEdm, e))" />
                                    <span>hrs</span>
                                </div>
                            </div>

                            <div style="margin-top:8px;">
                                <button class="btn btn-sm btn-success" @onclick="() => ReleasePlateAsync(build)" disabled="@_processing"
                                        title="Release plate — create part instances and per-part jobs with the above stage durations">
                                    📦 Release Plate
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @{
        var buildUnscheduled = Unscheduled.Where(e => e.ProductionStage?.IsBuildLevelStage == true).ToList();
    }
    <UnscheduledSidebar Executions="buildUnscheduled"
                        Title="📋 Unscheduled Build Stages"
                        UseBuildPackageName="true"
                        OnAutoSchedule="OnAutoSchedule" />
</div>

@code {
    [Parameter, EditorRequired] public List<BuildPackage> BuildPackages { get; set; } = [];
    [Parameter, EditorRequired] public List<Machine> SlsMachines { get; set; } = [];
    [Parameter, EditorRequired] public Dictionary<int, List<MachineTimelineEntry>> MachineTimelines { get; set; } = [];
    [Parameter, EditorRequired] public List<StageExecution> Unscheduled { get; set; } = [];
    [Parameter] public DateTime DataRangeStart { get; set; }
    [Parameter] public DateTime DataRangeEnd { get; set; }
    [Parameter] public double PixelsPerHour { get; set; }
    [Parameter] public BuildPackageStatus? BuildStatusFilter { get; set; }
    [Parameter] public EventCallback<int> OnAutoSchedule { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }
    [Parameter] public string UserName { get; set; } = "System";

    [Parameter] public EventCallback<double> OnPixelsPerHourChanged { get; set; }
    [Parameter] public EventCallback<GanttViewport.ViewportBoundsChangedArgs> OnViewportBoundsChanged { get; set; }
    [Parameter] public EventCallback OnDataRangeExtensionNeeded { get; set; }

    /// <summary>Exposes the inner GanttViewport for direct method calls (zoom, scroll, save state).</summary>
    public GanttViewport? Viewport { get; private set; }

    private bool _processing;
    private ConfirmDialog _confirmDialog = null!;

    // Stage slug constants for Razor binding
    private const string StageDepowdering = "depowdering";
    private const string StageHeatTreatment = "heat-treatment";
    private const string StageWireEdm = "wire-edm";

    /// <summary>Filters build packages based on the toolbar filter.</summary>
    private List<BuildPackage> FilteredBuilds => BuildStatusFilter == null
        ? BuildPackages
        : BuildPackages.Where(b => b.Status == BuildStatusFilter.Value).ToList();

    private double GetBarLeftPx(DateTime start) =>
        (start - DataRangeStart).TotalHours * PixelsPerHour;

    private double GetBarWidthPx(DateTime start, DateTime end) =>
        Math.Max(2, (end - start).TotalHours * PixelsPerHour);

    private string FormatPx(double value) => value.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private async Task TransitionToPostPrintAsync(BuildPackage build)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            $"Mark \"{build.Name}\" print as complete and move to Post-Print?",
            "Confirm Post-Print Transition");
        if (!confirmed) return;
        _processing = true;
        try
        {
            build.Status = BuildPackageStatus.PostPrint;
            build.PrintCompletedAt = DateTime.UtcNow;
            build.LastModifiedBy = UserName;
            build.LastModifiedDate = DateTime.UtcNow;
            await BuildPlanning.UpdatePackageAsync(build);
            Toast.ShowSuccess($"{build.Name} → Post-Print");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    private async Task UpdateStageDuration(BuildPackage build, string stageSlug, ChangeEventArgs e)
    {
        if (!double.TryParse(e.Value?.ToString(), out var hours)) return;
        hours = Math.Max(0, Math.Min(48, hours)); // Clamp to reasonable range

        switch (stageSlug)
        {
            case "depowdering": build.DepowderingHours = hours; break;
            case "heat-treatment": build.HeatTreatmentHours = hours; break;
            case "wire-edm": build.WireEdmHours = hours; break;
        }

        build.LastModifiedBy = UserName;
        build.LastModifiedDate = DateTime.UtcNow;

        try
        {
            await BuildPlanning.UpdatePackageAsync(build);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to save duration: {ex.Message}");
        }
    }

    private async Task ReleasePlateAsync(BuildPackage build)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            $"Release plate for \"{build.Name}\"? This will create part instances and per-part jobs.",
            "Confirm Plate Release");
        if (!confirmed) return;
        _processing = true;
        try
        {
            var result = await BuildScheduling.ReleasePlateAsync(build.Id, UserName);
            Toast.ShowSuccess($"Plate released: {result.TotalPartCount} part instance(s) created.");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    /// <summary>Marks a Sliced build as Ready after stage durations are set.</summary>
    private async Task MarkReadyAsync(BuildPackage build)
    {
        _processing = true;
        try
        {
            build.Status = BuildPackageStatus.Ready;
            build.LastModifiedBy = UserName;
            build.LastModifiedDate = DateTime.UtcNow;
            await BuildPlanning.UpdatePackageAsync(build);
            Toast.ShowSuccess($"{build.Name} → Ready to Schedule");
            await OnRefreshRequested.InvokeAsync();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _processing = false; }
    }

    /// <summary>Calculates total estimated build duration (print + post-print stages).</summary>
    private static double GetTotalBuildDuration(BuildPackage build) =>
        (build.EstimatedDurationHours ?? 0) +
        (build.DepowderingHours ?? 1.0) +
        (build.HeatTreatmentHours ?? 4.0) +
        (build.WireEdmHours ?? 2.0);

    private static string BuildStatusBadgeClass(BuildPackageStatus status) => status switch
    {
        BuildPackageStatus.Draft => "secondary",
        BuildPackageStatus.Sliced => "info",
        BuildPackageStatus.Ready => "warning",
        BuildPackageStatus.Scheduled => "primary",
        BuildPackageStatus.Printing => "accent",
        BuildPackageStatus.PostPrint => "info",
        BuildPackageStatus.Completed => "success",
        BuildPackageStatus.Cancelled => "secondary",
        _ => "secondary"
    };

    private static string BuildStatusIcon(BuildPackageStatus status) => status switch
    {
        BuildPackageStatus.Draft => "📝",
        BuildPackageStatus.Sliced => "🔪",
        BuildPackageStatus.Ready => "✅",
        BuildPackageStatus.Scheduled => "📅",
        BuildPackageStatus.Printing => "🖨️",
        BuildPackageStatus.PostPrint => "🔥",
        BuildPackageStatus.Completed => "✔️",
        BuildPackageStatus.Cancelled => "❌",
        _ => "📦"
    };
}
