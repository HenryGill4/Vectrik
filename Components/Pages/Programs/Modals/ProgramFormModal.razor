@* ProgramFormModal.razor — Slide-over panel for create/edit program *@
@using Vectrik.Components.Pages.Programs.Models
@using Vectrik.Components.Pages.Programs.Components
@using Vectrik.Components.Pages.Scheduler.Components

@{
    var isBuildPlate = Program.ProgramType == ProgramType.BuildPlate;
    var isNewProgram = Program.Id == 0;
    var normalizedMachineType = (Program.MachineType ?? "").ToUpperInvariant().Replace("-", "").Replace(" ", "");
    var machinesByType = Machines
        .Where(m => string.IsNullOrEmpty(_machineSearchTerm)
            || m.Name.Contains(_machineSearchTerm, StringComparison.OrdinalIgnoreCase)
            || (m.MachineType ?? "").Contains(_machineSearchTerm, StringComparison.OrdinalIgnoreCase))
        .GroupBy(m => m.MachineType ?? "Other")
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="prg-form-overlay" @onclick="HandleOverlayClick">
    <div class="prg-form-panel" @onclick:stopPropagation="true">

        @* ── Header ── *@
        <div class="prg-form-header">
            <div style="display:flex;align-items:center;gap:10px;">
                <h3 style="margin:0;font-size:1.1em;">
                    @if (isNewProgram)
                    {
                        @("New Program")
                    }
                    else
                    {
                        @($"Edit {Program.ProgramNumber}")
                    }
                </h3>
                @if (isBuildPlate)
                {
                    <span class="badge badge-info" style="font-size:0.78em;">Build Plate</span>
                }
                else if (!string.IsNullOrEmpty(Program.MachineType))
                {
                    <span class="badge badge-secondary" style="font-size:0.78em;">@Program.MachineType</span>
                }
            </div>
            <button class="btn btn-sm btn-secondary" @onclick="OnCancel" style="padding:4px 8px;line-height:1;">
                X
            </button>
        </div>

        @* ── Body ── *@
        <div class="prg-form-body">

            @* ── Warning: no parts for build plate ── *@
            @if (isBuildPlate && !PartsList.Any())
            {
                <div style="padding:8px 12px;background:rgba(var(--warning-rgb),0.1);border:1px solid rgba(var(--warning-rgb),0.3);border-radius:6px;margin-bottom:12px;font-size:0.85em;color:var(--warning);">
                    Add at least one part before saving.
                </div>
            }

            @* ═══ SECTION: Identity ═══ *@
            <div class="prg-form-section @(_collapsedSections.Contains("identity") ? "prg-form-section--collapsed" : "")">
                <div class="prg-form-section-title" @onclick='() => ToggleSection("identity")'>
                    Identity
                </div>
                <div class="prg-form-section-body">
                    <div class="prg-form-grid-2col">
                        @if (!isBuildPlate)
                        {
                            <div class="prg-form-field">
                                <label class="form-label">Program Number <span style="color:var(--danger)">*</span></label>
                                <input class="form-control" @bind="Program.ProgramNumber" placeholder="e.g. CNC-001" />
                            </div>
                        }
                        else
                        {
                            <div class="prg-form-field">
                                <label class="form-label">Build Plate ID</label>
                                <input class="form-control" @bind="Program.ProgramNumber" placeholder="Auto-generated if blank" />
                                <span style="font-size:0.72em;color:var(--text-muted);">Leave blank to auto-generate</span>
                            </div>
                        }

                        <div class="prg-form-field">
                            <label class="form-label">Name <span style="color:var(--danger)">*</span></label>
                            <input class="form-control" @bind="Program.Name" placeholder="@(isBuildPlate ? "e.g. PA12 Tube Plate 76pc" : "Program name")" />
                        </div>

                        <div class="prg-form-field">
                            <label class="form-label">Status</label>
                            <select class="form-control" @bind="Program.Status">
                                @foreach (var s in Enum.GetValues<ProgramStatus>())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>

                        <div class="prg-form-field">
                            <label class="form-label">Program Type</label>
                            <input class="form-control" value="@Program.ProgramType" readonly style="background:var(--surface-2);cursor:default;" />
                        </div>

                        <div class="prg-form-field prg-form-field--full">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="2" @bind="Program.Description" placeholder="Optional description..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            @* ═══ SECTION: Machine Assignment ═══ *@
            <div class="prg-form-section @(_collapsedSections.Contains("machines") ? "prg-form-section--collapsed" : "")">
                <div class="prg-form-section-title" @onclick='() => ToggleSection("machines")'>
                    Machine Assignment
                    @if (SelectedMachineIds.Count > 0)
                    {
                        <span class="badge badge-accent" style="font-size:0.75em;margin-left:8px;">@SelectedMachineIds.Count selected</span>
                    }
                </div>
                <div class="prg-form-section-body">
                    @if (!isBuildPlate)
                    {
                        <div class="prg-form-field" style="margin-bottom:12px;">
                            <label class="form-label">Machine Type</label>
                            <select class="form-control" value="@Program.MachineType" @onchange="HandleMachineTypeChange">
                                <option value="">-- Select Machine Type --</option>
                                @foreach (var t in MachineTypes)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="prg-form-field" style="margin-bottom:12px;">
                            <label class="form-label">Material</label>
                            <select class="form-control" @bind="EditMaterialId">
                                <option value="">-- Auto-detect from parts --</option>
                                @if (Materials != null)
                                {
                                    @foreach (var m in Materials)
                                    {
                                        <option value="@m.Id">@m.Name (@m.Category)</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="prg-form-field">
                        <input class="form-control" @bind="_machineSearchTerm" @bind:event="oninput" placeholder="Search machines..." style="margin-bottom:8px;" />
                    </div>

                    <div style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:6px;padding:8px;">
                        @if (!machinesByType.Any())
                        {
                            <div style="font-size:0.85em;color:var(--text-muted);padding:8px;">No machines found.</div>
                        }
                        @foreach (var group in machinesByType)
                        {
                            <div style="font-size:0.75em;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;padding:4px 0 2px 0;margin-top:4px;">@group.Key</div>
                            @foreach (var machine in group.OrderBy(m => m.Name))
                            {
                                <label style="display:flex;align-items:center;gap:8px;padding:3px 0;font-size:0.88em;cursor:pointer;">
                                    <input type="checkbox" checked="@SelectedMachineIds.Contains(machine.Id)" @onchange="() => HandleToggleMachine(machine.Id)" />
                                    @machine.Name
                                    @if (machine.IsAdditiveMachine)
                                    {
                                        <span class="badge badge-info" style="font-size:0.7em;">SLS</span>
                                    }
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>

            @* ═══ SECTION: Timing & Duration (Standard only) ═══ *@
            @if (!isBuildPlate)
            {
                <div class="prg-form-section @(_collapsedSections.Contains("timing") ? "prg-form-section--collapsed" : "")">
                    <div class="prg-form-section-title" @onclick='() => ToggleSection("timing")'>
                        Timing &amp; Duration
                    </div>
                    <div class="prg-form-section-body">
                        <DurationFieldsSection Program="Program" NormalizedMachineType="@normalizedMachineType" />
                        <MachineTypeSettingsSection Program="Program" NormalizedMachineType="@normalizedMachineType" />
                    </div>
                </div>
            }

            @* ═══ SECTION: Parts ═══ *@
            <div class="prg-form-section @(_collapsedSections.Contains("parts") ? "prg-form-section--collapsed" : "")">
                <div class="prg-form-section-title" @onclick='() => ToggleSection("parts")'>
                    Parts
                    @if (PartsList.Any())
                    {
                        <span class="badge badge-secondary" style="font-size:0.75em;margin-left:8px;">@PartsList.Count</span>
                    }
                </div>
                <div class="prg-form-section-body">
                    @* Add part form *@
                    <div style="display:flex;gap:8px;align-items:flex-end;margin-bottom:12px;">
                        <div style="flex:1;">
                            <label class="form-label" style="font-size:0.8em;">Search &amp; Select Part</label>
                            <input class="form-control" @bind="_partSearchTerm" @bind:event="oninput" placeholder="Search by part number or name..." style="margin-bottom:4px;" />
                            <select class="form-control" @bind="_selectedPartId">
                                <option value="0">-- Select a part --</option>
                                @foreach (var p in GetFilteredParts())
                                {
                                    <option value="@p.Id">@p.PartNumber - @p.Name</option>
                                }
                            </select>
                        </div>
                        <div style="width:70px;">
                            <label class="form-label" style="font-size:0.8em;">Qty</label>
                            <input class="form-control" type="number" min="1" @bind="_addPartQty" />
                        </div>
                        <button class="btn btn-sm btn-accent" @onclick="HandleAddPart" disabled="@(_selectedPartId <= 0)" style="white-space:nowrap;margin-bottom:0;">
                            + Add
                        </button>
                    </div>

                    @* Parts list *@
                    @if (PartsList.Any())
                    {
                        <div style="border:1px solid var(--border);border-radius:6px;overflow:hidden;">
                            <table style="width:100%;border-collapse:collapse;font-size:0.85em;">
                                <thead>
                                    <tr style="background:var(--surface-2);border-bottom:1px solid var(--border);">
                                        @if (!isBuildPlate)
                                        {
                                            <th style="padding:6px 8px;text-align:left;width:30px;"></th>
                                        }
                                        <th style="padding:6px 8px;text-align:left;">Part</th>
                                        <th style="padding:6px 8px;text-align:center;width:60px;">Qty</th>
                                        <th style="padding:6px 8px;text-align:center;width:40px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in PartsList)
                                    {
                                        <tr style="border-bottom:1px solid var(--border);">
                                            @if (!isBuildPlate)
                                            {
                                                <td style="padding:6px 8px;text-align:center;">
                                                    @if (entry.IsPrimary)
                                                    {
                                                        <span title="Primary part" style="color:var(--warning);cursor:default;">*</span>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm" @onclick="() => HandleSetPrimary(entry.PartId)" title="Set as primary"
                                                                style="padding:0;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.9em;">
                                                            *
                                                        </button>
                                                    }
                                                </td>
                                            }
                                            <td style="padding:6px 8px;">
                                                <strong>@entry.PartNumber</strong>
                                                <span style="color:var(--text-muted);margin-left:4px;">@entry.PartName</span>
                                            </td>
                                            <td style="padding:6px 8px;text-align:center;">@entry.Quantity</td>
                                            <td style="padding:6px 8px;text-align:center;">
                                                <button class="btn btn-sm btn-danger" @onclick="() => HandleRemovePart(entry.PartId)"
                                                        style="padding:2px 6px;font-size:0.8em;">X</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div style="font-size:0.85em;color:var(--text-muted);padding:8px 0;">No parts added yet.</div>
                    }

                    @* Certified Layouts (Build Plate with layouts available) *@
                    @if (isBuildPlate && CertifiedLayouts.Any())
                    {
                        <div style="margin-top:12px;">
                            <label class="form-label" style="font-size:0.85em;font-weight:600;">Plate Composition (Certified Layouts)</label>
                            <PlateLayoutEditor AvailableLayouts="CertifiedLayouts"
                                               Assignments="PlateAssignments"
                                               OnAssignmentsChanged="OnPlateAssignmentsChanged"
                                               ReadOnly="@(!IsNew && Program.IsLocked)" />
                        </div>
                    }
                </div>
            </div>

            @* ═══ SECTION: Parameters (Standard only, collapsed for new) ═══ *@
            @if (!isBuildPlate)
            {
                <div class="prg-form-section @(_collapsedSections.Contains("parameters") ? "prg-form-section--collapsed" : "")">
                    <div class="prg-form-section-title" @onclick='() => ToggleSection("parameters")'>
                        Parameters
                    </div>
                    <div class="prg-form-section-body">
                        <div style="display:flex;gap:6px;margin-bottom:8px;">
                            @if (!string.IsNullOrEmpty(Program.MachineType))
                            {
                                <button class="btn btn-sm btn-secondary" @onclick="OnLoadDefaultParameters">Load Defaults</button>
                            }
                            <button class="btn btn-sm btn-accent" @onclick="OnCopyParameters">Copy for AI</button>
                        </div>
                        @if (!string.IsNullOrEmpty(Program.MachineType))
                        {
                            <div style="font-size:0.78em;color:var(--text-muted);margin-bottom:8px;">
                                Template available for <strong>@Program.MachineType</strong>.
                            </div>
                        }
                        <textarea class="form-control" rows="5" style="font-family:monospace;font-size:0.85em;" @bind="Program.Parameters"
                                  placeholder='{ "param1": "value" }'></textarea>

                        <div class="prg-form-grid-2col" style="margin-top:12px;">
                            <div class="prg-form-field">
                                <label class="form-label">Tooling Required</label>
                                <input class="form-control" @bind="Program.ToolingRequired" placeholder="e.g. T1: 6mm End Mill" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Fixture Required</label>
                                <input class="form-control" @bind="Program.FixtureRequired" placeholder="e.g. Fixture-A-07" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ═══ SECTION: Slicer Data (Build Plate only) ═══ *@
            @if (isBuildPlate)
            {
                <div class="prg-form-section @(_collapsedSections.Contains("slicer") ? "prg-form-section--collapsed" : "")">
                    <div class="prg-form-section-title" @onclick='() => ToggleSection("slicer")'>
                        Slicer Data
                        @if (Program.HasSlicerData)
                        {
                            <span class="badge badge-success" style="font-size:0.7em;margin-left:8px;">Complete</span>
                        }
                    </div>
                    <div class="prg-form-section-body">
                        <div class="prg-form-grid-2col">
                            <div class="prg-form-field">
                                <label class="form-label">Print Duration (hrs)</label>
                                <input class="form-control" type="number" step="0.1" min="0" @bind="Program.EstimatedPrintHours" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Layer Count</label>
                                <input class="form-control" type="number" min="0" @bind="Program.LayerCount" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Build Height (mm)</label>
                                <input class="form-control" type="number" step="0.1" min="0" @bind="Program.BuildHeightMm" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Est. Powder (kg)</label>
                                <input class="form-control" type="number" step="0.1" min="0" @bind="Program.EstimatedPowderKg" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Slicer Software</label>
                                <input class="form-control" @bind="Program.SlicerSoftware" placeholder="e.g. Magics" />
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">Slicer Version</label>
                                <input class="form-control" @bind="Program.SlicerVersion" />
                            </div>
                            <div class="prg-form-field prg-form-field--full">
                                <label class="form-label">Slicer Filename</label>
                                <input class="form-control" @bind="Program.SlicerFileName" placeholder="e.g. MyBuild_v3.sli" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ═══ SECTION: Post-Processing (Build Plate only) ═══ *@
            @if (isBuildPlate)
            {
                <div class="prg-form-section @(_collapsedSections.Contains("postproc") ? "prg-form-section--collapsed" : "")">
                    <div class="prg-form-section-title" @onclick='() => ToggleSection("postproc")'>
                        Post-Processing
                        @if (!string.IsNullOrEmpty(EditDepowderProgramId) || !string.IsNullOrEmpty(EditEdmProgramId))
                        {
                            <span class="badge badge-secondary" style="font-size:0.7em;margin-left:8px;">Linked</span>
                        }
                    </div>
                    <div class="prg-form-section-body">
                        <div class="prg-form-grid-2col">
                            <div class="prg-form-field">
                                <label class="form-label">Depowder Program</label>
                                <select class="form-control" @bind="EditDepowderProgramId">
                                    <option value="">-- None --</option>
                                    @if (DepowderCandidates != null)
                                    {
                                        @foreach (var dp in DepowderCandidates)
                                        {
                                            <option value="@dp.Id">@dp.ProgramNumber - @dp.Name</option>
                                        }
                                    }
                                </select>
                                <span style="font-size:0.72em;color:var(--text-muted);">Powder removal after build</span>
                            </div>
                            <div class="prg-form-field">
                                <label class="form-label">EDM / Wire-Cut Program</label>
                                <select class="form-control" @bind="EditEdmProgramId">
                                    <option value="">-- None --</option>
                                    @if (EdmCandidates != null)
                                    {
                                        @foreach (var ep in EdmCandidates)
                                        {
                                            <option value="@ep.Id">@ep.ProgramNumber - @ep.Name</option>
                                        }
                                    }
                                </select>
                                <span style="font-size:0.72em;color:var(--text-muted);">Support removal / plate separation</span>
                            </div>
                        </div>
                        @if (string.IsNullOrEmpty(EditDepowderProgramId) && string.IsNullOrEmpty(EditEdmProgramId))
                        {
                            <div style="font-size:0.78em;color:var(--text-muted);margin-top:8px;">
                                No post-processing programs linked. Create Depowder or EDM programs first, then link them here.
                            </div>
                        }
                    </div>
                </div>
            }

            @* ═══ SECTION: Work Instruction ═══ *@
            <div class="prg-form-section @(_collapsedSections.Contains("workinst") ? "prg-form-section--collapsed" : "")">
                <div class="prg-form-section-title" @onclick='() => ToggleSection("workinst")'>
                    Work Instruction
                    @if (!string.IsNullOrEmpty(EditWorkInstructionId))
                    {
                        <span class="badge badge-accent" style="font-size:0.7em;margin-left:8px;">Linked</span>
                    }
                </div>
                <div class="prg-form-section-body">
                    @{
                        var wiMachineType = normalizedMachineType;
                        var primaryPart = PartsList.FirstOrDefault(p => p.IsPrimary);
                        var selectedPartIdForWi = primaryPart?.PartId;
                        var allActiveInstructions = WorkInstructions?
                            .Where(wi => wi.IsActive)
                            .Where(wi => selectedPartIdForWi == null || wi.PartId == selectedPartIdForWi)
                            .ToList() ?? [];
                        var filteredInstructions = allActiveInstructions
                            .OrderByDescending(wi =>
                            {
                                if (string.IsNullOrEmpty(wiMachineType)) return 0;
                                var stageNorm = (wi.ProductionStage?.Name ?? "").ToUpperInvariant().Replace("-", "").Replace(" ", "");
                                var slugNorm = (wi.ProductionStage?.StageSlug ?? "").ToUpperInvariant().Replace("-", "").Replace(" ", "");
                                return stageNorm.Contains(wiMachineType) || slugNorm.Contains(wiMachineType)
                                    || wiMachineType.Contains(stageNorm) || wiMachineType.Contains(slugNorm) ? 1 : 0;
                            })
                            .ThenBy(wi => wi.Title)
                            .ToList();
                    }
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                        @if (!string.IsNullOrEmpty(Program.MachineType))
                        {
                            <span class="badge badge-secondary" style="font-size:0.7em;">@Program.MachineType</span>
                        }
                        @if (!string.IsNullOrEmpty(EditWorkInstructionId))
                        {
                            <button class="btn btn-sm btn-secondary" @onclick='() => EditWorkInstructionId = ""' style="padding:2px 6px;font-size:0.78em;">Clear</button>
                        }
                    </div>
                    <select class="form-control" @bind="EditWorkInstructionId">
                        <option value="">-- No instruction linked --</option>
                        @foreach (var wi in filteredInstructions)
                        {
                            var partLabel = wi.Part != null ? wi.Part.PartNumber : "";
                            var stageLabel = wi.ProductionStage?.Name ?? "";
                            var subtitle = new[] { partLabel, stageLabel }.Where(s => !string.IsNullOrEmpty(s));
                            <option value="@wi.Id">@wi.Title @(subtitle.Any() ? $"({string.Join(" / ", subtitle)})" : "") - Rev @wi.RevisionNumber</option>
                        }
                    </select>
                    @if (filteredInstructions.Count == 0)
                    {
                        <div style="font-size:0.78em;color:var(--text-muted);margin-top:6px;">
                            No work instructions available.
                        </div>
                    }
                </div>
            </div>

            @* ═══ SECTION: Notes ═══ *@
            <div class="prg-form-section @(_collapsedSections.Contains("notes") ? "prg-form-section--collapsed" : "")">
                <div class="prg-form-section-title" @onclick='() => ToggleSection("notes")'>
                    Operator Notes
                </div>
                <div class="prg-form-section-body">
                    <textarea class="form-control" rows="3" @bind="Program.Notes"
                              placeholder="@(isBuildPlate ? "Build plate notes, orientation guidance..." : "Special instructions for the operator...")"></textarea>
                </div>
            </div>

        </div>

        @* ── Footer ── *@
        <div class="prg-form-footer">
            <button class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
            <button class="btn btn-primary" @onclick="OnSave" disabled="@Saving">
                @if (Saving)
                {
                    <span class="spinner" style="width:14px;height:14px;margin-right:6px;"></span>
                }
                @if (isNewProgram)
                {
                    @(isBuildPlate ? "Create Build Plate" : "Create Program")
                }
                else
                {
                    @("Save Changes")
                }
            </button>
        </div>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public MachineProgram Program { get; set; } = default!;
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public bool Saving { get; set; }
    [Parameter] public List<Machine> Machines { get; set; } = new();
    [Parameter] public List<string> MachineTypes { get; set; } = new();
    [Parameter] public List<Material> Materials { get; set; } = new();
    [Parameter] public List<Part> Parts { get; set; } = new();
    [Parameter] public List<Part> AdditiveParts { get; set; } = new();
    [Parameter] public List<WorkInstruction>? WorkInstructions { get; set; }
    [Parameter] public List<MachineProgram>? DepowderCandidates { get; set; }
    [Parameter] public List<MachineProgram>? EdmCandidates { get; set; }
    [Parameter] public HashSet<int> SelectedMachineIds { get; set; } = new();
    [Parameter] public List<CreateBuildPartEntry> PartsList { get; set; } = new();
    [Parameter] public List<CertifiedLayout> CertifiedLayouts { get; set; } = new();
    [Parameter] public List<PlateSlotAssignment> PlateAssignments { get; set; } = new();
    [Parameter] public EventCallback<List<PlateSlotAssignment>> OnPlateAssignmentsChanged { get; set; }
    [Parameter] public string EditMaterialId { get; set; } = "";
    [Parameter] public string EditWorkInstructionId { get; set; } = "";
    [Parameter] public string EditDepowderProgramId { get; set; } = "";
    [Parameter] public string EditEdmProgramId { get; set; } = "";
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<string> OnMachineTypeChanged { get; set; }
    [Parameter] public EventCallback<HashSet<int>> OnMachineIdsChanged { get; set; }
    [Parameter] public EventCallback OnLoadDefaultParameters { get; set; }
    [Parameter] public EventCallback OnCopyParameters { get; set; }

    // Internal state
    private string _machineSearchTerm = "";
    private string _partSearchTerm = "";
    private int _selectedPartId;
    private int _addPartQty = 1;
    private HashSet<string> _collapsedSections = new();

    protected override void OnInitialized()
    {
        // Collapse parameters section for new programs
        if (IsNew)
        {
            _collapsedSections.Add("parameters");
            _collapsedSections.Add("workinst");
            _collapsedSections.Add("notes");
        }
    }

    private void ToggleSection(string section)
    {
        if (!_collapsedSections.Remove(section))
            _collapsedSections.Add(section);
    }

    private void HandleOverlayClick()
    {
        OnCancel.InvokeAsync();
    }

    private void HandleMachineTypeChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        Program.MachineType = val;
        OnMachineTypeChanged.InvokeAsync(val);
    }

    private async Task HandleToggleMachine(int machineId)
    {
        if (!SelectedMachineIds.Add(machineId))
            SelectedMachineIds.Remove(machineId);
        await OnMachineIdsChanged.InvokeAsync(SelectedMachineIds);
    }

    private IEnumerable<Part> GetFilteredParts()
    {
        var isBuildPlate = Program.ProgramType == ProgramType.BuildPlate;
        var sourceParts = isBuildPlate ? AdditiveParts : Parts;
        if (sourceParts == null) return Enumerable.Empty<Part>();

        var alreadyAdded = PartsList.Select(cp => cp.PartId).ToHashSet();
        var parts = sourceParts.Where(p => !alreadyAdded.Contains(p.Id));

        if (!string.IsNullOrWhiteSpace(_partSearchTerm))
        {
            var search = _partSearchTerm.Trim();
            parts = parts.Where(p =>
                p.PartNumber.Contains(search, StringComparison.OrdinalIgnoreCase)
                || p.Name.Contains(search, StringComparison.OrdinalIgnoreCase));
        }

        if (isBuildPlate)
        {
            return parts.OrderByDescending(p => p.ManufacturingApproach?.RequiresBuildPlate == true)
                        .ThenBy(p => p.PartNumber);
        }
        return parts.OrderBy(p => p.PartNumber);
    }

    private void HandleAddPart()
    {
        if (_selectedPartId <= 0) return;
        var isBuildPlate = Program.ProgramType == ProgramType.BuildPlate;
        var allParts = isBuildPlate ? AdditiveParts : Parts;
        var part = allParts?.FirstOrDefault(p => p.Id == _selectedPartId);
        if (part == null) return;

        var makePrimary = !isBuildPlate && !PartsList.Any();
        PartsList.Add(new CreateBuildPartEntry(part.Id, part.PartNumber, part.Name, _addPartQty, makePrimary));
        _selectedPartId = 0;
        _addPartQty = 1;
        _partSearchTerm = "";
    }

    private void HandleSetPrimary(int partId)
    {
        for (int i = 0; i < PartsList.Count; i++)
        {
            PartsList[i] = PartsList[i] with { IsPrimary = PartsList[i].PartId == partId };
        }
    }

    private void HandleRemovePart(int partId)
    {
        var wasPrimary = PartsList.FirstOrDefault(p => p.PartId == partId)?.IsPrimary ?? false;
        PartsList.RemoveAll(x => x.PartId == partId);

        if (wasPrimary && PartsList.Any() && Program.ProgramType != ProgramType.BuildPlate)
        {
            PartsList[0] = PartsList[0] with { IsPrimary = true };
        }
    }
}
