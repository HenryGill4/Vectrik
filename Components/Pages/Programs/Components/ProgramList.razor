@* ProgramList.razor — Program card list with KPI strip, sort, and batch toolbar *@
@using Vectrik.Components.Pages.Programs.Components
@using Vectrik.Models.Enums

@* ── Compact KPI Strip (4 metrics) ── *@
<div class="prog-kpi-strip">
    <div class="prog-kpi">
        <div class="prog-kpi-value">@AllPrograms.Count</div>
        <div class="prog-kpi-label">Total</div>
    </div>
    <div class="prog-kpi">
        <div class="prog-kpi-value" style="color:var(--success)">@AllPrograms.Count(p => p.Status == ProgramStatus.Active)</div>
        <div class="prog-kpi-label">Active</div>
    </div>
    <div class="prog-kpi prog-kpi--clickable @(PendingSetupCount > 0 ? "prog-kpi--warning" : "")" @onclick="OnTogglePendingSetup">
        <div class="prog-kpi-value" style="color:@(PendingSetupCount > 0 ? "var(--warning)" : "var(--text-muted)")">@PendingSetupCount</div>
        <div class="prog-kpi-label">Setup</div>
    </div>
    @{
        var alertTotal = TotalUnresolvedFeedback + MaintenanceAlertCount;
    }
    <div class="prog-kpi @(alertTotal > 0 ? "prog-kpi--danger" : "")">
        <div class="prog-kpi-value" style="color:@(alertTotal > 0 ? "var(--danger)" : "var(--text-muted)")">@alertTotal</div>
        <div class="prog-kpi-label">Alerts</div>
    </div>
</div>

@if (!Programs.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">No programs</div>
        <div class="empty-state-text">No machine programs match your filters. Adjust filters or create a new program.</div>
    </div>
}
else
{
    @* ── Sort + Batch Actions ── *@
    <div class="prog-sort">
        <span>Sort:</span>
        <select class="form-control" @bind="SortField" @bind:after="HandleSortChanged">
            <option value="number">Program #</option>
            <option value="name">Name</option>
            <option value="status">Status</option>
            <option value="runs">Most Runs</option>
            <option value="recent">Recently Updated</option>
        </select>
    </div>

    <div class="prog-batch-bar">
        <label class="prog-batch-label">
            <input type="checkbox" checked="@(_batchSelectedIds.Count == Programs.Count && Programs.Any())"
                   @onchange="ToggleBatchSelectAll" />
            Select all
        </label>
        @if (_batchSelectedIds.Any())
        {
            <span style="color: var(--text-muted);">@_batchSelectedIds.Count selected</span>
            @if (_confirmingDelete)
            {
                <span class="prog-batch-confirm">Are you sure? @_batchSelectedIds.Count program(s) will be deleted.</span>
                <button class="btn btn-sm btn-danger" @onclick="ConfirmBatchDelete">Yes, Delete</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => _confirmingDelete = false">Cancel</button>
            }
            else
            {
                <button class="btn btn-sm btn-danger" @onclick="() => _confirmingDelete = true">Delete Selected</button>
            }
            <button class="btn btn-sm btn-ghost" @onclick="ClearBatchSelection">Clear</button>
        }
    </div>

    @* ── Program Cards ── *@
    @foreach (var program in Programs)
    {
        var isSelected = SelectedProgram?.Id == program.Id;
        var isBatchSelected = _batchSelectedIds.Contains(program.Id);
        var feedbackCount = FeedbackCounts.GetValueOrDefault(program.Id, 0);

        <ProgramCard Program="program"
                     IsSelected="isSelected"
                     IsBatchSelected="isBatchSelected"
                     FeedbackCount="feedbackCount"
                     OnClick="() => OnSelectProgram.InvokeAsync(program)"
                     OnBatchToggle="() => ToggleBatchSelect(program.Id)" />
    }
}

@code {
    [Parameter] public List<MachineProgram> Programs { get; set; } = [];
    [Parameter] public List<MachineProgram> AllPrograms { get; set; } = [];
    [Parameter] public MachineProgram? SelectedProgram { get; set; }
    [Parameter] public Dictionary<int, int> FeedbackCounts { get; set; } = new();
    [Parameter] public int PendingSetupCount { get; set; }
    [Parameter] public int TotalUnresolvedFeedback { get; set; }
    [Parameter] public int MaintenanceAlertCount { get; set; }
    [Parameter] public EventCallback<MachineProgram> OnSelectProgram { get; set; }
    [Parameter] public EventCallback<HashSet<int>> OnBatchDelete { get; set; }
    [Parameter] public EventCallback OnTogglePendingSetup { get; set; }
    [Parameter] public string SortField { get; set; } = "number";
    [Parameter] public EventCallback<string> OnSortChanged { get; set; }

    // Internal batch state
    private HashSet<int> _batchSelectedIds = new();
    private bool _confirmingDelete;

    private async Task HandleSortChanged() => await OnSortChanged.InvokeAsync(SortField);

    private void ToggleBatchSelect(int programId)
    {
        if (!_batchSelectedIds.Add(programId))
            _batchSelectedIds.Remove(programId);
        _confirmingDelete = false;
    }

    private void ToggleBatchSelectAll()
    {
        if (_batchSelectedIds.Count == Programs.Count)
            _batchSelectedIds.Clear();
        else
            _batchSelectedIds = Programs.Select(p => p.Id).ToHashSet();
        _confirmingDelete = false;
    }

    private void ClearBatchSelection()
    {
        _batchSelectedIds.Clear();
        _confirmingDelete = false;
    }

    private async Task ConfirmBatchDelete()
    {
        if (!_batchSelectedIds.Any()) return;
        await OnBatchDelete.InvokeAsync(new HashSet<int>(_batchSelectedIds));
        _batchSelectedIds.Clear();
        _confirmingDelete = false;
    }
}
