@* ProgramPartsEditor.razor — Program Parts section from the editor form *@
@using Vectrik.Components.Pages.Programs.Models

@{
    var partsCardTitle = IsBuildPlateEditor ? "Parts on Plate" : "Program Parts";
    var partsCardHint = IsBuildPlateEditor
        ? "Search and add parts that will be nested on this build plate."
        : "Add parts to this program. Click the star to set the primary part.";
    var partsSearchPlaceholder = "Search parts...";
    var hasPrimaryPart = Parts.Any(p => p.IsPrimary);
}

<div class="prg-parts-editor">
    <div class="prg-parts-editor-header">
        <div class="prg-parts-editor-title-row">
            <h4 class="prg-parts-editor-title">@partsCardTitle</h4>
            @if (Parts.Any())
            {
                <span class="prg-badge prg-badge--active">@Parts.Sum(p => p.Quantity) parts (@Parts.Count unique)</span>
            }
            @if (!IsBuildPlateEditor && hasPrimaryPart)
            {
                var primary = Parts.First(p => p.IsPrimary);
                <span class="prg-badge prg-badge--version">&#9733; @primary.PartNumber</span>
            }
        </div>
        @if (!IsBuildPlateEditor && !hasPrimaryPart && Parts.Any())
        {
            <span class="prg-parts-editor-warn">&#9888; No primary part selected</span>
        }
    </div>

    <div class="prg-parts-editor-controls">
        <div class="prg-parts-editor-field prg-parts-editor-field--search">
            <label class="prg-parts-editor-label">Search</label>
            <input class="form-control form-control-sm" placeholder="@partsSearchPlaceholder" value="@SearchTerm" @oninput="HandleSearchInput" />
        </div>
        <div class="prg-parts-editor-field prg-parts-editor-field--select">
            <label class="prg-parts-editor-label">Part</label>
            <select class="form-control form-control-sm" value="@SelectedPartId" @onchange="HandlePartSelection">
                <option value="0">Select part...</option>
                @if (FilteredParts != null)
                {
                    @foreach (var p in FilteredParts)
                    {
                        <option value="@p.Id">@p.PartNumber — @p.Name</option>
                    }
                }
            </select>
        </div>
        <div class="prg-parts-editor-field prg-parts-editor-field--qty">
            <label class="prg-parts-editor-label">Qty</label>
            <input class="form-control form-control-sm" type="number" min="1" max="500" value="@Quantity" @onchange="HandleQuantityChange" />
        </div>
        <button class="btn btn-sm btn-primary prg-parts-editor-add" @onclick="HandleAddPart" disabled="@(SelectedPartId <= 0)">+ Add</button>
    </div>

    @if (Parts.Any())
    {
        <div class="prg-parts-table-wrap">
            <table class="prg-parts-table">
                <thead>
                    <tr>
                        @if (!IsBuildPlateEditor)
                        {
                            <th class="prg-parts-editor-col-star" title="Primary Part">&#9733;</th>
                        }
                        <th>Part</th>
                        <th class="prg-parts-editor-col-qty">Qty</th>
                        <th class="prg-parts-editor-col-remove"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cp in Parts)
                    {
                        <tr>
                            @if (!IsBuildPlateEditor)
                            {
                                <td class="prg-parts-editor-star-cell">
                                    <button class="prg-parts-editor-star-btn @(cp.IsPrimary ? "prg-parts-editor-star-btn--active" : "")"
                                            @onclick="() => OnSetPrimary.InvokeAsync(cp.PartId)"
                                            title="@(cp.IsPrimary ? "Primary Part" : "Set as Primary")">
                                        &#9733;
                                    </button>
                                </td>
                            }
                            <td>
                                <span class="prg-parts-pn">@cp.PartNumber</span>
                                <span class="prg-parts-name"> — @cp.PartName</span>
                            </td>
                            <td class="prg-parts-qty">
                                <span class="prg-parts-qty-badge">@cp.Quantity</span>
                            </td>
                            <td class="prg-parts-actions">
                                <button class="btn btn-xs btn-danger-outline" @onclick="() => OnRemovePart.InvokeAsync(cp.PartId)" title="Remove">&#10005;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="prg-empty">@partsCardHint</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public bool IsBuildPlateEditor { get; set; }
    [Parameter, EditorRequired] public List<CreateBuildPartEntry> Parts { get; set; } = new();
    [Parameter] public IEnumerable<Part>? FilteredParts { get; set; }
    [Parameter] public string SearchTerm { get; set; } = "";
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }
    [Parameter] public int SelectedPartId { get; set; }
    [Parameter] public EventCallback<int> SelectedPartIdChanged { get; set; }
    [Parameter] public int Quantity { get; set; } = 1;
    [Parameter] public EventCallback<int> QuantityChanged { get; set; }
    [Parameter] public EventCallback OnAddPart { get; set; }
    [Parameter] public EventCallback<int> OnSetPrimary { get; set; }
    [Parameter] public EventCallback<int> OnRemovePart { get; set; }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        await SearchTermChanged.InvokeAsync(e.Value?.ToString() ?? "");
    }

    private async Task HandlePartSelection(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            await SelectedPartIdChanged.InvokeAsync(id);
    }

    private async Task HandleQuantityChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var qty))
            await QuantityChanged.InvokeAsync(qty);
    }

    private async Task HandleAddPart() => await OnAddPart.InvokeAsync();
}
