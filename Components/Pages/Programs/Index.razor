    private async Task EditToolingItem(ProgramToolingItem item)
    {
        _editingToolingItem = item;
        _editToolingComponentId = item.MachineComponentId?.ToString() ?? "";
        await LoadAvailableComponents();
        _showToolingEditor = true;
    }

    private void CloseToolingEditor() => _showToolingEditor = false;

    private async Task LoadAvailableComponents()
    {
        _availableComponents = new();
        var assignedMachineIds = _selectedProgram?.MachineAssignments?.Select(a => a.MachineId).ToList() ?? new();
        if (_selectedProgram?.MachineId.HasValue == true && !assignedMachineIds.Contains(_selectedProgram.MachineId.Value))
            assignedMachineIds.Add(_selectedProgram.MachineId.Value);

        if (assignedMachineIds.Count > 0)
        {
            foreach (var mid in assignedMachineIds)
            {
                var machine = _machines?.FirstOrDefault(m => m.Id == mid);
                if (machine != null)
                    _availableComponents.AddRange(await MaintenanceService.GetComponentsByMachineAsync(machine.MachineId));
            }
        }
        else if (_machines != null)
        {
            foreach (var machine in _machines.Take(10))
                _availableComponents.AddRange(await MaintenanceService.GetComponentsByMachineAsync(machine.MachineId));
        }
    }

    private async Task SaveToolingItem()
    {
        if (string.IsNullOrWhiteSpace(_editingToolingItem.ToolPosition) || string.IsNullOrWhiteSpace(_editingToolingItem.Name))
        { Toast.ShowError("Position and name are required."); return; }

        _savingTooling = true;
        try
        {
            _editingToolingItem.MachineComponentId = int.TryParse(_editToolingComponentId, out var cid) ? cid : null;
            await ProgramService.SaveToolingItemAsync(_editingToolingItem, _currentUser);
            Toast.ShowSuccess("Tooling item saved.");
            _showToolingEditor = false;
