    private List<string> GetMachineNamesForStage(ProcessStage stage)
    {
        if (string.IsNullOrWhiteSpace(stage.PreferredMachineIds) || _machines == null)
            return [];

        return stage.PreferredMachineIds
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(id => int.TryParse(id.Trim(), out var mid) ? _machines.FirstOrDefault(m => m.Id == mid)?.Name : null)
            .Where(n => n != null)
            .Cast<string>()
            .ToList();
    }

    private void CreateProgramForStage(ProcessStage stage)
    {
        var part = stage.ManufacturingProcess?.Part;
        var machineIds = stage.PreferredMachineIds?
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(id => int.TryParse(id.Trim(), out var mid) ? mid : 0)
            .Where(id => id > 0)
            .ToHashSet() ?? [];

        // Include the assigned machine if set
        if (stage.AssignedMachineId.HasValue)
            machineIds.Add(stage.AssignedMachineId.Value);

        var stageName = stage.ProductionStage?.Name ?? $"Stage-{stage.ExecutionOrder}";
        var machineType = stage.AssignedMachine?.MachineType
            ?? _machines?.FirstOrDefault(m => machineIds.Contains(m.Id))?.MachineType;

        // Pre-fill duration from stage defaults
        double? defaultRunMinutes = stage.RunTimeMinutes
            ?? (stage.ProductionStage?.DefaultDurationHours > 0 ? stage.ProductionStage.DefaultDurationHours * 60 : null);
        double? defaultSetupMinutes = stage.SetupTimeMinutes;

        _editingProgram = new MachineProgram
        {
            ProgramNumber = $"{part?.PartNumber ?? "NEW"}-{stageName.Replace(" ", "-").ToUpperInvariant()}-{stage.ExecutionOrder:D2}",
            Name = $"{part?.Name ?? "Part"} — {stageName}",
            PartId = part?.Id,
            ProcessStageId = stage.Id,
            MachineType = machineType,
            MachineId = stage.AssignedMachineId,
            RunTimeMinutes = defaultRunMinutes,
            SetupTimeMinutes = defaultSetupMinutes,
            Status = ProgramStatus.Draft,
            CreatedBy = _currentUser
        };

        // Add the part to the unified parts list as primary
        _createBuildPlateParts.Clear();
        if (part != null)
        {
            _createBuildPlateParts.Add(new CreateBuildPartEntry(
                part.Id, part.PartNumber, part.Name, Quantity: 1, IsPrimary: true));
        }

        _editSelectedMachineIds = machineIds;
        _showEditor = true;
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private static string GetStatusColor(ProgramStatus status) => status switch
    {
        ProgramStatus.Active => "var(--success)",
        ProgramStatus.Draft => "var(--warning)",
        ProgramStatus.Superseded => "var(--text-muted)",
        ProgramStatus.Archived => "var(--text-muted)",
        _ => "var(--border-color)"
    };

    private static string GetWearColor(double percent) => percent switch
    {
        >= 100 => "var(--danger)",
        >= 80 => "var(--warning)",
        _ => "var(--success)"
    };

    private static string GetFeedbackSeverityColor(ProgramFeedbackSeverity severity) => severity switch
    {
        ProgramFeedbackSeverity.Critical => "var(--danger)",
        ProgramFeedbackSeverity.High => "#e67700",
        ProgramFeedbackSeverity.Medium => "var(--warning)",
        _ => "var(--text-muted)"
    };

    // ══ UNIFIED PARTS MANAGEMENT (editor) ═════════════════════

    private void AddPartToCreateBuildPlate()
    {
        if (_createBuildAddPartId <= 0) return;
        var part = _parts?.FirstOrDefault(p => p.Id == _createBuildAddPartId)
                   ?? _additiveParts?.FirstOrDefault(p => p.Id == _createBuildAddPartId);
        if (part == null) return;

        // For standard programs, if this is the first part, make it primary
        var isBuildPlate = _editingProgram.ProgramType == ProgramType.BuildPlate;
        var makePrimary = !isBuildPlate && !_createBuildPlateParts.Any();

        _createBuildPlateParts.Add(new CreateBuildPartEntry(part.Id, part.PartNumber, part.Name, _createBuildAddPartQty, makePrimary));
        _createBuildAddPartId = 0;
        _createBuildAddPartQty = 1;
        _createBuildPartSearch = "";
    }

    private void SetPrimaryPart(int partId)
    {
        // Update all parts: only the selected one is primary
        _createBuildPlateParts = _createBuildPlateParts
            .Select(p => p with { IsPrimary = p.PartId == partId })
            .ToList();
    }

    private void RemovePartFromList(int partId)
    {
        var wasPrimary = _createBuildPlateParts.FirstOrDefault(p => p.PartId == partId)?.IsPrimary ?? false;
        _createBuildPlateParts.RemoveAll(x => x.PartId == partId);

        // If we removed the primary part, make the first remaining part primary (for standard programs)
        if (wasPrimary && _createBuildPlateParts.Any() && _editingProgram.ProgramType != ProgramType.BuildPlate)
        {
            var first = _createBuildPlateParts[0];
            _createBuildPlateParts[0] = first with { IsPrimary = true };
        }
    }

    // ── Build Plate Part Management (detail panel) ───────────

    private async Task AddPartToDetailBuildPlate()
    {
        if (_selectedProgram == null || _buildAddPartId <= 0) { Toast.ShowError("Select a part to add."); return; }
        if (_buildAddPartQty < 1) { Toast.ShowError("Quantity must be at least 1."); return; }
        try
        {
            await ProgramService.AddProgramPartAsync(_selectedProgram.Id, _buildAddPartId, _buildAddPartQty);
            _buildAddPartId = 0; _buildAddPartQty = 1; _buildPartSearch = "";
            Toast.ShowSuccess("Part added to build plate.");
            await SelectProgram(_selectedProgram);
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    private async Task RemoveBuildPartFromDetail(int programPartId)
    {
        try
        {
            await ProgramService.RemoveProgramPartAsync(programPartId);
            Toast.ShowSuccess("Part removed.");
            if (_selectedProgram != null) await SelectProgram(_selectedProgram);
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    private void StartBuildPartEdit(ProgramPart pp)
    {
        _buildEditingPartId = pp.Id;
        _buildEditQty = pp.Quantity;
        _buildEditStackLevel = pp.StackLevel;
        _buildEditNotes = pp.PositionNotes;
    }

    private void CancelBuildPartEdit() => _buildEditingPartId = null;

    private async Task SaveBuildPartEdit(int programPartId)
    {
        if (_buildEditQty < 1) { Toast.ShowError("Quantity must be at least 1."); return; }
        try
        {
            await ProgramService.UpdateProgramPartAsync(programPartId, _buildEditQty, _buildEditStackLevel, _buildEditNotes);
            _buildEditingPartId = null;
            Toast.ShowSuccess("Part updated.");
            if (_selectedProgram != null) await SelectProgram(_selectedProgram);
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    // ── Build Plate Status ───────────────────────────────────

    private async Task ActivateBuildPlate(MachineProgram plate)
    {
        _buildProcessing = true;
        try
        {
            plate.Status = ProgramStatus.Active;
            plate.LastModifiedBy = _currentUser;
            plate.LastModifiedDate = DateTime.UtcNow;
            await ProgramService.UpdateAsync(plate, _currentUser);
            Toast.ShowSuccess($"Build plate activated: {plate.Name}");
            await LoadData();
            if (_selectedProgram?.Id == plate.Id) await SelectProgram(plate);
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _buildProcessing = false; }
    }

    private async Task ArchiveBuildPlate(MachineProgram plate)
    {
        _buildProcessing = true;
        try
        {
            plate.Status = ProgramStatus.Archived;
            plate.LastModifiedBy = _currentUser;
            plate.LastModifiedDate = DateTime.UtcNow;
            await ProgramService.UpdateAsync(plate, _currentUser);
            Toast.ShowSuccess("Build plate archived.");
            await LoadData();
            if (_selectedProgram?.Id == plate.Id) await SelectProgram(plate);
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _buildProcessing = false; }
    }

    // ── Build Plate Slicer Data ──────────────────────────────

    private void ShowBuildSlicerEntry(MachineProgram plate)
    {
        _slicerBuildPlate = plate;
        _buildSlicerDuration = plate.EstimatedPrintHours;
        _buildSlicerLayers = plate.LayerCount;
        _buildSlicerHeight = plate.BuildHeightMm;
        _buildSlicerPowder = plate.EstimatedPowderKg;
        _buildSlicerSoftware = plate.SlicerSoftware;
        _buildSlicerVersion = plate.SlicerVersion;
        _buildSlicerFileName = plate.SlicerFileName;
        _showBuildSlicerEntry = true;
    }

    private async Task SaveBuildSlicerData()
    {
        if (_slicerBuildPlate == null || _buildSlicerDuration is null or <= 0) return;
        try
        {
            await ProgramService.UpdateSlicerDataAsync(
                _slicerBuildPlate.Id,
                _buildSlicerDuration,
                _buildSlicerLayers,
                _buildSlicerHeight,
                _buildSlicerPowder,
                _buildSlicerFileName,
                _buildSlicerSoftware,
                _buildSlicerVersion);

            Toast.ShowSuccess("Slicer data saved.");
            _showBuildSlicerEntry = false;
            await LoadData();
            if (_selectedProgram?.Id == _slicerBuildPlate.Id) await SelectProgram(_slicerBuildPlate);
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
    }

    // ── Build Plate Scheduling ───────────────────────────────

    private async Task ScheduleBuildPlate(MachineProgram plate)
    {
        var preferredMachine = plate.MachineAssignments?.FirstOrDefault(a => a.IsPreferred)
            ?? plate.MachineAssignments?.FirstOrDefault();
        if (preferredMachine == null)
        {
            Toast.ShowError("Assign at least one machine before scheduling.");
            return;
        }

        _buildProcessing = true;
        try
        {
            var result = await ProgramScheduling.ScheduleBuildPlateAsync(plate.Id, preferredMachine.MachineId);
            var stageCount = result.StageExecutions.Count;
            var msg = $"Scheduled: {result.Slot.PrintStart:g} → {result.Slot.PrintEnd:g} — {stageCount} stage(s)";
            if (result.Diagnostics?.Warnings.Count > 0)
                msg += $" ({string.Join("; ", result.Diagnostics.Warnings)})";
            Toast.ShowSuccess(msg);
            Nav.NavigateTo("/scheduler?view=builds");
        }
        catch (Exception ex) { Toast.ShowError($"Scheduling failed: {ex.Message}"); }
        finally { _buildProcessing = false; }
    }
}
