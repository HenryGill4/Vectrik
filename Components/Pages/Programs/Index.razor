    // ── Pending Setup ────────────────────────────────────────

    private void CreateProgramForStage(ProcessStage stage)
    {
        var part = stage.ManufacturingProcess?.Part;
        var machineIds = stage.PreferredMachineIds?
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(id => int.TryParse(id.Trim(), out var mid) ? mid : 0)
            .Where(id => id > 0)
            .ToHashSet() ?? [];
        if (stage.AssignedMachineId.HasValue) machineIds.Add(stage.AssignedMachineId.Value);

        var stageName = stage.ProductionStage?.Name ?? $"Stage-{stage.ExecutionOrder}";
        var machineType = stage.AssignedMachine?.MachineType
            ?? _machines?.FirstOrDefault(m => machineIds.Contains(m.Id))?.MachineType;
        double? defaultRunMinutes = stage.RunTimeMinutes
            ?? (stage.ProductionStage?.DefaultDurationHours > 0 ? stage.ProductionStage.DefaultDurationHours * 60 : null);

        _editingProgram = new MachineProgram
        {
            ProgramNumber = $"{part?.PartNumber ?? "NEW"}-{stageName.Replace(" ", "-").ToUpperInvariant()}-{stage.ExecutionOrder:D2}",
            Name = $"{part?.Name ?? "Part"} — {stageName}",
            PartId = part?.Id,
            ProcessStageId = stage.Id,
            MachineType = machineType,
            MachineId = stage.AssignedMachineId,
            RunTimeMinutes = defaultRunMinutes,
            SetupTimeMinutes = stage.SetupTimeMinutes,
            Status = ProgramStatus.Draft,
            CreatedBy = _currentUser
        };

        _createBuildPlateParts.Clear();
        if (part != null)
            _createBuildPlateParts.Add(new CreateBuildPartEntry(part.Id, part.PartNumber, part.Name, Quantity: 1, IsPrimary: true));

        _editSelectedMachineIds = machineIds;
        _showEditor = true;
    }

