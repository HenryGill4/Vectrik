    private bool _uploading;

    // ── SLS Build Plate State ────────────────────────────────
    private List<Part>? _additiveParts;
    private bool _buildProcessing;

    // Build plate inline editing
    private int? _buildEditingPartId;
    private int _buildEditQty;
    private int _buildEditStackLevel;
    private string? _buildEditNotes;

    // Build plate part search
    private string _buildPartSearch = "";
    private int _buildAddPartId;
    private int _buildAddPartQty = 1;

    // Unified parts list (used for all program types)
    private string _createBuildPartSearch = "";
    private int _createBuildAddPartId;
    private int _createBuildAddPartQty = 1;
    private List<CreateBuildPartEntry> _createBuildPlateParts = new();
    private record CreateBuildPartEntry(int PartId, string PartNumber, string PartName, int Quantity, bool IsPrimary = false);

    // Slicer data modal
    private bool _showBuildSlicerEntry;
    private MachineProgram? _slicerBuildPlate;
    private double? _buildSlicerDuration;
    private int? _buildSlicerLayers;
