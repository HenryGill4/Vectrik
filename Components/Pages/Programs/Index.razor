@page "/programs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMachineProgramService ProgramService
@inject IPartService PartService
@inject IMachineService MachineService
@inject IManufacturingProcessService ProcessService
@inject IMaintenanceService MaintenanceService
@inject IMaterialService MaterialService
@inject IProgramPlanningService ProgramPlanningService
@inject IProgramSchedulingService ProgramScheduling
@inject ToastService Toast
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ITenantFeatureService Features
@inject IWorkInstructionService WorkInstructionService
@inject ICertifiedLayoutService CertifiedLayoutService
@inject IWorkflowEngine WorkflowEngine
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Vectrik.Models.Enums
@using Vectrik.Models.Maintenance
@using Vectrik.Components.Pages.Programs.Components
@using Vectrik.Components.Pages.Programs.Sections
@using Vectrik.Components.Pages.Programs.Modals
@using Vectrik.Components.Pages.Programs.Views
@using Vectrik.Components.Pages.Programs.Models

<PageTitle>Machine Programs - Vectrik</PageTitle>

<AuthorizeView>
    <Authorized>
        @{ _currentUser = context.User.FindFirst("FullName")?.Value ?? context.User.FindFirst(ClaimTypes.Name)?.Value ?? "System"; }
    </Authorized>
</AuthorizeView>

@* ═══ PAGE HEADER ═══ *@
<div class="page-header">
    <h1 class="page-title">Machine Programs</h1>
    <div class="page-actions">
        <div style="display:inline-flex; gap: 2px; margin-right: 12px; border: 1px solid var(--border); border-radius: 6px; overflow: hidden;">
            <button class="btn btn-sm @(_activeView == "programs" ? "btn-primary" : "btn-secondary")" style="border-radius: 0;" @onclick='() => SwitchView("programs")'>📄 Programs</button>
            <button class="btn btn-sm @(_activeView == "machines" ? "btn-primary" : "btn-secondary")" style="border-radius: 0;" @onclick='() => SwitchView("machines")'>🖥️ Machine Setup</button>
        </div>
        @if (_activeView == "programs")
        {
            <button class="btn btn-primary" @onclick="ShowCreate">+ New Program</button>
        }
    </div>
</div>

@* ═══ EDITOR (slide-over) ═══ *@
@if (_showEditor)
{
    <ProgramFormModal Program="_editingProgram"
                      IsNew="@(_editingProgram.Id == 0)"
                      Saving="_saving"
                      Machines="@(_machines ?? [])"
                      MachineTypes="@(_machineTypes ?? [])"
                      Materials="@(_materials ?? [])"
                      Parts="@(_parts ?? [])"
                      AdditiveParts="@(_additiveParts ?? [])"
                      WorkInstructions="_workInstructions"
                      DepowderCandidates="_depowderCandidates"
                      EdmCandidates="_edmCandidates"
                      SelectedMachineIds="_editSelectedMachineIds"
                      PartsList="_createBuildPlateParts"
                      CertifiedLayouts="_certifiedLayouts"
                      PlateAssignments="_plateAssignments"
                      OnPlateAssignmentsChanged="HandlePlateAssignmentsChanged"
                      EditMaterialId="@_editMaterialId"
                      EditWorkInstructionId="@_editWorkInstructionId"
                      EditDepowderProgramId="@_editDepowderProgramId"
                      EditEdmProgramId="@_editEdmProgramId"
                      OnSave="SaveProgram"
                      OnCancel="CloseEditor"
                      OnMachineTypeChanged="HandleFormMachineTypeChanged"
                      OnMachineIdsChanged="HandleFormMachineIdsChanged"
                      OnLoadDefaultParameters="LoadDefaultParameters"
                      OnCopyParameters="CopyParametersToClipboard" />
}
else if (_programs == null)
{
    <div class="loading"><span class="spinner"></span></div>
}
else
{
    @* ── Pending Setup Banner ── *@
    <PendingSetupBanner PendingStages="_pendingSetupStages"
                        Machines="_machines"
                        IsVisible="_showPendingSetup"
                        OnToggle="() => _showPendingSetup = !_showPendingSetup"
                        OnCreateProgramForStage="CreateProgramForStage" />

    @if (_activeView == "machines")
    {
        <MachineSetupView Machines="@(_machines ?? [])"
                          Programs="@(_programs ?? [])"
                          OnNavigateToProgram="NavigateToProgram" />
    }
    else if (_activeView == "matrix")
    {
        <MachineMatrixView Machines="@(_machines ?? [])"
                           Programs="_programs"
                           OnNavigateToProgram="NavigateToProgram" />
    }
    else if (_activeView == "queue")
    {
        <ApprovalQueueView Programs="_programs"
                           FeedbackCounts="_feedbackCounts"
                           OnNavigateToProgram="NavigateToProgram" />
    }
    else
    {
        @* ═══ PROGRAMS VIEW ═══ *@

        @* ── Pipeline Bar ── *@
        <div class="prg-pipeline">
            @foreach (var status in new[] { ProgramStatus.Draft, ProgramStatus.Active, ProgramStatus.Superseded, ProgramStatus.Archived })
            {
                var count = _statusCounts.GetValueOrDefault(status, 0);
                var isSelected = _pipelineFilter == status;
                <div class="prg-pipeline-stage prg-pipeline-stage--@(status.ToString().ToLowerInvariant()) @(isSelected ? "prg-pipeline-stage--selected" : "")"
                     @onclick="() => TogglePipelineFilter(status)">
                    <span class="prg-pipeline-count">@count</span>
                    <span class="prg-pipeline-label">@status</span>
                </div>
            }
        </div>

        @* ── Command Bar ── *@
        <div class="prg-command-bar">
            <div class="prg-search">
                <span class="prg-search-icon">&#128269;</span>
                <input type="text" placeholder="Search programs..."
                       @bind="_searchTerm" @bind:after="ApplyFilters" />
            </div>

            <select class="prg-filter-select" @bind="_filterStatus" @bind:after="ApplyFilters">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<ProgramStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>

            <select class="prg-filter-select" @bind="_filterMachineType" @bind:after="ApplyFilters">
                <option value="">All Machine Types</option>
                @if (_machineTypes != null)
                {
                    @foreach (var t in _machineTypes)
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>

            <select class="prg-filter-select" @bind="_filterProgramType" @bind:after="ApplyFilters">
                <option value="">All Program Types</option>
                <option value="Standard">Standard</option>
                <option value="BuildPlate">Build Plate</option>
            </select>

            <select class="prg-filter-select" @bind="_sortBy" @bind:after="ApplyFilters">
                <option value="number">Sort: Number</option>
                <option value="name">Sort: Name</option>
                <option value="status">Sort: Status</option>
                <option value="modified">Sort: Modified</option>
            </select>

            <button class="btn btn-sm btn-secondary" @onclick="ToggleSortDirection"
                    title="@(_sortDesc ? "Descending" : "Ascending")">
                @(_sortDesc ? "\u2193" : "\u2191")
            </button>
        </div>

        @* ── Two-Panel Layout ── *@
        <div class="@(_selectedProgram != null ? "prg-layout" : "prg-layout prg-layout--no-detail")">

            @* ── LEFT: Sidebar ── *@
            <div class="prg-sidebar">
                @if (!_filteredPrograms.Any())
                {
                    <div class="prg-sidebar-empty">
                        <span style="font-size:2rem;">&#128196;</span>
                        <p>No programs match your filters.</p>
                        @if (!string.IsNullOrEmpty(_searchTerm) || !string.IsNullOrEmpty(_filterStatus) || !string.IsNullOrEmpty(_filterMachineType) || !string.IsNullOrEmpty(_filterProgramType) || _pipelineFilter.HasValue)
                        {
                            <button class="btn btn-sm btn-secondary" @onclick="ClearAllFilters">Clear Filters</button>
                        }
                    </div>
                }
                else
                {
                    <Virtualize Items="_filteredPrograms" Context="prog">
                        @{
                            var isSelected = _selectedProgram?.Id == prog.Id;
                            var statusClass = prog.Status.ToString().ToLowerInvariant();
                            var feedbackCount = _feedbackCounts.GetValueOrDefault(prog.Id, 0);
                        }
                        <div class="prg-sidebar-card prg-sidebar-card--@statusClass @(isSelected ? "prg-sidebar-card--selected" : "")"
                             @onclick="() => SelectProgram(prog)">
                            <div class="prg-card-row1">
                                <span class="prg-card-number">@prog.ProgramNumber</span>
                                <div class="prg-card-badges">
                                    <span class="prg-badge prg-badge--@statusClass">@prog.Status</span>
                                    @if (prog.Version > 1)
                                    {
                                        <span class="prg-badge prg-badge--version">v@(prog.Version)</span>
                                    }
                                    @if (prog.ProgramType == ProgramType.BuildPlate)
                                    {
                                        <span class="prg-badge prg-badge--buildplate">Build Plate</span>
                                    }
                                </div>
                            </div>
                            <div class="prg-card-name" title="@prog.Name">@prog.Name</div>
                            <div class="prg-card-meta">
                                @if (prog.RunTimeMinutes.HasValue)
                                {
                                    <span>@(prog.RunTimeMinutes < 60 ? $"{prog.RunTimeMinutes:F0}m" : $"{prog.RunTimeMinutes / 60:F1}h")</span>
                                    <span class="prg-card-meta-sep">|</span>
                                }
                                @if (prog.Files?.Count > 0)
                                {
                                    <span>@prog.Files.Count file(s)</span>
                                    <span class="prg-card-meta-sep">|</span>
                                }
                                @if (feedbackCount > 0)
                                {
                                    <span class="prg-badge prg-badge--feedback" style="font-size:0.7rem;">@feedbackCount feedback</span>
                                }
                                @if (!string.IsNullOrEmpty(prog.MachineType))
                                {
                                    <span>@prog.MachineType</span>
                                }
                            </div>
                        </div>
                    </Virtualize>
                }
            </div>

            @* ── RIGHT: Detail Panel ── *@
            @if (_selectedProgram != null)
            {
                <ProgramDetailPanel Program="_selectedProgram"
                                    CurrentUser="_currentUser"
                                    ToolingItems="_toolingItems"
                                    ToolingAlerts="_toolingAlerts"
                                    ExecutionHistory="_executionHistory"
                                    ProgramRuns="_programRuns"
                                    FeedbackList="_feedbackList"
                                    FeedbackFilter="_feedbackFilter"
                                    AdditiveParts="_additiveParts"
                                    Processing="_buildProcessing"
                                    UploadDescription="_uploadDescription"
                                    Uploading="_uploading"
                                    OnEdit="() => ShowEdit(_selectedProgram)"
                                    OnNewVersion="CreateNewVersion"
                                    OnClone="CloneProgramFromDetail"
                                    OnDelete="() => DeleteProgram(_selectedProgram)"
                                    OnAssignMachines="ShowAssignMachines"
                                    OnSetPreferred="SetPreferred"
                                    OnUnassign="UnassignMachine"
                                    OnMigrateLegacy="MigrateLegacyMachine"
                                    OnAddTooling="AddToolingItem"
                                    OnEditTooling="EditToolingItem"
                                    OnDeleteTooling="DeleteToolingItem"
                                    OnFeedbackFilterChanged="HandleFeedbackFilterChanged"
                                    OnReviewFeedback="HandleReviewFeedback"
                                    OnShowResolve="ShowResolveFeedback"
                                    OnCopyForAI="CopyDetailParametersToClipboard"
                                    OnFileUpload="HandleFileUpload"
                                    OnDeleteFile="DeleteFile"
                                    OnSetPrimary="SetPrimaryFile"
                                    OnUploadDescriptionChanged="(val) => _uploadDescription = val"
                                    OnShowSlicerEntry="() => ShowBuildSlicerEntry(_selectedProgram)"
                                    OnActivate="() => ActivateBuildPlate(_selectedProgram)"
                                    OnArchive="() => ArchiveBuildPlate(_selectedProgram)"
                                    OnSchedule="() => ScheduleBuildPlate(_selectedProgram)"
                                    OnBuildAddPart="HandleBuildAddPart"
                                    OnBuildRemovePart="HandleBuildRemovePart"
                                    OnBuildEditPart="HandleBuildEditPart"
                                    OnNavigateToProgram="HandleNavigateToProgram" />
            }
        </div>
    }
}

@* ═══ MODALS ═══ *@
<ToolingEditorModal IsVisible="_showToolingEditor"
                    ToolingItem="_editingToolingItem"
                    ComponentId="@_editToolingComponentId"
                    AvailableComponents="_availableComponents"
                    Saving="_savingTooling"
                    OnSave="SaveToolingItem"
                    OnClose="CloseToolingEditor"
                    ComponentIdChanged="(val) => _editToolingComponentId = val" />

<FeedbackResolveModal IsVisible="@(_showResolveModal && _resolvingFeedback != null)"
                      Feedback="_resolvingFeedback"
                      ResolutionText="_resolutionText"
                      OnSubmit="SubmitResolution"
                      OnClose="CloseResolveModal"
                      ResolutionTextChanged="(val) => _resolutionText = val" />

<MachineAssignmentModal IsVisible="_showAssignModal"
                        ProgramNumber="@(_selectedProgram?.ProgramNumber ?? "")"
                        Machines="_machines"
                        SelectedMachineIds="_assignSelectedMachineIds"
                        OnSave="SaveAssignMachines"
                        OnClose="() => _showAssignModal = false"
                        OnToggleMachine="ToggleAssignMachine" />

<SlicerDataModal IsVisible="@(_showBuildSlicerEntry && _slicerBuildPlate != null)"
                 BuildPlate="_slicerBuildPlate"
                 Duration="_buildSlicerDuration"
                 Layers="_buildSlicerLayers"
                 Height="_buildSlicerHeight"
                 Powder="_buildSlicerPowder"
                 Software="_buildSlicerSoftware"
                 Version="_buildSlicerVersion"
                 FileName="_buildSlicerFileName"
                 OnSave="SaveBuildSlicerData"
                 OnClose="() => _showBuildSlicerEntry = false"
                 DurationChanged="(val) => _buildSlicerDuration = val"
                 LayersChanged="(val) => _buildSlicerLayers = val"
                 HeightChanged="(val) => _buildSlicerHeight = val"
                 PowderChanged="(val) => _buildSlicerPowder = val"
                 SoftwareChanged="(val) => _buildSlicerSoftware = val"
                 VersionChanged="(val) => _buildSlicerVersion = val"
                 FileNameChanged="(val) => _buildSlicerFileName = val" />

@code {
    private string _currentUser = "System";
    private string _activeView = "programs";

    [SupplyParameterFromQuery(Name = "view")]
    public string? InitialView { get; set; }

    // Data
    private List<MachineProgram>? _programs;
    private List<MachineProgram> _filteredPrograms = new();
    private List<Part>? _parts;
    private List<Machine>? _machines;
    private List<string>? _machineTypes;
    private List<Material>? _materials;
    private Dictionary<int, int> _feedbackCounts = new();
    private List<MaintenanceAlert> _maintenanceAlerts = new();
    private int _totalUnresolvedFeedback;

    // Pending program setup
    private List<ProcessStage> _pendingSetupStages = new();
    private bool _showPendingSetup;

    // Filters
    private string _filterStatus = "";
    private string _filterMachineType = "";
    private string _filterProgramType = "";
    private string _searchTerm = "";
    private string _sortBy = "number";
    private bool _sortDesc = false;

    // Pipeline filter
    private ProgramStatus? _pipelineFilter;

    // Status counts for pipeline
    private Dictionary<ProgramStatus, int> _statusCounts = new();

    // Editor
    private bool _showEditor;
    private bool _saving;
    private MachineProgram _editingProgram = new();
    private string _editMaterialId = "";
    private HashSet<int> _editSelectedMachineIds = new();
    private string _editWorkInstructionId = "";
    private List<WorkInstruction>? _workInstructions;
    private string _editDepowderProgramId = "";
    private string _editEdmProgramId = "";
    private List<MachineProgram>? _depowderCandidates;
    private List<MachineProgram>? _edmCandidates;
    private List<CreateBuildPartEntry> _createBuildPlateParts = new();

    // Machine assignment modal
    private bool _showAssignModal;
    private HashSet<int> _assignSelectedMachineIds = new();

    // Detail panel
    private MachineProgram? _selectedProgram;

    // Tooling
    private List<ProgramToolingItem> _toolingItems = new();
    private List<ToolingReadinessAlert> _toolingAlerts = new();
    private bool _showToolingEditor;
    private bool _savingTooling;
    private ProgramToolingItem _editingToolingItem = new();
    private string _editToolingComponentId = "";
    private List<MachineComponent>? _availableComponents;

    // Feedback
    private List<ProgramFeedback> _feedbackList = new();
    private string _feedbackFilter = "";
    private bool _showResolveModal;
    private ProgramFeedback? _resolvingFeedback;
    private string _resolutionText = "";

    // Learning
    private List<StageExecution> _executionHistory = new();

    // Runs
    private List<StageExecution> _programRuns = new();

    // Files
    private string? _uploadDescription;
    private bool _uploading;

    // SLS Build Plate State
    private List<Part>? _additiveParts;
    private bool _buildProcessing;

    // Certified Layout State
    private List<CertifiedLayout> _certifiedLayouts = [];
    private List<PlateSlotAssignment> _plateAssignments = [];

    // Slicer data modal
    private bool _showBuildSlicerEntry;
    private MachineProgram? _slicerBuildPlate;
    private double? _buildSlicerDuration;
    private int? _buildSlicerLayers;
    private double? _buildSlicerHeight;
    private double? _buildSlicerPowder;
    private string? _buildSlicerSoftware;
    private string? _buildSlicerVersion;
    private string? _buildSlicerFileName;

    // ── Lifecycle ────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        if (!string.IsNullOrEmpty(InitialView))
            SwitchView(InitialView);
    }

    private async Task LoadData()
    {
        _programs = await ProgramService.GetAllAsync();
        _parts = await PartService.GetAllPartsAsync();
        _machines = await MachineService.GetAllMachinesAsync();
        _machineTypes = _machines?.Select(m => m.MachineType).Distinct().OrderBy(t => t).ToList() ?? new();
        _materials = await MaterialService.GetAllMaterialsAsync();
        _workInstructions = await WorkInstructionService.GetAllAsync();

        var allParts = _parts ?? await PartService.GetAllPartsAsync(activeOnly: true);
        _additiveParts = allParts.ToList();
        _certifiedLayouts = await CertifiedLayoutService.GetCertifiedAsync();

        if (_programs.Count > 0)
        {
            var programIds = _programs.Select(p => p.Id).ToList();
            _feedbackCounts = await ProgramService.GetUnresolvedFeedbackCountsAsync(programIds);
            _totalUnresolvedFeedback = _feedbackCounts.Values.Sum();
        }

        try { _maintenanceAlerts = await MaintenanceService.EvaluateMaintenanceRulesAsync(); }
        catch { _maintenanceAlerts = new(); }

        try { _pendingSetupStages = await ProcessService.GetStagesPendingProgramSetupAsync(); }
        catch { _pendingSetupStages = new(); }

        try { _depowderCandidates = await ProgramService.GetPostProcessingCandidatesAsync("Depowder"); }
        catch { _depowderCandidates = new(); }
        try { _edmCandidates = await ProgramService.GetPostProcessingCandidatesAsync("EDM"); }
        catch { _edmCandidates = new(); }

        ComputeStatusCounts();
        ApplyFilters();
    }

    private void ComputeStatusCounts()
    {
        _statusCounts = new();
        if (_programs == null) return;
        foreach (var s in Enum.GetValues<ProgramStatus>())
            _statusCounts[s] = _programs.Count(p => p.Status == s);
    }

    private void ApplyFilters()
    {
        if (_programs == null) { _filteredPrograms = new(); return; }
        var q = _programs.AsEnumerable();

        // Pipeline filter
        if (_pipelineFilter.HasValue)
            q = q.Where(p => p.Status == _pipelineFilter.Value);

        // Status dropdown filter
        if (!string.IsNullOrEmpty(_filterStatus) && Enum.TryParse<ProgramStatus>(_filterStatus, out var status))
            q = q.Where(p => p.Status == status);

        // Machine type filter
        if (!string.IsNullOrEmpty(_filterMachineType))
            q = q.Where(p => string.Equals(p.MachineType, _filterMachineType, StringComparison.OrdinalIgnoreCase)
                            || string.Equals(p.Machine?.MachineType, _filterMachineType, StringComparison.OrdinalIgnoreCase)
                            || (p.MachineAssignments?.Any(a => string.Equals(a.Machine?.MachineType, _filterMachineType, StringComparison.OrdinalIgnoreCase)) == true));

        // Program type filter
        if (!string.IsNullOrEmpty(_filterProgramType))
        {
            if (_filterProgramType == "Standard")
                q = q.Where(p => p.ProgramType == ProgramType.Standard);
            else if (_filterProgramType == "BuildPlate")
                q = q.Where(p => p.ProgramType == ProgramType.BuildPlate);
        }

        // Search
        if (!string.IsNullOrEmpty(_searchTerm))
            q = q.Where(p => (p.ProgramNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                            || (p.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                            || (p.Part?.PartNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                            || (p.Machine?.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

        // Sort
        q = _sortBy switch
        {
            "name" => _sortDesc ? q.OrderByDescending(p => p.Name) : q.OrderBy(p => p.Name),
            "status" => _sortDesc ? q.OrderByDescending(p => p.Status) : q.OrderBy(p => p.Status),
            "modified" => _sortDesc ? q.OrderByDescending(p => p.LastModifiedDate) : q.OrderBy(p => p.LastModifiedDate),
            _ => _sortDesc ? q.OrderByDescending(p => p.ProgramNumber) : q.OrderBy(p => p.ProgramNumber)
        };

        _filteredPrograms = q.ToList();
    }

    private void TogglePipelineFilter(ProgramStatus status)
    {
        _pipelineFilter = _pipelineFilter == status ? null : status;
        ApplyFilters();
    }

    private void ToggleSortDirection()
    {
        _sortDesc = !_sortDesc;
        ApplyFilters();
    }

    private void ClearAllFilters()
    {
        _searchTerm = "";
        _filterStatus = "";
        _filterMachineType = "";
        _filterProgramType = "";
        _pipelineFilter = null;
        _sortBy = "number";
        _sortDesc = false;
        ApplyFilters();
    }

    private void SwitchView(string view) => _activeView = view;

    // ── Selection / Detail ───────────────────────────────────

    private async Task SelectProgram(MachineProgram program)
    {
        _selectedProgram = await ProgramService.GetByIdAsync(program.Id);
        await LoadDetailData();
    }

    private async Task LoadDetailData()
    {
        if (_selectedProgram == null) return;
        _toolingItems = await ProgramService.GetToolingItemsAsync(_selectedProgram.Id);
        _toolingAlerts = await ProgramService.CheckToolingReadinessAsync(_selectedProgram.Id);
        _executionHistory = await ProgramService.GetExecutionHistoryAsync(_selectedProgram.Id);
        _programRuns = await ProgramService.GetProgramRunsAsync(_selectedProgram.Id);
        await LoadFeedback();
    }

    // ── Create / Edit ────────────────────────────────────────

    private void ShowCreate()
    {
        _editingProgram = new MachineProgram { ProgramType = ProgramType.Standard };
        _editMaterialId = "";
        _editWorkInstructionId = "";
        _editDepowderProgramId = "";
        _editEdmProgramId = "";
        _editSelectedMachineIds = new();
        _createBuildPlateParts.Clear();
        _showEditor = true;
    }

    private void ShowEdit(MachineProgram program)
    {
        _editingProgram = program;
        _editMaterialId = program.MaterialId?.ToString() ?? "";
        _editWorkInstructionId = program.WorkInstructionId?.ToString() ?? "";
        _editDepowderProgramId = program.DepowderProgramId?.ToString() ?? "";
        _editEdmProgramId = program.EdmProgramId?.ToString() ?? "";
        _editSelectedMachineIds = program.MachineAssignments?.Select(a => a.MachineId).ToHashSet() ?? new();
        _createBuildPlateParts.Clear();

        // Auto-detect SLS
        if (!program.IsBuildPlate && _editSelectedMachineIds.Count > 0 && _machines != null)
        {
            var selectedMachines = _machines.Where(m => _editSelectedMachineIds.Contains(m.Id)).ToList();
            if (selectedMachines.Count > 0 && selectedMachines.All(m => string.Equals(m.MachineType, "SLS", StringComparison.OrdinalIgnoreCase)))
            {
                _editingProgram.ProgramType = ProgramType.BuildPlate;
                _editingProgram.MachineType = "SLS";
            }
        }

        // Populate unified parts list
        if (_editingProgram.IsBuildPlate)
        {
            if (program.ProgramParts?.Any() == true)
            {
                foreach (var pp in program.ProgramParts)
                    _createBuildPlateParts.Add(new CreateBuildPartEntry(pp.PartId, pp.Part?.PartNumber ?? $"#{pp.PartId}", pp.Part?.Name ?? "", pp.Quantity, IsPrimary: false));
            }
            if (program.PartId.HasValue && program.Part != null && !_createBuildPlateParts.Any(p => p.PartId == program.PartId.Value))
                _createBuildPlateParts.Add(new CreateBuildPartEntry(program.Part.Id, program.Part.PartNumber, program.Part.Name, Quantity: 1, IsPrimary: false));
        }
        else
        {
            if (program.PartId.HasValue && program.Part != null)
                _createBuildPlateParts.Add(new CreateBuildPartEntry(program.Part.Id, program.Part.PartNumber, program.Part.Name, Quantity: 1, IsPrimary: true));
            if (program.ProgramParts?.Any() == true)
            {
                foreach (var pp in program.ProgramParts)
                    _createBuildPlateParts.Add(new CreateBuildPartEntry(pp.PartId, pp.Part?.PartNumber ?? $"#{pp.PartId}", pp.Part?.Name ?? "", pp.Quantity, IsPrimary: false));
            }
        }

        _showEditor = true;
    }

    private void CloseEditor()
    {
        _showEditor = false;
        _createBuildPlateParts.Clear();
    }

    private void HandlePlateAssignmentsChanged(List<PlateSlotAssignment> assignments)
    {
        _plateAssignments = assignments;

        // Sync certified layout assignments to legacy PartsList for save
        _createBuildPlateParts.Clear();
        foreach (var a in assignments)
        {
            var cl = _certifiedLayouts.FirstOrDefault(l => l.Id == a.CertifiedLayoutId);
            if (cl == null) continue;
            _createBuildPlateParts.Add(new CreateBuildPartEntry(
                cl.PartId, cl.Part?.PartNumber ?? $"#{cl.PartId}", cl.Part?.Name ?? "", cl.Positions));
        }
    }

    private void HandleFormMachineTypeChanged(string machineType)
    {
        _editingProgram.MachineType = machineType;
    }

    private void HandleFormMachineIdsChanged(HashSet<int> machineIds)
    {
        _editSelectedMachineIds = machineIds;

        // Auto-fill MachineType from first selected machine if blank
        if (string.IsNullOrEmpty(_editingProgram.MachineType) && _editSelectedMachineIds.Count > 0)
        {
            var machine = _machines?.FirstOrDefault(m => _editSelectedMachineIds.Contains(m.Id));
            if (machine != null)
                _editingProgram.MachineType = machine.MachineType;
        }

        // Auto-detect ProgramType
        if (_machines != null)
        {
            var selectedMachines = _machines.Where(m => _editSelectedMachineIds.Contains(m.Id)).ToList();
            var allSls = selectedMachines.Count > 0
                && selectedMachines.All(m => string.Equals(m.MachineType, "SLS", StringComparison.OrdinalIgnoreCase));

            if (allSls && _editingProgram.ProgramType != ProgramType.BuildPlate)
            {
                _editingProgram.ProgramType = ProgramType.BuildPlate;
                _editingProgram.MachineType = "SLS";
                _createBuildPlateParts = _createBuildPlateParts.Select(p => p with { IsPrimary = false }).ToList();
            }
            else if (!allSls && _editingProgram.ProgramType == ProgramType.BuildPlate)
            {
                _editingProgram.ProgramType = ProgramType.Standard;
                _editMaterialId = "";
                if (_createBuildPlateParts.Any())
                    _createBuildPlateParts[0] = _createBuildPlateParts[0] with { IsPrimary = true };
            }
        }
    }

