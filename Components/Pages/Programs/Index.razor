    private async Task AddToolingItem()
    {
        _editingToolingItem = new ProgramToolingItem { MachineProgramId = _selectedProgram!.Id, SortOrder = _toolingItems.Count + 1 };
        _editToolingComponentId = "";
        await LoadAvailableComponents();
        _showToolingEditor = true;
