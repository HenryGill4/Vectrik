    private async Task SaveProgram()
    {
        var isBuildPlate = _editingProgram.ProgramType == ProgramType.BuildPlate;
        var isNew = _editingProgram.Id == 0;

        if (string.IsNullOrWhiteSpace(_editingProgram.Name))
        {
            Toast.ShowError("Name is required.");
            return;
        }

        // Standard programs require a program number; build plates auto-generate if blank
        if (!isBuildPlate && string.IsNullOrWhiteSpace(_editingProgram.ProgramNumber))
        {
            Toast.ShowError("Program number is required.");
            return;
        }

        if (isBuildPlate && string.IsNullOrWhiteSpace(_editingProgram.ProgramNumber))
        {
            _editingProgram.ProgramNumber = $"BP-{DateTime.UtcNow:yyMMdd-HHmmss}";
        }

        if (isBuildPlate && !_createBuildPlateParts.Any())
        {
            Toast.ShowError("Add at least one part to the build plate.");
            return;
        }

        _saving = true;
        try
        {
            // Extract primary part from unified parts list (for standard programs)
            var primaryPart = _createBuildPlateParts.FirstOrDefault(p => p.IsPrimary);

            // Bind FK fields from editor state
            _editingProgram.PartId = isBuildPlate ? null : primaryPart?.PartId;
            _editingProgram.MaterialId = isBuildPlate && int.TryParse(_editMaterialId, out var mid) ? mid : null;
            _editingProgram.WorkInstructionId = int.TryParse(_editWorkInstructionId, out var wid) ? wid : null;
            _editingProgram.DepowderProgramId = isBuildPlate && int.TryParse(_editDepowderProgramId, out var dpid) ? dpid : null;
            _editingProgram.EdmProgramId = isBuildPlate && int.TryParse(_editEdmProgramId, out var epid2) ? epid2 : null;

            if (isNew)
            {
                _editingProgram.CreatedBy = _currentUser;
                await ProgramService.CreateAsync(_editingProgram, _currentUser);
            }
            else
            {
                await ProgramService.UpdateAsync(_editingProgram, _currentUser);
            }

            // Sync machine assignments
            await ProgramService.SyncMachineAssignmentsAsync(
                _editingProgram.Id, _editSelectedMachineIds.ToList(), _currentUser);

            // Get non-primary parts for ProgramParts table (primary is stored via PartId FK)
            var additionalParts = isBuildPlate 
                ? _createBuildPlateParts  // Build plates: all parts go to ProgramParts
                : _createBuildPlateParts.Where(p => !p.IsPrimary).ToList();  // Standard: only non-primary

            // Save parts to ProgramParts table
            if (additionalParts.Any())
            {
                if (isNew)
                {
                    // New program: add all parts
                    foreach (var cp in additionalParts)
                        await ProgramService.AddProgramPartAsync(_editingProgram.Id, cp.PartId, cp.Quantity);
                }
                else
                {
                    // Existing program: sync parts (remove old, add current)
                    var existingParts = await ProgramService.GetProgramPartsAsync(_editingProgram.Id);
                    foreach (var ep in existingParts)
                        await ProgramService.RemoveProgramPartAsync(ep.Id);
                    foreach (var cp in additionalParts)
                        await ProgramService.AddProgramPartAsync(_editingProgram.Id, cp.PartId, cp.Quantity);
                }
            }
            else if (!isNew)
            {
                // Editing a program with no additional parts: clear any existing ProgramParts
                var existingParts = await ProgramService.GetProgramPartsAsync(_editingProgram.Id);
                foreach (var ep in existingParts)
                    await ProgramService.RemoveProgramPartAsync(ep.Id);
            }

            // If created for a pending stage, link the program and clear the setup flag
            if (_editingProgram.ProcessStageId.HasValue)
            {
                await ProcessService.LinkProgramToStageAsync(
                    _editingProgram.ProcessStageId.Value, _editingProgram.Id);
            }

            var partCount = _createBuildPlateParts.Count;
            _showEditor = false;
            _createBuildPlateParts.Clear();

            var label = isBuildPlate ? "Build plate" : "Program";
            Toast.ShowSuccess(isNew
                ? $"{label} {_editingProgram.ProgramNumber} created{(partCount > 0 ? $" with {partCount} part(s)" : "")}."
                : $"{label} {_editingProgram.ProgramNumber} saved.");

            await LoadData();

            if (_selectedProgram?.Id == _editingProgram.Id)
                await SelectProgram(_editingProgram);
        }
        catch (Exception ex) { Toast.ShowError($"Error: {ex.Message}"); }
        finally { _saving = false; }
    }

