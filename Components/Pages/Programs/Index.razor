    private async Task LoadAvailableComponents()
    {
        _availableComponents = new();

        // Get components from machines assigned to this program
        var assignedMachineIds = _selectedProgram?.MachineAssignments?
            .Select(a => a.MachineId).ToList() ?? new();

        // Also include legacy single FK
        if (_selectedProgram?.MachineId.HasValue == true && !assignedMachineIds.Contains(_selectedProgram.MachineId.Value))
            assignedMachineIds.Add(_selectedProgram.MachineId.Value);

        if (assignedMachineIds.Count > 0)
        {
            foreach (var mid in assignedMachineIds)
            {
                var machine = _machines?.FirstOrDefault(m => m.Id == mid);
                if (machine != null)
                {
                    var components = await MaintenanceService.GetComponentsByMachineAsync(machine.MachineId);
                    _availableComponents.AddRange(components);
                }
            }
        }
        else if (_machines != null)
        {
            foreach (var machine in _machines.Take(10))
            {
                var components = await MaintenanceService.GetComponentsByMachineAsync(machine.MachineId);
                _availableComponents.AddRange(components);
            }
        }
    }

