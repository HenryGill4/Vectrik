    // ── Build Plate Status ───────────────────────────────────

    private async Task ActivateBuildPlate(MachineProgram plate)
    {
        _buildProcessing = true;
        try
        {
            // Gate activation behind workflow if defined
            if (await WorkflowEngine.HasWorkflowAsync("MachineProgram"))
            {
                var pending = await WorkflowEngine.GetPendingAsync("MachineProgram", plate.Id);
                if (pending == null)
                {
                    await WorkflowEngine.StartAsync("MachineProgram", plate.Id);
                    Toast.ShowInfo("Program activation submitted for approval.");
                    return;
                }
                if (pending.Status == "Pending")
                {
                    Toast.ShowWarning("Program is awaiting approval before activation.");
                    return;
                }
            }

            plate.Status = ProgramStatus.Active;
            plate.LastModifiedBy = _currentUser;
            plate.LastModifiedDate = DateTime.UtcNow;
            await ProgramService.UpdateAsync(plate, _currentUser);
            Toast.ShowSuccess($"Build plate activated: {plate.Name}");
            await LoadData();
            if (_selectedProgram?.Id == plate.Id) await SelectProgram(plate);
        }
        catch (Exception ex) { Toast.ShowError($"Failed: {ex.Message}"); }
        finally { _buildProcessing = false; }
    }

    private async Task ArchiveBuildPlate(MachineProgram plate)
    {
        _buildProcessing = true;
