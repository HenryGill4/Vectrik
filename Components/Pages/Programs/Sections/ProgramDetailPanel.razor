@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="prg-detail" @ref="_detailRef">
    <nav class="prg-section-tabs" @ref="_tabsRef">
        @foreach (var sec in _sections)
        {
            if ((sec.Id == "prg-section-buildplate" || sec.Id == "prg-section-runs") && !Program.IsBuildPlate) continue;
            var capturedId = sec.Id;
            var capturedLabel = sec.Label;
            <button class="prg-tab @(capturedId == _activeSection ? "prg-tab--active" : "")"
                    @onclick="() => ScrollToSection(capturedId)">
                @capturedLabel
            </button>
        }
    </nav>

    <div id="prg-section-hero">
        <DetailHero Program="Program"
                    OnEdit="OnEdit"
                    OnNewVersion="OnNewVersion"
                    OnClone="OnClone"
                    OnDelete="OnDelete" />
    </div>

    <div id="prg-section-metrics">
        <DetailMetrics Program="Program" />
    </div>

    <div id="prg-section-files">
        <DetailFilePackage Program="Program"
                           UploadDescription="UploadDescription"
                           Uploading="Uploading"
                           OnFileUpload="OnFileUpload"
                           OnDeleteFile="OnDeleteFile"
                           OnSetPrimary="OnSetPrimary"
                           OnUploadDescriptionChanged="OnUploadDescriptionChanged" />
    </div>

    <div id="prg-section-tooling">
        <DetailToolingReadiness ToolingItems="ToolingItems"
                                ToolingAlerts="ToolingAlerts"
                                OnAddTooling="OnAddTooling"
                                OnEditTooling="OnEditTooling"
                                OnDeleteTooling="OnDeleteTooling" />
    </div>

    <div id="prg-section-machines">
        <DetailMachineAssignments Program="Program"
                                  OnAssignMachines="OnAssignMachines"
                                  OnSetPreferred="OnSetPreferred"
                                  OnUnassign="OnUnassign"
                                  OnMigrateLegacy="OnMigrateLegacy" />
    </div>

    <div id="prg-section-params">
        <DetailParameters Program="Program"
                          OnCopyForAI="OnCopyForAI" />
    </div>

    <div id="prg-section-feedback">
        <DetailFeedbackStream FeedbackList="FeedbackList"
                              FeedbackFilter="FeedbackFilter"
                              OnFeedbackFilterChanged="OnFeedbackFilterChanged"
                              OnReviewFeedback="OnReviewFeedback"
                              OnShowResolve="OnShowResolve" />
    </div>

    <div id="prg-section-learning">
        <DetailLearning Program="Program"
                        ExecutionHistory="ExecutionHistory" />
    </div>

    @if (Program.IsBuildPlate)
    {
        <div id="prg-section-runs">
            <DetailRuns Program="Program"
                        ProgramRuns="ProgramRuns" />
        </div>

        <div id="prg-section-buildplate">
            <DetailBuildPlate Program="Program"
                              AdditiveParts="AdditiveParts"
                              Processing="Processing"
                              OnShowSlicerEntry="OnShowSlicerEntry"
                              OnActivate="OnActivate"
                              OnArchive="OnArchive"
                              OnSchedule="OnSchedule"
                              OnBuildAddPart="OnBuildAddPart"
                              OnBuildRemovePart="OnBuildRemovePart"
                              OnBuildEditPart="OnBuildEditPart"
                              OnNavigateToProgram="OnNavigateToProgram" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public MachineProgram Program { get; set; } = null!;
    [Parameter] public List<ProgramToolingItem> ToolingItems { get; set; } = new();
    [Parameter] public List<ToolingReadinessAlert> ToolingAlerts { get; set; } = new();
    [Parameter] public List<StageExecution> ExecutionHistory { get; set; } = new();
    [Parameter] public List<StageExecution> ProgramRuns { get; set; } = new();
    [Parameter] public List<ProgramFeedback> FeedbackList { get; set; } = new();
    [Parameter] public string FeedbackFilter { get; set; } = "All";
    [Parameter] public List<Part> AdditiveParts { get; set; } = new();
    [Parameter] public bool Processing { get; set; }
    [Parameter] public string? UploadDescription { get; set; }
    [Parameter] public bool Uploading { get; set; }
    [Parameter] public string CurrentUser { get; set; } = string.Empty;

    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnNewVersion { get; set; }
    [Parameter] public EventCallback OnClone { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnAssignMachines { get; set; }
    [Parameter] public EventCallback<MachineProgramAssignment> OnSetPreferred { get; set; }
    [Parameter] public EventCallback<MachineProgramAssignment> OnUnassign { get; set; }
    [Parameter] public EventCallback OnMigrateLegacy { get; set; }
    [Parameter] public EventCallback OnAddTooling { get; set; }
    [Parameter] public EventCallback<ProgramToolingItem> OnEditTooling { get; set; }
    [Parameter] public EventCallback<ProgramToolingItem> OnDeleteTooling { get; set; }
    [Parameter] public EventCallback<string> OnFeedbackFilterChanged { get; set; }
    [Parameter] public EventCallback<(ProgramFeedback, ProgramFeedbackStatus)> OnReviewFeedback { get; set; }
    [Parameter] public EventCallback<ProgramFeedback> OnShowResolve { get; set; }
    [Parameter] public EventCallback OnCopyForAI { get; set; }
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnFileUpload { get; set; }
    [Parameter] public EventCallback<MachineProgramFile> OnDeleteFile { get; set; }
    [Parameter] public EventCallback<MachineProgramFile> OnSetPrimary { get; set; }
    [Parameter] public EventCallback<string> OnUploadDescriptionChanged { get; set; }
    [Parameter] public EventCallback OnShowSlicerEntry { get; set; }
    [Parameter] public EventCallback OnActivate { get; set; }
    [Parameter] public EventCallback OnArchive { get; set; }
    [Parameter] public EventCallback OnSchedule { get; set; }
    [Parameter] public EventCallback<(int PartId, int Quantity)> OnBuildAddPart { get; set; }
    [Parameter] public EventCallback<ProgramPart> OnBuildRemovePart { get; set; }
    [Parameter] public EventCallback<(ProgramPart Part, int NewQty, int NewStack, string? Notes)> OnBuildEditPart { get; set; }
    [Parameter] public EventCallback<int> OnNavigateToProgram { get; set; }

    private ElementReference _detailRef;
    private ElementReference _tabsRef;
    private IJSObjectReference? _module;
    private string _activeSection = "prg-section-hero";

    private record SectionDef(string Id, string Label);
    private static readonly SectionDef[] _sections =
    [
        new("prg-section-hero", "Overview"),
        new("prg-section-metrics", "Metrics"),
        new("prg-section-files", "Files"),
        new("prg-section-tooling", "Tooling"),
        new("prg-section-machines", "Machines"),
        new("prg-section-params", "Params"),
        new("prg-section-feedback", "Feedback"),
        new("prg-section-learning", "Learning"),
        new("prg-section-runs", "Runs"),
        new("prg-section-buildplate", "Build Plate"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/program-detail-nav.js");
            await _module.InvokeVoidAsync("init", _detailRef, DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable("OnSectionVisible")]
    public void OnSectionVisible(string sectionId)
    {
        if (_activeSection != sectionId)
        {
            _activeSection = sectionId;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task ScrollToSection(string sectionId)
    {
        _activeSection = sectionId;
        if (_module != null)
            await _module.InvokeVoidAsync("scrollTo", sectionId);

        // Scroll the active tab into view in the tab strip
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            try { await _module.InvokeVoidAsync("dispose"); } catch { }
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
