<section class="prg-section">
    <div class="prg-section-header">
        <h3>Runs</h3>
        @if (ProgramRuns?.Any() == true)
        {
            <span class="prg-badge prg-badge--info">@ProgramRuns.Count run@(ProgramRuns.Count != 1 ? "s" : "")</span>
        }
    </div>

    @if (ProgramRuns?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Job</th>
                        <th>Machine</th>
                        <th>Scheduled Start</th>
                        <th>Scheduled End</th>
                        <th>Duration</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var runIndex = ProgramRuns.Count; }
                    @foreach (var run in ProgramRuns)
                    {
                        <tr>
                            <td>@(runIndex--)</td>
                            <td>@(run.Job?.JobNumber ?? "--")</td>
                            <td>@(run.Machine?.Name ?? "--")</td>
                            <td>@FormatDate(run.ScheduledStartAt)</td>
                            <td>@FormatDate(run.ScheduledEndAt)</td>
                            <td>@FormatDuration(run)</td>
                            <td>
                                <span class="prg-badge prg-badge--@GetStatusClass(run)">@GetStatusLabel(run)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="prg-empty">No runs scheduled for this program yet.</div>
    }
</section>

@code {
    [Parameter, EditorRequired] public MachineProgram Program { get; set; } = null!;
    [Parameter] public List<StageExecution> ProgramRuns { get; set; } = new();

    private string FormatDate(DateTime? dt)
    {
        return dt?.ToString("MMM dd, HH:mm") ?? "--";
    }

    private string FormatDuration(StageExecution run)
    {
        if (run.ActualHours.HasValue)
        {
            var h = (int)run.ActualHours.Value;
            var m = (int)((run.ActualHours.Value - h) * 60);
            return m > 0 ? $"{h}h {m}m" : $"{h}h";
        }
        if (run.EstimatedHours.HasValue)
        {
            var h = (int)run.EstimatedHours.Value;
            var m = (int)((run.EstimatedHours.Value - h) * 60);
            return m > 0 ? $"~{h}h {m}m" : $"~{h}h";
        }
        return "--";
    }

    private string GetStatusLabel(StageExecution run)
    {
        if (run.Job == null) return run.Status.ToString();
        return run.Job.Status switch
        {
            JobStatus.Scheduled => "Scheduled",
            JobStatus.InProgress => "Printing",
            JobStatus.Completed => "Completed",
            JobStatus.Cancelled => "Cancelled",
            _ => run.Job.Status.ToString()
        };
    }

    private string GetStatusClass(StageExecution run)
    {
        if (run.Job == null) return run.Status.ToString().ToLower();
        return run.Job.Status switch
        {
            JobStatus.Scheduled => "scheduled",
            JobStatus.InProgress => "printing",
            JobStatus.Completed => "completed",
            JobStatus.Cancelled => "cancelled",
            _ => "none"
        };
    }
}
