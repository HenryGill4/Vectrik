@page "/inventory/items/{Id:int}/ledger"
@inject IInventoryService InventoryService
@inject NavigationManager Nav
@inject ToastService Toast
@inject ITenantFeatureService Features

<PageTitle>Stock Ledger - OpCentrix</PageTitle>

<FeatureGate Feature="module.inventory" ModuleName="Inventory Management">

<div class="page-header">
    <h1 class="page-title">📒 Stock Ledger</h1>
    <div style="display: flex; gap: 8px;">
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/inventory/items")'>← Items</button>
        @if (_item != null)
        {
            <button class="btn btn-primary" @onclick="ShowAdjust">⚖️ Adjust</button>
        }
    </div>
</div>

        @if (_loading)
        {
            <div class="loading"><span class="spinner"></span> Loading...</div>
        }
        else if (_item == null)
        {
            <div class="card" style="padding: 40px; text-align: center; color: var(--text-muted);">Item not found.</div>
        }
        else
        {
            <!-- Item Header -->
            <div class="card" style="margin-bottom: 20px;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px;">
                    <div>
                        <span class="form-label">Item Number</span>
                        <div style="font-weight: 700; font-size: 1.1rem;">@_item.ItemNumber</div>
                    </div>
                    <div>
                        <span class="form-label">Name</span>
                        <div style="font-weight: 600;">@_item.Name</div>
                    </div>
                    <div>
                        <span class="form-label">Type</span>
                        <div><span class="badge badge-secondary">@_item.ItemType</span></div>
                    </div>
                    <div>
                        <span class="form-label">Current Stock</span>
                        <div style="font-weight: 700; font-size: 1.2rem; color: @GetStockColor()">@_item.CurrentStockQty @_item.UnitOfMeasure</div>
                    </div>
                    <div>
                        <span class="form-label">Reserved</span>
                        <div style="font-weight: 600;">@_item.ReservedQty @_item.UnitOfMeasure</div>
                    </div>
                    <div>
                        <span class="form-label">Available</span>
                        <div style="font-weight: 700; color: var(--success);">@_item.AvailableQty @_item.UnitOfMeasure</div>
                    </div>
                </div>
            </div>

            <!-- Lot Breakdown -->
            @if (_item.TrackLots && _lots.Count > 0)
            {
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">🏷️ Lot Breakdown</div>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Lot #</th>
                                <th>Certificate</th>
                                <th style="text-align: right;">Received</th>
                                <th style="text-align: right;">Current</th>
                                <th>Location</th>
                                <th>Received Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lot in _lots)
                            {
                                <tr>
                                    <td style="font-weight: 600;">@lot.LotNumber</td>
                                    <td>@(lot.CertificateNumber ?? "—")</td>
                                    <td style="text-align: right;">@lot.ReceivedQty</td>
                                    <td style="text-align: right; font-weight: 600;">@lot.CurrentQty</td>
                                    <td>@(lot.Location?.Code ?? "—")</td>
                                    <td>@lot.ReceivedAt.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge @GetLotBadge(lot.Status)">@lot.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Transaction History -->
            <div class="card">
                <div class="card-header">📜 Transaction History</div>
                @if (_transactions.Count == 0)
                {
                    <div style="color: var(--text-muted); padding: 12px;">No transactions recorded yet.</div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th style="text-align: right;">Qty</th>
                                <th style="text-align: right;">Balance</th>
                                <th>Reference</th>
                                <th>Lot</th>
                                <th>By</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in _transactions)
                            {
                                <tr>
                                    <td>@t.TransactedAt.ToString("MMM dd HH:mm")</td>
                                    <td><span class="badge @GetTxBadge(t.TransactionType)">@t.TransactionType</span></td>
                                    <td style="text-align: right; color: @(t.Quantity >= 0 ? "var(--success)" : "var(--danger)"); font-weight: 600;">
                                        @(t.Quantity >= 0 ? "+" : "")@t.Quantity
                                    </td>
                                    <td style="text-align: right;">@t.QuantityAfter</td>
                                    <td style="color: var(--text-muted);">@(t.Reference ?? "—")</td>
                                    <td>@(t.Lot?.LotNumber ?? "—")</td>
                                    <td>@t.PerformedByUserId</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }

        @if (_showAdjust && _item != null)
        {
            <div class="modal-overlay" @onclick="() => _showAdjust = false">
                <div class="modal-content" style="max-width: 500px;" @onclick:stopPropagation>
                    <div class="modal-header">
                        <span class="modal-title">Inventory Adjustment</span>
                        <button class="modal-close" @onclick="() => _showAdjust = false">&times;</button>
                    </div>
                    <div style="margin-bottom: 12px;">
                        <span class="form-label">Current Quantity</span>
                        <div style="font-weight: 600; font-size: 1.1rem;">@_item.CurrentStockQty @_item.UnitOfMeasure</div>
                    </div>
                    <div style="margin-bottom: 12px;">
                        <label class="form-label">New Quantity *</label>
                        <input type="number" step="0.01" class="form-control" @bind="_adjustNewQty" />
                    </div>
                    <div style="margin-bottom: 12px;">
                        <label class="form-label">Reason *</label>
                        <textarea class="form-control" rows="2" @bind="_adjustReason" placeholder="Cycle count, damage, etc."></textarea>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 8px;">
                        <button class="btn btn-secondary" @onclick="() => _showAdjust = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SubmitAdjustment">Submit Adjustment</button>
                    </div>
                </div>
            </div>
        }

</FeatureGate>

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private InventoryItem? _item;
    private List<InventoryLot> _lots = new();
    private List<InventoryTransaction> _transactions = new();
    private bool _showAdjust;
    private decimal _adjustNewQty;
    private string _adjustReason = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _item = await InventoryService.GetItemByIdAsync(Id);
        if (_item != null)
        {
            _lots = await InventoryService.GetLotsForItemAsync(Id);
            _transactions = await InventoryService.GetTransactionHistoryAsync(Id);
        }
        _loading = false;
    }

    private void ShowAdjust()
    {
        _adjustNewQty = _item?.CurrentStockQty ?? 0;
        _adjustReason = string.Empty;
        _showAdjust = true;
    }

    private async Task SubmitAdjustment()
    {
        if (string.IsNullOrWhiteSpace(_adjustReason))
        {
            Toast.ShowError("Please provide a reason for the adjustment.");
            return;
        }

        try
        {
            await InventoryService.AdjustAsync(Id, _adjustNewQty, _adjustReason, "System");
            Toast.ShowSuccess("Adjustment posted.");
            _showAdjust = false;

            _item = await InventoryService.GetItemByIdAsync(Id);
            _transactions = await InventoryService.GetTransactionHistoryAsync(Id);
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private string GetStockColor()
    {
        if (_item == null) return "inherit";
        if (_item.CurrentStockQty <= 0) return "var(--danger)";
        if (_item.ReorderPoint > 0 && _item.CurrentStockQty <= _item.ReorderPoint) return "var(--warning)";
        return "var(--success)";
    }

    private static string GetLotBadge(LotStatus status) => status switch
    {
        LotStatus.Available => "badge-success",
        LotStatus.Quarantine => "badge-warning",
        LotStatus.Depleted => "badge-secondary",
        LotStatus.Rejected => "badge-danger",
        _ => "badge-secondary"
    };

    private static string GetTxBadge(TransactionType type) => type switch
    {
        TransactionType.Receipt => "badge-success",
        TransactionType.JobConsumption => "badge-info",
        TransactionType.Adjustment or TransactionType.CycleCount => "badge-warning",
        TransactionType.Scrap => "badge-danger",
        _ => "badge-secondary"
    };
}
