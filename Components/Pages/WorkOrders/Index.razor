@page "/workorders"
@inject IWorkOrderService WorkOrderService
@inject IPartService PartService
@inject ITenantFeatureService Features
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Work Orders - Vectrik</PageTitle>

<div class="page-header">
    <h1 class="page-title">Work Orders</h1>
    <div style="display: flex; gap: 8px; align-items: center;">
        <button class="btn btn-sm @(_viewMode == "table" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "table"'>📋 Table</button>
        <button class="btn btn-sm @(_viewMode == "kanban" ? "btn-primary" : "btn-secondary")" @onclick='() => _viewMode = "kanban"'>🗂️ Kanban</button>
        <button class="btn btn-primary" @onclick="GoToCreate">+ New Work Order</button>
    </div>
</div>

<!-- Status Filter Tabs -->
<div class="content-tab-bar" style="margin-bottom: 16px;">
    <button class="tab @(_statusFilter == null ? "active" : "")" @onclick="() => FilterByStatus(null)">All (@_allOrders.Count)</button>
    @foreach (var s in _statusCounts)
    {
        <button class="tab @(_statusFilter == s.Key ? "active" : "")" @onclick="() => FilterByStatus(s.Key)">@s.Key (@s.Value)</button>
    }
</div>

@if (_loading)
{
    <div class="loading"><span class="spinner"></span> Loading...</div>
}
else if (_viewMode == "kanban")
{
    <!-- Kanban View -->
    <div class="kanban-board">
        @foreach (var status in new[] { WorkOrderStatus.Draft, WorkOrderStatus.Released, WorkOrderStatus.InProgress, WorkOrderStatus.Complete })
        {
            var statusOrders = _allOrders.Where(o => o.Status == status).ToList();
            <div class="kanban-column">
                <div class="kanban-column-header">
                    <span class="badge @GetBadge(status)">@status</span>
                    <span style="color: var(--text-muted); font-size: 0.8rem;">@statusOrders.Count</span>
                </div>
                @foreach (var wo in statusOrders.Take(20))
                {
                    <div class="kanban-card clickable-row" @onclick="() => GoToDetail(wo.Id)">
                        <div style="font-weight: 600; font-size: 0.85rem;">@wo.OrderNumber</div>
                        <div style="color: var(--text-secondary); font-size: 0.8rem;">@wo.CustomerName</div>
                        <div style="display: flex; justify-content: space-between; margin-top: 6px;">
                            <span style="font-size: 0.75rem; color: var(--text-muted);">@wo.Lines.Count line(s)</span>
                            <span style="font-size: 0.75rem; color: @(wo.DueDate < DateTime.UtcNow && wo.Status != WorkOrderStatus.Complete ? "var(--danger)" : "var(--text-muted)")">Due @wo.DueDate.ToString("MMM dd")</span>
                        </div>
                        @if (wo.Priority >= JobPriority.Rush)
                        {
                            <span class="badge badge-rush" style="margin-top: 4px;">@wo.Priority</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <!-- Table View -->
    <div class="card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>PO #</th>
                    <th>Due Date</th>
                    <th>Lines</th>
                    <th style="min-width: 200px;">Fulfillment</th>
                    <th>Status</th>
                    <th>Priority</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var wo in _filtered.Skip((_page - 1) * _pageSize).Take(_pageSize))
                {
                    var totalQty = wo.Lines.Sum(l => l.Quantity);
                    var shippedQty = wo.Lines.Sum(l => l.ShippedQuantity);
                    var producedQty = wo.Lines.Sum(l => l.ProducedQuantity);
                    var producedNotShipped = Math.Max(0, producedQty - shippedQty);
                    var inProductionQty = wo.Lines.Sum(l => GetInProductionQty(l));
                    var scheduledQty = wo.Lines.Sum(l => GetScheduledQty(l));
                    var outstandingQty = Math.Max(0, totalQty - producedQty - Math.Max(inProductionQty, scheduledQty));

                    var shippedPct = totalQty > 0 ? shippedQty * 100.0 / totalQty : 0;
                    var producedPct = totalQty > 0 ? producedNotShipped * 100.0 / totalQty : 0;
                    var inProdPct = totalQty > 0 ? inProductionQty * 100.0 / totalQty : 0;
                    var schedPct = totalQty > 0 ? scheduledQty * 100.0 / totalQty : 0;

                    var daysUntilDue = (wo.DueDate - DateTime.UtcNow).Days;
                    var isOverdue = daysUntilDue < 0 && wo.Status != WorkOrderStatus.Complete;
                    var isDueSoon = daysUntilDue >= 0 && daysUntilDue <= 7 && wo.Status != WorkOrderStatus.Complete;
                    var dueDateColor = isOverdue ? "var(--danger)" : isDueSoon ? "var(--warning)" : "inherit";

                    var buildsNeeded = wo.Lines.Sum(l => GetBuildsNeeded(l));

                    <tr class="clickable-row" @onclick="() => GoToDetail(wo.Id)">
                        <td><strong>@wo.OrderNumber</strong></td>
                        <td>@wo.CustomerName</td>
                        <td>@(wo.CustomerPO ?? "—")</td>
                        <td style="white-space: nowrap;">
                            <span style="color: @dueDateColor; font-weight: @(isOverdue ? "700" : "normal");">@wo.DueDate.ToString("yyyy-MM-dd")</span>
                            @if (isOverdue)
                            {
                                <div style="font-size: 0.68rem; color: var(--danger); font-weight: 600;">@(Math.Abs(daysUntilDue))d overdue</div>
                            }
                            else if (isDueSoon)
                            {
                                <div style="font-size: 0.68rem; color: var(--warning);">@daysUntilDue @(daysUntilDue == 1 ? "day" : "days") left</div>
                            }
                        </td>
                        <td>@wo.Lines.Count</td>
                        <td>
                            <div class="wo-fulfillment-bar">
                                @if (shippedPct > 0) { <div class="wo-bar-shipped" style="width: @F(shippedPct)%;" title="Shipped: @shippedQty"></div> }
                                @if (producedPct > 0) { <div class="wo-bar-produced" style="width: @F(producedPct)%;" title="Produced: @producedNotShipped"></div> }
                                @if (inProdPct > 0) { <div class="wo-bar-inprod" style="width: @F(inProdPct)%;" title="In production: @inProductionQty"></div> }
                                @if (schedPct > 0) { <div class="wo-bar-scheduled" style="width: @F(schedPct)%;" title="Scheduled: @scheduledQty"></div> }
                            </div>
                            <div style="display: flex; gap: 6px; font-size: 0.7rem; color: var(--text-muted); margin-top: 2px; flex-wrap: wrap;">
                                @if (shippedQty > 0) { <span style="color: var(--success-dark, #1a7f37);">@shippedQty shipped</span> }
                                @if (producedNotShipped > 0) { <span style="color: var(--success);">@producedNotShipped produced</span> }
                                @if (inProductionQty > 0) { <span style="color: var(--warning);">@inProductionQty in prod</span> }
                                @if (scheduledQty > 0) { <span style="color: var(--accent);">@scheduledQty scheduled</span> }
                                @if (outstandingQty > 0) { <span>@outstandingQty outstanding</span> }
                                @if (buildsNeeded > 0) { <span>· @buildsNeeded @(buildsNeeded == 1 ? "build" : "builds") needed</span> }
                            </div>
                        </td>
                        <td><span class="badge @GetBadge(wo.Status)">@wo.Status</span></td>
                        <td><span class="badge badge-@wo.Priority.ToString().ToLower()">@wo.Priority</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_filtered.Count > _pageSize)
    {
        <Pagination CurrentPage="_page" TotalItems="_filtered.Count" PageSize="_pageSize" OnPageChanged="p => _page = p" />
    }
}

@code {
    private bool _loading = true;
    private List<WorkOrder> _allOrders = new();
    private List<WorkOrder> _filtered = new();
    private Dictionary<WorkOrderStatus, int> _statusCounts = new();
    private WorkOrderStatus? _statusFilter;
    private string _viewMode = "table";
    private int _page = 1;
    private int _pageSize = 25;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allOrders = await WorkOrderService.GetAllWorkOrdersAsync();
            _statusCounts = _allOrders.GroupBy(o => o.Status).ToDictionary(g => g.Key, g => g.Count());
            _filtered = _allOrders;
        }
        catch (Exception ex) { Toast.ShowError($"Failed to load work orders: {ex.Message}"); }
        finally { _loading = false; }
    }

    private void FilterByStatus(WorkOrderStatus? status)
    {
        _statusFilter = status;
        _filtered = status.HasValue
            ? _allOrders.Where(o => o.Status == status.Value).ToList()
            : _allOrders;
        _page = 1;
    }

    private void GoToCreate() => Nav.NavigateTo("/workorders/new");
    private void GoToDetail(int id) => Nav.NavigateTo($"/workorders/{id}");

    private static string F(double val) => val.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private static int GetScheduledQty(WorkOrderLine line) =>
        line.ProgramParts?
            .Where(pp => pp.MachineProgram != null
                && pp.MachineProgram.ScheduleStatus is ProgramScheduleStatus.Scheduled
                    or ProgramScheduleStatus.Printing or ProgramScheduleStatus.PostPrint)
            .Sum(pp => pp.Quantity * pp.StackLevel) ?? 0;

    private static int GetInProductionQty(WorkOrderLine line) =>
        line.Jobs?
            .Where(j => j.Status is not (JobStatus.Completed or JobStatus.Cancelled))
            .Sum(j => j.Quantity) ?? 0;

    private static int GetBuildsNeeded(WorkOrderLine line)
    {
        var remaining = line.Quantity - line.ProducedQuantity
            - Math.Max(GetScheduledQty(line), GetInProductionQty(line));
        if (remaining <= 0) return 0;
        var perBuild = line.Part?.AdditiveBuildConfig?.PlannedPartsPerBuildSingle ?? 0;
        return perBuild > 0 ? (int)Math.Ceiling((double)remaining / perBuild) : 0;
    }

    private static string GetBadge(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.Draft => "badge-draft",
        WorkOrderStatus.Released => "badge-released",
        WorkOrderStatus.InProgress => "badge-inprogress",
        WorkOrderStatus.Complete => "badge-complete",
        WorkOrderStatus.Cancelled => "badge-cancelled",
        WorkOrderStatus.OnHold => "badge-warning",
        _ => ""
    };
}
