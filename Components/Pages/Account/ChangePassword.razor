@page "/account/change-password"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@layout Components.Layout.LoginLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Change Password - Vectrik</PageTitle>

<div class="login-card">
    <div class="login-logo-animated">
        <img src="/uploads/logos/vectrik-loading.svg" alt="Vectrik" class="login-animated-shield" />
    </div>

    <h2 style="text-align: center; margin-bottom: 4px; font-size: 1.25rem;">Change Your Password</h2>
    <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 20px;">
        You must set a new password before continuing.
    </p>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="form-group">
        <label class="form-label">Current Password</label>
        <input class="form-control" type="password" @bind="_currentPassword"
               autocomplete="current-password" placeholder="Enter your current password" />
    </div>
    <div class="form-group">
        <label class="form-label">New Password</label>
        <input class="form-control" type="password" @bind="_newPassword"
               autocomplete="new-password" placeholder="Minimum 8 characters" />
    </div>
    <div class="form-group">
        <label class="form-label">Confirm New Password</label>
        <input class="form-control" type="password" @bind="_confirmPassword"
               autocomplete="new-password" placeholder="Re-enter new password" />
    </div>
    <button class="btn btn-primary" style="width: 100%; margin-top: 12px; padding: 12px; font-size: 1rem;"
            @onclick="HandleChangePassword" disabled="@_saving">
        @(_saving ? "Saving..." : "Set New Password")
    </button>
</div>

<p class="login-powered-by">Powered by <strong>Vectrik</strong></p>

@code {
    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    private string? _currentPassword, _newPassword, _confirmPassword;
    private string? _errorMessage;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            var mustChange = state.User.FindFirst("MustChangePassword")?.Value;
            if (mustChange != "True")
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
    }

    private async Task HandleChangePassword()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_currentPassword))
        { _errorMessage = "Current password is required."; return; }
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
        { _errorMessage = "New password must be at least 8 characters."; return; }
        if (_newPassword != _confirmPassword)
        { _errorMessage = "New passwords do not match."; return; }
        if (_newPassword == _currentPassword)
        { _errorMessage = "New password must be different from your current password."; return; }

        _saving = true;
        try
        {
            // Submit via JS fetch to the API endpoint (which can modify cookies)
            var result = await JS.InvokeAsync<ChangePasswordResult>("changePasswordApi",
                _currentPassword, _newPassword);

            if (result.Success)
            {
                // Force reload to pick up new cookie
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                _errorMessage = result.Error ?? "Failed to change password.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private class ChangePasswordResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
    }
}
