@page "/account/change-password"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@attribute [ExcludeFromInteractiveRouting]
@layout Components.Layout.LoginLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Change Password - Vectrik</PageTitle>

<div class="login-card">
    <div class="login-logo-animated">
        <img src="/uploads/logos/vectrik-loading.svg" alt="Vectrik" class="login-animated-shield" />
    </div>

    <h2 style="text-align: center; margin-bottom: 4px; font-size: 1.25rem;">Change Your Password</h2>
    <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 20px;">
        You must set a new password before continuing.
    </p>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleChangePassword" FormName="ChangePasswordForm">
        <div class="form-group">
            <label class="form-label">Current Password</label>
            <InputText class="form-control" type="password" @bind-Value="_model.CurrentPassword"
                       autocomplete="current-password" placeholder="Enter your current password" />
        </div>
        <div class="form-group">
            <label class="form-label">New Password</label>
            <InputText class="form-control" type="password" @bind-Value="_model.NewPassword"
                       autocomplete="new-password" placeholder="Minimum 8 characters" />
        </div>
        <div class="form-group">
            <label class="form-label">Confirm New Password</label>
            <InputText class="form-control" type="password" @bind-Value="_model.ConfirmPassword"
                       autocomplete="new-password" placeholder="Re-enter new password" />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 12px; padding: 12px; font-size: 1rem;">
            Set New Password
        </button>
    </EditForm>
</div>

<p class="login-powered-by">Powered by <strong>Vectrik</strong></p>

@code {
    [SupplyParameterFromForm] private ChangePasswordModel _model { get; set; } = null!;
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? _errorMessage;
    private string? _successMessage;

    protected override void OnInitialized()
    {
        _model ??= new();

        // If user doesn't need to change password, redirect to dashboard
        if (HttpContext?.User.Identity?.IsAuthenticated == true)
        {
            var mustChange = HttpContext.User.FindFirst("MustChangePassword")?.Value;
            if (mustChange != "True")
            {
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
        }
    }

    private async Task HandleChangePassword()
    {
        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_model.CurrentPassword))
        {
            _errorMessage = "Current password is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_model.NewPassword) || _model.NewPassword.Length < 8)
        {
            _errorMessage = "New password must be at least 8 characters.";
            return;
        }
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _errorMessage = "New passwords do not match.";
            return;
        }
        if (_model.NewPassword == _model.CurrentPassword)
        {
            _errorMessage = "New password must be different from your current password.";
            return;
        }

        if (HttpContext?.User.Identity?.IsAuthenticated != true)
        {
            _errorMessage = "Session expired. Please log in again.";
            return;
        }

        var tenantCode = HttpContext.User.FindFirst("TenantCode")?.Value;
        var userIdStr = HttpContext.User.FindFirst("UserId")?.Value;
        if (string.IsNullOrEmpty(tenantCode) || !int.TryParse(userIdStr, out var userId))
        {
            _errorMessage = "Unable to determine your account. Please log in again.";
            return;
        }

        // Build tenant DB context manually (SSR page cannot use DI-injected TenantDbContext)
        var dataRoot = Environment.GetEnvironmentVariable("HOME") is { Length: > 0 } home
            ? Path.Combine(home, "data") : "data";
        var dbPath = Path.Combine(dataRoot, "tenants", $"{tenantCode}.db");

        if (!File.Exists(dbPath))
        {
            _errorMessage = "Tenant database not found. Contact your administrator.";
            return;
        }

        var options = new DbContextOptionsBuilder<Vectrik.Data.TenantDbContext>()
            .UseSqlite($"Data Source={dbPath}")
            .Options;

        using var db = new Vectrik.Data.TenantDbContext(options);
        var user = await db.Users.FindAsync(userId);
        if (user == null)
        {
            _errorMessage = "User not found. Contact your administrator.";
            return;
        }

        if (!AuthService.VerifyPassword(_model.CurrentPassword, user.PasswordHash))
        {
            _errorMessage = "Current password is incorrect.";
            return;
        }

        // Update password and clear the flag
        user.PasswordHash = AuthService.HashPassword(_model.NewPassword);
        user.MustChangePassword = false;
        user.LastModifiedDate = DateTime.UtcNow;
        user.LastModifiedBy = user.Username;
        await db.SaveChangesAsync();

        // Re-sign the cookie with updated claims
        var authResult = new Vectrik.Services.Auth.AuthResult
        {
            Success = true,
            TenantCode = tenantCode,
            CompanyName = HttpContext.User.FindFirst("CompanyName")?.Value,
            Username = user.Username,
            FullName = user.FullName,
            Role = user.Role,
            UserId = user.Id,
            IsPlatformUser = false,
            MustChangePassword = false
        };

        var principal = AuthService.GetClaimsPrincipal(authResult);
        if (principal != null)
        {
            await HttpContext.SignOutAsync(CookieAuthenticationDefaults.AuthenticationScheme);
            await HttpContext.SignInAsync(
                CookieAuthenticationDefaults.AuthenticationScheme,
                principal,
                new AuthenticationProperties { IsPersistent = true, ExpiresUtc = DateTimeOffset.UtcNow.AddHours(12) });
        }

        Navigation.NavigateTo("/dashboard", forceLoad: true);
    }

    private class ChangePasswordModel
    {
        public string? CurrentPassword { get; set; }
        public string? NewPassword { get; set; }
        public string? ConfirmPassword { get; set; }
    }
}
